[{"url": "http://bbs.fgfans.com/viewthread.php?tid=15&extra=page%3D1", "title": "\u5feb\u8f66FlashGet 3.0\u6cc4\u9732\u7248", "tags": "\u5feb\u8f66 ", "name": "yinyin", "posttime": "2008-12-03 10:03:00", "ip": "222.128.48.207", "mark": 1, "note": "\u5927\u5bb6\u671f\u5f85\u5df2\u4e45\u7684\u5feb\u8f663.0\uff0c\u6b64\u4e3a\u9884\u89c8\u7248\u7684\u6cc4\u9732\u7248\u672c\uff0c\u5185\u90e8\u7248\u672c\u53f71013\uff0c\u4e0d\u77e5\u6b63\u5f0f\u53d1\u5e03\u9884\u89c8\u7248\u65f6\u8fd8\u4f1a\u4e0d\u4f1a\u6709\u6539\u52a8\uff0c\u4f46\u662f\u73b0\u5728\u80fd\u627e\u5230\u7684\u6700\u65b0\u7248\u672c\r\n\u5feb\u8f663\u529f\u80fd\u66f4\u65b0\u5217\u8868\uff1a\r\n\u4e00\u3001        \u65b0\u5efa\u4efb\u52a1\r\n1        \u4e0b\u8f7d\u524d\u8bfb\u53d6\u6587\u4ef6\u5927\u5c0f\uff0c\u5224\u65ad\u78c1\u76d8\u7a7a\u95f4\u662f\u5426\u53ef\u7528\r\n2        \u81ea\u52a8\u5206\u7c7b\uff0c\u6309\u6269\u5c55\u540d\u81ea\u52a8\u5bf9\u4efb\u52a1\u8fdb\u884c\u5f52\u7c7b\uff0c\u5177\u4f53\u89c1\u9009\u9879\u2014\u4efb\u52a1\u7ba1\u7406\u2014\u5206\u7c7b\u89c4\u5219\r\n3        \u4e0b\u8f7d\u5230\uff0c\u5feb\u6377\u9009\u62e9\u201c\u684c\u9762\u201d\r\n4        \u4fe1\u606f\u63d0\u793a\uff0c\u5f53\u7528\u6237\u64cd\u4f5c\u51fa\u73b0\u9519\u8bef\u65f6\uff0c\u667a\u80fd\u63d0\u793a\u7528\u6237\r\n5        \u66f4\u591a\u9009\u9879\u91cc\u52a0\u5165\u201c\u4e0b\u8f7d\u5b8c\u6210\u540e\u81ea\u52a8\u8fd0\u884c\u201d\uff0c\u5c06\u5f15\u7528\u9875\u653e\u5165\u66f4\u591a\u9009\u9879\uff0c\u7b80\u5316\u9762\u677f\r\n6        \u4e0b\u8f7d\u591a\u4efb\u52a1\uff0c\u65b9\u4fbf\u7684\u5bf9\u4efb\u52a1\u8fdb\u884c\u7b5b\u9009\uff1b\u5176\u4e2d\u7684\u6587\u672c\u6846\u53ef\u4ee5\u52a8\u6001\u8fc7\u6ee4URL\uff0c\u5982\u8f93\u5165\u201cFlashget\u201d\u540e\u53ea\u51fa\u73b0\u5305\u542b\u6b64\u5b57\u7b26\u4e32\u7684\u5730\u5740\r\n\u4e8c\u3001        \u4efb\u52a1\u5217\u8868\r\n1        \u5206\u7ec4\u529f\u80fd\uff0c\u901a\u8fc7\u5206\u7ec4\u5feb\u6377\u7684\u5bf9\u4efb\u52a1\u8fdb\u884c\u7ba1\u7406\r\n2        \u65f6\u95f4\u5206\u7ec4\r\n3.        \u76ee\u5f55\u5206\u7ec4\r\n4.        \u5206\u7ec4\u8bbe\u7f6e\r\n5        \u6587\u4ef6\u5df2\u88ab\u5220\u9664\u7684\u4efb\u52a1\u81ea\u52a8\u7f6e\u7070\r\n6        \u5feb\u6377\u7684\u590d\u5236\u3001\u79fb\u52a8\r\n7        \u5feb\u6377\u91cd\u547d\u540d\r\n\u4e09\u3001        \u5e95\u90e8\u4fe1\u606f\r\n1        \u4e0b\u8f7d\u5206\u5757\u56fe\u793a\u663e\u793a\u8fdb\u5ea6\r\n2        \u8be6\u7ec6\u7684\u4efb\u52a1\u4fe1\u606f\uff0c\u5e76\u53ef\u8fdb\u884c\u6253\u5f00\u76ee\u5f55\u3001\u590d\u5236URL\u3001\u91cd\u547d\u540d\u7b49\u5feb\u6377\u64cd\u4f5c\r\n3        BT\u4efb\u52a1\u6587\u4ef6\u5217\u8868\uff0c\u53ef\u8fdb\u884c\u6253\u5f00\u3001\u76ee\u5f55\u7b49\u64cd\u4f5c\r\n\u56db\u3001        \u60ac\u6d6e\u7a97\r\n1        \u5168\u65b0\u5236\u4f5c\u900f\u660e\u60ac\u6d6e\u7a97\r\n2        \u5de6\u952e\u70b9\u51fb\u663e\u793a\u8ff7\u4f60\u4efb\u52a1\u5217\u8868\uff0c\u52a8\u6001\u663e\u793a\u8fdb\u5ea6\uff08\u4ec5\u5728\u672c\u6b21\u5f00\u542f\u5feb\u8f66\u540e\u4e0b\u8f7d\u8fc7\u4efb\u52a1\u540e\u663e\u793a\uff09\r\n3.        \u53ef\u9501\u5b9a\u3001\u5207\u6362\u5230\u4e3b\u754c\u9762\r\n4.        \u53ef\u5f00\u59cb\u3001\u6682\u505c\u4efb\u52a1\r\n5        \u4e0b\u8f7d\u5b8c\u6210\u7684\u4efb\u52a1\u53ef\u6253\u5f00\u5176\u76ee\u5f55\r\n6        \u662f\u5426\u76d1\u89c6\u6d4f\u89c8\u5668\u5feb\u901f\u5f00\u5173\r\n\u4e94\u3001        \u5176\u4ed6\u529f\u80fd\r\n1        \u4ece\u670d\u52a1\u5668\u83b7\u53d6\u6587\u4ef6\u7684\u65e5\u671f\r\n2        \u5bfc\u5165\u5bfc\u51fa\u6570\u636e\u5e93\uff0c\u53ef\u5bfc\u51651.9, 2.x, mini, 3.x\u7b49\u5404\u79cd\u6570\u636e\u5e93\uff0c\u53ef\u5bfc\u51fa\u6570\u636e\u5e93\u8fdb\u884c\u5907\u4efd\r\n3        \u6309\u4e0bAlt\u3001Ctrl\u3001Shift\u4efb\u4f55\u4e00\u4e2a\u6309\u952e\u65f6\uff0c\u4e0d\u76d1\u89c6\u6d4f\u89c8\u5668\u5de6\u952e\u70b9\u51fb\r\n4        \u5173\u4e8e\uff0c\u56fe\u7247\u6c34\u6ce2\u6548\u679c\r\n5        \u7ad9\u70b9\u7ba1\u7406\uff0c\u76ee\u524d\u5c1a\u672a\u