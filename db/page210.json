8bae\u60a8\u8e72\u4e0b\u6765\uff0c\u770b\u770b\u4f60\u719f\u6089\u7684\u4e16\u754c\u662f\u5426\u4e0e\u4f17\u4e0d\u540c\u3002", "imagename": "0cbe57db176f4a24a8a9abd019b01e5f.jpg", "infoid": 383830, "category": "culture_photograph", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "culture", "via": null, "real_tags": ["\u6444\u5f71"]}, {"url": "http://www.7weibo.com/blog/post/213.html", "title": "\u65b0\u6d6a\u5fae\u535a\u53d1\u5e03\u5373\u65f6\u901a\u8bafair\u5ba2\u6237\u7aef \u6311\u6218\u817e\u8baf\u6838\u5fc3IM\u4e1a\u52a1", "tags": "", "name": "edivista", "posttime": "2011-03-08 10:14:48", "ip": "58.213.142.216", "mark": 0, "note": "\u5fae\u535a\u8d44\u8baf\u7f51\uff08\u8f6c\u81ea\u51e4\u51f0\u7f51\uff09\r\n\u6ce8\uff1a\u65b0\u6d6a\u5fae\u535aair\u5ba2\u6237\u7aef\u4e0b\u8f7d\u5730\u5740\uff1ahttp://down.tech.sina.com.cn/content/482\r\n20.html\r\n\u8fc7\u53bb\u5341\u5e74\uff0c\u817e\u8baf\u751f\u6d3b\u5728\u4e00\u4e2a\u51e0\u4e4e\u6ca1\u6709\u654c\u4eba\u7684\u4e16\u754c\u91cc\u3002\u65b0\u6d6a\u5fae\u535a()\u5ba2\u6237\u7aefair\u6709\u53ef\u80fd\u7ec8\u7ed3\u8fd9\u6837\u7684\u65e5\u5b50\u3002\u4e00\u573a\u6218\u4e89\u5df2\u7ecf\u62c9\u5f00\u5927\u5e55\uff0c\u53ea\u662f\u9ad8\u6f6e\u5c1a\u672a\u5230\u6765\u3002\r\n3\u67084\u65e5\uff0c\u65b0\u6d6a\u63a8\u51fa\u4e86\u5176air\u5fae\u535a\u5ba2\u6237\u7aef\uff0c\u9664\u5177\u6709\u6d4f\u89c8\u9996\u9875\u3001\u53d1\u5fae\u535a\u3001\u8bc4\u8bba\u3001\u79c1\u4fe1\u7b49\u5168\u90e8\u7f51\u9875\u5fae\u535a\u529f\u80fd\uff0c\u5176\u4e2d\u6700\u62a2\u773c\u7684\u529f\u80fd\u662f\u5373\u65f6\u804a\u5929\u70b9\u51fb\u5ba2\u6237\u7aef\u754c\u9762\u4e0b\u9762\u7684\u804a\u5929\u6309\u94ae\uff0c\u7528\u6237\u754c\u9762\u4e2d\u592e\u5c31\u4f1a\u5217\u51fa\u6240\u6709\u4e92\u7c89\u7684\u8054\u7cfb\u4eba\uff0c\u70b9\u51fb\u8fd9\u4e9b\u8054\u7cfb\u4eba\uff0c\u5c31\u4f1a\u51fa\u73b0\u4e00\u4e2a\u5bf9\u8bdd\u6846\uff0c\u4e0e\u817e\u8bafQQ\u522b\u65e0\u4e8c\u81f4\u3002\r\n\u65b0\u6d6a\u516c\u5173\u90e8\u76f8\u5173\u8d1f\u8d23\u4eba\u6ca1\u6709\u5411\u8bb0\u8005\u900f\u9732air\u5ba2\u6237\u7aef\u51e0\u5929\u6765\u7684\u4e0b\u8f7d\u91cf\uff0c\u79f0\u624b\u5934\u8fd8\u6ca1\u6709\u5177\u4f53\u6570\u636e\u3002\u800c\u4e00\u4f4d\u65b0\u6d6a\u5458\u5de5\u53d1\u4e86\u4e00\u6761\u5173\u4e8eair\u5ba2\u6237\u7aef\u4e0b\u8f7d\u94fe\u63a5\u7684\u5fae\u535a\uff0c\u4e09\u5929\u5185\u88ab\u8f6c\u53d1\u4e862059\u6b21\uff0c\u8bc4\u8bba190\u6b21\u3002\r\n\u4e00\u4f4d\u4e0d\u613f\u900f\u9732\u59d3\u540d\u7684\u4e92\u8054\u7f51\u9ad8\u7ba1\u8ba4\u4e3a\uff1a\u817e\u8baf\u7ec8\u4e8e\u51fa\u73b0\u4e86\u4e00\u4e2a\u771f\u6b63\u7684\u654c\u4eba\uff0c360\u4e0d\u53ef\u6015\uff0c\u6ca1\u6709\u51b2\u51fb\u817e\u8baf\u7684\u6838\u5fc3\uff0c\u817e\u8baf\u7684\u6838\u5fc3\u662fIM\uff0c\u800c\u5fae\u535a\u5b8c\u5168\u5177\u6709\u817e\u8bafQQ\u7684\u5f3a\u5173\u7cfb\u5c5e\u6027\u3002\r\n\u4e0d\u8fc7\uff0c\u4e92\u8054\u7f51\u89c2\u5bdf\u4eba\u58eb\u8c22\u6587\u5219\u8ba4\u4e3a\uff1a\u65b0\u6d6a\u5fae\u535a()\u80fd\u505a\u591a\u5927\uff0cair\u624d\u80fd\u505a\u591a\u5927\uff0c\u800c\u4e0d\u4f1a\u56e0\u4e3a\u5fae\u535aair\u505a\u5927\u4e86\uff0c\u5c31\u80fd\u628a\u5fae\u535a\u5e26\u8d77\u6765\u3002\u4e5f\u5c31\u662f\u8bf4\uff0c\u65b0\u6d6aair\u80fd\u5426\u51b2\u51fb\u817e\u8baf\uff0c\u9700\u8981\u770b\u65b0\u6d6a\u5fae\u535a()\u81ea\u8eab\u7684\u53d1\u5c55\uff0c\u800c\u4e0d\u5728\u4e8eair\u5ba2\u6237\u7684\u53d1\u5c55\u3002\r\nair\u6697\u6218QQ\r\n\u628a\u5fae\u535a\u4e0a\u7684\u597d\u53cb\u5173\u7cfb\u590d\u5236\u5230air\u804a\u5929\u5217\u8868\uff0c\u65b0\u6d6a\u5c31\u62e5\u6709\u4e86\u4e00\u4e2a\u53ef\u4ee5\u4e0eQQ\u804a\u5929\u5217\u8868\u4e00\u6837\u6709\u4ef7\u503c\u7684\u5173\u7cfb\u7f51\u7edc\r\n\u8fc7\u53bb\u4e00\u5e74\u662f\u65b0\u6d6a\u80a1\u4ef7\u5feb\u901f\u589e\u957f\u7684\u4e00\u5e74\u30022010\u5e74\u521d\uff0c\u65b0\u6d6a\u80a1\u4ef7\u7ea6\u4e3a30\u7f8e\u5143\uff0c\u800c2011\u5e743\u67086\u65e5\uff0c\u65b0\u6d6a\u80a1\u4ef7\u4e3a84.12\u7f8e\u5143\uff0c\u5e02\u503c\u7ea6\u4e3a51\u4ebf\u7f8e\u5143\uff0c\u4e00\u5e74\u4e4b\u5185\u65b0\u6d6a\u80a1\u4ef7\u4e0a\u6da8\u4e24\u500d\u6709\u4f59\u3002\u8d44\u672c\u5e02\u573a\u9ad8\u4f30\u65b0\u6d6a\uff0c\u539f\u56e0\u5728\u4e8e\u65b0\u6d6a\u5fae\u535a()\u7684\u5feb\u901f\u53d1\u5c55\uff0c\u5728\u6b64\u671f\u95f4\uff0c\u65b0\u6d6a\u5fae\u535a()\u6237\u4ece\u96f6\u5f00\u59cb\uff0c\u589e\u957f\u81f31\u4ebf\u6709\u4f59\u3002\r\n\u5f53\u7136\uff0c\u4e0e\u817e\u8baf\u76f8\u6bd4\uff0c\u65b0\u6d6a\u4f53\u91cf\u5c1a\u5c0f\u30022011\u5e743\u67086\u65e5\uff0c\u817e\u8baf\u80a1\u4ef7\u4e3a221\u6e2f\u5143\uff0c\u5e02\u503c3959.26\u4ebf\u6e2f\u5143\uff0c\u7ea6\u4e3a510\u4ebf\u7f8e\u5143\u3002\u4e24\u8005\u5e02\u503c\u6070\u597d\u76f8\u5dee10\u500d\u3002\r\n\u4f46\u65b0\u6d6a\u5fae\u535a()\u5feb\u901f\u53d1\u5c55\u4e4b\u5feb\uff0c\u5374\u4e0d\u5f97\u4e0d\u8ba9\u5305\u62ec\u817e\u8baf\u5728\u5185\u7684\u4e92\u8054\u7f51\u4e1a\u754c\u4fa7\u76ee\u3002\u65b0\u6d6a\u4e0e\u817e\u8baf\u4e4b\u6218\uff0c\u59cb\u4e8e\u53bb\u5e74\u817e\u8baf\u63a8\u51fa\u817e\u8baf\u5fae\u535a\u3002\u7531\u4e8e\u5ba2\u6237\u7aef\u7684\u5de8\u5927\u5f71\u54cd\u529b\uff0c\u817e\u8baf\u5c3d\u7ba1\u672a\u80fd\u8d85\u8d8a\u65b0\u6d6a\uff0c\u4f46\u4e0e\u641c\u72d0\u3001\u7f51\u6613\u7b49\u76f8\u6bd4\uff0c\u4ecd\u7136\u8fdc\u8fdc\u8d85\u51fa\u3002\u5728\u5fae\u535a\u9886\u57df\uff0c\u817e\u8baf\u6210\u4e3a\u65b0\u6d6a\u6f5c\u5728\u6700\u5927\u7684\u7ade\u4e89\u5bf9\u624b\u3002\r\n\u4e0a\u8ff0\u4e92\u8054\u7f51\u9ad8\u7ba1\u8ba4\u4e3a\uff1a\u65b0\u6d6a\u5fae\u535a()\u63a8\u51faair\u5ba2\u6237\u7aef\uff0c\u6807\u5fd7\u53cc\u65b9\u6697\u5730\u89d2\u529b\u5230\u4e86\u4e00\u4e2a\u65b0\u7684\u9636\u6bb5\u3002\u628a\u5fae\u535a\u4e0a\u7684\u597d\u53cb\u5173\u7cfb\u590d\u5236\u5230air\u804a\u5929\u5217\u8868\uff0c\u65b0\u6d6aair\u5c31\u62e5\u6709\u4e86\u4e00\u4e2a\u53ef\u4ee5\u4e0eQQ\u804a\u5929\u5217\u8868\u4e00\u6837\u6709\u4ef7\u503c\u7684\u5173\u7cfb\u7f51\u7edc\u3002\r\n\u65b0\u6d6a\u5fae\u535a()\u7684\u5173\u7cfb\u7f51\u7edc\u6216\u8bb8\u66f4\u6709\u4ef7\u503c\uff0c\u7ecf\u5e74\u7d2f\u6708\uff0c\u5f88\u591aQQ\u597d\u53cb\u5df2\u7ecf\u957f\u671f\u4e0d\u8054\u7cfb\u4e86\uff0c\u6210\u4e3a\u6b7b\u5173\u7cfb\uff0c\u5fae\u535a\u4e0d\u540c\uff0c\u4e0a\u9762\u5f88\u591a\u597d\u53cb\u521a\u521a\u8f6c\u53d1\u3001\u8bc4\u8bba\u8fc7\u4f60\u7684\u5fae\u535a\uff0c\u6216\u662f\u4e0d\u4e45\u8fd8\u76f8\u4e92\u79c1\u4fe1\uff0c\u662f\u6d3b\u5173\u7cfb\u3002\u8be5\u4eba\u58eb\u8bf4\u3002\r\n\u6b63\u671b\u54a8\u8be2\u603b\u88c1\u5415\u4f2f\u671b\u8ba4\u4e3a\uff0c\u65b0\u6d6a\u5fae\u535a()\u7684\u6311\u6218\u662f\u7f51\u6c11\u6e17\u900f\u7387\u3002\u4ed6\u8bf4\uff1a\u5c3d\u7ba1\u65b0\u6d6a\u5fae\u535a()\u6ce8\u518c\u7528\u6237\u5df2\u7ecf\u8d85\u8fc71\u4ebf\uff0c\u4e0e\u817e\u8baf\u7684\u7528\u6237\u89c4\u6a21\u76f8\u6bd4\u8fd8\u6709\u4e0d\u5c0f\u5dee\u8ddd\u3002\u76ee\u524d\uff0c\u817e\u8baf\u540c\u65f6\u5728\u7ebf\u7528\u6237\u8d85\u8fc71\u4ebf\uff0c\u6ce8\u518c\u7528\u6237\u8d85\u8fc710\u4ebf\u3002\r\n5G\u54a8\u8be2\u521b\u59cb\u4eba\u6d2a\u6ce2\u8ba4\u4e3a\uff1aQQ\u5c31\u662f\u624b\u673a\uff0c\u5fae\u535a\u53d6\u4ee3\u4e0d\u4e86\u624b\u673a\uff0c\u53ea\u80fd\u5b9e\u73b0\u624b\u673a\u4e0a\u4e00\u90e8\u5206\u529f\u80fd\u3002\u4ed6\u8ba4\u4e3a\u5fae\u535a\u662f\u4f20\u64ad\u5de5\u5177\uff0c\u4e0d\u662f\u4e00\u5bf9\u4e00\u7684\u901a\u8baf\u5de5\u5177\uff0c\u8fd9\u79cd\u8eab\u4efd\u4f7f\u4ed6\u65e0\u6cd5\u53d6\u4ee3QQ\uff0cQQ\u5728\u5fae\u535a\u65f6\u4ee3\u6709\u5176\u5b58\u5728\u4ef7\u503c\u3002\u8c22\u6587\u8bf4\uff1a\u817e\u8baf\u62e5\u6709\u5f3a\u5927\u7684\u5ba2\u6237\u7aef\u5f71\u54cd\u529b\uff0c\u53ef\u4f5c\u4e3a\u5411\u4e91\u7aef\u8fc8\u8fdb\u7684\u6709\u529b\u7684\u6b66\u5668\u3002\r\n\u4e91\u65f6\u4ee3\uff1a\u5ba2\u6237\u7aef\u4e89\u593a\r\n\u5404\u5927\u4e92\u8054\u7f51\u516c\u53f8\u90fd\u5728\u52a0\u5feb\u901f\u5ea6\u63a8\u51fa\u5ba2\u6237\u7aef\r\n\u65b0\u6d6a\u901a\u8fc7\u5fae\u535a\u62a2\u5360\u5ba2\u6237\u7aef\u7684\u8ba1\u5212\u521a\u521a\u5f00\u59cb\uff0c2011\u5e74\uff0c\u8fd9\u4e00\u8ba1\u5212\u6216\u5c06\u52a0\u901f\u3002\r\n\u65b0\u6d