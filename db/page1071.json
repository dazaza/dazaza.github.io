[{"url": "http://web.qbar.qq.com/", "title": "Q\u5427", "tags": "Q\u5427 QQ \u817e\u8baf ", "name": "yinyin", "posttime": "2007-07-24 19:41:14", "ip": "58.241.195.193", "mark": 6, "note": "Q\u5427\u2014\u2014\u8ba9QQ\u7528\u6237\u8f7b\u677e\u62e5\u6709\u81ea\u5df1\u7684\u793e\u533a\u2026\u2026\r\n\r\nQ\u5427\u4e3a\u60a8\u63d0\u4f9b\uff1aBBS\u3001\u76f8\u518c\u3001\u7559\u8a00\u7248\u3001\u7fa4\u3001\u6bcf\u65e5\u62a5\u5230\u3001RSS\u8ba2\u9605\u3001\u53cb\u60c5\u94fe\u63a5\u3001\u56fe\u7247\u7f16\u8f91\u5668\u3001\u6279\u91cf\u53d1\u5e03\u4e0a\u4f20\u56fe\u7247\u7b49\u670d\u52a1 \r\nQ\u5427\u53ef\u4ee5\u5e2e\u60a8\u5b9e\u73b0\uff1a\u6e38\u620f\u516c\u4f1a\uff0c\u540c\u5b66\u5f55\uff0c\u660e\u661f\u3001\u8f66\u53cb\u4ff1\u4e50\u90e8\u7b49\u7b49\u201c\u72ec\u4e50\u4e50\u4e0d\u5982\u4f17\u4e50\u4e50\u201d\u7684\u5728\u7ebf\u6c9f\u901a\u793e\u533a\u5e73\u53f0\r\nQ\u5427\u80fd\u591f\u4e3a\u60a8\u5e26\u6765\uff1a\u5feb\u4e50\uff0c\u5206\u4eab\uff0c\u6c9f\u901a\u2026\u2026\u591a\u591a\u7684\u4e50\u8da3\u2026\u2026", "imagename": "a5c8498b2fe5427d8a2dc7691a1c2d68.gif", "infoid": 25622, "category": "technology_internet", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["q\u5427", "qq", "\u817e\u8baf"]}, {"url": "http://video.qq.com/doing.htm", "title": "QQ\u4e5fTwitter - \u770b\u770b\u5927\u5bb6\u6b63\u5728\u505a\u4ec0\u4e48", "tags": "twitter qq ", "name": "cacard", "posttime": "2007-07-24 19:34:39", "ip": "221.14.253.196", "mark": 7, "note": "\u6211\u770bQQ\u76f4\u63a5\u5728QQ\u8f6f\u4ef6\u4e0a\u9762\u505a\u4e00\u4e2a\u7c7b\u4f3cTwitter\u7684\u670d\u52a1\u7b97\u4e86\uff0c\u6bd5\u7adf\u662f\u4e00\u79cd\u201c\u8001\u5c11\u7686\u5b9c\uff0c\u5c45\u5bb6\u5fc5\u5907\u201d\u7684\u670d\u52a1\u3002", "imagename": "0b87a032f0b5425cbd512fb7e8ade114.gif", "infoid": 25621, "category": "technology_web2", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["twitter", "qq"]}, {"url": "http://dl_dir.qq.com/qqfile/qq/2007beta4jul/qq2007beta4.exe", "title": "QQ2007 Beta4 \u4e0b\u8f7d\uff01\u975eQQ\u4f1a\u5458\u4e00\u6837\u4f7f\u7528\uff01", "tags": "QQ \u817e\u8baf", "name": "yinyin", "posttime": "2007-07-24 19:25:01", "ip": "58.241.195.193", "mark": 4, "note": "\u867d\u7136\u6ca1\u6709\u516c\u5e03QQ2007 Beta4\u4f1a\u5458\u6d4b\u8bd5\u4e3b\u9875,\u4f46\u5b98\u65b9\u5df2\u7ecf\u5c06\u6587\u4ef6\u653e\u5728\u4e86\u670d\u52a1\u5668\u4e0a,\u6587\u4ef6\u5927\u5c0f17.73MB,\u6570\u5b57\u7b7e\u540d7\u670824\u4e5f\u5c31\u662f\u4eca\u5929,\u73b0\u5728\u5c31\u53ef\u4ee5\u4e0b\u8f7d.\r\n\u521a\u6d4b\u8bd5\u4e86\u4e00\u4e0b,\u975e\u9080\u8bf7\u4eba\u5458\u662f\u65e0\u6cd5\u767b\u5f55\u7684,\u5b89\u88c5\u5c0f\u5fc3.\r\np.s,\u5b89\u88c5\u5305\u5c0f\u4e862M,\u76f8\u5f53\u4e0d\u5bb9\u6613...\u597d\u50cf\u662f\u628aQQ\u6e38\u620f\u53bb\u6389\u4e86,\u5e9f\u8bdd\u4e0d\u591a\u8bf4\u4e0b\u8f7d\u5427!\r\nQQ2007 Beta4 Changelog:\r\n1. \u65b0\u589e\u4e86QQ\u4f1a\u5458\u8868\u60c5\u6f2b\u6e38\r\n2. \u65b0\u589e\u4e86QQ\u4f1a\u5458\u7fa4\u91cc\u663e\u793a\u7ea2\u8272\u6635\u79f0\r\n3. \u65b0\u589eQQ\u7a7a\u95f4\u9762\u677f\r\n4. \u4f18\u5316\u4e86\u62cd\u62cd\u7f51\u573a\u666f\u4e0b\u7684\u4e34\u65f6\u4f1a\u8bdd\u4f53\u9a8c\r\n\r\n\r\n\r\n\u4e0b\u8f7d\u5730\u5740:\r\nhttp://dl_dir.qq.com/qqfile/qq/2007beta4jul/qq2007beta4.exe\r\n\r\n\u5982\u679c\u4e0b\u8f7d\u6765\u7684\u6587\u4ef6\u4e0d\u6b63\u786e,\u8bf7\u5c1d\u8bd5IP\u5730\u5740\u76f4\u63a5\u4e0b\u8f7d:\r\nhttp://221.236.11.195/qqfile/qq/2007beta4jul/qq2007beta4.exe\r\n\r\nQQ\u4f1a\u5458\u9080\u8bf7\u767b\u8bb0\u5730\u5740,\u4eca\u65e5\u4e24\u4e07\u540d:\r\nvip.qq.com/act/2007/qq2007/index.php\r\n\r\nQQ2007beta4\u7248\u672c\u2014\u2014QQ\u4f1a\u5458\u62a2\u5148\u4f53\u9a8c \r\n\r\n\u5927\u5bb6\u671f\u5f85\u5df2\u4e45\u7684QQ2007beta4\u7248\u672c\u7ec8\u4e8e\u8981\u8ddf\u5927\u5bb6\u89c1\u9762\u4e86\uff01\r\n\r\n5\u6708\uff0cQQ\u4f1a\u5458\u4f18\u5148\u4f53\u9a8cQQ2007beta2\u7248\u672c\uff1b \r\n6\u6708\uff0cQQ\u4f1a\u5458\u4f18\u5148\u4f53\u9a8cQQ2007beta3\u7248\u672c\uff1b \r\n7\u6708\uff0c\u6211\u4eec\u8bda\u631a\u9080\u8bf7\u60a8\u53c2\u4e0eQQ2007beta4\u7248\u672c\u7684\u4f18\u5148\u4f53\u9a8c\u6d3b\u52a8\uff01\u8fd9\u4e00\u6b21\uff0c\u66f4\u591a\u7cbe\u5f69\u529f\u80fd\u4e0e\u60a8\u5171\u4eab\uff01 \r\n\r\nQQ2007beta4\u8d85\u70ab\u65b0\u529f\u80fd\uff1a\r\nQQ\u4f1a\u5458\u8868\u60c5\u6f2b\u6e38\u3001\u4f1a\u5458\u7fa4\u5185\u7ea2\u540d \r\nQQ2007beta4\u8d85\u70ab\u65b0\u56fe\u6807\uff1a\u98de\u884c\u5c9b\uff0c\u8d22\u4ed8\u901a\uff0cQ\u5427 \r\n\r\n\u6d3b\u52a8\u65f6\u95f4\uff1a2007\u5e747\u670824\u65e5\u2014\u20147\u670826\u65e5 \r\n\r\n\u6d3b\u52a8\u89c4\u5219 \r\n1\u3001\u8be5\u6d3b\u52a8\u9762\u5411\u6240\u6709QQ\u4f1a\u5458\u7528\u6237\u3002 \r\n2\u3001QQ\u4f1a\u5458\u767b\u5f55\u540e\uff0c\u5c06\u5f97\u5230\u4e0b\u8f7d\u6700\u65b0QQ\u7248\u672c\u7684\u94fe\u63a5\uff0c\u4e0b\u8f7d\u5b8c\u8f6f\u4ef6\u540e\u5373\u53ef\u767b\u5f55\u4f53\u9a8c\u3002 \r\n3\u3001\u817e\u8baf\u5ba2\u670d\u52a1\u7535\u8bdd0755-83765566\uff0c\r\n\r\n\u8bf7\u7ee7\u7eed\u5173\u6ce8QQ\u4f1a\u5458\u6d3b\u52a8\uff0c\u540e\u671f\u6211\u4eec\u5c06\u4e0d\u65ad\u4e3aQQ\u4f1a\u5458\u63d0\u4f9b\u66f4\u591a\u65b0\u4ea7\u54c1\u7684\u4f18\u5148\u4f53\u9a8c\uff0c\u8ba9\u60a8\u7684QQ\u751f\u6d3b\u6c38\u8fdc\u201c\u9c9c\u201d\u4eba\u4e00\u6b65\uff01", "imagename": "696950e043894c3f88c85f98080c7975.jpg", "infoid": 25620, "category": "technology_software", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["qq", "\u817e\u8baf"]}, {"url": "http://www.diglog.com/tools-widget.aspx", "title": "\u6b22\u8fce\u5927\u5bb6\u4f7f\u7528diglog Widget", "tags": "diglog widget ", "name": "cacard", "posttime": "2007-07-24 18:46:42", "ip": "221.14.253.196", "mark": 4, "note": "\u4f7f\u7528 diglog Widget \u53ef\u4ee5\u5c06 diglog \u90e8\u5206\u5185\u5bb9\u96c6\u6210\u5230\u60a8\u7684\u535a\u5ba2\u4fa7\u8fb9\u680f\u91cc\u9762\uff0c\u5185\u5bb9\u7c7b\u578b\u5305\u62ec\u70ed\u70b9\u3001\u65b0\u53d1\u73b0\u3001\u4e0a\u5347\u6700\u5feb\uff08\u53ef\u6307\u5b9a\u5206\u7c7b\uff09\uff1b\u67d0\u4e2a\u7528\u6237\u7684\u63d0\u4ea4\u3001\u63a8\u8350\u548c\u6536\u85cf\uff1b\u53e6\u5916\u8fd8\u53ef\u4ee5\u9009\u62e9Widget\u7684\u989c\u8272\u7b49\u3002", "imagename": "cdf5e31a8e9543d8a7def1e9788d4217.gif", "infoid": 25619, "category": "technology_web2", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["diglog", "widget"]}, {"url": "http://history.163.com/07/0724/08/3K5E399H00011247.html", "title": "\u6bdb\u6cfd\u4e1c\u8457\u4f5c\u8d34\u9ec4\u8272\u5c0f\u8bf4\u5c01\u9762\uff1a\u89e3\u653e\u524d\u7684\u4f2a\u88c5\u4e66", "tags": "\u6bdb\u6cfd\u4e1c \u9ec4\u8272\u5c0f\u8bf4 \u65b0\u6c11\u4e3b\u4e3b\u4e49\u8bba ", "name": "magictim", "posttime": "2007-07-24 18:13:52", "ip": "60.191.36.76", "mark": 10, "note": "\u4e00\u672c\u6bdb\u6cfd\u4e1c\u8457\u4f5c\u300a\u65b0\u6c11\u4e3b\u4e3b\u4e49\u8bba\u300b\u7684\u624b\u5de5\u4f2a\u88c5\u672c\u8fd1\u65e5\u5728\u5e7f\u5dde\u88ab\u53d1\u73b0\u3002\u4e13\u5bb6\u4f30\u8ba1\uff0c\u8fd9\u662f\u76ee\u524d\u53d1\u73b0\u7684\u552f\u4e00\u7684\u6bdb\u6cfd\u4e1c\u8457\u4f5c\u624b\u5de5\u88c5\u8ba2\u4f2a\u88c5\u672c\u3002 \r\n\r\n\u653f\u6cbb\u4e5f\u8981\u53d8\u901a\u624d\u884c\uff01\uff01", "imagename": "9a02d0a281684b0fa67fdac070734a92.jpg", "infoid": 25617, "category": "life_other", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "life", "via": null, "real_tags": ["\u6bdb\u6cfd\u4e1c", "\u9ec4\u8272\u5c0f\u8bf4", "\u65b0\u6c11\u4e3b\u4e3b\u4e49\u8bba"]}, {"url": "http://www.twango.com/?07a83fd1dc5c4046a218ea2398481ef9", "title": "\u8bfa\u57fa\u4e9a\u5ba3\u5e03\u5c06\u6536\u8d2d\u7167\u7247\u5171\u4eab\u7f51\u7ad9Twango", "tags": "\u8bfa\u57fa\u4e9a \u7167\u7247\u5171\u4eab ", "name": "yinyin", "posttime": "2007-07-24 17:34:15", "ip": "58.241.195.193", "mark": 5, "note": "\u5317\u4eac\u65f6\u95f47\u670824\u65e5\u7845\u8c37\u52a8\u529b\u4ece\u56fd\u5916\u5a92\u4f53\u5904\u83b7\u6089\uff1a\u8bfa\u57fa\u4e9a\u5468\u4e8c\u5ba3\u5e03\u5c06\u6536\u8d2d\u7f8e\u56fd\u7684\u56fe\u7247\u5171\u4eab\u793e\u4ea4\u7f51\u7ad9Twango\uff0c\u672a\u900f\u9732\u6536\u8d2d\u4ef7\u683c\u3002 \r\n\r\n\u3000\u3000\u4f4d\u4e8e\u7f8e\u56fdTwango\u516c\u53f8\u57282004\u5e74\u8bbe\u7acb\uff0c\u4f46\u51e0\u5bb6\u4e3b\u8981\u7f51\u7edc\u6d41\u91cf\u7edf\u8ba1\u516c\u53f8\u63d0\u4f9b\u7684\u6570\u636e\u8868\u660e\uff0c\u4e0eYouTube\u3001PhotoBuckert\u6216\u96c5\u864eFlickr\u8fd9\u7c7b\u89c6\u9891\u7f51\u7ad9\u76f8\u6bd4\uff0cTango\u516c\u53f8\u7684\u7528\u6237\u8fc4\u4eca\u51e0\u4e4e\u6ca1\u6709\u589e\u957f\u3002 \r\n\r\n\u3000\u3000\u81ea\u4ece\u8bfa\u57fa\u4e9a\u9996\u5e2d\u6267\u884c\u5b98Olli-Pekka Kallasvuo 2006\u5e746\u6708\u4e0a\u4efb\u4ee5\u6765\uff0c\u8bfa\u57fa\u4e9a\u52a0\u901f\u4e86\u5176\u5e76\u8d2d\u4e3e\u63aa\u3002Kallasvuo\u65e9\u524d\u8868\u793a\uff0c\u8bfa\u57fa\u4e9a\u8ba1\u5212\u6536\u8d2d\u66f4\u591a\u516c\u53f8\uff0c\u6765\u52a0\u5f3a\u5176\u5728\u591a\u5a92\u4f53\u548c\u9762\u5411\u4f01\u4e1a\u7ea7\u7528\u6237\u7684\u4e1a\u52a1\u3002 \r\n\r\n\u3000\u3000\u201c\u6536\u8d2dTwango\uff0c\u6807\u5fd7\u7740\u6211\u4eec\u5411\u63d0\u4f9b\u4fe1\u606f\u3001\u5a31\u4e50\u548c\u793e\u4ea4\u7f51\u7edc\u4e00\u4f53\u5316\u670d\u52a1\u8fc8\u51fa\u4e86\u575a\u5b9e\u7684\u4e00\u6b65\u201d\u3002\u8bfa\u57fa\u4e9a\u591a\u5a92\u4f53\u90e8\u95e8\u7684\u4e3b\u7ba1Anssi Vanjoki\u5728\u58f0\u660e\u4e2d\u8868\u793a\u3002", "imagename": "e00d1665e5fe48d9a5e9fa3b43b9ba85.gif", "infoid": 25610, "category": "technology_web2", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u8bfa\u57fa\u4e9a", "\u7167\u7247\u5171\u4eab"]}, {"url": "http://www.cncmax.cn/", "title": "\u4e2d\u56fd\u7f51\u901a\u53d1\u5e03\u5bbd\u5e26\u5965\u8fd0\u5ba2\u6237\u7aef\u4ea7\u54c1", "tags": "\u7f51\u901a \u5965\u8fd0 ", "name": "yinyin", "posttime": "2007-07-24 16:48:26", "ip": "58.241.195.193", "mark": 4, "note": "\u5728\u5317\u4eac2008\u5e74\u5965\u8fd0\u4f1a\u5f00\u5e55\u5012\u8ba1\u65f6\u4e00\u5468\u5e74\u4e4b\u524d,\u4e2d\u56fd\u7f51\u901a\u5c06\u5728\u5168\u56fd\u63a8\u51fa\u81ea\u4e3b\u96c6\u6210\u7814\u53d1\u7684\u201c\u5bbd\u5e26\u6211\u4e16\u754c\u201d\u62e8\u53f7\u5ba2\u6237\u7aef\u4ea7\u54c1,\u5e76\u5c06\u9646\u7eed\u514d\u8d39\u5411\u7528\u6237\u63d0\u4f9b\u8fd9\u6b3e\u7eff\u8272\u4e0a\u7f51\u8f6f\u4ef6.\r\n \u201c\u5bbd\u5e26\u6211\u4e16\u754c\u201d\u5ba2\u6237\u7aef\u662f\u4e2d\u56fd\u7f51\u901a\u4e3a\u7528\u6237\u63d0\u4f9b\u7684\u4e00\u4e2a\u7aef\u5230\u7aef\u7684\u4e00\u7ad9\u5f0f\u8bbf\u95ee\u4e92\u8054\u7f51\u7684\u670d\u52a1\u7a97\u53e3.\u5b83\u4ee5\u5bbd\u5e26\u63a5\u5165\u62e8\u53f7\u529f\u80fd\u4e3a\u57fa\u7840,\u7edf\u4e00\u89c4\u5212\u548c\u6574\u5408\u4e2d\u56fd\u7f51\u901a\u7684\u81ea\u8425\u548c\u5408\u4f5c\u7684\u5bbd\u5e26\u5185\u5bb9\u5e94\u7528\u4ee5\u53ca\u5176\u4ed6\u7efc\u5408\u4fe1\u606f\u670d\u52a1,\u4ee5\u5b9e\u73b0\u7528\u6237\u4e2a\u6027\u5316\u7684\u4e92\u8054\u7f51\u9700\u6c42.\r\n\r\n\u6b64\u6b3e\u4ea7\u54c1\u5177\u6709\u8fde\u63a5\u65b9\u5f0f\u4fbf\u6377\u3001\u62e8\u53f7\u8fde\u901a\u7a33\u5b9a\u6027\u9ad8\u3001\u652f\u6301\u591a\u4e2a\u5e10\u53f7\u548c\u64cd\u4f5c\u7cfb\u7edf\u7b49\u57fa\u672c\u7279\u5f81,\u800c\u4e14\u5b89\u88c5\u548c\u5378\u8f7d\u81ea\u7531,\u5e76\u91c7\u7528\u7eff\u8272\u5378\u8f7d\u65b9\u5f0f,\u5bf9\u7528\u6237\u7684\u64cd\u4f5c\u7cfb\u7edf\u6ca1\u6709\u4efb\u4f55\u5f71\u54cd.\r\n\r\n  \u4e2d\u56fd\u7f51\u901a\u970d\u6d77\u5cf0\u526f\u603b\u88c1\u5728\u63a5\u53d7\u91c7\u8bbf\u65f6\u8868\u793a,\u4f5c\u4e3a\u5317\u4eac2008\u5965\u8fd0\u4f1a\u56fa\u5b9a\u901a\u4fe1\u670d\u52a1\u5408\u4f5c\u4f19\u4f34,\u4e2d\u56fd\u7f51\u901a\u4e00\u76f4\u52aa\u529b\u5c06\u201c\u7eff\u8272\u5965\u8fd0\u3001\u79d1\u6280\u5965\u8fd0\u3001\u4eba\u6587\u5965\u8fd0\u201d\u7684\u7cbe\u795e\u878d\u5165\u5230\u4f01\u4e1a\u7684\u751f\u4ea7\u7ecf\u8425\u4e2d,\u6b63\u5728\u52aa\u529b\u4f7f\u7b2c29\u5c4a\u5965\u8fd0\u4f1a\u6210\u4e3a\u4e00\u5c4a\u201c\u5bbd\u5e26\u5965\u8fd0\u201d.\u4ed6\u8bf4,\u4e2d\u56fd\u7f51\u901a\u5c06\u6700\u5927\u9650\u5ea6\u6ee1\u8db3\u7528\u6237\u5b89\u5168\u3001\u65b9\u4fbf\u3001\u5feb\u6377\u3001\u9ad8\u6548\u7684\u901a\u4fe1\u9700\u6c42,\u5c24\u5176\u662f\u81f4\u529b\u4e8e\u63d0\u9ad8\u4e92\u8054\u7f51\u63a5\u5165\u548c\u5185\u5bb9\u5e94\u7528\u7684\u901a\u4fe1\u670d\u52a1\u8d28\u91cf.\r\n\r\n  \u5728\u4e92\u8054\u7f51\u5185\u5bb9\u5e94\u7528\u65b9\u9762,\u201c\u5bbd\u5e26\u6211\u4e16\u754c\u201d\u5ba2\u6237\u7aef\u96c6\u6210\u4e86\u591a\u8fbe26\u4e2a\u9891\u9053\u7684\u4e30\u5bcc\u7cbe\u5f69\u7684\u5185\u5bb9,\u5305\u62ec\u6743\u5a01\u5b98\u65b9\u65b0\u95fb\u3001\u7126\u70b9\u70ed\u70b9\u4fe1\u606f\u3001\u4f11\u95f2\u5a31\u4e50\u5185\u5bb9\u4ee5\u53ca\u4e92\u52a8\u5e73\u53f0\u548c\u5e94\u7528\u7c7b\u670d\u52a1.\u5176\u4e2d\u201c\u4f60\u597d2008\u201d\u9891\u9053\u662f\u4e2d\u56fd\u7f51\u901a\u4e13\u95e8\u8bbe\u8ba1\u5236\u4f5c\u7684\u5965\u8fd0\u4e13\u9898,\u4ecb\u7ecd\u5965\u8fd0\u5386\u53f2\u3001\u5965\u8fd0\u573a\u9986\u5efa\u8bbe\u8fdb\u884c\u65f6\u3001\u5965\u8fd0\u95e8\u7968\u548c\u8d5b\u7a0b\u5b89\u6392\u3001\u4ee5\u53ca\u4e2d\u56fd\u7f51\u901a\u5c06\u4e3a\u5965\u8fd0\u7528\u6237\u63d0\u4f9b\u7684\u5468\u5230\u9f50\u5168\u7684\u4fe1\u606f\u670d\u52a1.\r\n\r\n  \u63d0\u4f9b\u7eff\u8272\u4e0a\u7f51\u670d\u52a1,\u662f\u7f51\u901a\u5ba2\u6237\u7aef\u4ea7\u54c1\u7684\u53e6\u4e00\u4e2a\u4eae\u70b9.\u5b83\u6574\u5408\u4e86\u4e0a\u7f51\u65f6\u95f4\u7ba1\u7406\u3001\u62e6\u622a\u6709\u5bb3\u7f51\u7ad9\u3001\u5728\u7ebf\u6740\u6bd2\u3001\u5728\u7ebf\u5b66\u4e60\u7b49\u7eff\u8272\u4e0a\u7f51\u4e1a\u52a1,\u5e76\u63d0\u4f9b\u591a\u6837\u5316\u3001\u4e2a\u6027\u5316\u7684\u7cbe\u5f69\u5185\u5bb9\u5e94\u7528,\u4e3a\u5e7f\u5927\u7528\u6237\u8425\u9020\u4e86\u5065\u5eb7\u3001\u6587\u660e\u3001\u548c\u8c10\u7684\u7f51\u7edc\u5e94\u7528\u73af\u5883.\u8fd9\u4e00\u4ea7\u54c1\u975e\u5e38\u9002\u5408\u5e7f\u5927\u9752\u5c11\u5e74\u4e0a\u7f51\u6d3b\u52a8.\r\n\r\n  \u6b64\u5916,\u201c\u5bbd\u5e26\u6211\u4e16\u754c\u201d\u5ba2\u6237\u7aef\u4ea7\u54c1\u8fd8\u5f00\u901a\u4e86\u4e2d\u56fd\u7f51\u901a\u7f51\u4e0a\u8425\u4e1a\u5385\u7684\u90e8\u5206\u529f\u80fd,\u7f51\u901a\u7528\u6237\u53ef\u4ee5\u5728\u7f51\u4e0a\u81ea\u52a9\u529e\u7406\u5bbd\u5e26\u4e0a\u7f51\u3001\u5bbd\u5e26\u5e10\u6237\u4fee\u6539\u3001\u4e0a\u7f51\u8be6\u5355\u67e5\u8be2\u7b49\u4e1a\u52a1.\u8fd9\u5c06\u8fdb\u4e00\u6b65\u6539\u5584\u4e2d\u56fd\u7f51\u901a\u7684\u5bbd\u5e26\u670d\u52a1\u6c34\u5e73.\r\n\r\n  \u636e\u4e2d\u56fd\u7f51\u901a\u5e02\u573a\u7ecf\u8425\u90e8\u6709\u5173\u8d1f\u8d23\u4eba\u4ecb\u7ecd,\u4e2d\u56fd\u7f51\u901a\u7684\u8001\u5ba2\u6237\u53ef\u4ee5\u4ece\u4e2d\u56fd\u7f51\u901aCNCMAX\u7f51\u7ad9(www.cncmax.cn)\u81ea\u7531\u4e0b\u8f7d\u5ba2\u6237\u7aef\u8f6f\u4ef6,\u53ef\u4ee5\u81ea\u7531\u5b89\u88c5\u4f7f\u7528\u6216\u8005\u5378\u8f7d.\u65b0\u88c5\u5bbd\u5e26\u7528\u6237\u5c06\u7531\u7f51\u901a\u4e13\u4e1a\u6280\u672f\u4eba\u5458\u63d0\u4f9b\u4e0a\u95e8\u5b89\u88c5\u670d\u52a1.", "imagename": "", "infoid": 25603, "category": "technology_internet", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u7f51\u901a", "\u5965\u8fd0"]}, {"url": "http://www.chinaz.com/News/IT/0H412AR007.html", "title": "\u4e0d\u4e45\u5c06\u6765 \u6240\u6709\u4e2a\u4eba\u8bba\u575b\u5168\u88ab\u5494\u5693", "tags": "\u8bba\u575b \u6574\u987f \u5907\u6848 ", "name": "127702", "posttime": "2007-07-24 16:18:53", "ip": "58.63.75.223", "mark": 7, "note": "\u76ee\u524d\u5df2\u7ecf\u5f00\u5c55\u6574\u987f\u6240\u6709BBS\uff0c\u5168\u56fd\u5404\u5730\u5747\u5728\u5f00\u5c55\uff0c\u5e7f\u4e1c\u8fd9\u8fb9\u5148\u884c\uff01\uff01\uff01\r\n\r\n\u4e00\u3001 \u4e25\u67e5BBS\u57df\u540d\u5907\u6848\r\n\u4e8c\u3001 \u4e25\u67e5BBS\u4e13\u9879\u5907\u6848\r\n\u4e09\u3001 \u4e25\u67e5BBS\u670d\u52a1\u5668\u548c\u7f51\u7ad9 \r\n\r\n\u60f3\u8981\u5907\u6848\uff0c\u4f01\u4e1a\u4e0d\u4f46\u9700\u8981\u8fc7\u4e94\u5173\u65a9\u516d\u5c06\uff0c\u4e2a\u4eba\