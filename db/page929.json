[{"url": "http://www.mrprint.cn/default.asp", "title": "\u60f3\u51fa\u4e66\uff1f\u5f88\u7b80\u5355\uff0c\u5728\u7ebf\u5370\u4e66\u5427\uff0d\u8d85\u5370\u901f", "tags": "\u4e66 ", "name": "bugbear", "posttime": "2008-04-28 11:37:27", "ip": "222.178.10.240", "mark": 5, "note": "\u4f60\u4eec\u771f\u7684\u53ef\u4ee5\u5370\u4e66\u5417\uff1f\u548c\u5916\u9762\u7684\u4e66\u4e00\u6837\u4e48\uff1f\r\n\u4eb3\u65e0\u7591\u95ee,\u8fd9\u4e9b\u90fd\u662f\u771f\u7684\u3002\u5df1\u7ecf\u6709\u6210\u5343\u4e0a\u4e07\u7684\u7528\u6237\u5df1\u7ecf\u4f53\u9a8c\u4e86POD(\u6309\u9700\u5370\u5237)\u7684\u6548\u679c\u3002\u5176\u5b9e\u5728\u56fd\u5916,\u4e2a\u4eba\u5370\u4e66\u65e9\u5c31\u5f62\u6210\u6210\u719f\u7684\u5e02\u573a,\u800c\u56fd\u5185\u7531\u4e8e\u6210\u672c\u95ee\u9898,\u4e00\u76f4\u5f88\u96be\u63a8\u5e7f,\u73b0\u5728\u8d85\u5370\u901f\u901a\u8fc7\u4e0e\u6b27\u7f8e\u7684\u5370\u5237\u5382\u5546\u5408\u4f5c,\u4f7f\u6bcf\u4e00\u4e2a\u4eba\u90fd\u53ef\u4ee5\u901a\u8fc7\u5f88\u5c11\u7684\u6b65\u9aa4\u548c\u5f88\u77ed\u7684\u65f6\u95f4\u9a6c\u4e0a\u5c31\u62e5\u6709\u81ea\u5df1\u7684\u4e66\u3002\r\n\u7531\u4e8e\u6211\u4eec\u91c7\u7528\u6700\u65b0\u7684\u6570\u7801\u5370\u5237\u8bbe\u5907\u548c\u7ba1\u7406\u7406\u5ff5,\u91c7\u7528\u6570\u7801\u5370\u5237\u548c\u65e0\u7ebf\u80f6\u88c5,\u6211\u4eec\u6240\u5b8c\u6210\u7684\u4e66\u7c4d\u548c\u5916\u9762\u7684\u4e66\u6ca1\u6709\u4efb\u4f55\u533a\u522b\u3002\r\n\r\n\u4e00\u672c\u8d77\u5370\u53ef\u80fd\u4e48\uff1f\uff1f\r\n\u5b8c\u5168\u53ef\u80fd,\u6211\u4eec\u901a\u8fc7\u79d1\u5b66\u7684\u7ba1\u7406\u4e3a\u6bcf\u4e00\u4e2a\u7528\u6237\u63d0\u4f9b\u6700\u597d\u7684\u670d\u52a1,\u5fc5\u7136\u53ef\u4ee5\u6ee1\u8db3\u60a8\u4e00\u672c\u8d77\u5370\u7684\u9700\u6c42\u3002\r\n\r\n\u6211\u771f\u7684\u53ef\u4ee5\u514d\u8d39\u5370\u4e66\u4e48\uff1f\r\n\u662f\u7684\u3002\u4e3a\u4e86\u5feb\u901f\u63a8\u5e7f\u7f51\u7ad9,\u8ba9\u66f4\u591a\u7684\u4eba\u4e86\u89e3\u548c\u4eab\u53d7\u5230\u8d85\u5370\u901f\u7684\u670d\u52a1,\u6211\u4eec\u4e3e\u529e\u4e86\u514d\u8d39\u5370\u4e66\u6d3b\u52a8\u3002\u6211\u4eec\u7684\u514d\u8d39\u5370\u4e66\u6d3b\u52a8\u52309\u6708\u5e95\u622a\u6b62,\u4ee5\u540e\u8fd8\u5c06\u4e0d\u5b9a\u671f\u7684\u4e3e\u884c\u514d\u8d39\u5370\u4e66\u6d3b\u52a8\u3002\u514d\u8d39\u5370\u4e66\u4ec5\u9650\u4e8e\u539f\u521b\u4f5c\u54c1\uff0c\u800c\u4e14\u6bcf\u4f4d\u7528\u6237\u53ea\u80fd\u5370\u4e00\u672c\uff0c\u5177\u4f53\u6d3b\u52a8\u8be6\u60c5\u8bf7\u53c2\u89c1\u6d3b\u52a8\u516c\u544a\u3002\r\n\r\n\u6211\u53ef\u4ee5\u5370\u522b\u4eba\u7684\u4f5c\u54c1\u4e48\uff1f\r\n\u5f53\u7136\u53ef\u4ee5\uff0c\u6211\u4eec\u662f\u4e13\u4e1a\u7684\u5370\u5237\u5382\u5546\uff0c\u5c31\u50cf\u60a8\u53ef\u4ee5\u5728\u5bb6\u91cc\u81ea\u7531\u7684\u6253\u5370\u522b\u4eba\u7684\u4f5c\u54c1\u4e00\u6837\uff0c\u8fd9\u4e9b\u90fd\u662f\u60a8\u7684\u4e2a\u4eba\u6743\u5229\u3002\r\n\r\n\u5370\u4e66\u8fd9\u79cd\u884c\u4e3a\u5408\u6cd5\u4e48\uff1f\r\n\u5b8c\u5168\u5408\u6cd5\uff0c\u5c31\u50cf\u60a8\u53ef\u4ee5\u81ea\u7531\u7684\u5728\u5bb6\u6253\u5370\u4f5c\u54c1\u4e00\u6837\uff0c\u6211\u4eec\u63d0\u4f9b\u7684\u662f\u5370\u5237\u54c1\uff0c\u4e0d\u662f\u51fa\u7248\u7269\u3002\r\n\r\n\u6211\u4ea4\u4ed8\u4f5c\u54c1\u7684\u7248\u6743\u8fd8\u662f\u6211\u7684\u4e48\uff1f\u4f60\u4eec\u4f1a\u7ed9\u522b\u4eba\u770b\u4e48\uff1f\r\n\u5f53\u7136\u7248\u6743\u8fd8\u662f\u60a8\u7684\uff0c\u6211\u4eec\u4ec5\u4ec5\u662f\u5370\u5237\u5546\u800c\u5df2\u3002\u6211\u4eec\u4e0d\u4f1a\u4ee5\u4efb\u4f55\u5f62\u5f0f\u4f20\u64ad\u60a8\u7684\u4f5c\u54c1\uff0c\u5728\u60a8\u5141\u8bb8\u7684\u60c5\u51b5\u4e0b\uff0c\u6211\u4eec\u4ec5\u4ec5\u4f1a\u628a\u60a8\u4f5c\u54c1\u7684\u5c01\u9762\u548c\u540d\u79f0\u5c55\u793a\u5728\u7f51\u7ad9\u4e0a\uff0c\u4e5f\u4e0d\u4f1a\u63d0\u4f9b\u4e0b\u8f7d\u548c\u6d4f\u89c8\u3002", "imagename": "6a28baff79a546c6b6d949887aa223d1.gif", "infoid": 65755, "category": "technology_web2", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": []}, {"url": "http://www.comsharp.com/GetKnowle