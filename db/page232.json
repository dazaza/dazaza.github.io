[{"url": "http://jdxi.net/post/360-ma-li-ao.html", "title": "360\u516c\u53f8\u5e74\u4f1aUED\u4f5c\u54c1\uff1a\u8d85\u7ea7\u9a6c\u91cc\u5965", "tags": "360 \u9a6c\u91cc\u5965 ", "name": "wangweimei", "posttime": "2011-01-28 11:06:03", "ip": "113.95.36.143", "mark": 0, "note": "\u8c8c\u4f3c\u5c11\u4e86\u4e00\u6bb5\u5427\u3002\u3002\u8fd9\u6837\u6309\u7167360\u7684\u5957\u8def\uff0c\u6700\u540e\u5e94\u8be5\u662f\u4ee5\u6253\u5012\u4f01\u9e45\u5927\u9b54\u738b\u6551\u51fa\u516c\u4e3b\u7684\u7ed3\u5c40\u5427\u3002\u3002\u3002", "imagename": "5a02f4eff2d24fb882c817b471ef113e.jpg", "infoid": 380174, "category": "videos_tech-stuff", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "videos", "via": null, "real_tags": ["360", "\u9a6c\u91cc\u5965"]}, {"url": "http://jdxi.net/post/chu-yin-tan-te.html", "title": "\u521d\u97f3\u30df\u30af\u7248\u300a\u5fd0\u5fd1\u300b", "tags": "\u521d\u97f3 \u5fd0\u5fd1 ", "name": "wangweimei", "posttime": "2011-01-28 11:05:06", "ip": "113.95.36.143", "mark": 0, "note": "\u795e\u66f2\u300a\u5fd0\u5fd1\u300b\u4e4b\u521d\u97f3\u30df\u30af\u7248\uff0c\u5f53\u573a\u88ab\u96f7\u5230\u4e86\u3002\u3002\u3002", "imagename": "6dbc0fd9402e4b7eb824330b3e8dce43.jpg", "infoid": 380173, "category": "videos_tech-stuff", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "videos", "via": null, "real_tags": ["\u521d\u97f3", "\u5fd0\u5fd1"]}, {"url": "http://jdxi.net/post/jian-li.html", "title": "\u53f2\u4e0a\u6700\u96f7\u4eba\u7684\u62db\u8058\u7b80\u5386", "tags": "\u53f2\u4e0a \u96f7\u4eba \u62db\u8058 \u7b80\u5386 ", "name": "wangweimei", "posttime": "2011-01-28 11:04:11", "ip": "113.95.36.143", "mark": 0, "note": "\u7535\u89c6\u5267\u7231\u60c5\u516c\u5bd3\u7b2c\u4e8c\u5b63\u4e2d\u7684\u7ecf\u5178\u7247\u6bb5~", "imagename": "559c610e9866474db8def0fcbe48bd25.jpg", "infoid": 380172, "category": "videos_tech-stuff", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "videos", "via": null, "real_tags": ["\u53f2\u4e0a", "\u96f7\u4eba", "\u62db\u8058", "\u7b80\u5386"]}, {"url": "http://www.7weibo.com/blog/post/112.html", "title": "\u56db\u5927\u95e8\u6237\u6b7b\u6390\u5fae\u535a 360\u79f0\u65b0\u6d6a\u5fae\u535a\u5c06\u98a0\u8986\u817e\u8baf", "tags": "", "name": "edivista", "posttime": "2011-01-28 10:02:41", "ip": "58.213.142.216", "mark": 0, "note": "\u7ea2\u7f51\u5317\u4eac\u8baf\uff08\u6f47\u6e58\u6668\u62a5\u6eda\u52a8\u65b0\u95fb\u8bb0\u8005\u674e\u4f1f\uff09\u5fae\u535a\u4e0e\u56e2\u8d2d\u6210\u4e3a2010\u5e74\u7684\u4e24\u5927\u5173\u952e\u8bcd\uff0c\u800c\u56db\u5927\u95e8\u6237\u6b7b\u78d5\u5fae\u535a\u7684\u67b6\u52bf\uff0c\u8ba9\u4eba\u4eec\u60ca\u5947\u5fae\u535a\u5bf9\u4e8e\u95e8\u6237\u7f51\u7ad9\u7684\u610f\u4e49\u5230\u5e95\u6709\u591a\u5927\u3002\u5bf9\u6b64\uff0c\u641c\u72d0\u8463\u4e8b\u5c40\u4e3b\u5e2d\u517c\u9996\u5e2d\u6267\u884c\u5b98\u5f20\u671d\u963320\u65e5\u5728\u5317\u4eac\u63a5\u53d7\u6f47\u6e58\u6668\u62a5\u6eda\u52a8\u65b0\u95fb\u8bb0\u8005\u4e13\u8bbf\u65f6\u8868\u793a\uff0c\u4e0d\u6253\u5fae\u535a\u8fd9\u4e00\u6218\uff0c\u95e8\u6237\u7684\u5a92\u4f53\u4ef7\u503c\u5c06\u53d7\u5230\u6781\u5927\u5a01\u80c1\u3002\u5fae\u535a\u7684\u8bde\u751f\u8ba9\u4fe1\u606f\u7684\u4f20\u64ad\u6e20\u9053\u53d1\u751f\u4e86\u5f88\u5927\u7684\u53d8\u5316\uff0c\u6240\u4ee5\u5fae\u535a\u5bf9\u95e8\u6237\u5a92\u4f53\u7684\u610f\u4e49\u975e\u5e38\u5927\uff0c\u5982\u679c\u4e0d\u6253\u5fae\u535a\u8fd9\u4e2a\u4ed7\uff0c\u6211\u4eec\u5a92\u4f53\u5f88\u53d7\u5a01\u80c1\uff0c\u51e0\u4e2a\u539f\u56e0\u9020\u6210\u6211\u4eec\u5fc5\u987b\u505a\u5fae\u535a\u3002\u5f20\u671d\u9633\u8bf4\u3002\u5fae\u535a\u88ab\u8ba4\u4e3a\u5c06\u6210\u4e3a\u7f51\u6c11\u65e5\u5e38\u5438\u6536\u4fe1\u606f\u7684\u5f3a\u52bf\u6e20\u9053\uff0c\u5e76\u6b63\u6162\u6162\u6539\u53d8\u4eba\u4eec\u7684\u5a31\u4e50\u65b9\u5f0f\uff0c\u9010\u6b65\u6210\u4e3a\u5f71\u54cd\u7f51\u6c11\u751f\u6d3b\u3001\u4f53\u73b0\u5a92\u4f53\u4f20\u64ad\u6e20\u9053\u548c\u5f71\u54cd\u529b\u7684\u5f3a\u52bf\u8f7d\u4f53\u3002\u5f20\u671d\u9633\u4eb2\u81ea\u5e26\u961f\u53d1\u529b\u5fae\u535a\u5766\u8a00\u5728\u5fae\u535a\u9886\u57df\u75db\u5931\u5148\u673a\u7684\u5f20\u671d\u9633\uff0c\u4e0d\u60dc\u4eb2\u81ea\u5e26\u961f\u53d1\u529b\u5fae\u535a\u3002\u5728\u8fd9\u4f4d\u6570\u5b57\u82f1\u96c4\u7684\u773c\u4e2d\uff0c\u5fae\u535a\u7684\u610f\u4e49\u5df2\u88ab\u65e0\u9650\u653e\u5927\u30022010\u5e74\u4e92\u8054\u7f51\u7684\u4e00\u4e2a\u91cd\u8981\u53d1\u5c55\uff0c\u90a3\u5c31\u662f\u5fae\u535a\u7684\u6d41\u884c\u3002\u5fae\u535a\u4f7f\u6211\u4e0e\u4e16\u754c\u7684\u6c9f\u901a\u53d8\u6210\u4e86\u4e00\u4e2a\u4e0d\u95f4\u65ad\u7684\u4fe1\u606f\u6d41\u3002\u5230\u65f6\u5019\u5168\u4eba\u7c7b\u90fd\u5c06\u88ab\u7f16\u7ec7\u5728\u8fd9\u4e07\u80fd\u7684\u5fae\u535a\u4e0a\u3002\u5728\u5f20\u671d\u9633\u770b\u6765\uff0c\u5fae\u535a\u672c\u8eab\u4e5f\u662fSNS\uff08\u793e\u4ea4\u7f51\u7edc\uff09\u7684\u4e00\u79cd\uff0c\u800c\u8fd9\u79cd\u6a21\u5f0f\u7684\u8bde\u751f\u4e5f\u610f\u5473\u7740\u5168\u7403\u4e92\u8054\u7f51\u5f00\u59cb\u4ece\u4fe1\u606f\u7684\u6574\u7406\uff0c\u641c\u7d22\uff0c\u8d70\u5411\u5bf9\u4eba\u7684\u6574\u7406\u3002\u5f20\u671d\u9633\u4e3e\u4f8b\u8bf4\uff0c\u5168\u7403\u6700\u706b\u7684\u793e\u4ea4\u7f51\u7ad9FACEBOOK\uff08\u8bd1\u4e3a\u8138\u8c31\uff09\u5c31\u662f\u4eba\u6d41\u7279\u522b\u5f3a\uff0c\u4ece\u800c\u5bfc\u81f4\u5b83\u5bf9\u5a92\u4f53\u7684\u5f71\u54cd\u975e\u5e38\u5927\u3002\u6240\u4ee5\uff0c\u95e8\u6237\u7f51\u7ad9\u505a\u5fae\u535a\u662f\u5f88\u91cd\u8981\u7684\uff0c\u9996\u5148\u5185\u5bb9\u662f\u7528\u6237\u4ea7\u751f\u7684\uff0c\u5176\u6b21\u5f88\u591a\u4eba\u5f85\u5728\u5fae\u535a\u91cc\u53ef\u4ee5\u83b7\u53d6\u5f88\u591a\u4fe1\u606f\uff0c\u8fd9\u4e2a\u4fe1\u606f\u4e0d\u662f\u7f16\u8f91\u7ed9\u4ed6\u7684\uff0c\u800c\u662f\u4ed6\u5173\u6ce8\u7684\u597d\u670b\u53cb\u63a8\u8350\u7684\u3002\u8fd9\u5bf9\u4e8e\u4fe1\u606f\u7684\u4f20\u64ad\u6e20\u9053\u53d1\u751f\u4e86\u5f88\u5927\u7684\u53d8\u5316\u3002\u4e0d\u8fc7\uff0c\u8c08\u5230\u95e8\u6237\u7684\u5fae\u535a\u5f71\u54cd\u529b\uff0c\u5f20\u671d\u9633\u5766\u627f\u6700\u65e9\u8fdb\u5165\u8fd9\u4e00\u5e02\u573a\u7684\u65b0\u6d6a\u65e0\u7591\u5360\u636e\u7740\u7edd\u5bf9\u7684\u4f18\u52bf\u5730\u4f4d\uff0c\u6709\u6d88\u606f\u79f0\uff0c\u5916\u754c\u5bf9\u4e8e\u65b0\u6d6a\u5fae\u535a\u7684\u4f30\u4ef7\u5df2\u8fbe\u6570\u4ebf\u7f8e\u5143\uff0c\u65b0\u6d6a\u4e5f\u5df2\u5f00\u59cb\u5bf9\u5fae\u535a\u4ea7\u54c1\u8fdb\u884c\u72ec\u7acb\u5206\u62c6\u5e76\u6709\u4e0a\u5e02\u7684\u8ba1\u5212\u3002\u5bf9\u4e8e\u8fd9\u79cd\u4e0e\u65b0\u6d6a\u7684\u76f4\u63a5\u7ade\u4e89\u5173\u7cfb\uff0c\u5f20\u671d\u9633\u8ba4\u4e3a\uff0c\u5fae\u535a\u76ee\u524d\u5728\u4e2d\u56fd\u8fd8\u521a\u521a\u5904\u5728\u4e00\u4e2a\u8d77\u6b65\u7684\u9636\u6bb5\uff0c\u5f88\u591a\u4eba\u8fd8\u6ca1\u6709\u5f00\u59cb\u4f7f\u7528\u8fd9\u4e2a\u4ea7\u54c1\uff0c\u4e00\u65e6\u666e\u901a\u7f51\u6c11\u5f00\u59cb\u5173\u6ce8\u5fae\u535a\u5e76\u4f7f\u7528\u65f6\uff0c\u8fd9\u79cd\u5e73\u53f0\u7684\u89c4\u6a21\u6548\u5e94\u624d\u4f1a\u4ea7\u751f\uff0c\u8fdb\u800c\u624d\u4f1a\u6709\u5f88\u597d\u7684\u76c8\u5229\u6a21\u5f0f\u3002\u56db\u5927\u95e8\u6237\u7f51\u7ad9\u6b7b\u6390\u5fae\u535a2009\u5e748\u6708\uff0c\u65b0\u6d6a\u5728\u56fd\u5185\u7387\u5148\u63a8\u51fa\u5fae\u535a\u670d\u52a1\uff0c14\u4e2a\u6708\u540e\u76842010\u5e7410\u6708\uff0c\u65b0\u6d6a\u5fae\u535a\u6ce8\u518c\u7528\u6237\u6570\u8d85\u8fc7\u4e865000\u4e07\uff0c\u800c\u5fae\u535a\u9f3b\u7956Twitter\uff08\u8bd1\u4e3a\u63a8\u7279\uff09\u8fbe\u5230\u8fd9\u4e00\u89c4\u6a21\u7528\u4e863\u5e74\u65f6\u95f4\u3002\u76ee\u524d\uff0cTwitter\u53ea\u57fa\u4e8e\u6587\u5b57\u8fdb\u884c\u4f20\u64ad\uff0c\u56fd\u5185\u56db\u5927\u95e8\u6237\u7684\u5fae\u535a\uff0c\u5219\u53ef\u57fa\u4e8e\u591a\u5a92\u4f53\u8fdb\u884c\u4f20\u64ad\uff0c\u5141\u8bb8\u7528\u6237\u8bc4\u8bba\u3001\u8f6c\u53d1\u8bc4\u8bba\uff0c\u4e92\u52a8\u6027\u66f4\u5f3a\u3002\u53bb\u5e74\uff0c\u5305\u62ec\u65b0\u6d6a\u3001\u7f51\u6613\u3001\u641c\u72d0\u3001\u817e\u8baf\u5728\u5185\u7684\u56db\u5927\u95e8\u6237\u5728\u5fae\u535a\u4e0a\u7684\u53d1\u529b\u90fd\u662f\u4e0d\u60dc\u8840\u672c\uff0c\u660e\u4e89\u6697\u6597\u3002\u4e16\u754c\u4e0a\u65e2\u6709\u5f88\u5f3a\u5927\u7684\u95e8\u6237\u7f51\u7ad9\uff0c\u4e5f\u6709\u5f88\u5f3a\u5927\u7684\u793e\u4ea4\u5a92\u4f53\uff0c\u4f46\u540c\u65f6\u62e5\u6709\u6210\u529f\u7684\u95e8\u6237\u7f51\u7ad9\u548c\u5f3a\u5927\u7684\u793e\u4ea4\u5a92\u4f53\uff0c\u65b0\u6d6a\u53ef\u4ee5\u8bf4\u72ec\u4e00\u65e0\u4e8c\u3002\u65b0\u6d6a\u9996\u5e2d\u6267\u884c\u5b98\u517c\u603b\u88c1\u66f9\u56fd\u4f1f\u4eb2\u81ea\u51fa\u4efb\u65b0\u6d6a\u5fae\u535a\u7684\u603b\u8d1f\u8d23\u4eba\uff0c\u5e76\u4f7f\u65b0\u6d6a\u5728\u5fae\u535a\u9886\u57df\u4fdd\u6301\u660e\u663e\u4f18\u52bf\u3002\u66f9\u56fd\u4f1f\u8ba4\u4e3a\uff0c\u5fae\u535a\u4ee3\u8868\u4e92\u8054\u7f51\u7684\u53d1\u5c55\u8d8b\u52bf\uff0c\u662f\u79fb\u52a8\u7ec8\u7aef\u548c\u793e\u4f1a\u7f51\u7edc\u7684\u5b8c\u7f8e\u7ed3\u5408\uff0c\u662f\u79fb\u52a8\u4e92\u8054\u7f51\u65f6\u4ee3\u6740\u624b\u7ea7\u7684\u5e94\u7528\u4e4b\u4e00\u3002\r\n\u6614\u5e74\u4f0a\u59cb\uff0c\u7f51\u6613\u5fae\u535a\u63a8\u51fa\u4e86\u6709\u522b\u4e8e\u540d\u4eba\u653b\u52bf\u7684i\u8fbe\u4eba\u8ba1\u5212\u3002\u5fae\u535a\u662f\u7f51\u66132011\u5e74\u7684\u91cd\u70b9\u3002\u7f51\u6613\u638c\u95e8\u4eba\u4e01\u78ca\u65e5\u524d\u5bf9\u5916\u8868\u793a\u3002\u8d22\u5927\u6c14\u7c97\u7684\u817e\u8baf\u4e00\u76f4\u5728\u89ca\u89ce\u4e2d\u56fd\u7b2c\u4e00\u95e8\u6237\u7684\u5730\u4f4d\uff0c\u5728\u5fae\u535a\u4e0a\uff0c\u817e\u8baf\u638c\u95e8\u4eba\u9a6c\u5316\u817e\u53ef\u8c13\u4e0d\u60dc\u8840\u672c\u3002\u636e\u6089\uff0c\u817e\u8baf\u5fae\u535a\u4eca\u5e74\u5c06\u5f00\u653e\u5fae\u535aAPI\uff08\u5e94\u7528\u7a0b\u5e8f\u7f16\u7a0b\u63a5\u53e3\uff09\uff0c\u4e0e\u5404\u79cd\u4e92\u8054\u7f51\u5e94\u7528\u670d\u52a1\u63d0\u4f9b\u8005\u5171\u4eabQQ\u6570\u4ebf\u6d77\u91cf\u7528\u6237\u4ef7\u503c\u3002360\u8463\u4e8b\u957f\u5468\u9e3f\u794e\u9884\u6d4b\uff0c2011\u5e74\u4e2d\u56fd\u4e92\u8054\u7f51\u5c06\u53d1\u751f\u5fae\u535a\u3001\u7535\u5b50\u5546\u52a1\u548cSNS\u4e09\u573a\u5927\u6218\u3002\u4ed6\u7b11\u79f0\uff0c\u53bb\u5e74\u4e00\u76f4\u5728\u53d1\u529b\u641c\u7d22\u7684\u5f20\u671d\u9633\u3001\u4e0e360\u8f83\u52b2\u7684\u9a6c\u5316\u817e\uff0c\u90fd\u88ab\u5ffd\u60a0\u4e86\uff0c\u8001\u8c0b\u6df1\u7b97\u7684\u66f9\u56fd\u4f1f\u501f\u673a\u6084\u6084\u628a\u65b0\u6d6a\u5fae\u535a\u505a\u5230\u4e86\u6781\u81f4\u3002\u65b0\u6d6a\u53ea\u8981\u5f00\u653e\uff0c\u5f88\u53ef\u80fd\u53d8\u6210\u901a\u8baf\u7684\u57fa\u7840\u5de5\u5177\u3002\u5468\u9e3f\u794e\u79f0\uff1a\u4e5f\u8bb8\u9a6c\u5316\u817e\u73b0\u5728\u660e\u767d\u8fc7\u6765\u4e86\uff0c\u98a0\u8986\u817e\u8baf\u7684\u539f\u6765\u662f\u65b0\u6d6a\u5fae\u535a\u3002\u76f8\u5173\u94fe\u63a5\u5f20\u671d\u9633\u70ae\u8f70\u4e2d\u56fd\u60df\u8d22\u5bcc\u793e\u4f1a\u4ef7\u503c\u89c2\r\n\u5f20\u671d\u963320\u65e5\u57282011\u5e74\u641c\u72d0\u65b0\u89c6\u89d2\u9ad8\u5cf0\u8bba\u575b\u4e0a\u8868\u8fbe\u4e86\u5bf9\u8d22\u5bcc\u6570\u5b57\u72c2\u98d9\u4e0b\u7684\u4e2d\u56fd\u672a\u6765\u7684\u62c5\u5fe7\u3002\u4e0e\u4f1a\u5b66\u8005\u547c\u5401\uff0c\u4f5c\u4e3a\u4e00\u4e2a\u5929\u751f\u7684\u5927\u56fd\uff0c\u4e2d\u56fd\u5e94\u4ece\u8d22\u5bcc\u7684\u5d1b\u8d77\uff0c\u8f6c\u5411\u6587\u660e\u7684\u5d1b\u8d77\uff0c\u4e3a\u4e16\u754c\u505a\u51fa\u699c\u6837\u3002\u6bcf\u5e74\u8fd9\u4e2a\u65f6\u5019\uff0c\u6211\u90fd\u60f3\u8df3\u51faIT\u9886\u57df\uff0c\u5199\u70b9\u4e1c\u897f\uff0c\u5bf9\u7ecf\u6d4e\uff0c\u793e\u4f1a\uff0c\u653f\u6cbb\u7b49\u65b9\u9762\u505a\u4e2a\u5b8f\u89c2\u6027\u7684\u53d1\u8a00\uff0c\u4eca\u5e74\u5462\uff0c\u6211\u4e0d\u6253\u7b97\u505a\u4e86\uff0c\u6709\u51e0\u4e2a\u539f\u56e0\uff0c\u4e00\u662f\uff0c\u4ee5\u5f80\u5462\uff0c\u6211\u6709\u70b9\u7740\u6025\uff0c\u89c9\u5f97\u53ea\u6709\u6211\u770b\u5230\u4e86\u8ba9\u7956\u56fd\u5f3a\u5927\u7684\u65b9\u5411\uff0c\u6025\u7740\u8bb2\u51fa\u6765\uff0c\u80fd\u6709\u6240\u5e2e\u52a9\uff0c\u5176\u5b9e\u8fd9\u91cc\u9762\u4e5f\u6709\u70b9\u865a\u8363\u5fc3\u7684\u6210\u5206\uff0c\u60f3\u5c55\