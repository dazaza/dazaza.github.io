[{"url": "http://www.enet.com.cn/article/2007/0419/A20070419551482.shtml", "title": "RSA SecurID Mobile 2.0\u65f6\u4ee3\u7684\u79fb\u52a8\u5b89\u5168", "tags": "Web2.0 \u5b89\u5168 Mobile2.0 ", "name": "yinyin", "posttime": "2007-04-21 00:22:20", "ip": "58.212.73.142", "mark": 2, "note": "\u4f34\u968f\u7740Web2.0\u7684\u6d41\u884c\uff0cMobile2.0\u4e5f\u8fdb\u5165\u4eba\u4eec\u7684\u89c6\u91ce\u3002\u5c24\u5176\u662f\u5728\u4e92\u8054\u7f51\u7684\u683c\u5c40\u4e2d\uff0c\u79fb\u52a8\u8bbe\u5907\u6b63\u5728\u8fd9\u79cd\u80cc\u666f\u4e0b\u626e\u6f14\u7740\u8d8a\u6765\u8d8a\u91cd\u8981\u7684\u89d2\u8272\u3002\u79fb\u52a8\u8bbe\u5907\u4ee5\u5176\u72ec\u7279\u7684\u4e2a\u6027\u5316\u8272\u5f69\uff0c\u4ee5\u53ca\u4fbf\u643a\u548c\u79fb\u52a8\u6027\u53d7\u5230\u8d8a\u6765\u8d8a\u591a\u4eba\u7684\u9752\u7750\uff0cMobile2.0\u7406\u5ff5\u4e0b\u7684\u5e94\u7528\u548c\u521b\u65b0\u6b63\u5728\u6025\u901f\u589e\u52a0\u3002Mobile2.0\u65f6\u4ee3\u5b58\u5728\u7740\u5404\u79cd\u5404\u6837\u6709\u8da3\u7684\u670d\u52a1\uff0c\u4f8b\u5982\u4f01\u4e1a\u8d44\u6e90\u8bbf\u95ee\u3001\u6587\u4ef6\u540c\u6b65\u3001\u56fe\u7247\u5206\u4eab\u3001\u89c6\u9891\u76f4\u64ad\u3001\u7535\u5b50\u90ae\u4ef6\u548c\u641c\u7d22\u5f15\u64ce\u7b49\uff0c\u5b83\u4eec\u56e0\u521b\u9020\u4e86\u66f4\u591a\u7684\u7528\u6237\u4f53\u9a8c\u800c\u5e7f\u6cdb\u6d41\u884c\u8d77\u6765\u3002\u5728PC\u4e0a\u53ef\u4ee5\u83b7\u5f97\u7684\u5e94\u7528\u548c\u4f53\u9a8c\uff0c\u540c\u6837\u53ef\u4ee5\u5728\u79fb\u52a8\u8bbe\u5907\u4e0a\u5b9e\u73b0\u3002\u79fb\u52a8\u8bbe\u5907\u6b63\u5728\u4ee5\u66f4\u5f3a\u52b2\u7684\u6001\u52bf\u5f15\u9886\u4e92\u8054\u7f51\u53d1\u5c55\u7684\u6f6e\u6d41\uff0c\u4ee3\u66ffPC\u6210\u4e3a\u4e92\u8054\u7f51\u53d1\u5c55\u7684\u4e3b\u89d2\u3002", "imagename": "", "infoid": 17029, "category": "technology_web2", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["web2.0", "\u5b89\u5168", "mobile2.0"]}, {"url": "http://www.jingzhengli.cn/Blog/hbj/362.html", "title": "Google AdWords\u7684\u4e24\u4e2a\u7ec6\u5c0f\u6539\u8fdb", "tags": "Google ", "name": "yinyin", "posttime": "2007-04-21 00:19:41", "ip": "58.212.73.142", "mark": 2, "note": "Google Adwords\u5b98\u65b9\u535a\u5ba2http://adwords.blogspot.com/\u5ba3\u5e03\u5bf9Adwords\u5e7f\u544a\u4e2d\u7684\u9876\u90e8\u5e7f\u544a\u5c55\u793a\u65b9\u5f0f\u505a\u4e86\u4e24\u4e2a\u6539\u8fdb\uff0c\u8fd9\u662f\u4e24\u4e2a\u770b\u4f3c\u7ec6\u5c0f\u4f46\u5374\u5177\u6709\u91cd\u8981\u7684\u4f5c\u7528\u7684\u8c03\u6574\uff1a\u5176\u4e00\u662f\u641c\u7d22\u7ed3\u679c\u9876\u90e8\u7684\u5e7f\u544a\u989c\u8272\u7531\u84dd\u8272\u6539\u4e3a\u4e86\u9ec4\u8272\uff0c\u7b2c\u4e8c\u4e2a\u6539\u8fdb\u662f\uff1a\u8fc7\u53bb\uff0c\u5e7f\u544a\u7684\u9634\u5f71\u533a\u5757\u90fd\u4f1a\u5e26\u6709\u5e7f\u544a\u94fe\u63a5\uff0c\u7528\u6237\u5f88\u5bb9\u6613\u4e00\u4e0d\u5c0f\u5fc3\u5c31\u70b9\u51fb\u4e86\u5e7f\u544a\uff0c\u4ece\u800c\u4ea7\u751f\u4e0d\u5c11\u65e0\u6548\u70b9\u51fb\uff0c\u6d6a\u8d39\u5e7f\u544a\u5ba2\u6237\u7684\u91d1\u94b1\u3002\u6539\u8fdb\u540e\u7684\u94fe\u63a5\u53ea\u52a0\u5728\u5e7f\u544a\u94fe\u63a5\u6587\u672c\u4e0a\uff0c\u9634\u5f71\u533a\u5757\u65e0\u94fe\u63a5\uff0c\u4ece\u800c\u6781\u5927\u51cf\u5c11\u8bef\u70b9\u51fb\u7684\u53ef\u80fd\u3002", "imagename": "", "infoid": 17028, "category": "technology_google", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["google"]}, {"url": "http://tech.qq.com/a/20070420/000068.htm", "title": "Google\u5b66\u4e60\u4e2d\u56fd\u5bfc\u822a \u63a8\u4e2a\u6027\u5316\u7f51\u7ad9\u63a8\u8350", "tags": "Google \u641c\u7d22\u5f15\u64ce \u8c37\u6b4c ", "name": "yinyin", "posttime": "2007-04-21 00:18:20", "ip": "58.212.73.142", "mark": 2, "note": "4\u670819\u65e5\uff0c\u7f8e\u56fd\u641c\u7d22\u5f15\u64ce\u8c37\u6b4c\u516c\u53f8\u63a8\u51fa\u4e86\u4e00\u4e2a\u4e2a\u6027\u5316\u7f51\u7ad9\u63a8\u8350\u529f\u80fd\uff0c\u53ef\u4ee5\u6839\u636e\u7528\u6237\u7684\u641c\u7d22\u5386\u53