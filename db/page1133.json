s - Mozilla Firefox 1.5 , Opera 9  and Safari. On older browsers and Internet Explorer, it\u2019ll degrade and your visitors won\u2019t notice a thing. It\u2019s 6.4KB\u3002", "imagename": "7d6133b65005422da8b98911db323612.jpg", "infoid": 16920, "category": "technology_design", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["js", "\u5706\u89d2", "web", "\u8fb9\u6846", "corner.js"]}, {"url": "https://cn.widsets.com/index", "title": "\u7ef4\u4fe1", "tags": "\u7ef4\u4fe1 RSS ", "name": "yinyin", "posttime": "2007-04-19 19:59:20", "ip": "58.212.139.251", "mark": 4, "note": "\u4f7f\u7528\u7ef4\u4fe1\uff0c\u8fd9\u4e00\u5207\u7686\u6709\u53ef\u80fd\uff0c\u800c\u4e14\u66f4\u6709\u8bf8\u591a\u610f\u5916\u60ca\u559c\u3002\u60a8\u53ef\u4ee5\u83b7\u77e5\u4ea4\u901a\u72b6\u51b5\u9884\u8b66\u3001\u65f6\u4e8b\u65b0\u95fb\u3001\u535a\u5ba2\u4fe1\u606f\u3001\u5c0f\u9053\u6d88\u606f\u3001\u996d\u5e97\u8bc4\u8bba\u3001\u5929\u6c14\u9884\u62a5\u548c\u5404\u79cd\u6742\u4e03\u6742\u516b\u7684\u8baf\u606f\u7b49\uff0c\u800c\u8fd9\u4e9b\u4e1c\u897f\u60a8\u901a\u5e38\u8981\u901a\u8fc7\u65e0\u6570\u7f51\u7edc\u8f9b\u82e6\u641c\u7d22\u624d\u80fd\u83b7\u5f97\u3002 \r\n\u5b9e\u9645\u4e0a\uff0c\u7ef4\u4fe1\u63d0\u4f9b\u4fe1\u606f\u670d\u52a1\u6e38\u5203\u6709\u4f59\uff0c\u60a8\u6839\u672c\u4e0d\u9700\u8981\u4e00\u4e2a\u4e00\u4e2a\u7f51\u7ad9\u5730\u53bb\u70b9\u51fb\u3001\u5237\u65b0\uff0c\u641c\u5bfb\u6d4f\u89c8\u60a8\u60f3\u8981\u7684\u5185\u5bb9\uff0c\u6240\u6709\u4fe1\u606f\u90fd\u5c06\u81ea\u52a8\u66f4\u65b0\u4f20\u9001\u5230\u60a8\u7684\u624b\u673a\u4e0a\u3002\u6211\u4eec\u7684\u76ee\u6807\u5c31\u662f\u8981\u8ba9\u6bcf\u4e2a\u4eba\u90fd\u80fd\u4eab\u53d7\u5230\u8fd9\u9879\u670d\u52a1\uff0c\u5e76\u5c3d\u91cf\u4f7f\u5176\u64cd\u4f5c\u7b80\u5355\u3002 \r\n\u8fd9\u9879\u670d\u52a1\u6bcf\u4e2a\u4eba\u90fd\u4eab\u53d7\u5f97\u8d77\uff0c\u56e0\u4e3a\u5b83\u662f\u5b8c\u5168\u514d\u8d39\u7684\u3002\u60a8\u53ef\u4ee5\u968f\u5fc3\u6240\u6b32\u5730\u4f7f\u7528\u5b83\uff0c\u7f16\u5236\u670d\u52a1\u4fe1\u606f\u540c\u4ed6\u4eba\u5206\u4eab\uff0c\u76f4\u5230\u60a8\u5fc3\u6ee1\u610f\u8db3\u4e3a\u6b62\u3002", "imagename": "", "infoid": 16893, "category": "technology_software", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u7ef4\u4fe1", "rss"]}, {"url": "http://free.donews.com/viewthread.php?tid=86022", "title": "Myspace\u4e2d\u56fd\u4e5f\u662f\u8981\u505a\u65b0\u95fb", "tags": "Myspace ", "name": "yinyin", "posttime": "2007-04-19 19:57:21", "ip": "58.212.139.251", "mark": 4, "note": "Myspace\u4e2d\u56fd\u4e5f\u505a\u65b0\u95fb\uff0c\u65b0\u6d6a\u6015\u4e0d\u6015\uff1f\r\n\r\n\u65b0\u6d6a\u62a5\u9053\uff1aMySpace\u5c06\u63a8\u65b0\u95fb\u670d\u52a1\u5438\u5f15\u5e7f\u544a\u5ba2\u6237 \r\n\r\n\u5317\u4eac\u65f6\u95f44\u670819\u65e5\u6d88\u606f\uff0c\u636e\u56fd\u5916\u5a92\u4f53\u62a5\u9053\uff0c\u65b0\u95fb\u96c6\u56e2\u65d7\u4e0b\u793e\u4ea4\u7f51\u7ad9MySpace\u5c06\u4ece\u672c\u5468\u56db\u5f00\u59cb\u6d4b\u8bd5\u4e00\u9879\u65b0\u670d\u52a1\u2014\u2014MySpace\u65b0\u95fb\uff0c\u5e0c\u671b\u7c4d\u6b64\u4fc3\u8fdb\u5e7f\u544a\u8425\u6536\u7684\u589e\u957f\u3002\r\n\r\nMySpace\u65b0\u95fb\u4e3b\u8981\u63d0\u4f9b\u65b0\u95fb\u805a\u5408\u670d\u52a1\uff0c\u8fd9\u4e00\u70b9\u7c7b\u4f3c\u4e8eGoogle\u65b0\u95fb\uff1b\u4e0e\u6b64\u540c\u65f6\uff0c\u5b83\u8fd8\u5141\u8bb8\u8bfb\u8005\u5bf9\u65b0\u95fb\u8bc4\u5206\uff0c\u8fd9\u4e00\u70b9\u53c8\u7c7b\u4f3c\u4e8eDigg.com\u3002\u56e0\u6b64\uff0cMySpace\u65b0\u95fb\u53ef\u4ee5\u770b\u4f5c\u662fGoogle\u65b0\u95fb\u4e0eDigg.com\u7684\u6df7\u5408\u4f53\u3002\u6839\u636e\u5e02\u573a\u7814\u7a76\u516c\u53f8comScore Network\u516c\u5e03\u7684\u6700\u65b0\u6570\u636e\uff0c\u4eca\u5e743\u6708MySpace\u7684\u72ec\u7acb\u8bbf\u95ee\u8005\u4eba\u6570\u5df2\u7ecf\u8d85\u8fc71\u4ebf\u3002\u6beb\u65e0\u7591\u95ee\uff0cMySpace\u5e0c\u671b\u901a\u8fc7\u63a8\u51fa\u66f4\u591a\u6709\u5438\u5f15\u529b\u7684\u670d\u52a1\u7559\u4f4f\u8fd9\u4e9b\u7528\u6237\u3002\r\n\r\n\u65b0\u95fb\u96c6\u56e2\u9ad8\u7ba1\u8868\u793a\uff0c\u4e3a\u4e86\u8fdb\u4e00\u6b65\u5de9\u56fa\u81ea\u8eab\u5728\u4e92\u8054\u7f51\u5e02\u573a\u7684\u9886\u5148\u5730\u4f4d\uff0c\u4ed6\u4eec\u4e00\u76f4\u5728\u5bfb\u6c42\u4ece\u5176\u5b83\u5a92\u4f53\u8d44\u6e90\u83b7\u5f97\u66f4\u591a\u5a31\u4e50\u548c\u5176\u5b83\u7c7b\u578b\u7684\u5185\u5bb9\u3002\u65b0\u95fb\u96c6\u56e2\u9884\u8ba1\uff0c\u5176\u6570\u5b57\u4e1a\u52a1\u90e8\u95e8\u5f53\u524d\u8d22\u5e74\u5c06\u751f\u62105\u4ebf\u7f8e\u5143\u4ee5\u4e0a\u7684\u8425\u6536\u3002\u5728\u6b64\u4e4b\u524d\uff0cMySpace\u7528\u6237\u8981\u60f3\u9605\u8bfb\u7f51\u7edc\u65b0\u95fb\uff0c\u9700\u8981\u6682\u65f6\u79bb\u5f00\u8fd9\u4e00\u7f8e\u56fd\u6700\u5927\u7684\u793e\u4ea4\u7f51\u7ad9\u3002comScore\u516c\u5e03\u7684\u6570\u636e\u663e\u793a\uff0c\u4eca\u5e743\u6708\uff0c\u7f8e\u56fd\u7528\u6237\u5e73\u5747\u6bcf\u6b21\u8bbf\u95eeMySpace\u505c\u7559\u7684\u65f6\u95f4\u4e3a10\u5206\u949f\uff0c\u5e73\u5747\u6bcf\u540d\u7528\u6237\u6bcf\u6708\u8bbf\u95ee19\u6b21\u3002\r\n\r\nMySpace\u65b0\u95fb\u5c06\u5305\u542b25\u4e2a\u4e3b\u9898\uff0c\u4ee5\u53ca\u7ea6300\u4e2a\u5b50\u7c7b\uff0c\u8986\u76d6\u4e86\u6148\u5584\u3001\u95f2\u8c08\u3001\u6c7d\u8f66\u548c\u65f6\u5c1a\u7b49\u591a\u4e2a\u9886\u57df\u3002MySpace\u65b0\u95fb\u6240\u91c7\u7528\u7684\u6280\u672f\u7531Newroo\u516c\u53f8\u6253\u9020\uff0c\u8fd9\u5bb6\u516c\u53f8\u53bb\u5e74\u88ab\u65b0\u95fb\u96c6\u56e2\u6536\u8d2d\u3002Newroo\u8054\u5408\u521b\u59cb\u4eba\u5e03\u83b1\u6069&#183;\u8bfa\u52a0\u5fb7(Brian Norgard)\u8868\u793a\uff1a\u201c\u968f\u7740\u8fd9\u9879\u670d\u52a1\u7684\u63a8\u51fa\uff0c\u5c06\u6709\u5927\u91cf\u54c1\u724c\u524d\u6765\u5bfb\u6c42\u4e0eMySpace\u5408\u4f5c\u3002\u201d\u4f8b\u5982\uff0cMySpace\u65b0\u95fb\u7684\u6c7d\u8f66\u9891\u9053\u53ef\u80fd\u4f1a\u5438\u5f15\u5f88\u591a\u5e0c\u671b\u5728MySpace\u4f1a\u5458\u4e2d\u53d1\u5c55\u7528\u6237\u7684\u5927\u6c7d\u8f66\u5382\u5546\u3002\r\n\r\n\u65b0\u95fb\u96c6\u56e2