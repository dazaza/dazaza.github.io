518d\u5fc5\u987b\u53bb\u8f66\u7968\u4ee3\u552e\u70b9\u6392\u961f\uff0c\u800c\u4ec5\u4ec5\u901a\u8fc7\u9f20\u6807\u548c\u952e\u76d8\u5c31\u53ef\u4ee5\u4e70\u5230\u8f66\u7968\u3002\u201d\u9177\u8baf\u7f51CEO\u9648\u534e\u8868\u793a\uff0c\u201c\u8d2d\u4e70\u706b\u8f66\u7968\u96be\u201d\u4e00\u76f4\u662f\u4e00\u4e2a\u91cd\u8981\u793e\u4f1a\u95ee\u9898\uff0c\u5728\u7ebf\u8d2d\u7968\u529f\u80fd\u7684\u4e0a\u7ebf\u4e0d\u4ec5\u662f\u9177\u8baf\u7f51\u7684\u4e00\u9879\u529f\u80fd\u6027\u8865\u5145\uff0c\u66f4\u91cd\u8981\u7684\u662f\uff0c\u521b\u9020\u4e86\u5168\u65b0\u7684\u706b\u8f66\u7968\u5206\u9500\u6e20\u9053\u3002 \r\n\r\n\u3000\u3000\u53e6\u5916\uff0c\u5feb\u6377\u3001\u53ef\u9760\u7684\u7ebf\u4e0a\u9500\u552e\u6a21\u5f0f\u5c06\u6709\u6548\u89e3\u51b3\u201c\u5047\u7968\u201d\u7b49\u4e00\u7cfb\u5217\u96be\u9898\uff0c\u4ee4\u6d88\u8d39\u8005\u53d7\u76ca\u3002\u201c\u4ece\u4eca\u4ee5\u540e\uff0c\u65c5\u5ba2\u53ef\u4ee5\u50cf\u4e70\u673a\u7968\u4e00\u6837\u65b9\u4fbf\u5730\u8d2d\u4e70\u706b\u8f66\u7968\u3002\u201d\u6709\u4e13\u5bb6\u751a\u81f3\u5c06\u8fd9\u770b\u4f5c\u662f\u706b\u8f66\u7968\u7535\u5b50\u5546\u52a1\u5316\u7684\u7a81\u7834\u3002\u201c\u672a\u6765\u53ef\u63d0\u4f9b\u7684\u706b\u8f66\u7968\u670d\u52a1\u4f1a\u4e0d\u65ad\u66f4\u65b0\uff0c\u4ece\u706b\u8f66\u7968\u8f6c\u8ba9\u641c\u7d22\u3001\u7968\u9a97\u5b50\u8bc6\u522b\u3001\u706b\u8f66\u7968\u9884\u5b9a\u3001\u518d\u5230\u5982\u4eca\u7684\u706b\u8f66\u7968\u5728\u7ebf\u8d2d\u7968\uff0c\u8fd9\u4e9b\u529f\u80fd\u90fd\u5c06\u4e3a\u8fd1\u4ebf\u7f51\u6c11\u89e3\u51b3\u4e86\u51fa\u884c\u96be\u9898\u3002\u201d\u4e0d\u8fc7\u4e5f\u6709\u4eba\u63d0\u9192\uff0c\u4e0e\u98de\u673a\u7968\u5728\u7ebf\u9500\u552e\u6bd4\uff0c\u706b\u8f66\u7968\u8d70\u5411\u4e92\u8054\u7f51\u8fd8\u5b58\u5728\u7740\u653f\u7b56\u4e0a\u7684\u969c\u788d\u3002 \r\n\r\n\u3000\u3000\u201c\u76ee\u524d\u9177\u8baf\u7684\u706b\u8f66\u7968\u4fe1\u606f\u5df2\u7ecf\u5b8c\u5168\u4e0e\u94c1\u8def\u5c40\u5b98\u65b9\u7968\u6e90\u540c\u6b65\u66f4\u65b0\uff0c\u7528\u6237\u9009\u62e9\u5728\u7ebf\u8d2d\u7968\u540e\u4f1a\u6709\u4e13\u4eba\u63d0\u4f9b\u7ebf\u4e0a\u5ba2\u670d\uff0c\u586b\u5199\u57fa\u672c\u4fe1\u606f\u540e\u5373\u53ef\u8f7b\u677e\u7b49\u5f85\u706b\u8f66\u7968\u5230\u624b\u3002\u201d \u9177\u8baf\u65c5\u6e38\u9891\u9053\u8d1f\u8d23\u4eba\u4ecb\u7ecd\ue704\u201c\u76ee\u524d\u7684\u4eba\u5de5\u670d\u52a1\u65f6\u95f4\u4e3a\u6bcf\u65e58\uff1a00-21\uff1a00\uff0c\u53e6\u5916\uff0c\u7f51\u6c11\u4e5f\u53ef\u4ee5\u968f\u65f6\u901a\u8fc7\u767b\u5f55\u9177\u8baf\u76f4\u63a5\u9884\u8ba2\u8f66\u7968\u3002\u201d\u8bb0\u8005\u4e86\u89e3\u5230\uff0c\u76ee\u524d\u6bcf\u5f20\u201c\u7968\u5230\u4ed8\u6b3e\u201d\u7684\u706b\u8f66\u7968\u9700\u8981\u52a0\u65365\u5143\u7684\u5feb\u9012\u8d39\u3002\u636e\u6089\uff0c\u5728\u7ebf\u8d2d\u7968\u529f\u80fd\u4e0a\u7ebf\u4e00\u5468\u4ee5\u6765\uff0c\u8d2d\u7968\u4eba\u6570\u5df2\u8d85\u8fc76\u4e07\u4eba\u3002\u8fd9\u8db3\u4ee5\u8bc1\u660e\uff0c\u5728\u7ebf\u9500\u552e\u7684\u9700\u6c42\u6f5c\u529b\u5de8\u5927\u3002 \r\n\r\n\u3000\u3000\u201c\u5c3d\u7ba1\u76ee\u524d\u6211\u56fd\u65c5\u6e38\u884c\u4e1a\u4ea7\u503c\u8d85\u8fc7\u4e86\u4ebf\u4e07\uff0c\u5e76\u6bcf\u5e74\u4fdd\u630110.4%\u7684\u589e\u957f\u901f\u5ea6\uff0c\u4f46\u4e8b\u5b9e\u4e0a\u65c5\u6e38\u5e02\u573a\u6210\u719f\u5ea6\u5e76\u4e0d\u9ad8\uff0c\u800c\u5176\u4e2d\u5728\u7ebf\u65c5\u6e38\u670d\u52a1\u5219\u66f4\u9700\u8981\u6280\u672f\u548c\u521b\u65b0\u3002\u201d\u9648\u534e\u8ba4\u4e3a\uff0c\u901a\u8fc7\u641c\u7d22\u6280\u672f\u4e0e\u6d88\u8d39\u8005\u5229\u76ca\u7684\u7ed3\u5408\u91cd\u5851\u6574\u4e2a\u4ea7\u4e1a\u5f62\u6001\uff0c\u8fd9\u662f\u4e00\u79cd\u80fd\u5c06\u65c5\u6e38\u4ea7\u4e1a\u94fe\u901a\u8fc7\u4e92\u8054\u7f51\u8fdb\u884c\u6574\u5408\u7684\u529b\u91cf\u3002\u6709\u4e13\u5bb6\u8ba4\u4e3a\uff0c\u641c\u7d22\u7f51\u7ad9\u4e0e\u7ebf\u4e0b\u4ee3\u552e\u70b9\u5408\u4f5c\u6a21\u5f0f\u6709\u6781\u5f3a\u7684\u53ef\u590d\u5236\u6027\uff0c\u5c24\u5176\u5728\u7f51\u7edc\u73af\u5883\u6210\u719f\u7684\u57ce\u5e02\uff0c\u4e0d\u