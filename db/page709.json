\u5236\u7535\u8111\u4e0e\u7f51\u7edc\u3002\u4e3a\u7eaa\u5ff5\u6b64\u4f1f\u5927\u53d1\u660e\uff0cSRI\u57282008\u5e7412\u67089\u65e5\u4e3e\u529e\u4e86\u9f20\u6807\u53d1\u660e40\u5468\u5e74\u5e86\u3002\r\n\r\n\u7b2c\u4e00\u53ea\u9f20\u6807\u539f\u578b\r\n\u53c2\u8003\u7f51\u7ad9\uff1a\r\n\r\nSRI\u6ed1\u9f20\u7eaa\u5ff5\u7f51\u7ad9\r\n\u9f20\u6807\u7f51\r\nBBC\u5f71\u7247\r\n\r\nEngelbart\u8fd8\u662f\u7535\u5b50\u5de5\u7a0b\u5728\u6821\u5b66\u751f\u65f6\uff0c\u5c31\u5f00\u59cb\u60f3\u50cf\u5404\u79cd\u53ef\u80fd\u65b9\u5f0f\u8981\u8ba9\u6240\u6709\u7684\u8d44\u8baf\u663e\u793a\u5728\u6620\u8c61\u7ba1\u663e\u793a\u5668\u4e0a\uff0c\u68a6\u60f3\u80fd\u591f\u300c\u9068\u6e38\u300d\u4e8e\u5404\u79cd\u7684\u8d44\u8baf\u4e16\u754c\u91cc\u3002 1968\u5e74Doug Engelbart\u6210\u7acb\u5e76\u9886\u5bfcSRI\u7684Augmentation Research Center\uff08ARC\uff09\u3002 12\u67089\u65e5\u4ed6\u4e0e\u6240\u9886\u5bfc\u7684\u5e74\u8f7b\u7535\u8111\u79d1\u5b66\u5bb6\u53ca\u7535\u5b50\u5de5\u7a0b\u5e08\u56e2\u961f\uff0c\u4e00\u8d77\u5728\u65e7\u91d1\u5c71\u7684\u79cb\u5b63\u8054\u5408\u7535\u8111\u5927\u4f1a\uff08Fall Joint Computer Conference\uff09\u4e0a\u8fdb\u884c\u4e8690\u5206\u949f\u7684\u516c\u5f00\u591a\u5a92\u4f53\u5c55\u793a\uff0c\u800c\u8fd9\u573a\u5c55\u793a\u4e5f\u88ab\u5c01\u4e3a\u300c\u5c55\u793a\u4e4b\u6bcd\u300d\uff08The Mother of All Demos\uff09\u3002\r\n\r\n\u5c55\u793a\u4e4b\u6bcd\uff0d\uff0d\u56db\u5341\u5e74\u524d\u7684\u79cb\u5b63\u8054\u5408\u7535\u8111\u5927\u4f1a\u73b0\u573a\r\n\u5728\u8fd9\u573a\u5168\u7403\u7684\u53d1\u8868\u4f1a\u4e0a\uff0cEngelbart\u7684\u56e2\u961f\u9996\u6b21\u5229\u7528\u9f20\u6807\u63a7\u5236\u8fde\u7f51\u7684\u7535\u8111\u7cfb\u7edf\uff0c\u5c55\u793a\u8d85\u6587\u5b57\u8fde\u7ed3\u3001\u5373\u65f6\u7684\u6587\u5b57\u7f16\u8f91\u3001\u591a\u89c6\u7a97\u7684\u5f39\u6027\u89c6\u89c9\u63a7\u5236\uff0c\u4ee5\u53ca\u5171\u4eab\u8424\u5e55\u7684\u8fdc\u7aef\u4f1a\u8bae\u3002\u8fd9\u4e5f\u662f\u540e\u6765\u666e\u904d\u7528\u4e8e\u7535\u8111\u4e0a\u7684\u9f20\u6807\uff1b\u9f20\u6807\u7684\u9886\u5bfc\u5382\u5546\u7f57\u6280\u7535\u5b50\u4e5f\u5728\u9f20\u680740\u5468\u5e74\u4e0a\u5ba3\u5e03\uff0c\u5176\u51fa\u8d27\u7684\u9f20\u6807\u5df2\u783410\u4ebf\u53ea\u3002\r\n\r\n\u53f2\u4e39\u4f5b\u7814\u7a76\u6240\uff08Stanford Research Institute, SRI\uff09\u5728\u5176\u7f51\u7ad9\u4e0a\u8868\u793a\uff0c\u9f20\u6807\u662fSRI\u4f1f\u5927\u7684\u539f\u521b\u53d1\u660e\u4e4b\u4e00\u3002 Doug Engelbart\u57281960\u5e74\u4ee3\u521d\u671f\u5728\u7814\u7a76\u4eba\u7c7b\u4e0e\u7535\u8111\u4e92\u52a8\u65f6\u5c31\u8bbe\u8ba1\u51fa\u9f20\u6807\uff0cSRI\u7684\u5de5\u7a0b\u957fBill English\u5219\u57281964\u5e74\u6253\u9020\u51fa\u4e16\u754c\u4e0a\u7b2c\u4e00\u53ea\u9f20\u6807\u539f\u578b\uff0c\u5176\u539f\u59cb\u8bbe\u8ba1\u4e3a\u6728\u5236\u5916\u58f3\uff0c\u5e76\u53ea\u6709\u4e00\u9897\u7ea2\u8272\u6309\u94ae\uff0c\u76ee\u524d\u5e76\u6709\u590d\u5236\u54c1\u5c55\u793a\u5728SRI\u603b\u90e8\u5927\u5385\u3002\r\n\r\n\u63a5\u7740\u9f20\u6807\u6709\u4e86\u591a\u6309\u952e\u8bbe\u8ba1\uff0c\u5e76\u4f7f\u7528\u4e00\u6216\u4e24\u4e2a\u6eda\u8f6e\u5c06\u9f20\u6807\u7684\u4f4d\u79fb\u8f6c\u8bd1\u4e3a\u8424\u5e55\u4e0a\u7684\u6e38\u6807\u3002 \u300c\u663e\u793a\u7cfb\u7edf\u7684XY\u8f74\u4f4d\u7f6e\u6307\u793a\u300d\uff08XY Position Indicator for a Display System\uff09\u53ef\u4ee5\u8bf4\u662f\u9f20\u6807\u53d1\u660e\u7684\u57fa\u672c\u4e13\u5229\uff0c\u800cEngelbart\u4e5f\u662f\u8be5\u4e13\u5229\u7684\u53d1\u660e\u8005\u3002\r\n\r\n\u8fd9\u573a\u5c55\u793a\u7684\u5e55\u540e\u5de5\u4f5c\r\n\u4e3a\u8868\u5f70Engelbart\u7684\u8d21\u732e\uff0c2000\u5e74\u7f8e\u56fd\u603b\u7edf\u67ef\u7075\u987f\u66f4\u9881\u7ed9Engelbart\u300c\u7f8e\u56fd\u56fd\u5bb6\u79d1\u6280\u5956\u7ae0\u300d\uff08National Medal of Technology\uff09\u7684\u6700\u9ad8\u79d1\u6280\u754c\u6b8a\u8363", "imagename": "9f1a6348c43c4883aaae65a65ad696f3.jpg", "infoid": 110756, "category": "technology_hardware", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "