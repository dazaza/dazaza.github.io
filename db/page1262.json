[{"url": "http://tech.tom.com/2006-07-17/04B5/07214129.html", "title": "\u4f20ZCOM\u79d8\u8d2dFlashGet Google\u767e\u5ea6\u732b\u6251\u7ade\u8d2d\u672a\u6210\u529f", "tags": "ZCOM Google \u767e\u5ea6 ", "name": "yinyin", "posttime": "2006-08-20 14:14:51", "ip": "218.2.68.31", "mark": 2, "note": "\u5929\u6781Chinabyte7\u670817\u65e5\u6d88\u606f(\u8bb0\u8005 \u65b9\u5803)Chinabyte\u4ece\u53ef\u9760\u6e20\u9053\u83b7\u6089\uff0c\u7535\u5b50\u6742\u5fd7\u5e73\u53f0\u5f00\u53d1\u5546\u667a\u901a\u65e0\u9650(\u4ee5\u4e0b\u7b80\u79f0ZCOM)\u5df2\u5bf9FlashGet\u5b8c\u6210\u4e86\u79d8\u5bc6\u6536\u8d2d\uff0c\u81f3\u6b64\uff0cGoogle\u3001\u767e\u5ea6\u3001\u732b\u6251\u3001ZCOM\u51e0\u65b9\u4e89\u593a\u7684FlashGet\u6536\u8d2d\u6218\u63a5\u8fd1\u5c3e\u58f0\u3002Chinabyte\u968f\u540e\u5411ZCOM\u9ad8\u5c42\u5bf9\u4e0a\u8ff0\u4f20\u95fb\u8fdb\u884c\u6c42\u8bc1\uff0c\u8be5\u4eba\u58eb\u8868\u793a\u6682\u4e0d\u65b9\u4fbf\u900f\u9732\uff0c\u800cFlashGet\u521b\u59cb\u4eba\u4faf\u5ef6\u5802\u5219\u7531\u4e8e\u8eab\u5728\u52a0\u62ff\u5927\uff0c\u672a\u80fd\u53d6\u5f97\u8054\u7cfb\u3002 \r\n\r\n\u6d88\u606f\u4eba\u58eb\u79f0\uff0c\u6b64\u524d\u4e1a\u754c\u66fe\u76db\u4f20\u767e\u5ea6\u3001Google\u3001mop\u90fd\u66fe\u7ecf\u8bd5\u56fe\u6536\u8d2dflashGet\uff0c\u4f46\u662f\u5747\u672a\u6210\u529f\u3002\u636e\u719f\u6089FlashGet\u4f5c\u8005\u5019\u5ef6\u5802\u7684\u6d88\u606f\u4eba\u58eb\u900f\u9732\uff0c\u4faf\u5ef6\u5802\u4e00\u76f4\u4ee5\u6765\u90fd\u975e\u5e38\u4f4e\u8c03\uff0c\u5e76\u4e0d\u6ce8\u91cd\u5546\u4e1a\u5229\u76ca\u3002\u8be5\u6d88\u606f\u4eba\u58eb\u8fd8\u8868\u793a,\u201c\u88abZCOM\u6536\u8d2d\u540eFlashGet\u5c06\u7ee7\u7eed\u4fdd\u7559\u72ec\u7acb\u7684\u4e2a\u4eba\u8f6f\u4ef6\u8eab\u4efd\u201d\u3002\r\n\r\n\u4e1a\u5185\u4eba\u58eb\u8868\u793a\uff0c\u5728\u4e00\u4e9b\u4e13\u4e1a\u5a92\u4f53\u7684\u7535\u5b50\u6742\u5fd7\u5e73\u53f0\u6a2a\u5411\u8bc4\u6d4b\u4e2d\uff0c\u4e0b\u8f7d\u901f\u5ea6\u4e00\u76f4\u88ab\u89c6\u4e3a\u76f8\u5f53\u91cd\u8981\u7684\u8bc4\u6d4b\u6307\u6807\u4e4b\u4e00\u3002ZCOM\u6b64\u6b21\u5bf9FlashGet\u7684\u6536\u8d2d\u5c06\u6709\u5229\u4e8e\u63d0\u5347\u5176\u5728\u4e0b\u8f7d\u65b9\u9762\u7684\u4f18\u52bf\uff0c\u6240\u4ee5\u6b64\u6b21\u4e1a\u754c\u5173\u4e8eZCOM\u6536\u8d2dFlashGet\u7684\u4f20\u8a00\u4e5f\u8bb8\u5e76\u4e0d\u662f\u7a7a\u7a74\u6765\u98ce\uff0c\u4f46\u76ee\u524d\uff0c\u5c31\u6b64\u4e8b\u5f53\u4e8b\u53cc\u65b9\u5747\u672a\u786e\u8ba4\u3002\r\n\r\n\u636e\u4e86\u89e3\uff0cZCOM\u4e8e2005\u5e74\u83b7\u5f97\u5728\u5168\u7403\u6295\u8d44", "imagename": "98a311e7-9b83-431d-a002-ee0cc7b61b48.gif", "infoid": 4819, "category": "technology_Google", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["zcom", "google", "\u767e\u5ea6"]}, {"url": "http://www.ccw.com.cn/news2/news/htm2006/20060818_204184.htm", "title": "\u6234\u5c14\u4e8b\u4ef6\u8fde\u9501\u53cd\u5e94\u3000\u7d22\u5c3c\u9000\u51fa\u53f0\u5f0f\u673a\u663e\u793a\u5668", "tags": "\u6234\u5c14 \u7d22\u5c3c \u663e\u793a\u5668 ", "name": "yinyin", "posttime": "2006-08-20 14:12:27", "ip": "218.2.68.31", "mark": 1, "note": "\u8ba1\u7b97\u673a\u5236\u9020\u5546\u6234\u5c14\u516c\u53f8\u5927\u89c4\u6a21\u53ec\u56de\u4e86\u7d22\u5c3c\u516c\u53f8\u5236\u9020\u7684410\u4e07\u7b14\u8bb0\u672c\u7535\u8111\u7535\u6c60\u4f7f\u7d22\u5c3c\u516c\u53f8\u989c\u9762\u626b\u5730\uff0c\u516c\u53f8\u7684\u5f62\u8c61\u9996\u6b21\u53d7\u5230\u4e25\u91cd\u7684\u6253\u51fb\u3002\u7136\u800c\u4e0d\u5229\u7684\u6d88\u606f\u63a5\u8e35\u800c\u6765\uff0c\u6709\u6d88\u606f\u79f0\uff0c\u9762\u4e34\u6fc0\u70c8\u7684\u4ef7\u683c \r\n\u7ade\u4e89\uff0c\u7d22\u5c3c\u516c\u53f8\u5c06\u9000\u51fa\u53f0\u5f0f\u673a\u663e\u793a\u5668\u5e02\u573a\u3002\r\n\r\n\u3000\u3000\u5c3d\u7ba1\u7d22\u5c3c\u516c\u53f8\u7684\u5b98\u5458\u6ca1\u6709\u53d1\u8868\u8bc4\u8bba\uff0c\u4f46IT \u8f6c\u552e\u5546\u8868\u793a\uff0c\u5b83\u4eec\u5df2\u7ecf\u5f97\u5230\u7d22\u5c3c\u516c\u53f8\u7684\u901a\u62a5\uff0c\u516c\u53f8\u5c06\u9000\u51fa\u53f0\u5f0f\u673a\u663e\u793a\u5668\u5e02\u573a\u3002IT \u8f6c\u552e\u5546Zones\u516c\u53f8\u7684\u663e\u793a\u5668\u4ea7\u54c1\u7ecf\u7406Michael Stavnshoj\u8bf4\uff1a\u201c\u5e76\u4e0d\u662f\u5b83\u4eec\u7684\u6807\u51c6\u4f4e\u52a3\uff0c\u5b83\u4eec\u51b3\u5b9a\u9000\u51fa\u8fd9\u4e00\u4e1a\u52a1\u3002\u201d\r\n\r\n\u3000\u3000\u4e0a\u5468\u7d22\u5c3c\u516c\u53f8\u5411IT \u8f6c\u552e\u5546\u8868\u793a\uff0c\u5b83\u4eec\u5c06\u505c\u6b62\u63d0\u4f9b\u53f0\u5f0f\u673a\u663e\u793a\u5668\u4ea7\u54c1\u3002\u4f46\u5c06\u7ee7\u7eed\u51fa\u552e\u5927\u5c4f\u5e55\u6db2\u6676\u7535\u89c6\u4ee5\u53ca\u5728\u8fd0\u8f93\u548c\u96f6\u552e\u884c\u4e1a\u6570\u5b57\u5c55\u793a\u677f\u4f7f\u7528\u7684\u7b49\u79bb\u5b50\u5c4f\u5e55\u3002\r\n\r\n\u3000\u3000\u663e\u793a\u5668\u4e13\u5bb6\u8868\u793a\uff0c\u53f0\u5f0f\u673a\u663e\u793a\u5668\u884c\u4e1a\u5c06\u51fa\u73b0\u6fc0\u70c8\u7684\u4ef7\u683c\u7ade\u4e89\u3002\u5386\u53f2\u4e0a\u5728\u5168\u7403\u9634\u6781\u5c04\u7ebf\u7ba1\u663e\u793a\u5668\u5e02\u573a\uff0c\u7d22\u5c3c\u516c\u53f8\u7684\u6280\u672f\u662f\u9886\u5148\u7684\u3002\u5b83\u4eec\u5f00\u53d1\u7684\u5355\u67aa\u4e09\u675f\u5f69\u8272\u663e\u8c61\u7ba1\u6280\u672f\u53d7\u5230\u4e1a\u754c\u666e\u904d\u7684\u8d5e\u626c\u3002\u5728\u8f6c\u6362\u4e3a\u6db2\u6676\u9762\u677f\u65f6\uff0c\u5b83\u4eec\u4ecd\u7136\u662f\u516c\u8ba4\u7684\u54c1\u724c\u3002\u5728\u6210\u672c\u7ade\u4e89\u7684\u5e02\u573a\u4ecd\u7136\u83b7\u5f97\u4e86\u8bb8\u591a\u652f\u6301\u3002\u76ee\u524d\u5c3d\u7ba1\u5728\u9ad8\u7aef\u5e02\u573a\u4ecd\u7136\u6709\u673a\u4f1a\uff0c\u4f46\u7ade\u4e89\u662f\u975e\u5e38\u6fc0\u70c8\u7684\u3002\r\n\r\n\u5e02\u573a\u8c03\u7814\u673a\u6784iSuppli\u516c\u53f8\u663e\u793a\u5668\u7814\u7a76\u4e3b\u4efbRhoda Alexander\u8868\u793a", "imagename": "02d028f2-4d6c-4294-a8fa-74766a940ff0.jpg", "infoid": 4818, "category": "technology_internet", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u6234\u5c14", "\u7d22\u5c3c", "\u663e\