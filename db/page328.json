7403\u6392\u540d\u524d100\u7684\u7f51\u7ad9\u54c1\u724c\u653e\u5230\u4e00\u8d77\u8fdb\u884c\u5206\u6790\uff0c\u4ece\u8ba1\u7b97\u673a\u4f01\u4e1a\u5230\u641c\u7d22\u5f15\u64ce\u3001\u4ece\u793e\u4ea4\u7f51\u7ad9\u5230\u6210\u4eba\u7f51\u7ad9\u65e0\u6240\u4e0d\u5305\uff0c\u4ee5\u76f4\u89c2\u67e5\u770bWeb\u7684\u8272\u5f69\uff0c\u4e86\u89e3\u662f\u5426\u4ecd\u662f\u84dd\u8272\u638c\u63a7\u7740\u5168\u7403\u7f51\u7edc\u7684\u8272\u8c03\u3002</p>\r\n<p>\r\n\t\u6839\u636e\u5176\u8c03\u67e5\u7ed3\u679c\uff0c\u867d\u7136\u7f51\u7edc\u4e16\u754c\u8272\u5f69\u7f24\u7eb7\uff0c\u4f46\u662f<strong>\u84dd\u8272\u7cfb\u548c\u7ea2\u8272\u7cfb\u662f\u54c1\u724cLogo\u7684\u4e24\u5927\u9635\u8425</strong>\u3002</p>\r\n<p>\r\n\t<img alt=\"\" src=\"http://www.diglog.com/img/album/geekzhang/news/m_70ac8716-bc4f-4d8c-8cfd-40a6eef40652.jpg\" style=\"width: 550px; height: 1331px\" /></p>\r\n", "imagename": "", "infoid": 365203, "category": "technology_web2", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["web2", "logo"]}, {"url": "http://science.solidot.org/science/10/09/19/1048212.shtml", "title": "\u300a\u79d1\u5b66\u6742\u5fd7\u300b\uff1a\u81ea\u604b\u6709\u5229\u4e8e\u6210\u529f", "tags": "\u81ea\u604b ", "name": "geekzhang", "posttime": "2010-09-20 10:01:46", "ip": "117.40.196.173", "mark": 1, "note": "<p>\r\n\t\u65b0\u7684\u8bd5\u9a8c\u663e\u793a\uff0c<strong>\u81ea\u604b\u8005\u5584\u4e8e\u8bf4\u670d\u5176\u4ed6\u4eba\u76f8\u4fe1\u4ed6\u4eec\u7684\u60f3\u6cd5\u5bcc\u6709\u521b\u610f\uff0c\u5373\u4f7f\u4ed6\u4eec\u672c\u8eab\u5f88\u5e73\u5eb8\u3002\u800c\u6709\u81ea\u604b\u8005\u7684\u5c0f\u7ec4\u6bd4\u6ca1\u6709\u7684\u5c0f\u7ec4\u66f4\u80fd\u63d0\u51fa\u597d\u4e3b\u610f\uff0c\u6697\u793a\u81ea\u604b\u80fd\u5e26\u6765\u771f\u6b63\u7684\u6210\u529f\u3002</strong></p>\r\n<p>\r\n\t<br />\r\n\t&nbsp;\u81ea\u604b\u548c\u521b\u9020\u529b\u4f3c\u4e4e\u662f\u5de6\u624b\u5bf9\u53f3\u624b<strong>\uff0c\u6709\u521b\u9020\u529b\u7684\u4eba\u7ecf\u5e38\u8868\u73b0\u51fa\u81ea\u604b\u7684\u7279\u5f81&mdash;&mdash;\u5982\u81ea\u8ba4\u4e3a\u91cd\u8981\u3001\u6e34\u671b\u5f97\u5230\u91cd\u89c6\u3001\u5bf9\u4ed6\u4eba\u610f\u89c1\u6f20\u4e0d\u5173\u5fc3</strong>\u3002\u4f8b\u5982\uff0c\u5370\u8c61\u6d3e\u753b\u5bb6\u6bd5\u52a0\u7d22\u66fe\u7ecf\u5ba3\u79f0&ldquo;\u6211\u662f\u4e0a\u5e1d&rdquo;\u3002\u548c\u6bd5\u52a0\u7d22\u7c7b\u4f3c\uff0c\u81ea\u604b\u8005\u5e38\u5e38\u5728\u827a\u672f\u548c\u5546\u4e1a\u9886\u57df\u5360\u636e\u91cd\u8981\u5730\u4f4d\uff0c\u6697\u793a\u4ed6\u4eec\u62e5\u6709\u5176\u4ed6\u4eba\u6ca1\u6709\u7684\u80fd\u529b\u6216\u521b\u9020\u529b\u3002</p>\r\n<p>\r\n\t\u4f46\u8fd9\u4e2a\u89c2\u70b9\u662f\u5426\u6b63\u786e\uff1f\u5eb7\u5948\u5c14\u5927\u5b66\u548c\u65af\u5766\u798f\u5927\u5b66\u7684\u7814\u7a76\u4eba\u5458\u8ba976\u5927\u5b66\u751f\u7ed3\u6210\u5bf9\uff0c\u8bc4\u4f30\u4e86\u4ed6\u4eec\u7684\u81ea\u604b\u7a0b\u5ea6\u3002\u7814\u7a76\u4eba\u5458\u8bf7\u5176\u4e2d\u4e00\u4f4d\u52fe\u52d2\u4e00\u90e8\u7535\u5f71\u7684\u5927\u7eb2\uff0c\u7136\u540e\u5411\u53e6\u4e00\u4eba\u70ed\u60c5\u4ecb\u7ecd\u3002\u4ed6\u4eec\u8bbe\u60f3\u7684\u5267\u60c5\u591a\u6570\u5e76\u4e0d\u7cbe\u5f69\u3002\u4f46\u7814\u7a76\u4eba\u5458\u53d1\u73b0\uff0c<strong>\u6700\u81ea\u604b\u7684\u4eba\u80fd\u7ed9\u540c\u4f34\u7559\u4e0b\u6700\u6df1\u523b\u5370\u8c61</strong>\uff1b\u4ed6\u4eec\u7684\u8bc4\u5206\u6bd4\u6700\u4e0d\u81ea\u604b\u7684\u4eba\u9ad8\u51fa50%\u3002\u5728\u53e6\u4e00\u9879\u7814\u7a76\u4e2d\uff0c\u7814\u7a76\u4eba\u5458\u5c06292\u4f4d\u5b66\u751f\u5206\u6210\u56db\u7ec4\uff0c\u8bf7\u4ed6\u4eec\u63d0\u51fa\u6539\u8fdb\u771f\u5b9e\u4f01\u4e1a\u548c\u673a\u6784\u8868\u73b0\u7684\u63d0\u8bae\u3002\u7ed3\u679c\u663e\u793a\uff0c\u7531\u4e00\u534a\u4eba\u662f\u81ea\u604b\u8005\u7ec4\u6210\u7684\u5c0f\u7ec4\u63d0\u51fa\u4e86\u6700\u591a\u7684\u63d0\u8bae\u3002</p>\r\n", "imagename": "7b14465ea75440f0957aa8ca1c810011.jpg", "infoid": 365195, "category": "technology_other", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u81ea\u604b"]}]