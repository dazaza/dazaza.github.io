237\u5bf9\u6e20\u9053\u7684\u8865\u5145\uff0c\u5c24\u5176\u662f\u5728\u4e2d\u56fd\u3002&rdquo;\u4ed6\u8ba4\u4e3a\u7b2c\u56db\u5b63\u5ea6\u7684\u5904\u7406\u5668\u9700\u6c42\u4f1a\u9677\u5165\u505c\u6ede\uff0c\u56e0\u4e3a\u9ad8\u7aef\u7b14\u8bb0\u672c\u5ba2\u6237\u4f1a\u7b49\u5f85\u65b0\u7684Sandy Bridge\u5904\u7406\u5668\u6279\u91cf\u51fa\u8d27\uff0c\u4f4e\u7aef\u5ba2\u6237\u5219\u4f1a\u91cd\u70b9\u6e05\u7406\u5e93\u5b58\u3002Burleson\u6307\u51fa\uff0c\u5b8f\u7881\u3001\u8054\u60f3\u3001\u60e0\u666e\u90fd\u964d\u4f4e\u4e86\u5404\u81ea\u7b14\u8bb0\u672c\u4ea7\u54c1\u7684\u4ef7\u683c\uff0c\u4f46\u4e0b\u534a\u5e74\u7684\u7b14\u8bb0\u672c\u9700\u6c42\u90fd\u5f88", "imagename": "9466f3aeea9b49caa278a2b3f748813d.jpg", "infoid": 365805, "category": "technology_internet", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": null}]