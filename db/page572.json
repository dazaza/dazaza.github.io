a6\u201d\u3002\r\n\r\n WebOS\u7684\u754c\u9762\uff0c\u901a\u5e38\u7ed9\u7528\u6237\u6700\u76f4\u63a5\u7684\u4f53\u9a8c\u611f\u53d7\u3002\u79ef\u6728\u7684\u754c\u9762\u4e0e\u6211\u4eec\u5e38\u7528\u7684WINXP\u5e73\u53f0\u975e\u5e38\u76f8\u4f3c\uff0c\u5e76\u4e14\u5185\u7f6e\u4e86\u591a\u5957\u80cc\u666f\u548c\u4e3b\u9898\u53ef\u4f9b\u7528\u6237\u9009\u62e9\u3002\r\n\r\nimage\r\n\r\n \u800c\u7528\u6237\u6700\u5173\u5fc3\u7684\uff0c\u5c31\u662f\u79ef\u6728\u5230\u5e95\u80fd\u505a\u4ec0\u4e48\uff1f\u6211\u4eec\u77e5\u9053WebOS\u662f\u57fa\u4e8eWEB\u7684\u7c7b\u64cd\u4f5c\u7cfb\u7edf\u3002\u6240\u4ee5\u5b83\u4ecd\u7136\u9700\u8981\u771f\u5b9e\u7684\u64cd\u4f5c\u7cfb\u7edf\u548c\u7f51\u7edc\u7684\u652f\u6301\u3002\r\n\r\n \u79ef\u6728\u5185\u7f6e\u4e86\u591a\u79cd\u5e94\u7528\u7a0b\u5e8f\u548c\u5e38\u7528\u5de5\u5177\uff0c\u53ef\u4ee5\u5e2e\u4f60\u5b8c\u6210\u4e00\u4e9b\u65e5\u5e38\u7684\u5de5\u4f5c\uff0c\u4f8b\u5982\u6587\u5b57\u5904\u7406\uff0c\u90ae\u4ef6\u6536\u53d1\uff0c\u5728\u7ebf\u76f8\u518c\uff0c\u542c\u6b4c\u770b\u7535\u5f71\uff0c\u5c24\u5176\u662f\u5728\u4f60\u53ea\u6709\u4e00\u53f0\u88f8\u7cfb\u7edf\u7684\u60c5\u51b5\u4e0b\u3002\u800c\u4e14\uff0c\u79ef\u6728\u8fd8\u652f\u6301\u81ea\u5b9a\u4e49\u6dfb\u52a0\u8bb8\u591a\u7b2c\u4e09\u65b9\u5e94\u7528\u3002\u8fd9\u5c31\u50cf\u6211\u4eec\u7684\u64cd\u4f5c\u7cfb\u7edf\u4e00\u6837\uff0c\u7cfb\u7edf\u53ea\u662f\u63d0\u4f9b\u4e00\u4e2a\u5177\u6709\u63a5\u53e3\u7684\u5e73\u53f0\uff0c\u7528\u6237\u53ef\u4ee5\u81ea\u884c\u5b89\u88c5\u7b2c\u4e09\u65b9\u8f6f\u4ef6\u3002\r\n\r\nimage\r\n\r\n \u901a\u8fc7\u4ee5\u4e0b\u8fd9\u6bb5\u89c6\u9891\uff0c\u60a8\u53ef\u4ee5\u66f4\u76f4\u89c2\u5730\u4e86\u89e3\u5230\u79ef\u6728\u7684\u529f\u80fd\uff1a\r\n\r\n \u7531\u4e8e\u79ef\u6728\u8fd8\u5904\u4e8e\u6d4b\u8bd5\u671f\uff0c\u6ca1\u6709\u5f00\u653e\u516c\u5f00\u6ce8\u518c\u3002\u60a8\u53ef\u4ee5\u901a\u8fc7JarryJarry\u7684\u9080\u8bf7\u6ce8\u518c\u5230\u4f53\u9a8c\u5e10\u53f7\uff1a\u70b9\u51fb\u8fd9\u91cc\u6253\u5f00\u6ce8\u518c\u901a\u9