e7f\uff0c\u4e00\u4e1a\u5185\u4eba\u58eb\u8ba4\u4e3a\uff0c\u901a\u8fc7\u7f51\u9875\u6e38\u620f\u9500\u552e\u6e38\u620f\u5e01\u6765\u83b7\u5229\u6216\u8bb8\u662f\u6211\u4e50\u7f51\u8f6c\u578b\u540e\u63a2\u7d22\u76c8\u5229\u6a21\u5f0f\u7684\u4e00\u4e2a\u601d\u8def\u3002\r\n</p><p>\u3000\u3000\u6b64\u524d\uff0c\u89c6\u9891\u5206\u4eab\u7f51\u7ad9\u9177\u516d\u7f51\u4e5f\u63a8\u51fa\u4e86\u7f51\u9875\u6e38\u620f\u670d\u52a1\u3002</p><p><a href=\"http://it.sohu.com/20080927/n259777197.shtml\">\u6765\u6e90</a><br></p>", "imagename": null, "infoid": 95333, "category": "technology_internet", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u6211\u4e50\u7f51", "sns", "\u7f51\u9875", "\u6e38\u620f", "\u5e73\u53f0"]}, {"url": "http://www.applebeta.com.cn/archives/195", "title": "\u82f9\u679c\u5c06\u51fa\u65b0\u7b14\u8bb0\u672c\uff0c\u53d6\u540d\u7231\u7816\u5934?", "tags": "\u82f9\u679c ", "name": "yinyin", "posttime": "2008-09-27 09:59:12", "ip": "218.2.42.95", "mark": 1, "note": "\u524d\u4e9b\u5929\u5c31\u6709\u6d88\u606f\u79f0\u82f9\u679c\u572810\u670814\u65e5\u5c06\u53d1\u5e03\u65b0\u6b3e\u7684\u7b14\u8bb0\u672c\u4ea7\u54c1\uff0c\u4eca\u5929\u56fd\u5916\u8fdb\u4e00\u6b65\u900f\u9732\u4e86\u76f8\u5173\u6d88\u606f\u3002\u636e\u6089\uff0c\u82f9\u679c\u572810\u670814\u65e5\u4e3e\u884c\u7684\u53d1\u5e03\u4f1a\u548c\u201cBrick\u201d(\u7816\u5757)\u6709\u5173\uff0c\u90a3\u4e48\uff0c\u5230\u5e95\u201c\u7816\u5757\u201d\u5230\u5e95\u662f\u4ec0\u4e48\u4e1c\u897f\u5462?\u4e00\u65f6\u95f4\u56fd\u5916\u5404\u5927\u7f51\u7ad9\u7eb7\u7eb7\u53d1\u8868\u731c\u6d4b\u3002", "imagename": "b897d65a323d4135a478a5bd81b93768.jpg", "infoid": 95330, "category": "technology_apple", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u82f9\u679c"]}]