5\u8d8b\u6fc0\u70c8\u3002\u5206\u6790\u8ba4\u4e3a\uff0c\u5fae\u8f6f\u6709\u53ef\u80fd\u63a8\u51fa\u81ea\u6709\u54c1\u724c\u667a\u80fd\u624b\u673a\uff0c\u4f8b\u5982Zune\u624b\u673a\uff0c\u4ee5\u63d0\u9192\u5e02\u573a\u81ea\u5df1\u7684\u5b58\u5728\u3002\r\n<p>\u3000\u3000\u82f9\u679c\u76843G\u7248iPhone\u3001RIM\u7684\u65b0\u6b3e\u9ed1\u8393\u4ee5\u53caGoogle\u7684G1\u662f\u76ee\u524d\u5e02\u573a\u4e0a\u6700\u53d7\u5173\u6ce8\u7684\u667a\u80fd\u624b\u673a\u3002\u7136\u800c\u5e02\u573a\u4e0a\u66f4\u591a\u7684\u667a\u80fd\u624b\u673a\u91c7\u7528\u7684\u662f\u5fae\u8f6f\u7684Windows Mobile\u64cd\u4f5c\u7cfb\u7edf\u3002\u4e0e\u82f9\u679c\u548cRIM\u4e0d\u540c\uff0c\u5fae\u8f6f\u76ee\u524d\u53ea\u5173\u6ce8\u624b\u673a\u64cd\u4f5c\u7cfb\u7edf\uff0c\u800c\u624b\u673a\u7684\u751f\u4ea7\u548c\u9500\u552e\u90fd\u7531\u5408\u4f5c\u4f19\u4f34\u6765\u51b3\u5b9a\u3002Google\u76ee\u524d\u91c7\u7528\u7684\u4e5f\u662f\u540c\u6837\u7684\u7b56\u7565\u3002\r\n</p><p>\u3000\u3000\u5c3d\u7ba1\u5fae\u8f6f\u62e5\u6709\u66fe\u5f00\u53d1\u51faZune\u548cXbox\u7684\u8bbe\u8ba1\u56e2\u961f\uff0c\u4f46\u8be5\u516c\u53f8\u6b64\u524d\u4e00\u76f4\u575a\u79f0\u4e0d\u4f1a\u5f00\u53d1\u624b\u673a\u3002\u5fae\u8f6fWindows Mobile\u96c6\u56e2\u4ea7\u54c1\u7ecf\u7406Scott Rockfeld\u66fe\u8868\u793a\uff0c\u5fae\u8f6f\u6ca1\u6709\u8ba1\u5212\u5f00\u53d1\u81ea\u5df1\u7684\u624b\u673a\uff0c\u5fae\u8f6f\u5bf9\u4e8e\u76ee\u524d\u7684\u60c5\u51b5\u611f\u5230\u6ee1\u610f\u3002</p>\r\n<p>\u3000\u3000\u7136\u800c\u5728\u624b\u673a\u5e02\u573a\u4e0a\uff0c\u5fae\u8f6f\u76ee\u524d\u9762\u4e34\u82f9\u679c\u7684\u5de8\u5927\u538b\u529b\u3002\u82f9\u679c\u4eca\u5e74\u7684iPhone\u9500\u552e\u91cf\u6709\u53ef\u80fd\u8fbe\u52301000\u81f31200\u4e07\u90e8\uff0c\u800c\u5fae\u8f6f\u7684\u5408\u4f5c\u4f19\u4f34\u51fa\u8d27\u603b\u91cf\u5c06\u4e3a1800\u4e07\u90e8\u3002\u5fae\u8f6f\u7684\u5408\u4f5c\u4f19\u4f34\u4e2d\u5305\u62ec\u591a\u8fbe56\u5bb6\u624b\u673a\u5382\u5546\u4ee5\u53ca\u7ea6100\u5bb6\u8fd0\u8425\u5546\u3002</p>\r\n<p>\u3000\u3000\u82f9\u679c\u7684\u5e94\u7528\u7a0b\u5e8f\u5546\u5e97\u8fd1\u51e0\u4e2a\u6708\u4e5f\u5438\u5f15\u4e86\u5927\u91cf\u5173\u6ce8\uff0c\u5176\u4e2d\u5305\u62ec\u6570\u5343\u6b3eiPhone\u7b2c\u4e09\u65b9\u5e94\u7528\u3002\u5fae\u8f6f\u66fe\u7ecf\u82b1\u8d39\u591a\u5e74\u65f6\u95f4\u6765\u6253\u9020\u5f00\u53d1\u8005\u9879\u76ee\uff0c\u5fae\u8f6f\u5ba3\u79f0\u7f8e\u56fd\u5730\u533a\u7684Windows Mobile\u624b\u673a\u5df2\u7ecf\u80fd\u4f7f\u7528\u7ea61.8\u4e07\u6b3e\u7b2c\u4e09\u65b9\u8f6f\u4ef6\u3002</p>\r\n<p>\u3000\u3000\u5206\u6790\u8ba4\u4e3a\uff0c\u5fae\u8f6f\u77ed\u671f\u5185\u6700\u597d\u7684\u5e02\u573a\u8425\u9500\u8ba1\u5212\u662f\u51cf\u5c11\u5e02\u573a\u5bf9\u82f9\u679c\u548cGoogle\u7684\u5173\u6ce8\uff0c\u5e76\u63d0\u9192\u5e02\u573a\u5fae\u8f6f\u7684\u5b58\u5728\u3002\u76ee\u524d\u5f88\u5c11\u6709\u7528\u6237\u4f1a\u8bf4\uff0c\"\u7ed9\u6211\u62ff\u4e00\u90e8\u5fae\u8f6f\u624b\u673a\"\u3002\u56e0\u6b64\u968f\u7740\u82f9\u679c\u3001RIM\u548cGoogle\u7684\u53d1\u5c55\uff0c\u5fae\u8f6f\u9700\u8981\u89e3\u51b3\u8fd9\u4e00\u95ee\u9898\u3002</p>\r\n\u3000\u3000\u4ece\u957f\u671f\u6765\u770b\uff0c\u5fae\u8f6f\u9700\u8981\u66f4\u597d\u7684\u5229\u7528\u6b64\u524d\u6536\u8d2d\u7684\u624b\u673a\u516c\u53f8\uff0c\u4f8b\u5982Sidekick\u624b\u673a\u7684\u8f6f\u4ef6\u5f00\u53d1\u5546Danger\uff0c\u5e76\u63a8\u51fa\u66f4\u5f3a\u5927\u7684\u670d\u52a1\u5957\u88c5\uff0c\u4f8b\u5982\u514d\u8d39\u63a8\u9001Hotmail\u90ae\u4ef6\u7b49\u3002\u5fae\u8f6f\u672a\u6765\u4e5f\u6709\u53ef\u80fd\u63a8\u51fa\u81ea\u6709\u54c1\u724c\u624b\u673a\uff0c\u4f8b\u5982Zune\u624b\u673a\u3002<br><br><div class=\"left text\">\r\n\r\n\u6765\u6e90\uff1a\u641c\u72d0IT\r\n</div>\r\n\t\t\t\t\r\n\t\t\t\t\r\n<div class=\"ad_h_25\">\r\n<sohuadcode>\r\n</sohuadcode></div>\r\n                                    ", "imagename": null, "infoid": 95334, "category": "technology_internet", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u5fae\u8f6f"