a\u65f6\u5b9a\u4f4d\u95ee\u9898\u6240\u5728\uff0c\u771f\u6b63\u4e3a\u6bcf\u4e00\u4f4d\u7528\u6237\u63d0\u4f9b\u5168\u65b9\u4f4d\u7cfb\u7edf\u5b89\u5168\u4fdd\u62a4\u3002\r\n\r\n\u6700\u8fd1\u66f4\u65b0\uff1a\r\n\r\n\r\n\r\n\r\n1. \u65b0\u589e\u7cfb\u7edf\u5168\u9762\u4f53\u68c0\uff0c\u5b89\u5168\u9690\u60a3\u4e00\u7f51\u6253\u5c3d\r\n\r\n\u6f0f\u6d1e\u8865\u4e01\u3001\u6076\u8bc4\u63d2\u4ef6\u3001\u6d41\u884c\u6728\u9a6c\u2026\u2026\u7cfb\u7edf\u5168\u90e8\u5b89\u5168\u9690\u60a3\uff0c\u53ea\u9700\u6570\u79d2\u5168\u76d8\u68c0\u51fa\u3002 \r\n\r\n\r\n2. \u6700\u65b0\u6d41\u884c\u8f6f\u4ef6\u63a8\u8350\uff0c\u6700\u9177\u6700\u5b89\u5168\u8f6f\u4ef6\u5feb\u901f\u62e5\u6709 \r\n\r\n\u65b0\u589e\u6700\u65b0\u6d41\u884c\u8f6f\u4ef6\u63a8\u8350\uff0c\u6700\u9177\u6700\u5b89\u5168\u8f6f\u4ef6\u5feb\u901f\u4e0b\u8f7d\uff0c\u73a9\u9177\u4e00\u590f\u3002 \r\n\r\n\r\n3. \u6f0f\u6d1e\u8865\u4e01\u5373\u4e0b\u5373\u88c5\uff0c\u4fee\u590d\u66f4\u667a\u80fd\u5feb\u6377\r\n\r\n\u589e\u5f3a\u6f0f\u6d1e\u8865\u4e01\u6a21\u5757\uff0c\u5373\u4e0b\u5373\u88c5\uff0c\u667a\u80fd\u4fee\u590d\u66f4\u5feb\u6377\u65b9\u4fbf\u3002 \r\n\r\n\r\n4. \u589e\u5f3a\u75d5\u8ff9\u6e05\u7406\u529f\u80fd\uff0c\u5168\u9762\u4fdd\u62a4\u4e0a\u7f51\u9690\u79c1\r\n\r\n\u66f4\u5f3a\u52b2\u6e05\u7406\u7cfb\u7edf\u4f7f\u7528\u75d5\u8ff9\uff0c\u4fdd\u62a4\u4e0a\u7f51\u9690\u79c1\u540c\u65f6\u4f18\u5316\u7cfb\u7edf\u901f\u5ea6\u3002 \r\n\r\n\r\n5. \u67e5\u6740\u6700\u65b0\u6d41\u884c\u6728\u9a6c\uff0c\u66f4\u5f3a\u52b2\uff0c\u66f4\u5f7b\u5e95\r\n\r\n\u5168\u9762\u5f7b\u5e95\u67e5\u6740\u6700\u65b0\u673a\u5668\u72d7\u56db\u4ee3\u3001\u65b0\u578bAV\u7ec8\u7ed3\u8005\u7b49\u6700\u65b0\u6700\u6076\u52a3\u6728\u9a6c\u3002\r\n\r\n\r\n6. 360\u6587\u4ef6\u77e5\u8bc6\u5e93\u667a\u80fd\u67e5\u8be2\r\n\r\n\u7cfb\u7edf\u4e2d\u7684\u8bf8\u591a\u6587\u4ef6\u5b70\u597d\u5b70\u574f\uff1f\u53ea\u8981\u6709\u4e86360\u6587\u4ef6\u77e5\u8bc6\u5e93\uff0c\u81ea\u5df1\u5c31\u80fd\u63ea\u51fa\u6728\u9a6c\u75c5\u6bd2\u3002", "imagename": "3ecb55407d074d17b3094a62dd6fdc64.jpg", "infoid": 76488, "category": "technology_software", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["360\u5b89\u5168\u536b\u58eb"]}, {"url": "http://www.google.com/mobile/apple/talk/index.html", "title": "Google Talk\u82f9\u679ciPhone\u7248", "tags": "Google Talk \u82f9\u679c iPhone ", "name": "yinyin", "posttime": "2008-07-05 14:45:12", "ip": "122.194.152.215", "mark": 2, "note": "iphone \u548c ipod touch \u76f4\u63a5\u8bbf\u95ee:www.google.com/talk\r\n\r\nStay connected to your Google Talk contacts right from your iPhone.\r\n\r\nChat with contacts in real time \r\nView and search for your Google Talk contacts \r\nUpdate your status message on the go", "imagename": "786c023b7b55413aa9ddf3d08b0cdcd4.gif", "infoid": 76487, "category": "technology_google", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["google", "talk", "\u82f9\u679c", "iphone"]}, {"url": "http://ftp.mozillaonline.com/olympics/Firefox%20Setup%203.0.exe", "title": "\u9996\u6b3e\u5965\u8fd0\u6d4f\u89c8\u5668\u2014\u2014\u641c\u72d0\u5965\u8fd0\u706b\u72d0\u6d4f\u89c8\u5668\u6b63\u5f0f\u53d1\u5e03", "tags": "\u5965\u8fd0 \u6d4f\u89c8\u5668 \u641c\u72d0 \u706b\u72d0\u6d4f ", "name": "yinyin", "posttime": "2008-07-05 14:25:39", "ip": "122.194.152.215", "mark": 2, "note": "\u4e3a\u4e86\u66f4\u597d\u5730\u4e3a\u5317\u4eac\u5965\u8fd0\u4f1a\u63d0\u4f9b\u4e92\u8054\u7f51\u5185\u5bb9\u670d\u52a1\uff0c\u4f5c\u4e3a2008\u5e74\u5317\u4eac\u5965\u8fd0\u4f1a\u8d5e\u52a9\u5546\u7684\u641c\u72d0\u516c\u53f8\u548c\u4e16\u754c\u4e0a\u6700\u4f18\u79c0\u7684\u6d4f\u89c8\u5668Firefox\u5408\u4f5c\uff0c\u65e5\u524d\u8054\u5408\u63a8\u51fa\u201c\u641c\u72d0\u5965\u8fd0\u706b\u72d0\u6d4f\u89c8\u5668\u201d\uff0c\u5c06\u4e3a\u5e7f\u5927\u7f51\u6c11\u5feb\u901f\u3001\u81ea\u5982\u3001\u6d41\u7545\u5730\u83b7\u53d6\u5965\u8fd0\u4fe1\u606f\u66f4\u8fdb\u4e00\u6b65\u63d0\u4f9b\u4fbf\u5229\u3002\r\n\r\n2008\u5e747\u67083\u65e5\u5728\u6e05\u534e\u79d1\u6280\u56ed\u9633\u5149\u5385\u4e3e\u884c\u7684\u201c\u641c\u72d0\u5965\u8fd0\u706b\u72d0\u6d4f\u89c8\u5668\u201d\u53d1\u5e03\u4f1a\u66a8\u201c\u706b\u72d0\u6d4f\u89c8\u5668\u5965\u8fd0\u76ae\u80a4\u201d\u521b\u610fParty\u4e0a\uff0c\u5317\u4eac\u8c0b\u667a\u7f51\u7edc\u6280\u672f\u6709\u9650\u516c\u53f8\uff08mozillaonline.com\uff09CEO\u5bab\u529b\u535a\u58eb\u548c\u641c\u72d0\u526f\u603b\u88c1\u65b9\u521a\u8054\u624b\u4e3a\u8fd9\u6b3e\u201c\u641c\u72d0\u5965\u8fd0\u706b\u72d0\u6d4f\u89c8\u5668\u201d\u63ed\u5e55\u3002\u53cc\u65b9\u4e00\u81f4\u8ba4\u4e3a\uff0c\u8fd9\u662f\u4e00\u6b21\u5177\u6709\u5386\u53f2\u610f\u4e49\u7684\u5408\u4f5c\u3002\r\n\r\n\u706b\u72d0\u6d4f\u89c8\u5668\uff08Firefox\uff09\u662f\u76ee\u524d\u5e02\u573a\u4efd\u989d\u4ec5\u6b21\u4e8e\u5fae\u8f6fIE\u6d4f\u89c8\u5668\u7684\u4e16\u754c\u7b2c\u4e8c\u5927\u4e92\u8054\u7f51\u6d4f\u89c8\u5668\u3002\u706b\u72d0\u6d4f\u89c8\u5668\uff08Firefox\uff09\u7531\u5f00\u6e90\u7ec4\u7ec7Mozilla\u57fa\u91d1\u4f1a\u8fd0\u4f5c\uff0c\u662fMozilla\u5168\u7403\u793e\u533a\u4e2d\u6210\u5343\u4e0a\u4e07\u540d\u7a0b\u5e8f\u5458\u96c6\u4f53\u667a\u6167\u7684\u7ed3\u6676\u3002\u8fd9\u6b3e\u6d4f\u89c8\u5668\u4ee5\u5176\u201c\u5f00\u653e\u6e90\u4ee3\u7801\u201d\u7279\u6027\uff0c\u5728\u5206\u9875\u6d4f\u89c8\u4f53\u9a8c\u3001\u53ef\u6269\u5c55\u6027\u3001\u5b89\u5168\u6027\u7b49\u5404\u4e2a\u6027\u80fd\u65b9\u9762\u6709\u7740\u4e0d\u4fd7\u7684\u8868\u73b0\uff0c\u56e0\u800c\u53d7\u5230\u4e86\u4e0d\u5c11Fans\u7684\u9752\u7750\u3002\u201c\u641c\u72d0\u5965\u8fd0\u706b\u72d0\u6d4f\u89c8\u5668\u201d\u6b63\u662f\u57fa\u4e8e\u706b\u72d0\u6d4f\u89c8\u5668\uff08Firefox\uff09\u7684\u201c\u5f00\u6e90\u201d\u7279\u6027\uff0c\u5728Firefox 3.0\u7248\u672c\u4e0a\u4e13\u95e8\u4e3a\u4e2d\u56fd\u7f51\u6c11\u6253\u9020\u7684\u4e00\u6b3e\u5965\u8fd0\u4e13\u7528\u4e92\u8054\u7f51\u6d4f\u89c8\u5668\u3002\r\n\r\n\u636e\u8c0b\u667a\u7f51\u7edc\u5de5\u7a0b\u5e08\u7c73\u5609\u4ecb\u7ecd\uff0c\u201c\u641c\u72d0\u5965\u8fd0\u706b\u72d0\u6d4f\u89c8\u5668\u201d\u501f\u52a9\u641c\u72d0\u4f5c\u4e3a\u5965\u8fd0\u8d5e\u52a9\u5546\u548c\u5965\u8fd0\u5b98\u7f51\u627f\u5efa\u8005\u7684\u8d44\u6e90\u4f18\u52bf\uff0c\u5c06\u6781\u5927\u5730\u65b9\u4fbf\u4e2d\u56fd\u7f51\u6c11\u5728\u5965\u8fd0\u4f1a\u671f\u95f4\u5373\u65f6\u83b7\u53d6\u5965\u8fd0\u4fe1\u606f\u3002\u9996\u5148\uff0c\u901a\u8fc7\u5373\u65f6\u7684\u5965\u8fd0\u65b0\u95fb\u5feb\u62a5\u529f\u80fd\uff08\u72b6\u6001\u680f\u5373\u65f6\u6d88\u606f\uff0c\u4e0b\u62c9\u680f\u65b0\u95fb\u5217\u8868\u529f\u80fd\uff09\uff0c\u7528\u6237\u5c06\u4f1a\u5728\u7b2c\u4e00\u65f6\u95f4\u83b7\u5f97\u5965\u8fd0\u8d5b\u4e8b\u7684\u6700\u65b0\u6d88\u606f\u3002\u5176\u6b21\uff0c\u7528\u6237\u8fd8\u53ef\u4ee5\u76f4\u63a5\u70b9\u51fb\u9884\u5148\u6536\u85cf\u597d\u7684\u201c\u641c\u72d0\u5965\u8fd0\u201d\u4e66\u7b7e\u6309\u94ae\uff0c\u8bbf\u95ee\u641c\u72d0\u5965\u8fd0\u9891\u9053\uff0c\u5168\u9762\u4e86\u89e3\u5965\u8fd0\u4fe1\u606f\u3002\u540c\u65f6\uff0c\u5728\u201c\u641c\u72d0\u5965\u8fd0\u706b\u72d0\u6d4f\u89c8\u5668\u201d\u7684\u53f3\u4fa7\u680f\u91cc\u63d0\u4f9b\u4e86\u5965\u8fd0\u7efc\u5408\u4fe1\u606f\u67e5\u8be2\u529f\u80fd\uff0c\u8d5b\u4e8b\u6b63\u5f0f\u5f00\u59cb\u540e\uff0c\u91d1\u724c\u699c\u3001\u65b0\u8d5b\u7a0b\u90fd\u4f1a\u5728\u4fa7\u8fb9\u680f\u91cc\u7b2c\u4e00\u65f6\u95f4\u66f4\u65b0\u548c\u663e\u793a\u3002\u6b64\u5916\uff0c\u201c\u641c\u72d0\u5965\u8fd0\u706b\u72d0\u6d4f\u89c8\u5668\u201d\u63d0\u4f9b\u4e865\u6b3e\u4ee5\u798f\u5a03\u4e3a\u4e3b\u9898\u7684\u5965\u8fd0\u76ae\u80a4\uff0c\u7528\u6237\u53ef\u4ee5\u6839\u636e\u81ea\u5df1\u7684\u559c\u597d\u8fdb\u884c\u9009\u62e9\uff0c\u6781\u5927\u5730\u6ee1\u8db3\u4e86\u4e2a\u6027\u5316\u7684\u9700\u6c42\u3002\r\n\r\n\u5728\u641c\u72d0\u5965\u8fd0\u706b\u72d0\u6d4f\u89c8\u5668\u4e2d\uff0c\u706b\u72d0\u6d4f\u89c8\u5668\uff08Firefox\uff093.0\u7248\u672c\u7684\u5934\u53f7\u5229\u5668\u201c\u667a\u80fd\u5730\u5740\u680f\u201d\uff08Awesome Bar\uff09\u529f\u80fd\uff0c\u5c06\u628a\u7f51\u6c11\u7ecf\u5e38\u8bbf\u95ee\u7684\u5965\u8fd0\u7f51\u9875\u52a0\u4ee5\u4fdd\u5b58\u957f\u8fbe90\u5929\u5e76\u667a\u80fd\u68c0\u7d22\uff0c\u53ea\u8981\u4f60\u8f93\u5165\u201c\u5965\u8fd0\u201d\u4e24\u4e2a\u5b57\uff0c\u81ea\u5df1\u7ecf\u5e38\u8bbf\u95ee\u7684\u5965\u8fd0\u7f51\u9875\u5c31\u4f1a\u5728\u5730\u5740\u680f\u4e2d\u81ea\u52a8\u94fe\u63a5\u3002\r\n\r\n\u8c0b\u667a\u7f51\u7edcCEO\u5bab\u529b\u535a\u58eb\u8868\u793a\uff0c\u201c\u641c\u72d0\u5965\u8fd0\u706b\u72d0\u6d4f\u89c8\u5668\u201d\u662f\u706b\u72d0\u6d4f\u89c8\u5668\u672c\u5730\u5316\u52aa\u529b\u4e2d\u7684\u4e00\u6b3e\u6807\u5fd7\u6027\u7684\u4ea7\u54c1\uff0c\u4e0d\u4ec5\u80fd\u591f\u4e3a\u641c\u72d0\u63d0\u9ad8\u5965\u8fd0\u4f1a\u4e92\u8054\u7f51\u5185\u5bb9\u670d\u52a1\u54c1\u8d28\u63d0\u4f9b\u66f4\u5145\u5206\u7684\u4ea7\u54c1\u652f\u6301\uff0c\u4e5f\u80fd\u591f\u4f7f\u4e2d\u56fd\u7f51\u6c11\u66f4\u4fbf\u5229\u5730\u83b7\u53d6\u5965\u8fd0\u8d44\u8baf\uff0c\u4ece\u800c\u4f7f\u706b\u72d0\u6d4f\u89c8\u5668\u66f4\u5e7f\u6cdb\u5730\u4e3a\u4e2d\u56fd\u7f51\u6c11\u6240\u719f\u77e5\uff0c\u6210\u4e3a\u4e2d\u56fd\u7528\u6237\u4e0a\u7f51\u5a31\u4e50\u3001\u5b66\u4e60\u3001\u83b7\u53d6\u4fe1\u606f\u7684\u5229\u5668\u3002\r\n\r\n\u641c\u72d0\u526f\u603b\u88c1\u65b9\u521a\u8868\u793a\uff0c \u201c\u641c\u72d0\u5965\u8fd0\u706b\u72d0\u6d4f\u89c8\u5668\u201d\u662f\u4e92\u8054\u7f51\u5185\u5bb9\u670d\u52a1\u548c\u4ea7\u54c1\u670d\u52a1\u4e4b\u95f4\u4f18\u52bf\u4e92\u8865\u7684\u5178\u8303\uff0c\u641c\u72d0\u8fd1\u4e4e\u5784\u65ad\u7684\u5965\u8fd0\u8d44\u6e90\u548c\u9886\u5148\u7684\u62a5\u9053\u80fd\u529b\uff0c\u7ed3\u5408\u706b\u72d0\u6d4f\u89c8\u5668\u9886\u5148\u7684\u6280\u672f\u548c\u4ea7\u54c1\uff0c\u5fc5\u5c06\u4e3a\u5e7f\u5927\u4e2d\u56fd\u7f51\u6c11\u63d0\u4f9b\u66f4\u4f18\u8d28\u7684\u4e92\u8054\u7f51\u670d\u52a1\u3002\r\n\r\n\u4e3a\u4e86\u5145\u5206\u5c55\u793a\u706b\u72d0\u6d4f\u89c8\u5668\uff08Firefox\uff09\u7684\u4e2a\u6027\u5316\u548c\u81ea\u5b9a\u4e49\u7279\u6027\uff0c\u53d1\u5e03\u4f1a\u73b0\u573a\u8fd8\u8bbe\u8ba1\u4e86\u6781\u5bcc\u521b\u610f\u7684\u201c\u706b\u72d0\u6d4f\u89c8\u5668\u5965\u8fd0\u76ae\u80a4\u201d\u521b\u610fParty\u73af\u8282\u3002\u8bbe\u8ba1\u8fc7\u7a0b\u4e2d\u5f69\u58a8\u98de\u626c\uff0c\u5927\u5bb6\u901a\u8fc7\u81ea\u5df1\u52a8\u624b\u6d82\u753b\u81ea\u5df1\u5fc3\u4e2d\u7684\u201c\u706b\u72d0\u6d4f\u89c8\u5668\u5965\u8fd0\u76ae\u80a4\u201d\uff0c\u8868\u8fbe\u4e86\u5bf9\u5965\u8fd0\u7684\u795d\u798f\u548c\u671f\u5f85\uff0c\u5145\u5206\u4f53\u9a8c\u5230\u4e86\u5f00\u6e90\u521b\u610f\u7684\u5feb\u4e50\uff0c\u5bf9\u4e8e\u706b\u72d0\u6d4f\u89c8\u5668\uff08Firefox\uff09\u7684\u81ea\u5b9a\u4e49\u7279\u6027\u548c\u201c\u641c\u72d0\u5965\u8fd0\u706b\u72d0\u6d4f\u89c8\u5668\u201d\u6709\u4e86\u66f4\u76f4\u89c2\u3001\u771f\u5207\u7684\u4e86\u89e3\u3002\u8c0b\u667a\u7f51\u7edc\u4e5f\u8868\u793a\u5c06\u628a\u4f18\u79c0\u7684\u8bbe\u8ba1\u4f5c\u54c1\u5236\u4f5c\u6210\u76f8\u5e94\u7684\u4e3b\u9898\uff0c\u4f9b\u66f4\u591a\u7528\u6237\u5206\u4eab\u3002\r\n\r\n\u53e6\u636e\u4e86\u89e3\uff0c\u641c\u72d0\u5965\u8fd0\u706b\u72d0\u6d4f\u89c8\u5668\u6b63\u5f0f\u53d1\u5e03\u4e4b\u540e\uff0c\u7528\u6237\u53ef\u4ee5\u4ece\u8c0b\u667a\u7f51\u7edc\u4e3b\u9875\uff08mozillaonline.com\uff0c\u706b\u72d0\u6d4f\u89c8\u5668\u4e2d\u56fd\u552f\u4e00\u5b98\u65b9\u7f51\u7ad9\uff09\u4ee5\u53ca\u641c\u72d0IT\u9891\u9053\u8fdb\u884c\u4e0b\u8f7d\u3002", "imagename": "cb0985945253488eba366a6c953f2f29.png", "infoid": 76485, "category": "technology_software", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u5965\u8fd0", "\u6d4f\u89c8\u5668", "\u641c\u72d0", "\u706b\u72d0\u6d4f"]}, {"url": "http://bbs.xunlei.com/thread-1600392-1-1.html", "title": "\u8fc5\u96f7\u8f6f\u4ef6\u52a9\u624b1.0\u6b63\u5f0f\u7248\u53d1\u5e03\u2014\u5168\u65b0\u7684\u8f6f\u4ef6\u7ba1\u7406\u4f53\u9a8c", "tags": "\u8fc5\u96f7 \u8f6f\u4ef6 ", "name": "yinyin", "posttime": "2008-07-05 14:23:19", "ip": "122.194.152.215", "ma