f85\u6b63\u5f0f\u6ce8\u518c\u5f00\u653e\uff0c\u4e2d\u56fd\u4e07\u7f51\u5c31\u4f1a\u5728\u7b2c\u4e00\u65f6\u95f4\u5c06\u7528\u6237\u7684\u6ce8\u518c\u4fe1\u606f\u63d0\u4ea4\u5230\u56fd\u9645\u6ce8\u518c\u673a\u6784\u3002\r\n\r\n\u4e2d\u56fd\u4e07\u7f51\u63a8\u51fa\u7684\u201c.me\u201d\u9884\u6ce8\u518c\u4ef7\u683c\u4e3a320\u5143/\u5e74\uff0c\u9996\u6b21\u6ce8\u518c\u81f3\u5c112\u5e74\u3002\u201c.me\u201d\u57df\u540d\u53ea\u63d0\u4f9b\u82f1\u6587\u5b57\u6bcd\u3001\u6570\u5b57\u4ee5\u53ca\u4e24\u8005\u7684\u7ec4\u5408\u7684\u6ce8\u518c\uff0c\u53ef\u4ee5\u4e3a\uff1a\u5b57\u6bcda-z\u3001\u6570\u5b570-9\u3001\u4ee5\u53ca\u201c-\u201d\uff08\u5373\uff1a\u4e2d\u6a2a\u7ebf\uff09\uff0c\u4e14\u4e2d\u6a2a\u7ebf\u4e0d\u80fd\u51fa\u73b0\u5728\u9996\u5c3e\u3002\u201c.me\u201d\u57df\u540d\u7684\u6ce8\u518c\u957f\u5ea6\u987b\u57283\u81f363\u4e2a\u5b57\u7b26\u4e4b\u95f4\u3002", "imagename": "858f188de68548c9a74920f16d343ece.gif", "infoid": 76501, "category": "technology_internet", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u4e07\u7f51", ".me", "\u57df\u540d"]}, {"url": "http://ttplayer.com/down.html", "title": "\u5343\u5343\u9759\u542c5.2\u6b63\u5f0f\u7248", "tags": "\u5343\u5343\u9759\u542c \u97f3\u4e50 ", "name": "yinyin", "posttime": "2008-07-05 15:39:12", "ip": "122.194.152.215", "mark": 2, "note": "\u5343\u5343\u9759\u542c\u4e00\u6b3e\u56fd\u4ea7\u97f3\u4e50\u64ad\u653e\u8f6f\u4ef6\uff0c\u51ed\u501f\u5176\u4eba\u6027\u5316\u7684\u64cd\u4f5c\u548c\u5b8c\u7f8e\u7684\u7f51\u7edc\u652f\u6301\u51e0\u4e4e\u5360\u9886\u4e86\u6240\u6709\u684c\u9762\u97f3\u4e50\u64ad\u653e\u5668\u7684\u5e02\u573a\uff0c\u867d\u7136\u5343\u5343\u9759\u542c\u6ca1\u6709Foobar\u90a3\u6837\u7b80\u6d01\uff0c\u4f46\u662f\u548c\u8001\u724cWinamp\u76f8\u6bd4\u8fd8\u662f\u5c0f\u5de7\u591a\u4e86\u3002\u65b0\u7248\u7684\u5343\u5343\u9759\u542c\u66f4\u52a0\u5f3a\u5316\u4e86\u7f51\u7edc\u8bd5\u542c\u64ad\u653e\u7684\u529f\u80fd\u3002 \r\n\r\n\r\n\u5343\u5343\u9759\u542c V5.2\u6b63\u5f0f\u7248\u66f4\u65b0\u529f\u80fd\uff1a\r\n\r\n1.\u97f3\u4e50\u7a97\u53e3\u652f\u6301\u66f4\u6362\u914d\u8272\u65b9\u6848\uff1b\r\n\r\n2.\u652f\u6301\u5728\u97f3\u4e50\u7a97\u53e3\u5185\u4f7f\u7528\u53f3\u952e\u83dc\u5355\u529f\u80fd\uff1b\r\n\r\n3.\u5173\u95ed\u97f3\u4e50\u7a97\u53e3\u65f6\u8bb0\u5fc6\u5f53\u524d\u9875\u9762\u72b6\u6001\uff1b\r\n\r\n4.\u4e3a\u5343\u5343\u9759\u542cWeb\u63a7\u4ef6\u5b9a\u5236\u4e86\u9ed8\u8ba4\u754c\u9762\uff1b\r\n\r\n5.\u6e05\u7a7a\u7f13\u5b58\u6587\u4ef6\u65f6\u533a\u5206\u7f13\u5b58\u6587\u4ef6\u548c\u7528\u6237\u6587\u4ef6\uff1b\r\n\r\n6.\u4fee\u6b635.2Beta\u7248\u4e0d\u80fd\u6b63\u5e38\u64ad\u653eCD\u7684\u95ee\u9898\uff1b\r\n\r\n7.\u4fee\u6b635.2Beta\u7248\u4e0d\u80fd\u6536\u542cMMS\u534f\u8bae\u7f51\u7edc\u5e7f\u64ad\u7684\u95ee\u9898\uff1b\r\n\r\n8.\u4fee\u6b63\u5176\u4ed6BUG\u3002\r\n\r\n\u5343\u5343\u97f3\u4e50\u7a97\u96c6\u5408\u4e86\u5343\u5343\u63a8\u8350\u3001\u6392\u884c\u699c\u3001\u6b4c\u624b\u5e93\u3001\u641c\u7d22\u7b49\u4e30\u5bcc\u7684\u97f3\u4e50\u5185\u5bb9\u548c\u529f\u80fd\uff0c\u5e76\u53ca\u65f6\u66f4\u65b0\u3002\u6253\u5f00\u97f3\u4e50\u7a97\uff0c\u4e0d\u7528\u5728\u7f51\u4e0a\u82e6\u82e6\u641c\u7d22\uff0c\u7ede\u5c3d\u8111\u6c41\u4e0b\u8f7d\u6b4c\u66f2\uff0c\u76f4\u63a5\u8f7b\u8f7b\u4e00\u70b9\uff0c\u5373\u53ef\u76f4\u63a5\u7528\u5343\u5343\u9759\u542c\u64ad\u653e\u559c\u6b22\u7684\u6b4c\u66f2\u3002\u6b64\u5916\uff0c\u968f\u77405.2\u6b63\u5f0f\u7248\u672c\u7684\u53d1\u5e03\uff0c\u5343\u5343\u97f3\u4e50\u7a97\u8fd8\u652f\u6301\u4e86\u6362\u8272\u529f\u80fd\uff0c\u7cbe\u5f69\u968f\u80a4\u53d8!\u5feb\u4e0b\u8f7d\u6700\u65b0\u7248\u672c\u7684\u5343\u5343\u9759\u542c\uff0c\u7f8e\u597d\u7684\u4e00\u5929\uff0c\u5c31\u4ece\u5343\u5343\u97f3\u4e50\u7a97\u5f00\u59cb\u5427\u2026\u2026\r\n\r\n\u5982\u4f55\u8bd5\u542c\u5343\u5343\u97f3\u4e50\u7a97\u4e2d\u7684\u6b4c\u66f2?\r\n\r\n\u70b9\u51fb\u6b4c\u66f2\u540d\u79f0\uff1a\u6b64\u65f6\u6b4c\u66f2\u540d\u79f0\u4f1a\u6d6e\u73b0\u201c\u64ad\u653e\u201d\u201c\u6dfb\u52a0\u201d\u201c\u4e0b\u8f7d\u201d\u201c\u66f4\u591a\u201d\u56db\u4e2a\u64cd\u4f5c\u63d0\u793a\uff0c\u60a8\u53ef\u4ee5\u9009\u62e9\u64cd\u4f5c\u3002\r\n\r\n\u70b9\u51fb\u64ad\u653e\u6309\u94ae\uff1a\u6b4c\u66f2\u6216\u4e13\u8f91\u4f1a\u76f4\u63a5\u6dfb\u52a0\u5230\u5343\u5343\u9759\u542c\u5f53\u524d\u64ad\u653e\u5217\u8868\u5e76\u540c\u65f6\u64ad\u653e\u6dfb\u52a0\u7684\u6b4c\u66f2\u3002\r\n\r\n\u70b9\u51fb\u6dfb\u52a0\u6309\u94ae\uff1a\u5982\u679c\u60a8\u6709\u591a\u4e2a\u5217\u8868\uff0c\u4f1a\u63d0\u793a\u60a8\u9009\u62e9\u5e0c\u671b\u6dfb\u52a0\u7684\u64ad\u653e\u5217\u8868\u3002\r\n\r\n\u9009\u62e9\u4e0b\u8f7d\u64cd\u4f5c\uff1a\u60a8\u53ef\u4ee5\u5728\u5343\u5343\u97f3\u4e50\u5728\u7ebf\u5173\u4e8e\u6b64\u9996\u6b4c\u66f2\u7684\u641c\u7d22\u7ed3\u679c\u4e2d\u4e0b\u8f7d\u6b4c\u66f2\u6587\u4ef6\u3002\r\n\r\n\u9009\u62e9\u66f4\u591a\u64cd\u4f5c\uff1a\u60a8\u53ef\u4ee5\u5728\u5343\u5343\u97f3\u4e50\u5728\u7ebf\u67e5\u770b\u66f4\u591a\u548c\u6b64\u9996\u6b4c\u66f2\u76f8\u5173\u7684\u4fe1\u606f\u3002\r\n\r\n\u60a8\u8fd8\u53ef\u4ee5\u76f4\u63a5\u5728\u97f3\u4e50\u7a97\u4e2d\u641c\u7d22\u60a8\u559c\u6b22\u7684\u6b4c\u66f2\u8bd5\u542c\u4e0b\u8f7d\u54e6!\r\n\r\n\u5343\u5343\u97f3\u4e50\u7a97\u7684\u6253\u5f00\u548c\u5173\u95ed\u662f\u901a\u8fc7\u4e3b\u63a7\u7a97\u53e3\u7684\u97f3\u4e50\u7a97\u6309\u94ae\u6765\u63a7\u5236\u7684\uff0c\u60a8\u4e5f\u53ef\u4ee5\u4f7f\u7528\u5feb\u6377\u952eF11\u64cd\u4f5c\u3002\r\n\r\n\u9ed8\u8ba4\u60c5\u51b5\u4e0b\uff0c\u60a8\u6bcf\u6b21\u542f\u52a8\u5343\u5343\u9759\u542c\uff0c\u90fd\u4f1a\u81ea\u52a8\u6253\u5f00\u97f3\u4e50\u7a97\uff0c\u5982\u679c\u60a8\u4e0d\u5e0c\u671b\u81ea\u52a8\u5f00\u542f\uff0c\u4e5f\u53ef\u4ee5\u5173\u95ed\u6b64\u529f\u80fd\u3002\u65b9\u6cd5\u5f88\u7b80\u5355\uff0c\u53ea\u9700\u8981\u5c06\u97f3\u4e50\u7a97\u53e3\u6700\u4e0b\u65b9\u201c\u542f\u52a8\u65f6\u663e\u793a\u97f3\u4e50\u7a97\u201d\u7684\u52fe\u9009\u53d6\u6d88\u5373\u53ef\u3002\r\n\r\n\u5982\u4f55\u66f4\u6362\u5343\u5343\u97f3\u4e50\u7a