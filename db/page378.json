u79bb\u5730\u7403\u8fd1\u771f\u53ef\u601c\r\n\r\n\r\n\u81f3\u4e8e\u53d1\u7535\u673a\u7684\u5b89\u88c5\uff0c\u5c06\u4ece\u5730\u7403\u4e0a\u628a\u96f6\u90e8\u4ef6\u4f20\u9001\u5230\u592a\u7a7a\u5e76\u8fdb\u884c\u7ec4\u88c5\uff0c\u7136\u540e\u518d\u843d\u5730\u6708\u7403\u3002\u5176\u4e2d\u7edd\u5927\u591a\u6570\u4efb\u52a1\u5c06\u7531\u673a\u5668\u4eba\u6765\u5b8c\u6210\uff0c\u53e6\u6709\u4e00\u7ec4\u5b87\u822a\u5458\u5c06\u88ab\u6d3e\u5f80\u6708\u7403\u76d1\u7763\u673a\u5668\u4eba\u5de5\u4f5c \u66f4\u591a\r\n\r\n2.\u6d77\u6d0b\u57ce\u5e02\uff08Green Float\uff09\r\n\r\n\u8fd9\u79cd\u7c7b\u4f3c\u4e8e\u6f02\u6d6e\u5728\u6c34\u9762\u4e0a\u8377\u53f6\u7684\u5927\u578b\u5efa\u7b51\u7269\u5b9e\u9645\u4e0a\u662f\u672a\u6765\u6f02\u6d6e\u5728\u592a\u5e73\u6d0b\u8d64\u9053\u6d77\u9762\u7684\u57ce\u5e02\uff0c\u9009\u62e9\u8fd9\u91cc\u662f\u56e0\u4e3a\u6b64\u5904\u7684\u70ed\u5e26\u98ce\u66b4\u5f71\u54cd\u8f83\u5c0f\r\n\r\n\u6bcf\u4e2a\u6f02\u6d6e\u5c9b\u90fd\u6709\u4e00\u4e2a\u9ad81000\u7c73\u7684\u4e2d\u592e\u5854\uff0c\u5e95\u5c42\u662f\u5404\u79cd\u8fd0\u8f6c\u8bbe\u5907\u7684\u5de5\u4e1a\u533a\uff0c\u9ad8\u5c42\u662f\u5c45\u4f4f\u533a\u3002\u6574\u4e2a\u5854\u5185\u5c06\u5bb9\u7eb3\u5c45\u6c114000\u4eba\u5de6\u53f3\uff0c\u5c9b\u5c7f\u7531\u68ee\u6797\uff0c\u7eff\u5730\uff0c\u6c34\u8def\u548c\u50a8\u6c34\u533a\u7ec4\u6210\u3002\u5f53\u7136\u4e5f\u6709\u519c\u4e1a\u79cd\u690d\u533a\u548c\u6c34\u4ea7\u54c1\u517b\u6b96\u533a\uff0c\u672a\u6765\u8fd9\u662f\u4e00\u4e2a\u5b8c\u5168\u81ea\u7ed9\u7684\u57ce\u5e02\r\n\r\n#steen:\u8fea\u62dc\u4e5f\u6709\u4e00\u4e2a\u6982\u5ff5\u91d1\u5b57\u5854 &amp\uff1b \u516b\u5927\u8d85\u725b\u9879\u76ee\r\n\r\n\u6d77\u6d0b\u57ce\u5e02\u7684\u57fa\u5730\u662f\u7531\u91cd7000\u5428\uff0c\u5bbd20\u7c73\uff0c\u6df1\u5165\u6c34\u4e0b50\u7c73\u7684\u5c0f\u57fa\u5730\u901a\u8fc7\u516d\u8fb9\u5f62\u7684\u7ba1\u9053\u76f8\u4e92\u8fde\u63a5\u800c\u6210\u7684\uff0c\u8fd9\u4e9b\u57fa\u5730\u7684\u4e3b\u8981\u5efa\u7b51\u6750\u6599\u9541\u53ef\u4ee5\u4ece\u6d77\u6c34\u4e2d\u63d0\u53d6\u800c\u5f97\uff0c\u6bcf770\u5428\u6d77\u6c34\u53ef\u63d0\u70bc\u51fa1\u5428\u9541 \u66f4\u591a\r\n\r\n3.\u91d1\u5b57\u5854\u57ce\u5e02\uff08Mega-City Pyramid\uff09\r\n\r\n\u91d1\u5b57\u5854\u57ce\u5e02\u662f\u4e00\u5ea7\u81ea\u8db3\u7684\uff0c\u53ef\u5bb9\u7eb3100\u4e07\u4eba\u7684\u57ce\u5e02\uff0c\u5b83\u7531\u7c7b\u4f3c\u78b3\u548c\u73bb\u7483\u7ea4\u7ef4\u7684\u8f7b\u91cf\u6750\u6599\u5efa\u9020\u800c\u6210\uff0c\u8fd9\u79cd\u91d1\u5b57\u5854\u6a21\u5f0f\u53ef\u4f7f\u6bcf\u4e2a\u8282\u70b9\u5747\u80fd\u63a5\u6536\u5230\u9633\u5149\r\n\r\n\u5728\u91d1\u5b57\u5854\u7684\u5185\u90e8\u8282\u70b9\u4e2d\u53ef\u7528\u4e8e\u5c45\u4f4f\u3001\u529e\u516c\u3001\u7814\u7a76\u3001\u5546\u573a\u8d2d\u7269\u548c\u5a31\u4e50\u4e2d\u5fc3\u7b49\u7528\u9014\uff0c\u6bcf\u4e2a\u8282\u70b9\u4e4b\u95f4\u7684\u8fde\u63a5\u6746\u76f4\u5f84\u8fbe10-16\u7c73\uff0c\u5728\u5176\u4e2d\u88c5\u8f7d\u57ce\u5e02\u6240\u9700\u7684\u7535\u529b\uff0c\u901a\u8baf\u7cfb\u7edf\uff0c\u7535\u68af\uff0c\u4f9b\u6c34\u751a\u81f3\u662f\u4ea4\u901a\u8f68\u9053 \u66f4\u591a\r\n\r\n4.\u592a\u7a7a\u65c5\u9986\uff08Space Hotel\uff09\r\n\r\n\u968f\u7740\u672a\u6765\u592a\u7a7a\u65c5\u6e38\u4e1a\u7684\u4e0d\u65ad\u53d1\u5c55\uff0c\u5efa\u9020\u592a\u7a7a\u65c5\u9986\u662f\u6bd4\u8f83\u6709\u524d\u9014\u7684\u3002\u6e05\u6c34\u516c\u53f8\u8bbe\u8ba1\u7684\u592a\u7a7a\u65c5\u9986\u8fd0\u884c\u5728\u8fd1\u5730\u7403\u8f68\u9053\uff0c\u5728\u8fd9\u4e00\u533a\u57df\u5c06\u6709\u53ef\u80fd\u5b9e\u73b0\u5fae\u91cd\u529b\u3002\u6574\u4e2a\u65c5\u9986\u7684\u80fd\u91cf\u5168\u90e8\u6765\u81ea\u592a\u9633\u80fd\uff0c\u4eba\u4eec\u53ef\u4ee5\u5728\u8fd9\u91cc\u8fdb\u884c\u8fd0\u52a8\u5a31\u4e50\uff0c\u5c31\u9910\u548c\u89c2\u770b\u5730\u7403\u548c\u661f\u661f \u66f4\u591a\r\n\r\n5.\u6708\u7403\u57fa\u5730\uff08Lunar Bases\uff09\r\n\r\n\u55ef\uff0c\u53c8\u662f\u6708\u7403\u3002\u4e3a\u65b9\u4fbf\u672a\u6765\u7684\u5916\u592a\u7a7a\u7684\u8fdc\u8db3\u4eba\u7fa4\uff0c\u5728\u6708\u7403\u4e0a\u4fee\u5e