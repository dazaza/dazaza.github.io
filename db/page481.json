le\u4e3a\u7eaa\u5ff5\u4e00\u4ee3\u5de8\u661f\u8fc8\u514b\u5c14\u6770\u514b\u900a\u800c\u4e13\u5f00\u4e86\u201c\u8fc8\u514b\u5c14\u6770\u514b\u900a\u97f3\u4e50\u4e13\u680f\u201d\u3002\u6574\u4e2a\u754c\u9762\u91cc\u6211\u4eec\u53ef\u4ee5\u770b\u5230\u6709\u5173\u4e8e\u8fd9\u4f4d\u4f20\u5947\u5de8\u661f\u4e00\u751f\u7684\u7ecf\u5178\u66f2\u76ee\uff0c\u4e0d\u6127\u4e3a\u632f\u52a8\u4e16\u754c\u7684\u58f0\u97f3\uff0c\u9707\u64bc\u4e16\u754c\u7684\u7075\u9b42\u3002\r\n\r\n\u3000\u3000\u5728\u6574\u4e2a\u97f3\u4e50\u4e13\u680f\u91cc\u9762\uff0c\u6211\u4eec\u8fd8\u53ef\u4ee5\u770b\u5230\u4e0e\u8fc8\u514b\u5c14\u6770\u514b\u900a\u76f8\u5173\u7684\u660e\u661f\u94fe\u63a5\uff0c\u90fd\u662f\u8c37\u6b4c\u97f3\u4e50\u91cc\u7684\u5927\u8155\uff0c\u6709\u7684\u5df2\u7ecf\u79bb\u6211\u4eec\u800c\u53bb\uff0c\u5982\u732b\u738b\uff0c\u6709\u7684\u5df2\u7ecf\u9000\u51fa\u821e\u53f0\uff0c\u5982\uff1a\u9ea6\u5f53\u5a1c\uff0c\u5c0f\u751c\u751c\u3002\u8fd8\u80fd\u770b\u5230\u4e0e\u8fc8\u514b\u5c14&#183\uff1b\u7ea6\u745f\u592b&#183\uff1b\u6770\u514b\u900a(Michael Joseph Jackson)\u4e00\u540c\u6210\u957f\u7684\u5bb6\u5ead\u660e\u661f\u6210\u5458\uff0c\u4ed6\u7684\u59b9\u59b9\u73cd\u59ae\u6770\u514b\u900a\u3001\u6770\u514b\u900a\u4e94\u5144\u5f1f\u65f6\u671f\u7b49\u7b49\u3002\u8c37\u6b4c\u97f3\u4e50\u5c06\u8fd9\u4e9b\u5448\u73b0\u7ed9\u5927\u5bb6\uff0c\u80af\u5b9a\u4e86\u8fc8\u514b\u5c14\u6770\u514b\u900a\u5728\u4e16\u754c\u4e0a\u7684\u4f1f\u5927\u5730\u4f4d\uff0c\u540c\u65f6\u4e5f\u8bf4\u660e\u8fc8\u514b\u5c14\u6770\u514b\u900a\u7684\u738b\u8005\u4e4b\u98ce\u7559\u7ed9\u641c\u7d22\u5f15\u64ce\u592a\u591a\u56de\u5fc6\uff1a\u4e3a\u4e86\u56de\u5fc6\u8fd9\u4e9b\u97f3\u4e50\uff0c\u6211\u4eec\u4f1a\u627e\u5bfb\u66fe\u7ecf\u7684\u8bb0\u5fc6-\u90a3\u4e9b\u7ecf\u5178\u3002\r\n\r\n\u3000\u3000\u8fc8\u514b\u5c14 \u6770\u514b\u900a(Michael Jackson)\r\n\u3000\u3000\u8fc8\u514b\u5c14&#183\uff1b\u7ea6\u745f\u592b&#183\uff1b\u6770\u514b\u900a(Michael Joseph Jackson\uff0c1958\u5e748\u670829\u65e5\u20142009\u5e746\u670826\u65e5 )\uff0c\u8fd9\u4e2a\u540d\u5b57\u4e00\u76f4\u88ab\u8d4b\u4e88\u7740\u4e30\u5bcc\u7684\u542b\u4e49\uff0c\u4ed6\u7684\u4eba\u751f\u4e5f\u5145\u6ee1\u7740\u53d8\u5e7b\u83ab\u6d4b\u3002\u6b4c\u8005\u3001\u821e\u8005\u3001\u5929\u624d\u7684\u521b\u4f5c\u5bb6\uff1b\u6d41\u884c\u97f3\u4e50\u4e4b\u738b\u3001\u821e\u53f0\u4e0a\u7684\u4f20\u5947\u6559\u4e3b\u3002\u5bf9\uff0cJackson\u4ee3\u8868\u4e86\u8fd9\u4e00\u5207\uff0c\u751a\u81f3\u66f4\u591a\u3002\u4ed6\u7528\u751f\u547d\u8be0\u91ca\u4e86\u8fd9\u4e2a\u590d\u6742\u800c\u4e30\u5bcc\u7684\u4e3b\u9898\u3002\u4f5c\u4e3a\u4e00\u4e2a\u4e16\u7eaa\u6d41\u884c\u6587\u5316\u7684\u5316\u8eab\uff0c\u4ed6\u7684\u4e00\u751f\u662f\u65e0\u4e0e\u4f26\u6bd4\u7684\u3002Michael Jackson\u751f\u4e8e\u7f8e\u56fd\u5370\u5730\u5b89\u90a3\u5dde\u76d6\u745e\u5e02\uff0c\u7f8e\u56fd\u7740\u540d\u6d41\u884c\u6b4c\u624b\u3001\u4f5c\u66f2\u5bb6\u3001\u821e\u8e48\u5bb6\u548c\u5531\u7247\u5236\u4f5c\u4eba\u30021960\u5e74\u4ee3\u548c70\u5e74\u4ee3\u6770\u514b\u900a\u4f5c\u4e3a\u6770\u514b\u900a5\u4eba\u7ec4\u4e50\u961f\u7684\u4e3b\u5531\u5f00\u59cb\u4e86\u4ed6\u7684\u97f3\u4e50\u5386\u7a0b\uff0c\u5e76\u4e8e1979\u5e74\u5f00\u59cb\u4e86\u4e2a\u4eba\u72ec\u5531\u751f\u6daf\uff0c\u7ee7\u800c\u6210\u4e3a\u6d41\u884c\u97f3\u4e50\u53f2\u4e0a\u6700\u6210\u529f\u7684\u975e\u6d32\u88d4\u7f8e\u56fd\u7c4d\u9ed1\u4eba\u6b4c\u624b\uff0c\u4e5f\u662f\u4e16\u754c\u4e0a\u6700\u6210\u529f\u7684\u6d41\u884c\u97f3\u4e50\u6b4c\u624b\u4e4b\u4e00\u3002\u4ed6\u88ab\u8a89\u4e3a\u201c\u6d41\u884c\u97f3\u4e50\u4e4b\u738b\u201d\u6216\u201c\u97f3\u4e50\u7535\u89c6\u4e4b\u738b\u201d\u3002\u6770\u514b\u900a\u6f14\u5531\u4e8b\u4e1a\u7684\u6210\u529f\u4f7f\u4ed6\u83b7\u5f97\u4e86\u5168\u4e16\u754c\u4f17\u591a\u6b4c\u8ff7\u7684\u652f\u6301\u4e0e\u559c\u7231\uff0c\u5305\u62ec\u4ed6\u7684\u6b4c\u66f2\u548c\u6807\u5fd7\u6027\u7684\u821e\u6b65\u3002\u7136\u800c\uff0c\u5a92\u4f53\u66f4\u611f\u5174\u8da3\u7684\u5374\u662f\u4ed6\u80a4\u8272\u7684\u53d8\u5316\u548c\u602a\u50fb\u7