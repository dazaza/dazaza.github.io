[{"url": "http://duller.kukuchew.com/archives/5544", "title": "\u73a9Twitter\u89e6\u7535\u8eab\u4ea1", "tags": "\u63a8\u7279 \u7f51\u7edc \u610f\u5916 \u6b7b\u4ea1 ", "name": "nikewong", "posttime": "2009-06-20 12:35:51", "ip": "203.217.68.78", "mark": 0, "note": "Brasov\u4e00\u540d17\u5c81\u7684\u5c11\u5973Maria Barbu\u88ab\u53d1\u73b0\u9648\u5c38\u5728\u81ea\u5bb6\u6d74\u5ba4\u91cc\uff0c\u8eab\u8fb9\u6709\u4e2a\u7b14\u8bb0\u672c\u7535\u8111\u3002\u8b66\u65b9\u76f8\u4fe1\u8fd9\u4f4d\u5c11\u5973\u4e00\u8fb9\u6d17\u6fa1\u4e00\u8fb9\u7528\u7535\u8111\u4f7f\u7528Twitter\uff0c\u5f53\u7535\u8111\u5feb\u8981\u6ca1\u7535\u65f6\uff0c\u5979\u8bd5\u56fe\u5145\u7535\u53ef\u662f\u5374\u56e0\u4e3a\u6ca1\u64e6\u5e72\u624b\u800c\u5bfc\u81f4\u89e6\u7535\u6b7b\u4ea1\u3002", "imagename": "c4bbac0cb55f46cb8ff4953639bc4d49.jpg", "infoid": 164399, "category": "technology_internet", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u63a8\u7279", "\u7f51\u7edc", "\u610f\u5916", "\u6b7b\u4ea1"]}, {"url": "http://www.ajax-cms.org/cms/file389.aspx", "title": "\u7a0b\u5e8f\u5458\u5341\u5927\u7ea7\u522b", "tags": "\u7a0b\u5e8f\u5458 \u7ea7\u522b ", "name": "ajaxcms", "posttime": "2009-06-20 09:39:11", "ip": "58.49.255.235", "mark": 0, "note": "\u7537\u5973\u5e7d\u9ed8\r\n    \u7a0b\u5e8f\u5458\u5c31\u50cf\u7537\u4eba\uff0c\u8bed\u8a00\u5c31\u50cf\u5973\u4eba\uff0c\u6bcf\u4e2a\u7537\u4eba\u90fd\u60f3\u8981\u5f88\u591a\u5973\u4eba\uff0c\u5374\u5f88\u5c11\u6709\u7537\u4eba\u80fd\u771f\u6b63\u4e86\u89e3\u4e00\u4e2a\u5973\u4eba\uff0c\u56e0\u4e3a\u7537\u4eba\u603b\u662f\u671d\u4e09\u66ae\u56db\uff0c\u800c\u5973\u4eba\u6bcf\u5929\u90fd\u5728\u53d8\uff0c\u751a\u81f3\u6709\u4e9b\u662f\u7ecf\u8fc7\u53d8\u6027\u548c\u4e0d\u5bb9\u7684\u3002\r\n\u7a0b\u5e8f\u5458\u7406\u60f3\r\n    \u5929\u4e0b\u8bed\u8a00\u5269\u4e00\u5e99\uff0c\u665a\u4e0a\u52a0\u73edMM\u62b1\uff1b\r\n    \u90e8\u95e8\u7ecf\u7406\u90fd\u6b7b\u6389\uff0c\u5168\u90e8\u5956\u91d1\u4e00\u4eba\u8981\u3002\r\n\u7a0b\u5e8f\u5458\u81f3\u53ef\u5206\u4e3a\u5341\u79cd\u7ea7\u522b\uff1a\r\n    1. \u795e\u4eba\uff1a\u5929\u8d44\u8fc7\u4eba\u800c\u53c8\u662f\u6280\u672f\u72c2\u70ed\u8005\u540c\u65f6\u4e0d\u5b9a\u671f\u62e5\u6709\u8fc7\u4eba\u7684\u5546\u4e1a\u5934\u8111\uff0c\u9ad8\u77bb\u65e0\u77a9\uff0c\u6280\u672f\u8fc7\u4eba\uff0c\u6210\u5927\u5668\u4e5f\u2014\u2014\u5982\u4e01\u78ca\uff0c\u6c42\u4f2f\u541b\u3002\r\n    2. \u9ad8\u4eba\uff1a\u6709\u5929\u8d4b\uff0c\u6280\u672f\u8fc7\u4eba\u4f46\u662f\u6ca1\u6709\u8fc7\u4eba\u7684\u5546\u4e1a\u5934\u8111\uff0c\u901a\u5e38\u6b64\u7c7b\u4eba\u4e0d\u662f\u9876\u5c16\u9ed1\u5ba2\u5c31\u662f\u6280\u672f\u603b\u76d1\u3002\r\n    3. \u725b\u4eba\uff1a\u6280\u672f\u7cbe\u6e5b\uff0c\u719f\u6089\u884c\u4e1a\u77e5\u8bc6\uff0c\u6562\u4e8e\u521b\u65b0\uff0c\u6709\u81ea\u5df1\u7684\u516c\u53f8\u548c\u8f6f\u4ef6\u4ea7\u54c1\u3002\r\n    4. \u5de5\u5934\uff1a\u6280\u672f\u7cbe\u6e5b\uff0c\u6709\u9886\u5bfc\u56e2\u961f\u7684\u80fd\u529b\uff0c\u6b64\u7c7b\u4eba\u5927\u591a\u662f\u5927\u516c\u53f8\u7684\u9879\u76ee\u7ecf\u7406\u3002\r\n    5. \u6280\u672f\u5de5\u4eba\uff1a\u6280\u672f\u7cbe\u6e5b\uff0c\u719f\u6089\u884c\u4e1a\u77e5\u8bc6\u4f46\u9886\u5bfc\u80fd\u529b\u6b20\u52a0\uff0c\u5927\u90fd\u662f\u8d44\u6df1\u7a0b\u5e8f\u5458\u3002\u57fa\u672c\u4e0a\u81ea\u89c6\u6e05\u9ad8\u4e0d\u613f\u4e0e\u4e00\u822c\u6280\u672f\u4eba\u5458\u5408\u4f5c\uff0c\u5728\u8bba\u575b\u4e0a\u7ecf\u5e38\u4ee5\u9ad8\u624b\u9762\u76ee\u51fa\u73b0\u3002\r\n    6. \u719f\u7ec3\u5de5\u4eba\uff1a\u6280\u672f\u6709\u5e7f\u5ea6\u65e0\u6df1\u5ea6\uff0c\u559c\u6b22\u94bb\u7814\u4f46\u4e0d\u559c\u6b22\u8fc7\u4efd\u7684\u94bb\u7814\u3002\u5927\u6211\u662f\u8001\u7a0b\u5e8f\u5458\uff0c\u8fd8\u6709\u4e00\u90e8\u5206\u559c\u6b22\u7528\u4e00\u4e9b\u5de5\u5177\u5728\u7f51\u7ad9\u627e\u4e0b\u670d\u52a1\u5668\u6f0f\u6d1e\uff0c\u4e0d\u5e72\u70b9\u597d\u4e8b\u3002\u8bba\u575b\u4e0a\u7ecf\u5e38\u80fd\u770b\u89c1\u4ed6\u4eec\u56de\u7b54\u83dc\u9e1f\u7684\u95ee\u9898\u3002\u4e5f\u662f\u8f6f\u4ef6\u4e1a\u82e6\u529b\u7684\u91cd\u8981\u7ec4\u6210\u90e8\u5206\u3002\r\n    7. \u82e6\u529b\u4eba\u5458\uff1a\u4e00\u4e9b\u6280\u672f\u8f83\u719f\u7ec3\u5021\u7f3a\u4e4f\u6280\u672f\u7684\u6df1\u5ea6\u548c\u5e7f\u5ea6\uff0c\u5927\u591a\u662f\u7a0b\u5e8f\u5458\u7684\u7ea7\u522b\uff0c\u5403\u4e8f\u4e0d\u8ba8\u597d\u7684\u5dee\u4e8b\u3002\u4e5f\u662f\u8f6f\u4ef6\u884c\u4e1a\u82e6\u529b\u7684\u91cd\u8981\u7ec4\u6210\u90e8\u5206\u3002\r\n    8. \u83dc\u9e1f\uff1a\u5165\u95e8\u65f6\u95f4\u4e0d\u957f\uff0c\u5728\u8bba\u575b\u4e0a\u53cd\u590d\u63d0\u95ee\u5f88\u521d\u7ea7\u7684\u95ee\u9898\uff0c\u6709\u4e00\u79cd\u5510\u50e7\u7684\u98ce\u8303\uff0c\u867d\u7136\u62db\u4eba\u70e6\u5021\u57fa\u672c\u5f88\u53ef\u7231\u3002\u53ea\u8981\u52aa\u529b\u70b9\uff0c\u4e00\u4e24\u5e74\u5c31\u80fd\u4e0a\u5347\u4e00\u4e2a\u7ea7\u522b\u3002\r\n    9. \u5927\u5ffd\u60a0\uff1a\u5229\u7528\u4e2d\u56fd\u6559\u80b2\u7684\u5f0a\u75c5\uff0c\u9876\u7740\u4e00\u9876\u9ad8\u5b66\u5386\u7684\u5e3d\u5b50\uff0c\u5728\u5c0f\u516c\u53f8\u91cc\u6df7\u4e2a\u8f6f\u4ef6\u90e8\u7ecf\u7406\uff0c\u8bbe\u8ba1\u4e0d\u884c\uff0c\u4ee3\u7801\u4e0d\u884c\uff0c\u53ea\u4f1a\u80e1\u4e71\u652f\u914d\u8001\u5b9e\u4eba\uff0c\u62cd\u62cd\u9886\u5bfc\u9a6c\u5c41\uff0c\u5728\u9886\u5bfc\u9762\u524d\u80e1\u5439\u6d77\u4f83\uff0c\u628a\u81ea\u5df1\u6253\u626e\u6210\u6280\u672f\u9ad8\u624b\u7684\u6a21\u6837\u3002\u628a\u52fe\u5fc3\u6597\u89d2\u7684\u529e\u516c\u5ba4\u6587\u5316\u5e26\u5165\u6280\u672f\u90e8\u95e8\uff0c\u5b9e\u5728\u9f8c\u9f8a\u3002\r\n    10. ***\uff08\u65e0\u6587\u660e\u8bcd\u53ef\u5f62\u5bb9\uff0c\u5373\u7528***\uff09\uff1a\u4f1a\u5199SELECT\u8bed\u53e5\u5c31\u8bf4\u81ea\u5df1\u7cbe\u901aOralce\uff0c\u8fde\u5bc4\u5b58\u5668\u6709\u51e0\u79cd\u90fd\u4e0d\u77e5\u9053\u5c31\u8bf4\u81ea\u5df1\u61c2\u6c47\u7f16\uff0c\u5efa\u8bae\u5168\u90e8\u9001\u5230\u65e5\u672c\u5f53IT\u4ea7\u4e1a\u5de5\u4eba\uff0c\u6323\u65e5\u672c\u4eba\u7684\u94b1\uff0c\u8fd8\u4e25\u91cd\u6253\u51fb\u65e5\u67