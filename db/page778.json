f\u5c31\u662f\u8bf4\uff0cWindows 7\u5728\u660e\u5e7411\u6708\u4e4b\u524d\u81f3\u5c11\u4f1a\u53d1\u5e03RTM\u7248\u3002<BR><BR>\u5728\u6b64\u4e4b\u524d\uff0c\u534e\u7855\u7684\u9996\u5e2d\u6267\u884c\u5b98\u6c88\u632f\u6765\u8868\u793a\uff0c\u534e\u7855\u5c06\u5728\u660e\u5e74\u4e0b\u534a\u5e74\u63a8\u51fa\u57fa\u4e8eWindows 7\u7684Eee PC\u3002</P>\r\n<P>\u5982\u679c\u8fd9\u4e00\u5207\u90fd\u662f\u771f\u7684\uff0c\u90a3\u4e48\u5fae\u8f6f\u5c06\u5728\u5341\u4e8c\u6708\u53d1\u5e03Windows 7\u7684Beta 1\u7684\u8c23\u8a00\u5c31\u4e0d\u662f\u7a7a\u7a74\u6765\u98ce\u4e86\uff0c\u800c\u4e14\u6211\u4eec\u6709\u53ef\u80fd\u5728\u660e\u5e74\u5e74\u5e95\u5c31\u89c1\u5230Windows 7\u6b63\u5f0f\u7248\u4e86\u3002</P>\r\n<P>\u5fae\u8f6f\u5c06\u5728\u4e0b\u5468\u4e8e\u6d1b\u6749\u77f6\u4e3e\u884c\u7684\u4e13\u4e1a\u5f00\u53d1\u8005\u5927\u4f1a\uff08PDC\uff09\u4e0a\u5c55\u793a\u5b8c\u6574\u7248\u7684Windows 7\uff0c\u53c2\u4f1a\u8005\u90fd\u6709\u673a\u4f1a\u8bd5\u7528Windows 7\u7684Pre-Beta\u7248\u672c\u3002</P>\r\n<P><IMG src=\"http://www.technewscn.com/pic/common/windows7-logo.jpg\"></P>\r\n<P>&nbsp;</P>\r\n<P>\u9a71\u52a8\u4e4b\u5bb6</P>", "imagename": null, "infoid": 98368, "category": "technology_software", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["windows", "\u5fae\u8f6f"]}, {"url": null, "title": "Office 2007 SP2\u660e\u5e742-4\u6708\u53d1\u5e03 \u7ec6\u8282\u521d\u73b0", "tags": "Office \u5fae\u8f6f Microsoft ", "name": "yinyin", "posttime": "2008-10-23 17:32:06", "ip": "222.128.48.207", "mark": 1, "note": "<P>\u5fae\u8f6fOffice\u6301\u7eed\u6027\u670d\u52a1\u56e2\u961f\u5ba3\u5e03\uff0c\u4ed6\u4eec\u5c06\u5728\u8fd1\u671f\u53d1\u5e032007 Microsoft Office system\u7684\u7b2c\u4e8c\u4e2aSevice Pack\u670d\u52a1\u5305\uff0c\u4f46\u8fd8\u6ca1\u6709\u786e\u5b9a\u5177\u4f53\u65f6\u95f4\uff0c\u521d\u6b65\u9884\u8ba1\u4e3a<STRONG>2009\u5e742\u6708\u52304\u6708\u4e4b\u95f4</STRONG>\u3002</P>\r\n<P>\u5728\u5386\u53f2\u4e0a\uff0c\u5fae\u8f6f\u4e00\u5411\u5f88\u5c11\u63d0\u524d\u516c\u5e03Office SP\u7684\u5177\u4f53\u7ec6\u8282\uff0c\u6bd4\u5982Office 2003 SP3\u548cOffice 2007 SP1\u90fd\u662f\u4e34\u8fd1\u53d1\u5e03\u7684\u65f6\u5019\u6216\u8005\u53d1\u5e03\u4e4b\u540e\u624d\u8ba9\u5927\u4f17\u77e5\u9053\u5b83\u4eec\u5230\u5e95\u66f4\u65b0\u4e86\u4ec0\u4e48\u3002\u8fd9\u4e00\u6b21\uff0c\u5fae\u8f6f\u51b3\u5b9a\u63d0\u9ad8\u900f\u660e\u5ea6\uff0c\u65e9\u65e9\u5c31\u548c\u7528\u6237\u5206\u4eabOffice 2007 SP2\u7684\u4e00\u4e9b\u7ec6\u8282\u3002\u5f53\u7136\uff0c\u73b0\u5728\u4e0d\u53ef\u80fd\u5305\u542b\u6240\u6709\u7684\u5347\u7ea7\u5185\u5bb9\uff0c\u53ea\u662f\u4e00\u4e2a\u521d\u671f\u9636\u6bb5\u7684\u6982\u8ff0\u800c\u5df2\u3002</P>\r\n<P>\u4e8b\u5b9e\u4e0a\uff0c\u5fae\u8f6f\u6b64\u524d\u5c31\u5df2\u7ecf\u4fdd\u8bc1\uff0c<STRONG>Office 2007 SP2\u4f1a\u96c6\u6210\u5bf9ODF\u3001XPS\u548cPDF\u7b49\u6587\u4ef6\u683c\u5f0f\u7684\u652f\u6301</STRONG>\uff0c\u65e0\u9700\u989d\u5916\u63d2\u4ef6\u5373\u53ef\u5c06\u6587\u6863\u4fdd\u5b58\u4e3a\u8fd9\u4e9b\u7c7b\u578b\u3002\u5176\u5b9e\u5fae\u8f6f\u5728\u5f00\u53d1Office 2007\u7684\u65f6\u5019\u5c31\u8ba1\u5212\u76f4\u63a5\u652f\u6301PDF\uff0c\u4f46\u56e0\u4e3aAdobe\u7684\u53cd\u5bf9\u800c\u4f5c\u7f62\uff0c\u770b\u6765\u73b0\u5728\u53cc\u65b9\u53c8\u6c9f\u901a\u597d\u4e86\u3002</P>\r\n<P><IMG src=\"http://www.oab2b.cn/syssite/home/shop/1/pictures/productsimg/small/422.jpg\"></P>\r\n<P>Office 2007 SP2\u5728\u684c\u9762\u65b9\u9762\u7684\u5176\u4ed6\u66f4\u65b0\u8fd8\u6709\uff1a</P>\r\n<P><STRONG>1\u3001\u6539\u5584Outlook\u7684\u6027\u80fd</STRONG></P>\r\n<P><STRONG>2\u3001\u63d0\u9ad8Outlook\u65e5\u5386\u529f\u80fd\u7684\u7a33\u5b9a\u6027</STRONG></P>\r\n<P><STRONG>3\u3001Word\u548cPowerPoint\u56fe\u8868\u5c06\u652f\u6301\u5bf9\u8c61\u6a21\u578b(Object Model)</STRONG></P>\r\n<P><STRONG>4\u3001\u652f\u6301\u64cd\u4f5c\u7cfb\u7edf\u63d0\u4f9b\u7684\u6240\u6709\u52a0\u5bc6\u7b97\u6cd5\uff0c\u4ece\u800c\u6539\u8fdb\u52a0\u5bc6\u529f\u80fd\u6027</STRONG></P>\r\n<P><STRONG>5\u3001\u6539\u8fdbExcel\u521b\u5efa\u56fe\u8868\u7684\u529f\u80fd\u6027</STRONG></P>\r\n<P><STRONG>6\u3001\u80fd\u591f\u53d6\u6d88SmartArt\u56fe\u7247\u7684\u7ec4\u5408\uff0c\u4ece\u800c\u53ef\u4ee5\u5728PowerPoint\u91cc\u4e3a\u5176\u589e\u52a0\u52a8\u753b\u6548\u679c</STRONG></P>\r\n<P><STRONG>7\u3001\u63d0\u4f9bOffice SP\u5378\u8f7d\u5de5\u5177</STRONG></P>\r\n<P>\u5fae\u8f6f\u5c06\u5f88\u5feb\u9080\u8bf7\u4e00\u4e9bOffice\u4f01\u4e1a\u5ba2\u6237\u53c2\u4e0eSP2 Beta\u6d4b\u8bd5\u9879\u76ee\uff0cOffice\u5404\u4e2a\u7ec4\u4ef6\u7684\u76f8\u5173\u535a\u5ba2\u4e5f\u4f1a\u9646\u7eed\u516c\u5e03\u66f4\u591a\u6709\u5173SP2\u7684\u65b0\u5185\u5bb9\uff0c\u611f\u5174\u8da3\u7684\u53ef\u4ee5\u5173\u6ce8\u4ee5\u4e0b\u94fe\u63a5\uff1a</P>\r\n<P class=MsoNormal style=\"MARGIN: 0in 0in 0pt\"><A href=\"http://blogs.msdn.com/access/\"><FONT face=Calibri color=#0000ff size=3>Access Team Blog</FONT></A><SPAN style=\"FONT-SIZE: 12pt\" twffan=\"done\"><?XML:NAMESPACE PREFIX = O /><O:P></O:P></SPAN></P>\r\n<P class=MsoNormal style=\"MARGIN: 0in 0in 0pt\"><A href=\"http://blogs.msdn.com/descapa/\"><FONT face=Calibri color=#0000ff size=3>Daniel Escapa\u2019s Blog (OneNote)</FONT></A></P>\r\n<P class=MsoNormal style=\"MARGIN: 0in 0in 0pt\"><A href=\"http://blogs.msdn.com/infopath/\"><FONT face=Calibri size=3>InfoPath Team Blog</FONT></A></P>\r\n<P class=MsoNormal style=\"MARGIN: 0in 0in 0pt\"><A href=\"http://blogs.msdn.com/johnguin/\"><FONT face=Calibri color=#0000ff size=3>John Guin\u2019s Blog (OneNote)</FONT></A></P>\r\n<P class=MsoNormal style=\"MARGIN: 0in 0in 0pt\"><A href=\"http://blogs.msdn.com/excel/\"><FONT face=Calibri color=#0000ff size=3>Excel Team Blog</FONT></A></P>\r\n<P class=MsoNormal style=\"MARGIN: 0in 0in 0pt\"><A href=\"http://blogs.msdn.com/project\"><FONT face=Calibri color=#0000ff size=3>Project Team Blog</FONT></A></P>\r\n<P class=MsoNormal style=\"MARGIN: 0in 0in 0pt\"><A href=\"http://blogs.msdn.com/outlook\"><FONT face=Calibri color=#0000