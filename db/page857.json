[{"url": "http://www.kenengba.com/post/487.html", "title": "\u53ea\u8bb8\u770b\u56fe\u4e0d\u8bb8\u8054\u60f3\uff087\uff09-\u5047\u7167\u7247", "tags": "", "name": "jason5ng32", "posttime": "2008-07-28 09:42:43", "ip": "121.12.3.211", "mark": 5, "note": "\u6709\u4e9b\u4eba\u505a\u5047\u7167\u7247\u662f\u4e3a\u4e86\u535a\u5f97\u4e00\u7b11\uff0c\u6709\u4e9b\u4eba\u662f\u4e3a\u4e86\u91d1\u94b1\u5229\u76ca\uff0c\u800c\u6709\u4e9b\u4eba\u662f\u4e3a\u4e86\u5ba3\u4f20\u67d0\u79cd\u4e1c\u897f\uff08\u6cb3\u87f9\uff09\u3002\r\n\r\n\u67d0\u4e9b\u7834\u7efd\u660e\u663e\u7684\u5df2\u7ecf\u7528\u7ea2\u5708\u5708\u51fa\uff0c\u5176\u5b83\u7684\uff0c\u7a76\u7adf\u5047\u5728\u4ec0\u4e48\u5730\u65b9\uff0c\u6211\u5148\u4e0d\u8bf4\uff0c\u806a\u660e\u7684\u8bfb\u8005\u4f60\u4e00\u5b9a\u80fd\u627e\u5230\u3002", "imagename": "", "infoid": 80011, "category": "technology_internet", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": null}, {"url": "http://maitianmayi.cn/archives/pipebytes.html", "title": "PipeBytes\uff1a\u6587\u4ef6\u4f20\u8f93\u670d\u52a1", "tags": "\u4f20\u8f93 \u6587\u4ef6 ", "name": "hooooooo", "posttime": "2008-07-28 09:11:42", "ip": "121.100.131.183", "mark": 4, "note": "PipeBytes \u662f\u4e00\u500b\u7dda\u4e0a\u7684\u6a94\u6848\u50b3\u9001\u670d\u52d9\uff0c\u4e0d\u540c\u65bc\u7db2\u8def\u786c\u789f\uff0c\u5b83\u4e26\u4e0d\u63d0\u4f9b\u6a94\u6848\u7684\u5132\u5b58\u670d\u52d9\u3002PipeBytes \u7684\u6a94\u6848\u50b3\u8f38\u65b9\u5f0f\u6bd4\u8f03\u985e\u4f3cIM\uff0c\u4e5f\u662f\u96d9\u65b9\u90fd\u8981\u5728\u7dda\u4e0a\u624d\u80fd\u9032\u884c\u6a94\u6848\u50b3\u8f38\u3002\u8207P2P\u8edf\u9ad4\u6bd4\u8f03\u4e0d\u540c\u7684\u662f\u4f60\u8981\u50b3\u8f38\u7684\u6a94\u6848\u4e26\u4e0d\u6703\u5206\u4eab\u5230\u7db2\u8def\u4e0a\uff0c\u5176\u4ed6\u4f7f\u7528\u8005\u4e5f\u7121\u6cd5\u53d6\u5f97\uff0c\u552f\u6709\u63a5\u6536\u8005\u624d\u80fd\u5920\u53d6\u5f97\u4f60\u8981\u50b3\u8f38\u7684\u6a94\u6848\u3002\u66f4\u68d2\u7684\u662f\u4e0d\u9700\u8981\u4e0b\u8f09\u4efb\u4f55\u8edf\u9ad4\u3002", "imagename": "e910dc163afe4ae99fb4579b55f0c695.jpg", "infoid": 80010, "category": "technology_web2", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u4f20\u8f93", "\u6587\u4ef6"]}, {"url": "http://www.itvisitor.com/?p=236", "title": "\u5728\u7ebf\u521b\u4f5c\u6570\u5b57\u7eb8\u73a9\u5177:papercritters", "tags": "\u6570\u5b57 \u73a9\u5177 \u7eb8 web2.0 ", "name": "wendong", "posttime": "2008-07-28 09:11:26", "ip": "124.135.61.2", "mark": 3, "note": "\u8da3\u7ad9\u96c6\u4eca\u5929\u53c8\u53d1\u73b0\u4e00\u4e2a\u597d\u73a9\u7684\u7f51\u7ad9\uff0cpaper critters\u662f\u4e00\u4e2a\u5728\u7ebf\u521b\u4f5c\u548c\u5206\u4eab\u6570\u5b57\u7eb8\u73a9\u5177\u7684\u5728\u7ebf\u5e94\u7528\u7f51\u7ad9\uff0c\u636e\u4ed6\u7684\u4f5c\u8005JR Fabito\u79f0\uff0c\u8fd9\u662f\u4ed6\u5927\u5b66\u7684\u6bd5\u4e1a\u8bbe\u8ba1\u4f5c\u54c1\uff0c\u8fd9\u4e2a\u5de5\u5177\u7528flash\u548c3D MAX\u5b8c\u6210,\u91cc\u9762\u5185\u5bb9\u4e86\u4e0d\u5c11\u5b9a\u4e49\u597d\u7684\u7eb8\u7684\u6a21\u578b\uff0c\u53ef\u4ee5\u76f4\u63a5\u8c03\u7528\uff0c\u4f60\u53ef\u4ee5\u50cf\u64cd\u4f5cFlash\u4e00\u6837,\u8f7b\u677e\u7684\u64cd\u4f5c\u4ed6\u3002", "imagename": "", "infoid": 80008, "category": "technology_web2", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u6570\u5b57", "\u73a9\u5177", "web2.0"]}, {"url": null, "title": "\u8c37\u6b4c\u5458\u5de5\u5e78\u798f\u751f\u6d3b \u7d2f\u4e86\u5c31\u8fdb\u9694\u97f3\u592a\u7a7a\u8231(\u7ec4\u56fe)", "tags": "\u8c37\u6b4c\u5458\u5de5 \u592a\u7a7a\u8231 ", "name": "maker", "posttime": "2008-07-28 00:22:33", "ip": "219.153.131.101", "mark": 5, "note": "<DIV id=ArtFrom><B>\u817e\u8baf\u79d1\u6280\u8baf</B> \u5317\u4eac\u65f6\u95f47\u670827\u65e5\u6d88\u606f\uff0c\u636e\u56fd\u5916\u5a92\u4f53\u62a5\u9053\uff0c\u4f17\u6240\u5468\u77e5\uff0cGoogle(\u8c37\u6b4c)\u7d20\u4ee5\u4e3a\u5458\u5de5\u63d0\u4f9b\u826f\u597d\u5de5\u4f5c\u73af\u5883\u800c\u8457\u79f0\uff0c\u4f46\u201c\u8033\u542c\u4e3a\u865a\uff0c\u773c\u89c1\u4e3a\u5b9e\u201d\uff0c\u5982\u679c\u4f60\u6709\u673a\u4f1a\u8fdb\u5165\u5230Google\u529e\u516c\u5730\u70b9\u53c2\u89c2\uff0c\u4f60\u80af\u5b9a\u4f1a\u7559\u4e0b\u6df1\u523b\u5370\u8c61\u3002\u867d\u7136\u4e0d\u662f\u6bcf\u4e2a\u4eba\u90fd\u6709\u673a\u4f1a\u5230Google\u529e\u516c\u5730\u70b9\u53c2\u89c2\uff0c\u4f46\u901a\u8fc7\u4ee5\u4e0b\u56fe\u7247\uff0c\u6211\u4eec\u540c\u6837\u4e5f\u80fd\u4e86\u89e3\u5230Google\u5458\u5de5\u4eec\u7684\u201c\u5e78\u798f\u751f\u6d3b\u201d\uff1a </DIV>\r\n<DIV id=ArticleCnt>\r\n<P style=\"TEXT-INDENT: 2em\"></P>\r\n<P align=center>&nbsp;</P>\r\n<P style=\"TEXT-INDENT: 2em\"><STRONG>1\u3001\u9694\u97f3\u592a\u7a7a\u8231</STRONG> </P>\r\n<P style=\"TEXT-INDENT: 2em\"></P>\r\n<P style=\"TEXT-INDENT: 2em\">\u5982\u679c\u5de5\u4f5c\u7d2f\u4e86\uff0c\u53ef\u5728\u8fd9\u4e2a\u592a\u7a7a\u8231\u597d\u597d\u4f11\u606f\u4e00\u4f1a\u513f\u3002\u8be5\u5a31\u4e50\u8bbe\u65bd\u4e0d\u4f46\u53ef\u9694\u97f3\uff0c\u800c\u4e14\u80fd\u963b\u6321\u4efb\u4f55\u5149\u7ebf\u8fdb\u5165\u3002 </P>\r\n<P style=\"TEXT-INDENT: 2em\"></P>\r\n<P align=center><IMG alt=\"\u8c37\u6b4c\u5458\u5de5\u5e78\u798f\u751f\u6d3b \u7d2f\u4e86\u5c31\u8fdb\u9694\u97f3\u592a\u7a7a\u8231(\u7ec4\u56fe)\" src=\"http://img1.qq.com/tech/pics/11907/11907159.jpg\" border=0 name=MM></P>\r\n<P style=\"TEXT-INDENT: 2em\"><STRONG>2\u3001\u56de\u5230\u5e7c\u513f\u56ed</STRONG> </P>\r\n<P style=\"TEXT-INDENT: 2em\"></P>\r\n<P style=\"TEXT-INDENT: 2em\">\u6bcf\u5c42\u529e\u516c\u697c\u4e4b\u95f4\u90fd\u5b89\u88c5\u4e86\u4e00\u4e2a\u6ed1\u68af\u3002\u9664\u4e86\u5a31\u4e50\u529f\u80fd\u5916\uff0c\u8fd8\u53ef\u4f9b\u5458\u5de5\u4eec\u5728\u53d1\u751f\u706b\u707e\u65f6\u7d27\u6025\u64a4\u79bb\u3002 </P>\r\n<P style=\"TEXT-INDENT: 2em\"></P>\r\n<P align=center><IMG alt=\"\u8c37\u6b4c\u5458\u5de5\u5e78\u798f\u751f\u6d3b \u7d2f\u4e86\u5c31\u8fdb\u9694\u97f3\u592a\u7a7a\u8231(\u7ec4\u56fe)\" src=\"http://img1.qq.com/tech/pics/11907/11907160.jpg\" border=0 name=MM></P>\r\n<P style=\"TEXT-INDENT: 2em\"><STRONG>3\u3001\u7f8e\u5473\u4f73\u80b4</STRONG> </P>\r\n<P style=\"TEXT-INDENT: 2em\"></P>\r\n<P style=\"TEXT-INDENT: 2em\">\u5728\u4e0a\u73ed\u65f6\u95f4\uff0cGoogle\u5458\u5de5\u53ef\u968f\u65f6\u5230\u98df\u5802\u5c31\u9910\uff0c\u98df\u54c1\u79cd\u7c7b\u4e5f\u4e30\u5bcc\u591a\u6837\u3002 </P>\r\n<P style=\"TEXT-INDENT: 2em\"></P>\r\n<P align=center><IMG alt=\"\u8c37\u6b4c\u5458\u5de5\u5e78\u798f\u751f\u6d3b \u7d2f\u4e86\u5c31\u8fdb\u9694\u97f3\u592a\u7a7a\u8231(\u7ec4\u56fe)\" src=\"http://img1.qq.com/tech/pics/11907/11907161.jpg\" border=0 name=MM></P>\r\n<P style=\"TEXT-INDENT: 2em\"><STRONG>4\u3001\u5de5\u4f5c\u5730\u70b9</STRONG> </P>\r\n<P style=\"TEXT-INDENT: 2em\"></P>\r\n<P style=\"TEXT-INDENT: 2em\">\u6bcf\u4f4d\u5458\u5de5\u81f3\u5c11\u914d\u5907\u4e24\u53f0\u5927\u5c4f\u5e55\u663e\u793a\u5668\uff0c\u5e73\u5747\u6bcf\u4e2a\u529e\u516c\u5ba4\u67094~6\u540d\u5458\u5de5\u3002 </P>\r\n<P style=\"TEXT-INDENT: 2em\"></P>\r\n<P align=center><IMG alt=\"\u8c37\u6b4c\u5458\u5de5\u5e78\u798f\u751f\u6d3b \u7d2f\u4e86\u5c31\u8fdb\u9694\u97f3\u592a\u7a7a\u8231(\u7ec4\u56fe)\" src=\"http://img1.qq.com/tech/pics/11907/11907162.jpg\" border=0 name=MM></P>\r\n<P style=\"TEXT-INDENT: 2em\"><STRONG>5\u3001\u6280\u672f\u521b\u65b0</STRONG> </P>\r\n<P style=\"TEXT-INDENT: 2em\"></P>\r\n<P style=\"TEXT-INDENT: 2em\">\u529e\u516c\u5927\u697c\u968f\u5904\u53ef\u89c1\u767d\u8272\u4e66\u5199\u677f\uff0c\u76ee\u7684\u662f\u65b9\u4fbf\u5458\u5de5\u968f\u65f6\u8bb0\u4e0b\u5404\u79cd\u65b0\u521b\u610f\u3002\u4e00\u4f4dGoogle\u4ea7\u54c1\u7ecf\u7406\u5bf9\u6b64\u8868\u793a\uff1a\u201c\u4f60\u5750\u5728\u529e\u516c\u5ba4\u65f6\uff0c\u7075\u611f\u5e76\u4e0d\u4e00\u5b9a\u4f1a\u6765\uff1b\u6216\u8bb8\u5c31\u5728\u4f60\u8d70\u52a8\u65f6\uff0c\u7075\u611f\u5c31\u4f1a\u5982\u671f\u800c\u81f3\u3002\u201d </P>\r\n<P style=\"TEXT-INDENT: 2em\"></P>\r\n<P al