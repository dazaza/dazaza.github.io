81ea\u5df1\u5728\u667a\u80fd\u624b\u673a\u8fd9\u4e00\u5757\u7684\u5730\u4f4d\u3002\u8fd1\u65e5\uff0c\u5fae\u8f6f\u5168\u65b0\u7684WindowsPhone7\u5728\u6d77\u5916\u5e02\u573a\u4e0a\u5f00\u5356\uff0c\u9996\u6279WP7\u624b\u673a\u5f97\u5230\u4e86\u5305\u62ecHTC\u3001\u4e09\u661f\u3001LG\u7b49\u4e00\u7ebf\u5927\u5382\u7684\u652f\u6301\u3002\u4f5c\u4e3aWindowsMobile\u7684\u5927\u5382\uff0cHTC\u63a8\u51fa\u7684\u9996\u6279WP7\u624b\u673a\u2014\u2014HD7\u5728\u8fd1\u65e5\u4e5f\u5728\u6b66\u6c49\u6539\u7248\u624b\u673a\u5e02\u573a\u4e0a\u5f00\u5356\uff0c\u5f3a\u5927\u7684\u8bbe\u8ba1\u4ee5\u53ca\u9876\u7ea7\u7684\u8f6f\u786c\u4ef6\u8ba9HD7\u518d\u6b21\u6210\u4e3a\u7126\u70b9\u7684\u4e2d\u5fc3\uff0c\u76ee\u524d\u8be5\u673a\u5728\u6b66\u6c49\u6539\u7248\u624b\u673a\u5e02\u573a\u4e0a\u62a5\u4ef7\u4e3a4999\u5143\uff0c\u559c\u6b22\u7684\u670b\u53cb\u53ef\u4ee5\u7814\u7a76\u4e00\u4e0b\u3002HTCHD7\u56fe\u7247\u8bc4\u6d4b\u8bba\u575b\u62a5\u4ef7\u7f51\u8d2d\u5b9e\u4ef7HTCHD7\u4f5c\u4e3a\u9996\u6279\u7684WP7\u624b\u673a\u5728\u5916\u5f62\u8bbe\u8ba1\u4e0a\u7ee7\u627f\u4e86HTC\u4e00\u8d2f\u7684\u5927\u6c14\uff0c\u5176\u6574\u4f53\u5de5\u4e1a\u8bbe\u8ba1\u548c\u505a\u5de5\u90fd\u8fbe\u5230\u4e86\u76f8\u5f53\u9ad8\u7684\u6c34\u51c6\uff0c\u4f5c\u4e3a\u5fae\u8f6f\u7684\u6838\u5fc3\u5382\u5546\uff0cHTC\u8fd9\u6b21\u7684HD7\u4e0d\u7ba1\u54ea\u65b9\u9762\u6765\u770b\u90fd\u662f\u975e\u5e38\u7684\u5f3a\u5927\uff0c\u7edd\u5bf9\u53ef\u4ee5\u8d85\u8fc7WM6.5\u65f6\u4ee3\u7684\u5dc5\u5cf0\u4e4b\u4f5cHD2\u3002HTCHD7HTCHD7\u5728\u7cfb\u7edf\u65b9\u9762\u91c7\u7528\u4e86\u76ee\u524d\u6700\u65b0\u7684Windowsphone7\u7cfb\u7edf\uff0c\u6838\u5fc3\u786c\u4ef6\u5219\u4e3a1GHz\u9891\u7387\u7684\u9ad8\u901aScopion\u6838\u5fc3QSD8250+512MBRAM\uff0c\u867d\u7136\u8fd9\u6837\u7684\u914d\u7f6e\u540cHD2\u65f6\u4ee3\u6ca1\u6709\u592a\u591a\u7684\u5dee\u522b\uff0c\u4f46\u662f\u5168\u65b0\u7684\u7cfb\u7edf\u67b6\u6784\u548c\u754c\u9762\u8ba9HD7\u5728\u4f53\u9a8c\u3001\u6027\u80fd\u7b49\u5404\u65b9\u9762\u90fd\u8981\u6bd4\u524d\u4ee3\u7684\u673a\u578b\u597d\u5f88\u591a\uff0c\u53e6\u5916\uff0cWP7\u867d\u7136\u5728\u547d\u540d\u65b9\u9762\u91c7\u7528\u4e86\u201c7\u201d\uff0c\u4f46\u662f\u540cWM6\u6ca1\u6709\u4efb\u4f55\u5173\u7cfb\uff0cWP7\u5b8c\u5168\u662f\u5168\u65b0\u7684\u4e1c\u897f\uff0c\u76f8\u4fe1\u7ecf\u8fc7\u4e00\u6bb5\u65f6\u95f4\u7684\u79ef\u7d2f\uff0c\u5176\u4f18\u70b9\u4f1a\u88ab\u9010\u6e10\u6316\u6398\u51fa\u6765\u3002HTCHD7HTCHD7\u5728\u5c4f\u5e55\u65b9\u9762\u91c7\u7528\u4e86\u4e00\u57574.3\u5bf8\u5206\u8fa8\u7387\u4e3aWVGA\uff08480*800\u50cf\u7d20\uff09\u7684\u7535\u5bb9\u5c4f\uff0c\u6444\u50cf\u5934\u5219\u4e3a\u4e00\u9897500\u4e07\u50cf\u7d20\u7684\u81ea\u52a8\u5bf9\u7126\u6444\u50cf\u5934\uff0c\u652f\u6301\u65f6\u4e0b\u6d41\u884c\u7684720P\u5f55\u5236\u3002\u5176\u4ed6\u65b9\u9762\uff0cHD7\u5177\u6709\u4e30\u5bcc\u7684\u4e0a\u7f51\u3001\u591a\u5a92\u4f53\u3001\u5c0f\u8f6f\u4ef6\u7b49\u5b8c\u6574\u7684\u529f\u80fd\uff0c\u53e6\u5916\u50cf3G\u3001GPS\u3001Wifi\u3001\u6269\u5c55\u5361\u3001\u84dd\u7259\u3001\u6570\u636e\u7ebf\u7b49\u5e38\u89c4\u914d\u7f6e\u4e5f\u662f\u4e00\u5e94\u4ff1\u5168\u3002", "imagename": "49a6c4012c3442c39713bfb883aaaa8a.jpg", "infoid": 370718, "category": "technology_internet", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": null}]