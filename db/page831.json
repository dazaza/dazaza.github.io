r\n\u9177\u7231\u4e0a\u7f51\u51b2\u6d6a\u7684\u5c0f\u5218\u5f00\u59cb\u5728\u7f51\u4e0a\u6dd8\u9ad8\u6e05\u7535\u89c6\uff0c\u201c\u4e70\u7535\u5668\uff0c\u4e0a\u56fd\u7f8e\u201d\u7684\u8bcd\u5f88\u5feb\u5c31\u51fa\u73b0\u5728\u5c0f\u5218\u7684\u8111\u6d77\u91cc\uff0c\u5f97\uff0c\u5c31\u53bb\u56fd\u7f8e\u770b\u770b\u4e86\u3002\u6765\u5230\u56fd\u7f8e\u4e3b\u9875\uff0c\u7ea2\u7ea2\u7eff\u7eff\u7684\u6587\u5b57\u548c\u56fe\u7247\u51fa\u73b0\u5728\u5c0f\u5218\u773c\u524d\uff0c\u4ed6\u5fc3\u60f3\uff1a\u6562\u60c5\u8fd9\u91cc\u4e5f\u5f00\u5965\u8fd0\u4f1a\u5462\u3002\u518d\u4e00\u770b\uff0c\u4e56\u4e56\uff01\u91d1\u724c\u4ea7\u54c1\u6b63\u662f\u671d\u601d\u66ae\u60f3\u7684\u9ad8\u6e05\u7535\u89c6\u5462\uff0c\u5c0f\u5218\u8fde\u5fd9\u70b9\u51fb\u4e86\u9875\u9762\u3002\u4e0d\u70b9\u4e0d\u77e5\u9053\uff0c\u4e00\u70b9\u5413\u4e00\u8df3\u3002\u5c0f\u5218\u770b\u5230\u4e86\u8bb8\u591a\u77e5\u540d\u54c1\u724c\u7684\u9ad8\u6e05\u7535\u89c6\uff0c\u6709\u6700\u65b0\u6b3e\u7684\uff0c\u6709\u7279\u4ef7\u7684\uff0c\u6211\u5f97\u9009\u4e2a\u7269\u6709\u6240\u503c\u7684\uff0c\u4ed6\u7422\u78e8\u7740\u3002\r\n\r\n \r\n\r\n\u4e0d\u4e45\uff0c\u9875\u9762\u4e0a\u5f39\u51fa\u4e86\u4e00\u4e2a\u5bf9\u8bdd\u6846\uff1a\u201c\u6b22\u8fce\u6765\u81ea\u5317\u4eac\u7684\u670b\u53cb\u201d\u3002\u5c0f\u5218\u5fc3\u60f3\uff1a\u5947\u602a\uff0c\u4ed6\u4eec\u600e\u4e48\u77e5\u9053\u6211\u5728\u5317\u4eac\u5462\u3002\u5e26\u7740\u7591\u95ee\u548c\u597d\u5947\uff0c\u4ed6\u70b9\u51fb\u4e86\u4e0b\u5bf9\u8bdd\u6846\uff0c\u8f93\u5165\u4e86\u59d3\u540d\u3001\u95ee\u9898\u548c\u90ae\u7bb1\uff0c\u9009\u62e9\u4e86\u5ba2\u670d\u90e8\u6765\u670d\u52a1\uff0c\u4e00\u4e2a\u65b0\u5bf9\u8bdd\u6846\u9a6c\u4e0a\u51fa\u73b0\u5728\u4ed6\u773c\u524d\u3002\u5c0f\u5218\u6b63\u60f3\u770b\u4e2a\u7a76\u7adf\uff0c\u4e00\u884c\u4fe1\u606f\u5c31\u51fa\u73b0\u5728\u4ed6\u773c\u524d\uff1a\u201c\u4f60\u597d\uff0c\u6211\u662f\u5ba2\u670d888\u53f7\uff0c\u5f88\u9ad8\u5174\u4e3a\u4f60\u670d\u52a1\u201d\u3002\u8fd9\u4e0d\u4f1a\u662f\u4ec0\u4e48\u5ba2\u670d\u673a\u5668\u4eba\u5427\uff0c\u6211\u53ef\u89c1\u591a\u4e86\uff0c\u5c0f\u5218\u5f97\u610f\u4e8e\u8fd9\u4e00\u65b0\u53d1\u73b0\uff0c\u4ed6\u6545\u610f\u6253\u4e86\u4e00\u5927\u4e32\u4e71\u7801\u3002\u5f88\u5feb\uff0c\u5bf9\u8bdd\u6846\u4e0a\u663e\u793a\u5bf9\u65b9\u6b63\u5728\u8f93\u5165\uff0c\u5bf9\u65b9\u5f00\u59cb\u8bb2\u4e86\uff1a\u201c\u5bf9\u4e0d\u8d77\uff0c\u5218\u5148\u751f\uff0c\u6211\u662f\u5ba2\u670d888\u53f7\u738b\u5c0f\u59d0\uff0c\u6211\u662f\u5728\u2018\u70b9\u51fb\u5ba2\u670d\u2019\u5e73\u53f0\u4e0a\u548c\u4f60\u5bf9\u8bdd\uff0c\u6211\u770b\u4e0d\u61c2\u4f60\u7684\u4e71\u7801\uff0c\u6211\u80fd\u5e2e\u4f60\u505a\u70b9\u4ec0\u4e48\u5417\uff1f\u201d\u8fd9\u65f6\u5019\uff0c\u5c0f\u5218\u7ec8\u4e8e\u660e\u767d\u4e86\u5bf9\u65b9\u662f\u5ba2\u670d\u5c0f\u59d0\uff0c\u8bf4\u4e86\u4e9b\u6b49\u610f\u7684\u8bdd\uff0c\u5f00\u59cb\u548c\u738b\u5c0f\u59d0\u804a\u5f00\u4e86\u3002\u5c0f\u5218\u5411\u5bf9\u65b9\u8be6\u7ec6\u8be2\u95ee\u4e86\u5404\u6b3e\u9ad8\u6e05\u7535\u89c6\u7684\u529f\u80fd\u548c\u4ef7\u683c\uff0c\u6700\u540e\u4ed6\u76f8\u4e2d\u4e86\u4e00\u6b3e\u7535\u89c6\uff0c\u5c06\u5546\u54c1\u653e\u5165\u4e86\u5546\u57ce\u7684\u8d2d\u7269\u8f66\uff0c\u9009\u62e9\u4ed8\u6b3e\u65b9\u5f0f\u540e\u4ed4\u7ec6\u586b\u5199\u4e86\u9001\u8d27\u5730\u70b9\u3002\r\n\r\n\u8fc7\u4e86\u4e00\u4f1a\uff0c\u5c0f\u5218\u60f3\uff1a\u54e6\uff0c\u539f\u6765\u521a\u624d\u6211\u662f\u5728\u7528\u201c\u70b9\u51fb\u5ba2\u670d\u201d\u548c\u5ba2\u670d\u5c0f\u59d0\u804a\uff0c\u804a\u5929\u8bb0\u5f55\u8fd8\u53d1\u9001\u5230\u4e86\u6211\u7684\u90ae\u7bb1\u91cc\uff0c\u6211\u5f97\u518d\u770b\u770b\u804a\u5929\u8bb0\u5f55\uff0c\u770b\u4e70\u5f97\u5212\u4e0d\u5212\u7b97\u3002\u201d\u60f3\u7740\uff0c\u5c0f\u5218\u5f97\u610f\u5730\u7b11\u4e86\uff0c\u5c31\u7b49\u7740\u7528\u9ad8\u6e05\u5f69\u7535\u770b\u7cbe\u5f69\u5965\u8fd0\u8d5b\u4e8b\u4e86\u3002", "imagename": "", "infoid": 87394, "category": "technology_other", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "te