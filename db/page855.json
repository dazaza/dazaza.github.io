8\u5c06\u5728\u5e97\u9762\u9500\u552e\u7684\u76d2\u88c5\u4ea7\u54c1\u516d\u6298\u4f18\u60e0\u3002\r\n<P>\u4ee5\u4e0b\u662f\u745e\u661f\u7684\u8be6\u7ec6\u653f\u7b56\uff1a</P>\r\n<P>&nbsp;&nbsp; 1\u3001\u6240\u6709\u4e0b\u8f7d\u201c\u745e\u661f\u5361\u53616.0\u201d\u7684\u7528\u6237\uff0c\u90fd\u53ef\u4ee5\u83b7\u5f97\u514d\u8d39\u7684\u201c\u745e\u661f\u6740\u6bd2\u8f6f\u4ef62008\u7248\u201d\u548c\u201c\u745e\u661f\u4e2a\u4eba\u9632\u706b\u58992008\u7248\u201d\uff0c\u514d\u8d39\u4f7f\u7528\u671f\u4e3a\u4e00\u5e74\u3002<BR>&nbsp;&nbsp; 2\u30012008\u5e741\u67081\u65e5\u4e4b\u540e\uff0c\u8d2d\u4e70\u745e\u661f\u6740\u6bd2\u8f6f\u4ef62008\u76d2\u88c5\u7248\u7684\u7528\u6237\uff0c\u4ea7\u54c1\u4f7f\u7528\u671f\u81ea\u52a8\u5ef6\u957f\u4e00\u5e74\u3002<BR>&nbsp;&nbsp; 3\u3001\u745e\u661f\u5728\u5e97\u9762\u9500\u552e\u7684\u76d2\u88c5\u4ea7\u54c1\u516d\u6298\u4f18\u60e0\uff0c\u5728\u6d3b\u52a8\u671f\u95f4\u8d2d\u4e70\u745e\u661f\u4ea7\u54c1\u7684\u7528\u6237\uff0c\u9664\u4e86\u4eab\u53d7\u516d\u6298\u7684\u8d85\u4f18\u60e0\u4ef7\u683c\u4e4b\u5916\uff0c\u6240\u8d2d\u4ea7\u54c1\u7684\u4f7f\u7528\u671f\u5c06\u81ea\u52a8\u5ef6\u957f\u4e00\u5e74\u3002<BR>&nbsp;&nbsp; 4\u3001\u6240\u67092008\u5e741\u67081\u65e5\u540e\u8d2d\u4e70\u745e\u661f\u6740\u6bd2\u8f6f\u4ef6\u4e0b\u8f7d\u7248(\u534a\u5e74\u4ee5\u4e0a\u670d\u52a1\u671f)\u7684\u7528\u6237\uff0c\u4ea7\u54c1\u4f7f\u7528\u671f\u81ea\u52a8\u5ef6\u957f\u4e00\u5e74\u3002</P>\r\n<P>&nbsp;&nbsp; \u745e\u661f\u4e4b\u524d\u4e00\u76f4\u662f\u56fd\u5185\u4e2a\u4eba\u6740\u6bd2\u5e02\u573a\u7684\u8001\u5927\uff0c\u5360\u636e\u4e86\u5927\u91cf\u7684\u5e02\u573a\u4efd\u989d\u3002\u4f46\u8fd1\u5e74\u6765\u5947\u864e\u7684\u5b89\u5168\u536b\u58eb360\u548c\u5361\u5df4\u65af\u57fa\u5408\u4f5c\u63a8\u51fa\u7684\u6740\u6bd2\u8f6f\u4ef6\u534a\u5e74\u514d\u8d39\u4f18\u60e0\u5219\u593a\u53bb\u4e86\u90e8\u5206\u7528\u6237\uff0c\u53cc\u65b9\u4e5f\u5c31\u7ed3\u4e0b\u4e86\u524d\u6028\u3002\u5982\u4eca\uff0c\u5728\u745e\u661f\u63a8\u51fa\u534a\u5e74\u5