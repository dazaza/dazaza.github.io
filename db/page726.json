8c\u5bb6\u53f2\u7814\u7a76\u6280\u672f\uff0c\u7528\u6237\u73b0\u5728\u53ef\u4ee5\u7528\u5b58\u5728\u4ed6\u4eecDNA\u91cc\u7684\u4fe1\u606f\u627e\u5230\u5f53\u4eca\u6709\u7740\u5171\u540c\u7956\u5148\u7684\u4eb2\u621a\u3002FamilyTreeDNA\u7528\u6237\u5219\u53ef\u4ee5\u5229\u7528MyHeritage\u7684\u7f51\u7ad9\uff0c\u4e0d\u4ec5\u8fdb\u4e00\u6b65\u7814\u7a76\u5bb6\u65cf\u5386\u53f2\uff0c\u800c\u4e14\u8fd8\u53ef\u4ee5\u4e0e\u76ee\u524d\u5728\u4e16\u754c\u5404\u5730\u5bb6\u5ead\u6210\u5458\u4fdd\u6301\u8054\u7cfb\u3002&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; <BR>&nbsp;<BR>\u201c\u62e5\u6709\u8fd122\u4e07\u8bb0\u5f55\u8d44\u6599\uff0c FamilyTreeDNA\u662f\u5bf9\u7cfb\u8c31\u7684DNA\u4fe1\u606f\u4e16\u754c\u4e2d\u6700\u5927\u7684\u6570\u636e\u5e93\u3002\u8fd9\u5bf9MyHeritage\u76ee\u524d\u7684\u7814\u7a76\u5de5\u5177\u63d0\u4f9b\u4e86\u5b8c\u7f8e\u7684\u8865\u5145\uff0c\u4f7f\u6211\u4eec\u7f51\u7ad9\u7684\u6210\u5458\u7528\u53e6\u4e00\u79cd\u65b9\u5f0f\uff0c\u4e86\u89e3\u4ed6\u4eec\u7684\u6765\u5386\uff0c MyHeritage\u7684\u521b\u53f2\u4eba\u53caCEO Gilad Japhet\u8868\u793a\u3002\u201c\u6211\u4eec\u5e2e\u52a9\u4e16\u754c\u5404\u5730\u7684\u4eba\u4eec\u8f7b\u677e\u5730<BR>\u53d1\u73b0\uff0c\u8fde\u63a5\u548c\u6c9f\u901a\u4ed6\u4eec\u7684\u5bb6\u5ead\u7f51\u7edc\uff0c\u7814\u7a76\u4ed6\u4eec\u7684\u5bb6\u5ead\u7684\u5386\u53f2\u3002\u73b0\u5728\uff0c\u901a\u8fc7\u4e0eFamilyTreeDNA\u7684\u5408\u4f5c\uff0c\u6211\u4eec\u53ef\u4ee5\u63d0\u4f9b\u4e00\u4e2a\u5bf9\u6587\u4ef6\u7ebf\u7d22\u8017\u5c3d\u7684\u89e3\u51b3\u529e\u6cd5\u3002\u201c&nbsp;&nbsp;&nbsp;&nbsp; <BR>&nbsp;<BR>\u81ea2000\u5e74\u6210\u7acb\u4ee5\u6765\uff0c FamilyTreeDNA\u6d4b\u8bd5\u8d85\u8fc745\u4e07\u7684<BR>\u4eba\uff0c\u5e2e\u52a9\u6ca1\u6709\u5e38\u89c4\u8bb0\u5f55\u53ef\u7528\u7684\u5ba2\u6237\u8ffd\u8e2a\u5bb6\u65cf\u53f2. \u5148\u8fdb\u7684DNA\u7684\u7b5b\u9009\u6280\u672f\uff0c\u9664\u5176\u4ed6\u4e8b\u9879\u5916\uff0c\u8fd8\u53ef\u4ee5\u63ed\u793a\u7f8e\u6d32\uff0c\u975e\u6d32\u6216\u72b9\u592a\u8840\u7edf\u7684\u7236\u4eb2\u6216\u6bcd\u4eb2\u884c\uff0c\u4ee5\u53ca\u53d1\u73b0\u7956\u4f20\u7684\u4fe1\u606f\u3002\u901a\u8fc7\u4e00\u7cfb\u5217\u7684\u6d4b\u8bd5\uff0c\u7528\u6237\u53ef\u4ee5\u83b7\u53d6\u6700\u8fd1\u7684\u5bb6\u53f2\u8d44\u6599\u548c\u7956\u5148\u7684\u5386\u53f2\u6e0a\u6e90\uff0c\u5176\u4e2d\u5305\u62ec\u4e00\u4e2a\u79fb\u6c11\u5730\u56fe\u63d0\u4f9b\u7236\u4eb2\u548c\u6bcd\u4eb2\u7684\u5bb6\u53f2\u6765\u5386\u3002MyHeritage\u768427\u4e07\u7528\u6237\u5c06\u6709\u673a\u4f1a\u83b7\u5f97\u4ee5\u4e0b\u4e09\u4e2a\u6d4b\u8bd5\uff1a<BR>\u00b7&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; Y\u578bDNA25 -\u4e00\u4e2aY\u67d3\u8272\u4f53\uff0c\u7537\u6027\u6d4b\u8bd5\uff08129\u7f8e\u5143\uff09<BR>\u00b7&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; \u7ebf\u7c92\u4f53DNA -\u4e00\u4e2a\u7ebf\u7c92\u4f53DNA\u6d4b\u8bd5\u7684\u7537\u6027\u548c\u5973\u6027\uff08129\u7f8e\u5143\uff09<BR>\u00b7&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; Y\u578bDNA25+\u7ebf\u7c92\u4f53DNA -\u8054\u5408Y\u67d3\u8272\u4f53\u548c\u7ebf\u7c92\u4f53DNA\u68c0\u6d4b\u4e3a\u7537\u6027\uff08219\u7f8e\u5143\uff09<BR>&nbsp;<BR>\u8d1d\u5185\u7279.\u683c\u6797\u65af\u6f58(Bennett Greenspan)-FamilyTreeDNAde\u7684\u603b\u88c1\u517c\u9996\u5e2d\u6267\u884c\u5b98\u8bf4\uff0c\u201cMyHeritage\u662f\u4e00\u79cd\u5728\u7ebf\u7814\u7a76\u5bb6\u65cf\u53f2\u65f6\u5b9d\u8d35\u7684\u8d44\u6e90\uff0c\u8fd9\u6b63\u662f\u662f\u4e00\u4e2a\u5bf9\u6211\u4eecDNA\u7814\u7a76\u7684\u4e00\u4e2a\u5b8c\u7f8e\u8865\u5145\u3002\u6211\u4eec\u7684DNA\u7814\u7a76\u80fd\u8bc1\u660e\u4e24\u4e2a\u4eba\u6709\u5173\uff0c\u540c\u65f6\uff0cMyHeritage\u7684\u667a\u80fd\u5339\u914d\u6280\u672f\u4e5f\u53ef\u4ee5\u6bd4\u8f83\u4ed6\u4eec\u7684\u5bb6\u5ead\u6811\uff0c\u4ee5\u663e\u793a\u8fde\u63a5\u5173\u7cfb\u3002\u6211\u4eec\u8fd8\u8363\u5e78\u5730\u7ed9\u6211\u4eec\u7684\u6210\u5458\uff0c\u901a\u8fc7MyHeritage\u7684\u65b9\u5f0f\u548c\u5728\u4e16\u754c\u5404\u5730\u7684\u4eb2\u4eba\u670b\u53cb\u4fdd\u6301\u5bc6\u5207\u8054\u7cfb.\u201c<BR>&nbsp;<BR>MyHeritage\u662f\u4e00\u4e2a\u4e16\u754c\u9886\u5148\u7684\u5728\u7ebf\u5bb6\u5ead\u76ee\u7684\u5730\u3002\u5728\u8fd9\u4e2a\u7f51\u7ad9\u4e0a\uff0c\u4eba\u4eec\u53ef\u4ee5\u627e\u5230\u4eb2\u4eba\uff0c\u7814\u7a76\u5bb6\u65cf\u53f2\uff0c\u5e76\u548c\u8eab\u5728\u4efb\u4f55\u5730\u65b9\u7684\u4eb2\u4eba\u4fdd\u6301\u6c9f\u901a\u3002\u6b64\u5916\uff0c MyHeritage\u63d0\u4f9b\u81ea\u52a8\u7167\u7247\u6807\u8bb0\u6280\u672f\uff0c\u53ef\u66f4\u52a0\u65b9\u4fbf\u5730\u6807\u7b7e\uff0c\u7ec4\u7ec7\u548c\u641c\u7d22\u6570\u7801\u7167\u7247\uff0c\u8ba9\u5bb6\u5ead\u7684\u53e6\u4e00\u4e2a\u6709\u8da3\u7684\u65b9\u5f0f\u4fdd\u6301\u8054\u7cfb\u3002<BR>&nbsp;<BR>\u5173\u4e8eMyHeritage<BR>MyHeritage\u662f\u7531\u4e00\u4e2a\u70ed\u5fe0\u4e8e\u5bb6\u5ead\u5386\u53f2\u540c\u65f6\u53c8\u5177\u6709\u53d1\u5c55\u521b\u65b0\u7f51\u7edc\u6280\u672f\u7684\u56e2\u961f\u7ec4\u6210\u7684\u3002MyHeritage\u73b0\u5728\u4ee5\u662f\u4e00\u4e2a\u4e16\u754c\u9886\u5148\u7684\u5728\u7ebf\u7f51\u7edc\u5bb6\u5ead\uff0c\u4ee5\u53ca\u7b2c\u4e8c\u5927\u5bb6\u65cf\u53f2\u7f51\u7ad9\u3002 MyHeritage\u63d0\u4f9b34\u79cd\u8bed\u8a00\u548c\u5bb6\u5ead\u8d85\u8fc72700\u4e07\u7684\u5bb6\u5ead\u6210\u5458\u548c2.8\u4ebf\u7f8e\u5143\u7684\u914d\u7f6e\u6587\u4ef6\u3002\u8be5\u516c\u53f8\u6700\u8fd1\u6536\u8d2d\u4e86Kindo \uff0c\u53e6\u4e00\u4e2a\u5bb6\u5ead\u7684\u793e\u4f1a\u7f51\u7edc\u3002MyHeritage\u603b\u90e8\u8bbe\u5728\u4ee5\u8272\u5217Bnei Atarot\uff0c\u9760\u8fd1\u7279\u62c9\u7ef4\u592b\u3002\u6b32\u4e86\u89e3\u66f4\u591a\u4fe1\u606f\uff0c\u8bf7\u8bbf\u95ee<A href=\"http://www.myheritage.com\">www.myheritage.com</A> \u3002<BR>&nbsp;<BR>\u4e0b\u9762\u8fd9\u4e2a\u94fe\u89e3\u662f\u4ecb\u53ecMyHeritage\u65b0\u7167\u7247\u6807\u8bb0\u529f\u80fd\u7684\u89c6\u5c4f\uff1a<BR><A href=\"http://www.myheritage.com/blogs/companyblog/2008/09/get_to_know_our_smart_new_phot.html\">http://www.myheritage.com/blogs/companyblog/2008/09/get_to_know_our_smart_new_phot.html</A><BR>&nbsp;<BR>\u5173\u4e8eFamilyTreeDNA\uff0d\u65cf\u8c31DNA<BR>&n