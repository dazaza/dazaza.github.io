a\u5408\u4e0e\u5185\u7f6e\u535a\u5ba2widget\u3002\u514d\u8d39\u7528\u6237\u6700\u591a\u53ef\u5c0650\u4e2afeed\u8fdb\u884c\u805a\u5408\uff0c\u63d2\u5165\u535a\u5ba2\u4e2d\u4e0e\u670b\u53cb\u5206\u4eab\u9605\u8bfb\u3002\u76f8\u4fe1\u5f88\u591a\u4eba\u4ee5\u524d\u4e5f\u66fe\u542c\u8bf4\u8fc7Grazr\uff0c\u6216\u8bb8\u4f60\u8fd8\u66fe\u7ecf\u7528\u8fc7\uff0c\u4eca\u5929\u6211\u4eec\u5c31\u91cd\u70b9\u770b\u770b Grazr beta3.0 \u7684\u4e00\u4e9b\u6539\u8fdb\u3002", "imagename": "9d2618392ed8405587f3eb7886d299e3.jpg", "infoid": 72569, "category": "technology_web2", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["feed", "web2.0", "widget"]}, {"url": "http://tech.qq.com/a/20080602/000303.htm", "title": "Pirate Bay\u56e2\u961f\u5728\u535a\u5ba2\u4e2d\u5efa\u8bae\uff0c\u5c065\u670831\u65e5\u4f5c\u4e3a\u5e86\u795d\u76d7\u7248\u7684\u65e5\u5b50", "tags": "bt PirateBay ", "name": "geekzhang", "posttime": "2008-06-02 22:56:08", "ip": "222.178.10.240", "mark": 4, "note": "\u636e\u56fd\u5916\u5a92\u4f53\u62a5\u9053\uff0c5\u670831\u65e5\u662f\u745e\u5178\u8b66\u65b9\u7a81\u51fb\u641c\u67e5BT\u7f51\u7ad9Pirate Bay\u4e24\u5e74\u7eaa\u5ff5\u65e5\u3002\u745e\u5178\u8b66\u65b9\u57282006\u5e745\u670831\u65e5\u7a81\u88ad\u4e86\u201c\u6d77\u76d7\u6e7e\u201d\uff0c\u5f3a\u5236\u5173\u95ed\u4e86\u8be5\u7f51\u7ad9\uff0c\u5e76\u902e\u6355\u4e86\u7f51\u7ad9\u7684\u4e24\u540d\u7ba1\u7406\u8005\u3002\u4e0d\u8fc7\u5728\u5f88\u77ed\u7684\u65f6\u95f4\u5185\uff0cPirate Bay\u4fbf\u91cd\u65b0\u5f00\u5f20\u3002\u5a92\u4f53\u7684\u5173\u6ce8\u8ba9Pirate Bay\u56e0\u7978\u5f97\u798f\u3002\u622a\u81f3\u76ee\u524d\uff0c\u745e\u5178\u6cd5\u9662\u4ecd\u672a\u5bf9Pirate Bay\u505a\u51fa\u4efb\u4f55\u5904\u7f5a\u51b3\u5b9a\uff0c\u800c\u4e14\u968f\u7740\u77e5\u540d\u5ea6\u7684\u4e0a\u6da8\uff0cPirate Bay\u7684\u652f\u6301\u8005\u4e5f\u662f\u8d8a\u6765\u8d8a\u591a\u3002 \r\n\r\n\u81ea\u906d\u5230\u745e\u5178\u8b66\u65b9\u7684\u7a81\u88ad\u4e4b\u540e\uff0cPirate Bay\u7684\u6d41\u91cf\u5f00\u59cb\u5448\u73b0\u51fa\u7206\u70b8\u5f0f\u7684\u4e0a\u6da8\u8d8b\u52bf\u3002\u622a\u81f3\u76ee\u524d\uff0c\u6839\u636ePirate Bay\u81ea\u5df1\u7684\u7edf\u8ba1\u6570\u636e\u663e\u793a\uff0cPirate Bay\u7f51\u7ad9\u4e0a\u7684\u79cd\u5b50\u6570\u91cf\u5df2\u4ece250\u4e07\u589e\u957f\u81f31200\u4e07\u4ee5\u4e0a\uff0c\u6ce8\u518c\u7528\u6237\u4e5f\u4ece100\u4e07\u4e0a\u5347\u81f3270\u4e07\u3002\u800c\u4e14\u66f4\u4e3a\u91cd\u8981\u7684\u662f\uff0cPirate Bay\u7f51\u7ad9\u7684\u6d41\u91cf\u548c\u6ce8\u518c\u7528\u6237\u6570\u91cf\u6bcf\u5929\u90fd\u5728\u4e0d\u65ad\u7684\u4e0a\u6da8\u3002 \r\n\r\n\u745e\u5178\u8b66\u65b9\u5728\u5f53\u65f6\u66fe\u67e5\u5904\u4e86Pirate Bay\u7684180\u53f0\u670d\u52a1\u5668\uff0c\u4f46\u5927\u591a\u6570\u4e0ePirate Bay\u65e0\u5173\u3002\u745e\u5178\u8b66\u65b9\u5728\u53bb\u5e7412\u6708\u7ed3\u675f\u4e86\u5bf9Pirate Bay\u7684\u8c03\u67e5\uff0c\u4ec5\u6cd5\u5f8b\u6587\u4ef6\u5c31\u957f\u8fbe400\u591a\u9875\u3002\u745e\u5178\u68c0\u5bdf\u5b98\u968f\u540e\u5ba3\u5e03\uff0c\u67094\u4eba\u56e0\u63d0\u4f9b\u4e864\u6b3e\u8f6f\u4ef6\u30019\u90e8\u7535\u5f71\u53ca22\u9996\u97f3\u4e50\u7684\u4e0b\u8f7d\uff0c\u88ab\u4ee5\u201c\u534f\u52a9\u4fb5\u72af\u7248\u6743\u7f6a\u201d\u8d77\u8bc9\u3002\u8bb8\u591a\u4eba\u90fd\u8ba4\u4e3a\uff0c\u745e\u5178\u8b66\u65b9\u6263\u62bcPirate Bay\u670d\u52a1\u5668\u7684\u505a\u6cd5\u5e76\u4e0d\u5408\u9002\u3002\u800c\u4e14\u8b66\u65b9\u7528\u5f88\u957f\u65f6\u95f4\u53bb\u8fdb\u884c\u8c03\u67e5\uff0c\u4e5f\u8868\u660e\u5e76\u6ca1\u6709\u8db3\u591f\u6709\u6548\u7684\u8bc1\u636e\u8bc1\u660ePirate Bay\u5b58\u5728\u4fb5\u72af\u7248\u6743\u7f6a\u7684\u95ee\u9898\u3002 \r\n\r\n\u5f53\u7136\uff0c\u5e76\u4e0d\u662f\u6240\u6709\u4eba\u90fd\u5bf9Pirate Bay\u62b1\u6709\u597d\u611f\u3002\u52a8\u753b\u7247\u4ea7\u4e1a\u548c\u7535\u5f71\u4ea7\u4e1a\u5c31\u8ba4\u4e3aPirate Bay\u5e94\u5f53\u5173\u95e8\u6b47\u4e1a\u3002\u56fd\u9645\u5531\u7247\u4e1a\u534f\u4f1a(International Federation of the Phonographic Industry)\u6ce8\u5b9a\u4fbf\u662fPirate Bay\u7684\u4e00\u751f\u4e4b\u654c\u3002\u9664\u6b64\u4e4b\u5916\uff0c\u7f8e\u56fd\u7535\u5f71\u534f\u4f1a\uff08The Motion Picture Association of America\uff09\u4e5f\u56e0\u6d89\u5acc\u4fb5\u72af\u7248\u6743\u7f6a\u8d77\u8bc9Pirate Bay\uff0c\u5e76\u63d0\u51fa\u4e861540\u4e07\u7f8e\u5143\u7684\u7d22\u8d54\u8981\u6c42\u3002 \r\n\r\nPirate Bay\u56e2\u961f\u5728\u535a\u5ba2\u4e2d\u5efa\u8bae\uff0c\u5c065\u670831\u65e5\u4f5c\u4e3a\u5e86\u795d\u76d7\u7248\u7684\u65e5\u5b50\u3002\u8be5\u56e2\u961f\u5728\u535a\u5ba2\u4e2d\u8868\u793a\uff1a\u201c\u8ba9\u4eca\u5929\u6210\u4e3a\u76d7\u7248\u72ec\u7acb\u65e5\u5427\uff01\u8ba9\u6211\u4eec\u6765\u5e86\u795d\u8fc7\u53bb\u548c\u672a\u6765\u6240\u53d6\u5f97\u7684\u80dc\u5229\uff0c\u5e86\u795d\u6211\u4eec\u5171\u540c\u52aa\u529b\u7684\u6210\u679c\u3002\u201d\u5bf9\u4e8ePirate Bay\u672a\u6765\u662f\u5426\u4f1a\u56e0\u4e3a\u4fb5\u72af\u7248\u6743\u7f6a\u800c\u88ab\u8feb\u5173\u95ed\u7684\u95ee\u9898\uff0c\u5206\u6790\u5e08\u8ba4\u4e3a\uff0c\u5373\u4fbf\u662fPirate Bay\u672a\u6765\u88ab\u6c38\u4e45\u6027\u7684\u5173\u95ed\uff0c\u4f46\u5b83\u4ecd\u7136\u4f1a\u5b58\u5728\u4e8eBT\u7528\u6237\u7684\u5fc3\u4e2d\u3002\u6709\u6ca1\u6709Pirate Bay\uff0c\u4e92\u8054\u7f51\u7528\u6237\u4ecd\u7136\u70ed\u7231BT\uff0c\u4ecd\u7136\u4f1a\u4f7f\u7528BT\u3002", "imagename": "8518ec4c2f244c168db3fe90670257e1.jpg", "infoid": 72563, "category": "technology_internet", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["bt", "piratebay"]}]