7a74\u98de\u8d70\u3002\u4e00\u53ea\u4f53\u578b\u66f4\u5927\u7684\u6b27\u690b\u9e1f\u864e\u89c6\u7708\u7708\u5730\u770b\u7740\u5b83\u7684\u5bb6\uff0c\u5b83\u88ab\u8feb\u642c\u5bb6\uff0c\u5e26\u7740\u4e00\u4e2a\u767d\u8272\u5c0f\u86cb\u98de\u5f80\u65b0\u5de2\u7a74\u3002", "imagename": "b1a750d42d3445ea9f7391ddc92a9bd1.jpg", "infoid": 755880, "category": "culture_photograph", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "culture", "via": null, "real_tags": null}, {"url": "http://www.ifanr.com/103295", "title": "Google 199 \u7f8e\u5143\u5e73\u677f\u6765\u4e86\uff01", "tags": "google \u8c37\u6b4c \u8c37\u6b4c\u5e73\u677f google\u5e73\u677f ", "name": "geekzhang", "posttime": "2012-06-28 09:23:31", "ip": "219.141.211.201", "mark": 0, "note": "\u4e54\u5e03\u65af\u53bb\u4e16\u540e\uff0c\u79d1\u6280\u754c\u4fdd\u5bc6\u63aa\u65bd\u4ee5\u4e25\u683c\u8457\u79f0\u7684\u6807\u6746\u4f3c\u4e4e\u8f70\u7136\u5012\u584c\u4e86\uff0c\u79d1\u6280\u754c\u6ca1\u6709\u4e86\u79d8\u5bc6\u3002Google \u5e73\u677f\u7684\u6d88\u606f\u6982\u83ab\u80fd\u5916\uff0c\u5728\u53d1\u5e03\u4f1a\u4e4b\u524d\u4e00\u5929\uff0c\u88ab Gizmodo \u6fb3\u5927\u5229\u4e9a\u7ad9\u6cc4\u9732\u5177\u4f53\u53c2\u6570\uff0c\u5e76\u5148\u540e\u5f97\u5230\u5f6d\u535a\u793e\u548c\u8def\u900f\u793e\u8fd9\u6837\u4e25\u8083\u5a92\u4f53\u7684\u201c\u786e\u8ba4\u201d\u3002\u2014\u2014\u5f53\u7136\uff0c\u82f9\u679c\u4e5f\u672a\u80fd\u81ea\u4fdd\uff0c\u5728 WWDC \u524d\u4e00\u5468\uff0c9to5mac \u7684\u4e00\u4e2a\u9ad8\u4e2d\u751f\u51e0\u4e4e\u201c\u62bc\u4e2d\u201d\u4e86\u5173\u4e8e WWDC 2012 \u7684\u5168\u90e8\u91cd\u5927\u6d88\u606f\u3002\r\n\r\n\u8fd9\u662f Google\u201c\u5ae1\u4f20\u201dNexus \u5e73\u677f\u53c2\u6570\uff0c\u4e0e Gizmodo \u6b64\u524d\u6cc4\u9732\u7684\u6d88\u606f\u51e0\u4e4e\u533a\u522b\uff1a\r\n\u20221.3 GHz Tegra 3 \u56db\u6838\u5904\u7406\u5668\uff08\u5305\u542b 12 \u82af GPU\uff09\r\n\u20221 GB RAM\r\n\u20228 G/16 G \u5b58\u50a8\r\n\u2022\u642d\u914d NFC\uff0cAndroid Beam\r\n\u20227\u5bf8 IPS \u5c4f\u5e55\uff0c\u5206\u8fa8\u7387 1280 x 800\r\n\u2022120 \u4e07\u524d\u7f6e\u6444\u50cf\u5934\uff08\u65e0\u540e\u7f6e\u6444\u50cf\u5934\uff09\r\n\u2022\u7535\u6c60\u7eed\u822a\u80fd\u529b\u4e3a\u64ad\u653e\u89c6\u9891 9 \u5c0f\u65f6\r\n\r\n\u4e0e\u6b64\u524d\u4f20\u95fb\u76f8\u6bd4\uff0c\u53ea\u6709\u4ef7\u683c\u4e0a\u7684\u7ec6\u5fae\u7684\u53d8\u5316\uff1a199 \u7f8e\u5143\u4ef7\u683c\uff0c\u5728 Google Play \u5546\u5e97\u8d2d\u4e70\u8fd8\u53ef\u4ee5\u83b7\u5f97 25 \u7f8e\u5143\u793c\u5238\u3002\u53e6\u5916\uff0c\u5e73\u677f\u7eed\u822a\u63cf\u8ff0\u4e3a\u201c\u64ad\u653e 720 P \u89c6\u9891\u53ef\u4ee5\u6491 9 \u5c0f\u65f6\u201d\uff0c\u90a3\u4e48\u666e\u901a\u6d4f\u89c8\u7f51\u9875\u6216\u5f85\u673a\u5e94\u8be5\u4f1a\u6bd4\u8fd9\u4e2a\u65f6\u95f4\u66f4\u957f\u3002\r\n\r\n\u5173\u4e8e\u5e73\u677f\u7684\u540d\u79f0\uff0c\u5ef6\u7eed Google \u5728\u667a\u80fd\u624b\u673a\u9886\u57df\u7684 Nexus \u54c1\u724c\uff0c\u5e76\u4e14\u5982\u7b2c\u4e00\u4ee3 Nexus \u624b\u673a\u4e00\u6837\uff0c\u540d\u79f0\u91cc\u6ca1\u6709\u5939\u6742\u4ee3\u5de5\u5382\u7684\u4fe1\u606f\uff08ASUS Nexus 7\uff09\u3002\r\n\u9769 Kindle Fire \u7684\u547d\r\n\r\n\u4ef7\u683c\u4e0e\u5982\u5404\u5927\u901a\u8baf\u793e\u5728\u53d1\u5e03\u4f1a\u4e4b\u524d\u201c\u786e\u8ba4\u201d\u7684\u4e00\u6837\uff0c\u4e3a 199 \u7f8e\u5143\u3002\u8fd9\u4e00\u4ef7\u683c\u5f88\u5bb9\u6613\u8ba9\u4eba\u8054\u60f3\u5230 Amazon \u5bb6\u7684 Kindle Fire\uff0c\u540e\u8005\u867d\u7136\u57fa\u672c\u4e0a Google \u6ca1\u6709\u534a\u5206\u94b1\u5173\u7cfb\uff0c\u4f46\u5728\u7edf\u8ba1\u673a\u6784\u8ba1\u6570\u7684\u65f6\u5019\u662f\u88ab\u5f52\u7c7b\u5230 Android \u9635\u8425\u7684\uff0c\u5e76\u4e14\u88ab\u5a92\u4f53\u89e3\u8bfb\u4e3a\u201cKindle Fire \u7545\u9500\u5e2e\u52a9 Android \u63d0\u9ad8\u4e86\u5728\u5e73\u677f\u7535\u8111\u5e02\u573a\u7684\u4efd\u989d\u201d\u3002\u5982\u4eca\uff0c\u4e0e Kindle Fire \u76f8\u540c\u7684\u4ef7\u683c\uff0c\u5b8c\u5168\u4e0d\u540c\u65f6\u4ee3\u7684\u786c\u4ef6\u914d\u7f6e\uff0c\u4eba\u4eec\u5728\u9f13\u5439\u201cNexus \u8fce\u6218\u82f9\u679c\u201d\u65f6\uff0c\u4e0d\u8981\u5fd8\u8bb0\u4e86\u9996\u5148\u88ab\u9769\u547d\u7684\u662f\u81ea\u5df1\u7684\u201c\u4f2a\u5144\u5f1f\u201dKindle Fire\u3002\r\n\r\n\u9664\u4e86\u9769\u7b2c\u4e00\u4ee3 Kindle Fire \u7684\u547d\uff0cNexus \u5e73\u677f\u5bf9\u7b2c\u4e8c\u4ee3 Kindle Fire \u4e5f\u6709\u76f4\u63a5\u800c\u7b80\u5355\u7c97\u66b4\u7684\u5f71\u54cd\uff1a\u63d0\u9ad8\u786c\u4ef6\u914d\u7f6e\uff0c\u5411 Nexus \u5e73\u677f\u770b\u9f50\u3002\u5982\u679c\u4e0d\u8003\u8651\u5916\u90e8\u56e0\u7d20\uff0c\u8fd9\u4e2a\u6548\u679c\u6b63\u662f Google \u81ea\u5df1\u64b8\u8d77\u8896\u5b50\u81ea\u5df1\u505a\u5e73\u677f\u7535\u8111\u7684\u6700\u539f\u59cb\u52a8\u673a\u2014\u2014\u8fd9\u4e2a\u52a8\u673a\u4e0e\u5fae\u8f6f Surface \u662f\u4e0d\u540c\u7684\uff0cJohn Gruber \u8bf4 Surface \u662f\u5fae\u8f6f\u8ffd\u6c42\u9ad8\u5229\u6da6\u7387\u7684\u4ea7\u54c1\uff0c\u4e3a\u8fbe\u6b64\u76ee\u7684\u751a\u81f3\u4e0d\u60dc\u4e0e\u76df\u53cb\u53cd\u76ee\u3002\r\n\r\nAndroid \u5e73\u677f\u6807\u6746\r\n\r\n\u65e0\u7591\uff0cNexus \u5c06\u6210\u4e3a Android \u5e73\u677f\u65e5\u540e\u7684\u6807\u6746\uff0c\u4e00\u5982 Nexus \u7cfb\u5217\u201c\u4eb2\u513f\u5b50\u201d\u624b\u673a\u4e00\u6837\u3002\u6b64\u524d\u8fd9\u4e00\u9635\u8425\u7684\u6563\u5175\u6e38\u52c7\u662f Galaxy Tab\u3001HTC Flyer\u3001Kindle Fire\u2026\u2026\u4f5c\u4e3a\u4e00\u6b3e\u6807\u6746\u578b\u4ea7\u54c1\uff0cNexus \u5e73\u677f\u7684\u53c2\u6570\u5177\u6709\u6307\u5bfc\u610f\u4e49\uff1a7 \u5bf8 IPS \u5c4f\u5e55\uff0cnVIDIA \u82af\u7247\uff0c\u8fd0\u884c\u5185\u5b58\uff0c\u5b58\u50a8\u7a7a\u95f4\uff0c\u7535\u6c60\u7eed\u822a\u7b49\u7b49\u3002\u8fd9\u4e9b\u5c06\u6210\u4e3a\u5404\u5927 Android \u5e73\u677f\u5382\u5546\u672a\u6765\u4ea7\u54c1\u7684\u5e95\u7ebf\uff0c\u81f3\u5c11\u662f\u52aa\u529b\u63a5\u8fd1\u7684\u76ee\u6807\u3002\u4e0d\u8fc7\u6beb\u65e0\u7591\u95ee\uff0c\u4ef7\u683c\u662f\u65e0\u6cd5\u505a\u5230\u5982\u6b64\u4f4e\u5ec9\u7684\uff0c\u8981\u77e5\u9053\u540c\u4e3a ASUS \u5e73\u677f\u7684  Transformer Prime \u5b9a\u4ef7\u662f 499 \u7f8e\u5143\u3002\r\n\r\nGoogle \u5e73\u677f\u8fd8\u5c06\u9762\u4e34\u6765\u81ea\u5e02\u573a\u63a8\u5e7f\u65b9\u9762\u7684\u538b\u529b\uff0c\u5230\u5e95\u662f\u5ef6\u7eed Nexus \u7cfb\u5217\u667a\u80fd\u624b\u673a\u7684\u8ba9 OEM \u5546\u201c\u4f60\u5403\u8089\u6211\u559d\u6c64\u201d\u7684\u7b56\u7565\uff0c\u8fd8\u662f\u5b8c\u5168\u81ea\u5df1\u6765\u625b\uff1f\u5c06\u662f Google \u601d\u8003\u7684\u4e00\u4e2a\u91cd\u8981\u95ee\u9898\u3002\u6211\u4eec\u77e5\u9053\uff0cGoogle \u5f53\u521d\u63a8\u5e7f Nexus One \u7684\u65f6\u5019\uff0c\u610f\u56fe\u6446\u8131\u8fd0\u8425\u5546\u7684\u9650\u5236\uff0c\u5b8c\u5168\u8d70\u7f51\u7edc\u6e20\u9053\u6765\u9500\u552e\uff0c\u4f46\u8fd9\u4e00\u7b56\u7565\u5728\u8fd0\u8425\u5546\u5f3a\u52bf\u7684\u7f8e\u56fd\u5e02\u573a\u663e\u7136\u662f\u5931\u8d25\u7684\u3002\u6b64\u4e00\u65f6\u5f7c\u4e00\u65f6\uff0c\u5e73\u677f\u5e02\u573a\u7684\u63a8\u5e7f\u73af\u5883\u6ca1\u6709\u667a\u80fd\u624b\u673a\u90a3\u4e48\u88ab\u52a8\uff0c\u56e0\u4e3a\u5e73\u677f\u7535\u8111\u4e3b\u8981\u8d70 Wi-Fi \u6570\u636e\u6d41\u91cf\uff0c\u53d7\u8fd0\u8425\u5546\u7684\u63a7\u5236\u6bd4\u8f83\u5f31\uff0c\u4e8b\u5b9e\u4e0a\u4ece\u8fd0\u8425\u5546\u90a3\u91cc\u7b7e\u7ea6\u4e70 iPad \u7684\u4eba\u51e0\u4e4e\u662f\u6ca1\u6709\u7684\uff1b\u7f8e\u56fd\u8fd0\u8425\u5546\u6b64\u524d\u5bf9 Android \u5e73\u677f\u7684\u63a7\u5236\u4e5f\u6bd4\u8f83\u5f31\u3002\r\n\r\n\u4ee3\u5de5\u8fd8\u662f\u4eb2\u81ea\u4e0a\u9635\uff1f\r\n\r\n\u90a3\u4e48\u73b0\u5728\u5b58\u7684\u7591\u95ee\u662f Google \u51c6\u5907\u81ea\u5df1\u6765\u6253\u5e73\u677f\u7535\u8111\u5e02\u573a\u8fd9\u573a\u786c\u4ed7\u5417\uff1f\u7b54\u6848\u57fa\u672c\u4e0a\u662f\u80af\u5b9a\u7684\u3002\u534e\u7855\u4ee3\u5de5\u7684\u5e73\u677f\u5c06\u53ef\u80fd\u53ea\u662f\u4e00\u4e2a\u8fc7\u6e21\u671f\uff0c\u5728\u6295\u77f3\u95ee\u8def\u4e4b\u540e\uff0c\u6469\u6258\u7f57\u62c9\u5c06\u4f1a\u662f Google \u5e73\u677f\u7684\u4e3b\u529b\u519b\u3002\r\n\r\n\u4e54\u5e03\u65af\u53d1\u660e\u4e86\u201c\u540e PC \u65f6\u4ee3\u201d\u4e00\u8bcd\uff0c\u4e8b\u5b9e\u4e0a\u6211\u4eec\u5df2\u7ecf\u8fdb\u5165\u4e86\u8fd9\u4e2a\u65f6\u4ee3\uff1b\u4ece\u6765\u4e0d\u505a\u786c\u4ef6\u7684\u5fae\u8f6f\u4e5f\u5f00\u59cb\u81ea\u5df1\u7ed9\u81ea\u5df1\u505a OEM\uff0c\u73b0\u5728 Google \u4e5f\u8fdb\u5165\u4e86\u8fd9\u4e2a\u9886\u57df\u3002\u5e73\u677f\u7edd\u5bf9\u662f\u4e00\u4e2a\u6218\u7565\u6027\u8981\u5730\uff0cGoogle \u5728\u81ea\u5df1\u80fd\u505a\u7684\u60c5\u51b5\u4e0b\uff08\u6469\u6258\u7f57\u62c9\uff09\uff0c\u4f55\u987b\u66f4\u591a\u53d7\u5236\u4e8e\u4eba\uff1f\u4e0d\u8fc7\u4fdd\u6301 Android \u7cfb\u7edf\u7684\u5f00\u653e\u6027\u5c06\u4f1a\u662f Google \u4e00\u8d2f\u7684\u57fa\u8c03\uff0c\u5176\u4ed6\u751f\u4ea7\u5546\u613f\u610f\u6765\u505a Android \u5e73\u677f\uff0c\u4f7f\u7528 Android OS \u662f\u6ca1\u6709\u95ee\u9898\u7684\u2014\u2014\u95ee\u9898\u6765\u81ea\u4e8e\u6210\u672c\u63a7\u5236\u3002\r\n\r\n\u4ece\u5916\u90e8\u73af\u5883\u6765\u770b\uff0c\u7559\u7ed9 Google \u7684\u65f6\u95f4\u5e76\u4e0d\u591a\u3002IDC \u516c\u5e03\u7684\u6570\u636e\u663e\u793a\uff0c\u4eca\u5e74\u4e00\u5b63\u5ea6 iPad \u5728\u5168\u7403\u5e73\u677f\u7535\u8111\u5e02\u573a\u7684\u4efd\u989d\u6b62\u8dcc\u53cd\u5347\uff0c\u4ece\u53bb\u5e74\u56db\u5b63\u5ea6\u7684 57% \u4e0a\u5347\u5230 68%\uff0ciPad \u7684\u7ade\u4e89\u5bf9\u624b\u663e\u73b0\u75b2\u6001\u3002\u800c Gartner \u7684\u62a5\u544a\u663e\u793a\u5230 2016 \u5e74 iPad \u7684\u5e02\u573a\u4efd\u989d\u5c06\u4e0b\u964d\u81f3 46%\uff1b\u4eca\u5e74\u91cd\u65b0\u8d77\u6b65\u7684\u5fae\u8f6f\u5e73\u677f\u7535\u8111\u5c06\u4ece\u96f6\u589e\u52a0\u957f 12%\u2014\u2014\u8fd9\u4e00\u6570\u636e\u8fd8\u662f\u5728\u5fae\u8f6f\u6ca1\u6709\u53d1\u5e03 Surface \u4e4b\u524d\u9884\u6d4b\u7684\uff0c\u5982\u679c\u8ba1\u5165\u9884\u8ba1\u5e74\u5e95\u5f00\u552e Surface \u5e73\u677f\uff0c\u5fae\u8f6f\u7684\u4efd\u989d\u5c06\u518d\u4e00\u6b65\u589e\u5927\u3002\u90a3\u4e48 Google \u5176\u5b9e\u5df2\u7ecf\u9762\u4e34\u4e86\u6765\u81ea\u82f9\u679c\u548c\u5fae\u8f6f\u5171\u540c\u7684\u538b\u529b\u3002IDC \u9884\u6d4b\u4eca\u5e74\u5e73\u677f\u7535\u8111\u51fa\u8d27\u91cf\u5c06\u8fbe\u5230 1.061 \u4ebf\u53f0\uff0c2016 \u5e74\u589e\u957f\u5230 1.982 \u4ebf\u53f0\uff0c\u5982\u679c Google \u4e0d\u4eb2\u81ea\u4e0a\u9635\uff0c\u5f62\u52bf\u4e0d\u5bb9\u4e50\u89c2\u3002\r\n\r\n\u5f53\u7136\uff0c\u5de7\u5999\u7684\u662f\uff0cGoogle \u6240\u4e13\u6ce8\u7684\u9886\u57df\u2014\u20147 \u5bf8\u5e73\u677f\u2014\u2014\u662f iPad \u548c\u5fae\u8f6f\uff08Surface \u662f 10.6 \u5bf8\uff09\u6240\u7f3a\u4f4d\u7684\u9886\u57df\uff0cGoogle \u7ecf\u8425\u597d\u8fd9\u4e00\u9635\u5730\uff0c\u540c\u6837\u4e5f\u5c06\u5f62\u6210\u81ea\u5df1\u7684\u95e8\u69db\uff08\u54c1\u724c\u3001\u4ef7\u683c\u3001\u7528\u6237\u4f53\u9a8c\u7b49\uff09\u3002\u6211\u53ea\u662f\u5e0c\u671b\uff0c\u4f4e\u5ec9\u7684 Nexus \u5e73\u677f\u4e0d\u8981\u50cf Kindle Fire \u7684\u4f53\u9a8c\u90a3\u6837\u7cdf\u7cd5\u3002", "imagename": "36d2e957e49e4a1798c6ff32bbad6271.png", "infoid": 755879, "category": "technology_google", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["google", "\u8c37\u6b4c", "\u8c37\u6b4c\u5e73\u677f", "google\u5e73\u677f"]}, {"url": "http://tech.sina.com.cn/it/2012-06-28/01577319615.shtml", "title": "\u8c37\u6b4c\u53d1\u5e03Nexus Q\u64ad\u653e\u5668 \u552e\u4ef7299\u7f8e\u5143", "tags": "Nexus Q\u64ad\u653e\u5668 google ", "name": "geekzhang", "posttime": "2012-06-28 09:20:57", "ip": "219.141.211.201", "mark": 0, "note": "\u8c37\u6b4c(\u5fae\u535a)2012\u5e74I/O\u5f00\u53d1\u8005\u5927\u4f1a\u4eca\u5929\u5f00\u5e55\uff0c\u8c37\u6b4c\u5728\u5927\u4f1a\u4e0a\u53d1\u5e03\u4e86\u4e00\u6b3e\u540d\u4e3a\u201cNexus Q\u201d\u7684\u5706\u7403\u72b6\u6d41\u5a92\u4f53\u64ad\u653e\u5668\uff0c\u552e\u4ef7299\u7f8e\u5143\uff0c7\u6708\u4efd\u5f00\u552e\u3002\r\n\r\n\u3000\u3000\u636e\u8c37\u6b4c\u5e94\u7528\u5546\u5e97Google Play\u4e0a\u7684\u4ecb\u7ecd\uff0cN