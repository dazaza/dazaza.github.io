u8d77\u60a8\u5c1d\u8bd5\u7684\u5174\u8da3\uff1f:P\r\n\r\n\u4e00\u3001\u6709\u9053\u97f3\u4e50\u641c\u7d22\u2014\u2014\u80fd\u201c\u62a2\u9c9c\u542c\u201d\u7684\u5728\u7ebf\u97f3\u4e50\u641c\u7d22\r\n\r\n\r\n\r\n\u7247\u6bb5\u9884\u542c\uff1a\u542c\u4e00\u4e0b\uff0c\u5c31\u77e5\u9053\u662f\u6211\u60f3\u8981\u7684\uff01\r\n\u9996\u5148\u8981\u9686\u91cd\u4ecb\u7ecd\u7684\u662f\u6709\u9053\u72ec\u6709\u7684\u201c\u7247\u6bb5\u9884\u542c\u201d\u529f\u80fd\uff0c\u5728\u641c\u7d22\u7ed3\u679c\u9875\u9762\u4e0a\u70b9\u51fb\u67d0\u4e00\u9996\u6b4c\u66f2\u540d\u65c1\u540e\u9762\u7684\u5c0f\u5587\u53ed\uff0c\u5c31\u53ef\u4ee5\u7acb\u523b\u64ad\u653e\u51fa\u8fd9\u9996\u6b4c\u7684\u7247\u6bb5\u3002\u4f7f\u7528\u201c\u7247\u6bb5\u9884\u542c\u201d\u5c31\u4eff\u4f5b\u60a8\u5728CD\u5e97\u7528\u4e13\u4e1a\u8bbe\u5907\u5feb\u901f\u7ffb\u627e\u4f60\u559c\u6b22\u7684\u6b4c\uff0c\u8fd9\u53ef\u6bd4\u5e38\u89c1\u7684\u201c\u8bd5\u542c\u201d\u529f\u80fd\u66f4\u5feb\u6377\u54e6\uff0c\u53ef\u4ee5\u8bf4\u662f\u65e0\u9700\u7b49\u5f85\u3001\u4e00\u6309\u5c31\u5531\uff01\r\n\r\n\u600e\u4e48\u6837\uff0c\u8fd9\u4e2a\u65b0\u529f\u80fd\u662f\u4e0d\u662f\u633a\u7279\u522b\u7684\uff1f\u5982\u679c\u60a8\u4e86\u89e3\u6709\u9053\u7f51\u9875\u641c\u7d22\u7684\u4e13\u5229\u529f\u80fd\u201c\u7f51\u9875\u9884\u89c8\u201d\uff0c\u662f\u5426\u4f1a\u89c9\u5f97\u6709\u4e9b\u76f8\u901a\u4e4b\u5904\u5462\uff1f\u201c\u66f4\u5feb\u4e00\u79d2\u201d\u7684\u627f\u8bfa\u8d2f\u7a7f\u4e8e\u6709\u9053\u7684\u5404\u9879\u4ea7\u54c1\u4e2d\uff0c\u5728\u6709\u9053\u97f3\u4e50\u641c\u7d22\u4e2d\u589e\u52a0\u4e86\u72ec\u7279\u7684\u201c\u7247\u6bb5\u9884\u542c\u201d\uff0c\u60a8\u53ef\u4ee5\u201c\u542c\u4e00\u4e0b\uff0c\u5c31\u77e5\u9053\u662f\u6211\u60f3\u8981\u7684\uff01\u201d\r\n\r\n\u4e8c\u3001\u6709\u9053\u97f3\u4e50\u76d2\u2014\u2014\u65b9\u4fbf\u597d\u7528\u7684\u201c\u5728\u7ebf\u97f3\u4e50\u968f\u8eab\u542c\u201d\r\n\r\n\r\n\r\n1. \u5185\u5d4c\u641c\u7d22\uff1a\u8fb9\u542c\u8fb9\u641c\uff0c\u4e00\u952e\u6536\u85cf\r\n\u6709\u65f6\u5019\u4e3a\u4e86\u67e5\u627e\u591a\u9996\u6b4c\u66f2\u5e76\u9010\u4e2a\u8bd5\u542c\uff0c\u9700\u8981\u5728\u641c\u7d22\u7ed3\u679c\u9875\u9762\u548c\u591a\u4e2a\u8bd5\u542c\u7a97\u53e3\u4e4b\u95f4\u8df3\u6765\u8df3\u53bb\u3002\u5728\u6709\u9053\u97f3\u4e50\u76d2\u91cc\uff0c\u6211\u4eec\u901a\u8fc7\u201c\u5185\u5d4c\u641c\u7d22\u201d\u529f\u80fd\u8ba9\u8fd9\u4e2a\u64cd\u4f5c\u53d8\u5f97\u66f4\u4e3a\u5bb9\u6613\u3002\u60a8\u53ef\u4ee5\u76f4\u63a5\u5728\u97f3\u4e50\u76d2\u91cc\u8fdb\u884c\u65b0\u7684\u641c\u7d22\uff0c\u800c\u8fd9\u5e76\u4e0d\u4f1a\u6253\u65ad\u60a8\u6b63\u5728\u542c\u7684\u6b4c\u66f2\uff1b\u6b64\u5916\uff0c\u5bf9\u4e8e\u641c\u7d22\u7ed3\u679c\u4e2d\u7684\u6b4c\u66f2\u53ea\u9700\u8981\u70b9\u51fb\u4e00\u6b21\uff0c\u5c31\u53ef\u4ee5\u201c\u52a0\u5165\u8bd5\u542c\u201d\u6216\u8005\u201c\u6536\u85cf\u5230\u201d\u60a8\u81ea\u5df1\u7684\u5217\u8868\u4e2d\u3002\u9700\u8981\u63d0\u9192\u7684\u662f\uff0c\u5982\u679c\u60a8\u5e0c\u671b\u4fdd\u5b58\u81ea\u5df1\u7684\u6536\u85cf\u5217\u8868\uff0c\u9700\u8981\u5148\u4f7f\u7528163\u901a\u884c\u8bc1\u767b\u9646\u6709\u9053\u97f3\u4e50\u76d2\u540e\u624d\u53ef\u4ee5\u4fdd\u5b58\u5728\u81ea\u5df1\u7684\u540d\u4e0b\u54e6\u3002\r\n\r\n2. \u667a\u80fd\u63a8\u8350\uff1a\u731c\u4f60\u559c\u6b22\uff0c\u5fc3\u6709\u7075\u7280\r\n\u9762\u5bf9\u4f17\u591a\u6b4c\u66f2\uff0c\u6211\u4eec\u5e38\u5e38\u5e0c\u671b\u542c\u4e00\u4e9b\u65b0\u9c9c\u4f46\u53c8\u7b26\u5408\u81ea\u5df1\u4e00\u8d2f\u559c\u597d\u7684\u6b4c\u66f2\u3002\u5c31\u50cf\u60a8\u5728\u7f51\u4e0a\u4e66\u5e97\u4e70\u4e66\u65f6\u4f1a\u53d1\u73b0\u4e0b\u9762\u6709\u4e00\u884c\u63a8\u8350\u4e66\u5355\uff0c\u6709\u9053\u97f3\u4e50\u76d2\u901a\u8fc7\u6570\u636e\u6316\u6398\u7b49\u6280\u672f\uff0c\u7edf\u8ba1\u5206\u6790\u6d77\u91cf\u7528\u6237\u542c\u6b4c\u6536\u85cf\u7684\u4e00\u822c\u559c\u597d\uff0c\u5c31\u53ef\u4ee5\u9488\u5bf9\u6bcf\u9996\u6b4c\u66f2\u731c\u6d4b\u51fa\u60a8\u53ef\u80fd\u4e5f\u4f1a\u559c\u6b22\u7684\u6b4c\u66f2\u3002\u4ee5\u4e0a\u9762\u7684\u793a