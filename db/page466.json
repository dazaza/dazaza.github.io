a\uff0c\u5979\u4eec\u5f80\u5f80\u4f1a\u53d8\u5f97\u50cf\u6bcd\u4eb2\u4e00\u6837\u6f02\u4eae\u5e76\u5c06\u7f8e\u4e3d\u7ee7\u7eed\u4f20\u7ed9\u4e0b\u4e00\u4ee3\u3002  \r\n\r\n\u3000\u3000\u7f8e\u5973\u751f\u80b2\u5c0f\u5b69\u66f4\u591a\r\n\r\n\u3000\u3000\u6839\u636e\u4e00\u7cfb\u5217\u4f53\u683c\u5438\u5f15\u529b\u53ca\u751f\u6b96\u8fdb\u5316\u76f8\u5173\u7814\u7a76\uff0c\u5728\u4eba\u7c7b\u7e41\u884d\u7684\u8fc7\u7a0b\u4e2d\uff0c\u6240\u8c13\u201c\u7f8e\u4e3d\u79cd\u65cf\u201d\u80fd\u4e00\u76f4\u5ef6\u7eed\u4e0b\u53bb\u3002\r\n\r\n\u3000\u3000\u82ac\u5170\u8d6b\u5c14\u8f9b\u57fa\u5927\u5b66\u7684\u7814\u7a76\u8005\u4e0a\u5468\u53d1\u5e03\u62a5\u544a\uff0c\u5c06\u8fd9\u4e00\u7814\u7a76\u5177\u4f53\u5316\u3002\r\n\r\n\u3000\u3000\u4e3b\u6301\u7814\u7a76\u7684\u9a6c\u5e93\u65af&#183\uff1b\u7ea6\u514b\u62c9\u79f0\uff0c\u7814\u7a76\u5c0f\u7ec4\u5bf9\u7f8e\u56fd1244\u540d\u5973\u6027\u548c997\u540d\u7537\u6027\u7684\u6709\u5173\u6570\u636e\u8fdb\u884c\u4e8640\u5e74\u7684\u8ddf\u8e2a\u8c03\u67e5\u3002\u8fd9\u4e9b\u7814\u7a76\u5bf9\u8c61\u7684\u5916\u8c8c\u6c34\u5e73\u6839\u636e\u7167\u7247\u8fdb\u884c\u8bc4\u5b9a\uff0c\u540c\u65f6\uff0c\u7814\u7a76\u4eba\u5458\u8fd8\u5bf9\u4ed6\u4eec\u7684\u5b69\u5b50\u6570\u91cf\u8fdb\u884c\u4e86\u91c7\u96c6\u3002\u7ed3\u679c\u663e\u793a\uff0c\u5916\u8c8c\u6f02\u4eae\u7684\u5973\u6027\u751f\u80b2\u7684\u5b69\u5b50\u6570\u91cf\u6bd4\u5176\u4ed6\u5973\u6027\u5e73\u5747\u591a16\uff05\u3002\r\n\r\n\u3000\u3000\u7236\u6bcd\u597d\u770b \u6613\u751f\u5973\u5a74\r\n\r\n\u3000\u3000\u8fd9\u6b21\u516c\u5e03\u7684\u7814\u7a76\u6210\u679c\u5efa\u7acb\u5728\u6b64\u524d\u4f26\u6566\u7ecf\u6d4e\u5b66\u9662\u8fdb\u5316\u5fc3\u7406\u5b66\u5bb6\u91d1\u6cfd\u667a\u6240\u505a\u7684\u7814\u7a76\u57fa\u7840\u4e4b\u4e0a\u3002\u91d1\u6cfd\u667a\u8bf4\uff0c\u5916\u8c8c\u597d\u770b\u7684\u7236\u6bcd\u5f80\u5f80\u66f4\u5bb9\u6613\u751f\u4e0b\u5973\u5a74\uff0c\u8fd9\u662f\u201c\u8fdb\u5316\u7b56\u7565\u201d\u5728\u4eba\u7c7b\u57fa\u56e0\u91cc\u7684\u7cbe\u5fc3\u8bbe