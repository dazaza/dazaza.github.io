u5730\u65b9\u65b9\u8a00\u4e2d\u5c31\u662f\u201c\u5e26\u52b2\u513f\u201d\u201c\u725b\u201d\u201c\u9177\u201d\u7684\u610f\u601d\uff1b\u7528\u4f5c\u52a8\u8bcd\uff0c\u6307\u201c\u7ed9\u4ee5\u529b\u91cf\u201d\u201c\u52a0\u6cb9\u201d\u3002\u201c\u7ed9\u529b\u201d\u4e00\u8bcd\u56e0\u767b\u4e0a\u300a\u4eba\u6c11\u65e5\u62a5\u300b\u5934\u7248\u5934\u6761\u800c\u767b\u5cf0\u9020\u6781\u3002\r\n\r\n\u897f\u6bd5\u751f \u8fd9\u662f\u7f51\u53cb\u9488\u5bf9\u5510\u9a8f\u5b66\u4f4d\u95e8\u7cfb\u5217\u4e8b\u4ef6\u521b\u9020\u51fa\u6765\u7684\u6d41\u884c\u8bed\uff0c\u6cdb\u6307\u6765\u81ea\u7f8e\u56fd\u897f\u592a\u5e73\u6d0b\u5927\u5b66\u5e76\u5728\u540d\u4f01\u62c5\u4efb\u8981\u804c\u7684\u4e2d\u56fd\u6bd5\u4e1a\u751f\uff0c\u4ee5\u53ca\u90a3\u4e9b\u8d2d\u4e70\u6d77\u5916\u201c\u91ce\u9e21\u5927\u5b66\u201d\u5b66\u5386\u7684\u4eba\u58eb\u3002\r\n\r\n\u8db3\u56da\u534f\u4f1a \u539f\u4e2d\u56fd\u8db3\u534f\u526f\u4e3b\u5e2d\u3001\u8db3\u7ba1\u4e2d\u5fc3\u4e3b\u4efb\u8c22\u4e9a\u9f99,\u539f\u4e2d\u56fd\u8db3\u534f\u88c1\u5224\u59d4\u5458\u4f1a\u4e3b\u4efb\u674e\u51ac\u751f,\u539f\u56fd\u5bb6\u8db3\u7403\u961f\u9886\u961f\u851a \r\n\u5c11\u8f89\u88ab\u7acb\u6848\u4fa6\u67e5\uff0c\u81f3\u6b64\uff0c\u4e2d\u56fd\u8db3\u534f\u5df2\u7ecf\u67099\u4eba\u5728\u201c\u53cd\u8d4c\u626b\u9ed1\u201d\u4e2d\u843d\u9a6c\u3002\r\n\r\n\u6da8\u65f6\u4ee3 2010\u5e74\u7269\u4ef7\u75af\u6da8\u3002\u76f8\u4fe1\u5728\u56fd\u5bb6\u7269\u4ef7\u8c03\u63a7\u7ec4\u5408\u62f3\u7684\u5f3a\u52bf\u5e72\u9884\u4e0b\uff0c\u201c\u6da8\u65f6\u4ee3\u201d\u4f1a\u7ec8\u7ed3\u3002\r\n\r\n\u545c\u545c\u7956\u62c9 \u8fd9\u662f\u5357\u975e\u4e16\u754c\u676f\u4e0a\u7403\u8ff7\u7684\u52a9\u5a01\u5de5\u5177\uff0c\u53ef\u4ee5\u53d1\u51fa\u6781\u9ad8\u5206\u8d1d\u7684\u566a\u58f0\uff0c\u636e\u8bf4\u4f1a\u5bfc\u81f4\u6c38\u4e45\u6027\u542c\u89c9\u4e27\u5931\u3002\u8981\u6c42\u7981\u6b62\u201c\u545c\u545c\u7956\u62c9\u201d\u8fdb\u573a\u7684\u547c\u58f0\u4e0d\u7edd\u4e8e\u8033\uff0c\u4e0d\u8fc7\u5357\u975e\u7403\u8ff7\u62d2\u7edd\u505c\u6