53d1\u88687\u82f1\u5bf8\u53ca10\u82f1\u5bf8\uff0c\u91c7\u7528Android\u5e73\u53f0\u7684\u5e73\u677f\u7535\u8111\uff0c\u8fd1\u65e5\u5219\u63a8\u51fa\u5e73\u677f\u7535\u8111\u7684\u5e7f\u544a\u5f71\u7247\uff0c\u5e76\u9884\u544a\u5c06\u4e8e2011\u5e74\u7684CES\u5c55\u4e0a\uff0c\u5c55\u51fa\u642d\u8f7dAndroid\u7684\u8702\u7a9d\u7248\u672c\u3002\u8fd9\u4e5f\u662f\u7ee7\u4e09\u661f\u63a8\u51faGalaxy Tab\u540e\uff0c\u518d\u6709\u624b\u673a\u5382\u5546\u8de8\u8db3\u5e73\u677f\u7535\u8111\u5e02\u573a\u3002\r\n\r\n \u5728\u5e7f\u544a\u5f71\u7247\u4e2d\uff0c\u5e76\u6ca1\u6709\u5927\u529b\u63a8\u5e7f\u5373\u5c06\u95ee\u5e02\u7684\u5e73\u677f\u7535\u8111\uff0c\u6574\u6bb5\u5f71\u7247\u662f\u4ee5\u5e73\u677f\u7684\u6f14\u5316\u4e3a\u4e3b\u8f74\uff0c\u5c31\u50cf\u53c2\u89c2\u535a\u7269\u9986\u4e00\u6837\uff0c\u5206\u522b\u5c55\u793a\u6bcf\u4e00\u4e2a\u9636\u6bb5\u7684\u5e73\u677f\uff0c\u5e76\u7ed9\u4e88\u6279\u6ce8\uff0c\u6700\u5f00\u59cb\u65f6\u662f\u8b6c\u8c15\u57c3\u53ca\u7684\u8c61\u5f62\u6587\u5b57\uff0c\u5177\u6709\u6f02\u4eae\u7684\u56fe\u7247\u5374\u4e0d\u6613\u643a\u5e26\uff1b\u4e4b\u540e\u9646\u7eed\u5c55\u51fa\u51e0\u6b3e\u5206\u8fa8\u7387\u4e0d\u9ad8\uff0c\u652f\u6301\u591a\u79cd\u8bed\u8a00\u7684\u5e73\u677f\uff0c\u751a\u81f3\u5728\u5f71\u7247\u4e2d\u8fd8\u53ef\u4ee5\u770b\u5230\u9884\u8a002012\u5e74\u5730\u7403\u6bc1\u706d\u7684\u739b\u96c5\u77f3\u677f\u3002\r\n\r\n \u5f53\u7136\uff0c\u5f71\u7247\u4e5f\u4e0d\u4e4f\u82f9\u679c\u7684iPad\uff0c\u4ee5\u53caSamsung\u7684Galaxy Tab\uff0c\u4f46MOTO\u5bf9iPad\u7684\u6279\u6ce8\u662f\u5927\u578b\u7684iPhone\uff0cGalaxy Tab\u5219\u662f\u4ee5\u624b\u673a\u6982\u5ff5\u6253\u9020\u7684Android\u5e73\u53f0\uff0c\u81f3\u4e8e\u5373\u5c06\u8981\u5c55\u51fa\u7684MOTO\u5e73\u677f\u7535\u8111\uff0c\u5219\u4ee5\u5e03\u5e55\u76d6\u7740\uff0c\u5728\u663e\u773c\u7684\u7ea2\u5e95\u767d\u5b57\u6807\u5fd7\u9644\u8fd1\uff0c\u5219\u6709\u871c\u8702\u51fa\u6ca1\u3002\u8fd9\u9690\u55bbMOTO\u5373\u5c06\u63a8\u51fa\u7684\u5e73\u677f\u7535\u8111\uff0c\u662f\u91c7\u7528Android\u7684\u8702\u7a9d\u7248\u672c\uff0c\u800c\u6b64\u7248\u672cAndroid\u4e0e\u73b0\u5728\u624b\u673a\u4f7f\u7528\u7684\u7248\u672c\u4e0d\u540c\uff0c\u662f\u4ee5\u5e73\u677f\u7535\u8111\u7684\u64cd\u4f5c\u6982\u5ff5\u6240\u8bbe\u8ba1\uff0c\u4e14\u9884\u8ba1\u4f1a\u5728\u660e\u5e74\u53d1\u5e03\u3002", "imagename": "dcb846a71fe740fd8ad02d8d22dcf97e.jpg", "infoid": 375706, "category": "technology_gadgets", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u5e73\u677f", "android", "\u6469\u6258\u7f57\u62c9", "motorola"]}, {"url": "http://fzwb.ynet.com/article.jsp?oid=75702627", "title": "\u6cd5\u56fd\u4e00\u5c0f\u6751\u5e84\u79f0\u4e3a2012\u5e74\u201c\u5730\u7403\u672b\u65e5\u201d\u6765\u4e34\u65f6\u552f\u4e00\u7684\u5e78\u5b58\u5730", "tags": "2012\u5e74 \u5730\u7403\u672b\u65e5 ", "name": "geekzhang", "posttime": "2010-12-24 22:03:19", "ip": "222.221.77.60", "mark": 0, "note": "\u636e\u82f1\u56fd\u300a\u6bcf\u65e5\u7535\u8baf\u62a5\u300b\u65e5\u524d\u62a5\u9053\uff0c\u6cd5\u56fd\u4e00\u5c0f\u6751\u5e84\u8fd1\u6765\u88ab\u4f20\u4e3a2012\u5e74\u201c\u5730\u7403\u672b\u65e5\u201d\u6765\u4e34\u65f6\u552f\u4e00\u7684\u5e78\u5b58\u5730\uff0c\u5f15\u6765\u6570\u4ee5\u4e07\u8ba1\u7684\u201c\u672b\u65e5\u8bba\u8005\u201d\u75af\u72c2\u6d8c\u5165\u3002\r\n\r\n\u62a5\u9053\u8bf4\uff0c\u8fd9\u4e2a\u540d\u4e3a\u201c\u5e03\u52a0\u62c9\u4ec0\u201d\uff08Bugarach\uff09\u7684\u5c0f\u6751\u5e84\u4f4d\u4e8e\u6cd5\u56fd\u897f\u5357\u90e8\uff0c\u6751\u5b50\u91cc\u53ea\u4f4f\u7740189\u4eba\uff0c\u6751\u6c11\u4eec\u751f\u6d3b\u60a0\u95f2\u800c\u5b89\u9759\uff0c\u72b9\u5982\u5904\u4e8e\u4e16\u5916\u6843\u6e90\u3002\u4f46\u8fd1\u6765\uff0c\u7a81\u7136\u6709\u5927\u6279\u795e\u795e\u53e8\u53e8\u7684\u4eba\u8702\u62e5\u5165\u6751\uff0c\u8bf4\u8fd9\u91cc\u662f2012\u5e74\u201c\u4e16\u754c\u706d\u4ea1\u540e\u5730\u7403\u4e0a\u552f\u4e00\u80fd\u5e78\u5b58\u4e4b\u5730\u201d\u3002\r\n\r\n\u8fd9\u4e9b\u5ba3\u79f0\u6765\u907f\u96be\u7684\u4eba\u4eec\u8bf4\uff0c\u5e03\u52a0\u62c9\u4ec0\u5c0f\u6751\u5750\u843d\u5728\u6cd5\u56fd\u8457\u540d\u8461\u8404\u9152\u4ea7\u533a\u8003\u5c14\u6bd4\u5c71\u8109\u6700\u9ad8\u5cf0\u5339\u514b\u8fea\u5e03\u52a0\u62c9\u4ec0\u5c71\u5c71\u811a\uff0c\u800c\u5339\u514b\u8fea\u5e03\u52a0\u62c9\u4ec0\u5c71\u9876\u5c31\u662f\u5916\u661f\u4eba\u5728\u5730\u7403\u7684\u201c\u6839\u636e\u5730\u201d\u3002\u56e0\u4e3a\u5b83\u7684\u5c71\u5cf0\u4e2d\u95f4\u662f\u4e2d\u7a7a\u7684\uff0c\u5916\u661f\u4eba\u5c31\u6f5c\u85cf\u5728\u5176\u4e2d\uff0c\u9759\u5019\u201c\u5730\u7403\u706d\u4ea1\u7684\u90a3\u4e00\u523b\uff0c\u518d\u542f\u7a0b\u56de\u5230\u81ea\u5df1\u7684\u661f\u7403\u201d\u3002\r\n\r\n\u201c\u5230\u65f6\u5019\uff0c\u8bf4\u4e0d\u5b9a\u53ef\u4ee5\u634e\u4e0a\u5468\u8fb9\u7684\u4e00\u4e9b\u4eba\u7c7b\u8eb2\u8fc7\u5927\u52ab\u5462\uff01\u201d\u201c\u672b\u65e5\u8bba\u8005\u201d\u90fd\u6709\u8fd9\u4e48\u4e00\u5957\u8bf4\u8f9e\u3002\r\n\r\n\u6751\u957f\u8bf7\u653f\u5e9c\u6d3e\u519b\u961f\u7ef4\u6301\u79e9\u5e8f\r\n\r\n\u8fd9\u4e0a\u4e07\u7684\u4eba\u7fa4\u548c\u795e\u53e8\u53e8\u7684\u8bf4\u8f9e\u7740\u5b9e\u5413\u574f\u4e86\u6751\u6c11\uff0c\u767d\u53d1\u82cd\u82cd\u7684\u8001\u6751\u957f\u8fea\u6d1b\u5fb7\u5fe7\u5fc3\u5fe1\u5fe1\uff0c\u53ea\u597d\u5411\u4e0a\u7ea7\u653f\u5e9c\u6c42\u52a9\uff0c\u5e0c\u671b\u52302012\u5e7412\u6708\uff0c\u653f\u5e9c\u80fd\u6d3e\u519b\u961f\u524d\u6765\u7ef4\u6301\u79e9\u5e8f\u3002\r\n\r\n\u6751\u957f\u8fea\u6d1b\u5fb7\u8bf4\uff0c\u4ed6\u8fd1\u6765\u628a\u8fd9\u4e00\u751f\u5947\u602a\u7684\u4e8b\u60c5\u90fd\u7ecf\u5386\u4e86\uff0c\u201c\u8bb8\u591a\u4eba\u8dd1\u5230\u5c71\u4e0a\u7948\u7977\u3002\u6211\u6709\u4e00\u6b21\u8fd8\u770b\u89c1\u4e00\u4e2a\u4eba\u8d64\u8eab\u88f8\u4f53\u5730\u4e0d\u77e5\u9053\u5728\u8fdb\u884c\u4ec0\u4e48\u4eea\u5f0f\u3002\u201d\r\n\r\n\u8fd9\u4e9b\u53e4\u602a\u7684\u5c0f\u4e8b\u90fd\u4e0d\u662f\u6751\u957f\u6700\u62c5\u5fc3\u7684\uff0c\u4ed6\u6700\u62c5\u5fc3\u7684\u662f\u6751\u5b50\u91cc\u7684\u623f\u4ef7\u8ddf\u7740\u6c34\u6da8\u8239\u9ad8\uff0c\u751a\u81f3\u90bb\u6751\u4e5f\u53d7\u5230\u4e86\u5f71\u54cd\u3002\u5f88\u591a\u75f4\u8ff7\u5916\u661f\u4eba\u7814\u7a76\u7684\u4eba\u58eb\u5728\u8fd9\u513f\u4e70\u623f\u7f6e\u5730\uff0c\u5f53\u5730\u4eba\u62b1\u6028\u623f\u4ef7\u88ab\u8fc7\u5ea6\u62ac\u9ad8\u3002\r\n\r\n\u8fd8\u6709\u4eba\u5728\u5468\u8fb9\u5f00\u8bfe\uff0c\u6559\u6388\u4e0e\u5916\u661f\u4eba\u5fc3\u7075\u6c9f\u901a\u4e4b\u7c7b\u7684\u53e4\u602a\u8bfe\u7a0b\uff0c\u4e00\u5468\u8bfe\u65f6\u7684\u4ef7\u683c\u5c45\u7136\u9ad8\u8fbe800\u6b27\u5143\uff08\u7ea6\u54086963\u5143\u4eba\u6c11\u5e01\uff09\u3002\r\n\r\n\u4f20\u6709\u98de\u789f\u5760\u6bc1\u7f8e\u5c0f\u9547\r\n\r\n\u300a\u6bcf\u65e5\u7535\u8baf\u62a5\u300b\u62a5\u9053\u6307\u51fa\uff0c\u56e0\u5916\u661f\u4eba\u8d70\u7ea2\u7684\u5c0f\u5730\u65b9\u5e76\u975e\u53ea\u6709\u6cd5\u56fd\u5e03\u52a0\u62c9\u4ec0\u6751\u5e84\uff0c\u6700\u5178\u578b\u7684\u83ab\u8fc7\u4e8e\u7f8e\u56fd\u65b0\u58a8\u897f\u54e5\u5dde\u5c0f\u57ce\u7f57\u65af\u5a01\u5c14\u3002\r\n\r\n\u4f20\u95fb\u8be5\u57301947\u5e747\u6708\u53d1\u751f\u4e86\u5916\u661f\u4eba\u98de\u789f\u5760\u6bc1\u4e8b\u4ef6\uff0c\u6b64\u540e\u7f57\u65af\u5a01\u5c14\u5c31\u6210\u4e3a\u5168\u7403\u4e0d\u660e\u98de\u884c\u7269\u7231\u597d\u8005\u5fc3\u76ee\u4e2d\u7684\u201c\u5723\u5730\u201d\u3002\r\n\r\n\u5f53\u5730\u8d81\u673a\u5f00\u53d1\u65c5\u6e38\u4e1a\uff0c\u751f\u610f\u505a\u5f97\u98ce\u751f\u6c34\u8d77\uff0c\u4f46\u5916\u661f\u4eba\u4e00\u4e8b\u5374\u518d\u65e0\u4e0b\u6587\u3002", "imagename": "5df3c82874c54938b2c9604c17165cd6.jpg", "infoid": 375701, "category": "culture_other", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "culture", "via": null, "real_tags": ["2012\u5e74", "\u5730\u7403\u672b\u65e5"]}, {"url": "http://ie.microsoft.com/testdrive/Info/MissingBrowserFeature/Default.html?message=Your%20browser%20doesn%27t%20support%20XHTML%20documents.&url=http://ie.microsoft.com/testdrive/performance/SantasWorkshop/", "title": "\u5fae\u8f6f\u4e5f