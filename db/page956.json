3b7\u53d6\u6728\u9a6c\u75c5\u6bd2\u6837\u672c\uff0c\u5bf9\u5176\u5206\u6790\u540e\u81ea\u52a8\u67e5\u6740\uff0c\u5728\u6700\u77ed\u65f6\u95f4\u5185\u5e2e\u52a9\u5361\u5361\u7528\u6237\u6e05\u9664\u76d7\u53f7\u6728\u9a6c\u75c5\u6bd2\u3002\u5728\u6700\u5927\u8d1f\u8f7d\u80fd\u529b\u4e0b\uff0c\u8be5\u7cfb\u7edf\u6bcf\u5929\u53ef\u81ea\u52a8\u5904\u74063-5\u4e07\u4e2a\u6728\u9a6c\u75c5\u6bd2\u6837\u672c\uff0c\u5c06\u4ece\u6839\u672c\u4e0a\u89e3\u51b3\u76ee\u524d\u6728\u9a6c\u75c5\u6bd2\u5448\u51e0\u4f55\u7ea7\u6570\u66b4\u589e\u7684\u884c\u4e1a\u96be\u9898\u3002\r\n\r\n\u745e\u661f\u53d1\u5e03\u76842007\u5e74\u5b89\u5168\u62a5\u544a\u6307\u51fa\uff0c\u7531\u4e8e\u75c5\u6bd2\u5236\u9020\u8005\u96c6\u56e2\u5316\u3001\u81ea\u52a8\u5316\u5730\u6279\u91cf\u5236\u9020\u76d7\u53f7\u6728\u9a6c\u75c5\u6bd2\uff0c\u5b89\u5168\u884c\u4e1a\u6b63\u9762\u4e34\u524d\u6240\u672a\u6709\u7684\u6311\u6218\uff0c\u6bcf\u5e74\u65b0\u75c5\u6bd2\u7684\u6570\u91cf\u5df2\u7ecf\u4ece2004\u5e74\u76846\u4e07\u4e2a\u4e0a\u5347\u5230\u53bb\u5e74\u768491\u4e07\u4e2a\uff0c\u800c2008\u5e74\u5219\u9884\u8ba1\u4f1a\u67092\u3001300\u4e07\u4e2a\u65b0\u7684\u76d7\u53f7\u6728\u9a6c\u51fa\u73b0\u3002\u745e\u661f\u5b89\u5168\u4e13\u5bb6\u6307\u51fa\uff0c\u4f20\u7edf\u7684\u201c\u622a\u83b7-\u5206\u6790-\u5347\u7ea7\u201d\u53cd\u75c5\u6bd2\u6a21\u5f0f\uff0c\u5b8c\u5168\u65e0\u6cd5\u5e94\u5bf9\u5982\u6b64\u6d77\u91cf\u7684\u6728\u9a6c\u75c5\u6bd2\u3002\r\n\r\n\u745e\u661f\u65b0\u5efa\u6210\u7684\u201c\u75c5\u6bd2\u81ea\u52a8\u5206\u6790\u7cfb\u7edf\u201d\uff0c\u5b89\u88c5\u4e86\u745e\u661f\u5361\u5361\u52a9\u624b\u4e4b\u540e\uff0c\u65e0\u9700\u7528\u6237\u8fdb\u884c\u4efb\u4f55\u64cd\u4f5c\uff0c\u5176\u8fdb\u5165\u201c\u75c5\u6bd2\u81ea\u52a8\u5206\u6790\u7cfb\u7edf\u201d\u8fdb\u884c\u5904\u7406\uff0c\u5e76\u5c06\u7ed3\u679c\u77ac\u65f6\u53cd\u9988\u7ed9\u7528\u6237\uff0c\u745e\u661f\u5361\u5361\u5373\u53ef\u6e05\u9664\u6389\u5927\u90e8\u5206\u76d7\u53f7\u6728\u9a6c\u75c5\u6bd2\uff0c\u800c\u76f8\u5e94\u7684\u5206\u6790\u7ed3\u679c\u4e5f\u5c06\u540c\u65f6\u63d0\u4f9b\u7ed9\u745e\u661f\u6740\u6bd2\u8f6f\u4ef6\u3002\r\n\r\n\u745e\u661f\u526f\u603b\u88c1\u6bdb\u4e00\u4e01\u8868\u793a\uff0c\u8fd9\u662f\u4e00\u6b21\u884c\u4e1a\u6a21\u5f0f\u5de8\u5927\u7684\u6539\u53d8\uff0c\u4ee5\u5f80\u7684\u75c5\u6bd2\u622a\u83b7\u548c\u5206\u6790\uff0c\u90fd\u4f9d\u8d56\u6740\u6bd2\u5382\u5546\u624b\u5de5\u8fdb\u884c\u3002\u6b64\u6b21\u75c5\u6bd2\u81ea\u52a8\u5206\u6790\u7cfb\u7edf\u7684\u5efa\u6210\uff0c\u5c06\u4f7f\u6570\u5343\u4e07\u745e\u661f\u5361\u5361\u7528\u6237\u53c2\u4e0e\u5230\u67e5\u6740\u6728\u9a6c\u7684\u6597\u4e89\u4e2d\u6765\uff0c\u8fd9\u6bb5\u514d\u8d39\u7684\u5b89\u5168\u5de5\u5177\u5c06\u6210\u4e3a\u5e7f\u5927\u7528\u6237\u67e5\u6740\u6728\u9a6c\u7684\u5229\u5668\u3002 \u53e4\u4e30", "imagename": "", "infoid": 55486, "category": "technology_internet", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u75c5\u6bd2"]}, {"url": "http://down.360safe.com/setupbeta.exe", "title": "\u5947\u864e360\u5b89\u5168\u536b\u58ebV4.1 Beta2", "tags": "360\u5b89\u5168\u536b\u58eb ", "name": "yinyin", "posttime": "2008-03-20 16:48:32", "ip": "218.94.91.239", "mark": 2, "note": "360 \u5b89\u5168\u536b\u58eb\u662f\u56fd\u5185\u6700\u5927\u7684\u514d\u8d39\u5b89\u5168\u8f6f\u4ef6\uff0c\u5b83\u62e5\u6709\u67e5\u6740\u6d41\u884c\u6728\u9a6c\u3001\u6e05\u7406\u6076\u8bc4\u53ca\u7cfb\u7edf\u63d2\u4ef6\uff0c\u7ba1\u7406\u5e94\u7528\u8f6f\u4ef6\uff0c\u5361\u5df4\u65af\u57fa\u6740\u6bd2\uff0c\u7cfb\u7edf\u5b9e\u65f6\u4fdd\u62a4\uff0c\u4fee\u590d\u7cfb\u7edf\u6f0f\u6d1e\u7b49\u6570\u4e2a\u5f3a\u52b2\u529f\u80fd\uff0c \u540c\u65f6\u8fd8\u63d0\u4f9b\u7cfb\u7edf\u5168\u9762\u8bca\u65ad\uff0c\u5f39\u51fa\u63d2\u4ef6\u514d\u75ab\uff0c\u6e05\u7406\u4f7f\u7528\u75d5\u8ff9\u4ee5\u53ca\u7cfb\u7edf\u8fd8\u539f\u7b49\u7279\u5b9a\u8f85\u52a9\u529f\u80fd\uff0c\u5e76\u4e14\u63d0\u4f9b\u5bf9\u7cfb\u7edf\u7684\u5168\u9762\u8bca\u65ad\u62a5\u544a\uff0c\u65b9\u4fbf\u7528\u6237\u53ca\u65f6\u5b9a\u4f4d\u95ee\u9898\u6240\u5728\uff0c\u771f\u6b63\u4e3a\u6bcf\u4e00 \u4f4d\u7528\u6237\u63d0\u4f9b\u5168\u65b9\u4f4d\u7cfb\u7edf\u5b89\u5168\u4fdd\u62a4\u3002\r\n360\u5b89\u5168\u536b\u58ebV4.1Beta2\u7248\u6b63\u5f0f\u53d1\u5e03\uff0c\u65b0\u589e\u81ea\u6211\u4fdd\u62a4\u529f\u80fd\u3002\r\n\r\n\r\n360\u5b89\u5168\u536b\u58ebV4.1Beta2\u7248\u53ea\u67094.6M\u5de6\u53f3\uff0c\u9002\u5408\u5feb\u901f\u5b89\u88c5\u3002\uff08\u4f7f\u7528\u5361\u5df4\u65af\u57fa\u6740\u6bd2\u529f\u80fd\u65f6\uff0c\u9700\u8981\u624b\u5de5\u4e0b\u8f7d\u5361\u5df4\u65af\u57fa\u6740\u6bd2\u8f6f\u4ef6\u3002\uff09\r\n\r\n\u8f6f\u4ef6\u7b80\u4ecb\uff1a\r\n\r\n\r\n\r\n4.1Beta2\u7248\u65b0\u589e\u529f\u80fd\uff1a\r\n\r\n1. \u65b0\u589e\u81ea\u6211\u4fdd\u62a4\u529f\u80fd\uff0c\u963b\u6b62\u6728\u9a6c\u3001\u75c5\u6bd2\u6076\u610f\u7834\u574f\r\n\r\n\u963b\u6b62\u6728\u9a6c\u3001\u75c5\u6bd2\u5bf9360\u5b89\u5168\u536b\u58eb\u7684\u6076\u610f\u653b\u51fb\u548c\u7834\u574f\uff0c\u4fdd\u62a4\u7cfb\u7edf\u66f4\u5b89\u5168 \r\n\r\n2. \u7b2c\u4e09\u65b9\u8f6f\u4ef6\u6f0f\u6d1e\u4e00\u952e\u641e\u5b9a\uff0c\u4fee\u590d\u65b9\u5f0f\u66f4\u667a\u80fd\r\n\r\n\u4fee\u590d\u65b9\u5f0f\u66f4\u52a0\u667a\u80fd\uff0c\u65e0\u9700\u5230\u7f51\u9875\u4e0b\u8f7d\uff0c360\u5b89\u5168\u536b\u58eb\u4e00\u952e\u641e\u5b9a\u3002\r\n\r\n3. \u7f51\u9875\u9632\u6f0f\u589e\u52a0\u514d\u6253\u6270\u8bbe\u7f6e\uff0c\u4fe1\u4efb\u7a0b\u5e8f\u4e0d\u518d\u63d0\u9192\r\n\r\n\u7528\u6237\u53ef\u5c06\u5df2\u77e5\u7a0b\u5e8f\u6dfb\u52a0\u81f3\u7f51\u9875\u9632\u6f0f\u767d\u540d\u5355\uff0c\u6700\u5927\u7a0b\u5ea6\u51cf\u5c11\u6253\u6270\u3002\r\n\r\n4. \u65b0\u589e\u7cfb\u7edf\u6f0f\u6d1e\u201c\u5ffd\u7565\u201d\u529f\u80fd\uff0c\u4e2a\u6027\u5316\u9009\u62e9\u66f4\u8d34\u5fc3\r\n\r\n\u5982\u679c\u5b58\u5728\u4e0d\u60f3\u4fee\u590d\u7684\u7cfb\u7edf\u6f0f\u6d1e\uff0c\u60a8\u53ef\u4ee5\u9009\u62e9\u201c\u5ffd\u7565\u201d\uff0c\u4e2a\u6027\u5316\u9009\u62e9\u6ee1\u8db3\u4e0d\u540c\u9700\u8981\u3002\r\n\r\n5. 