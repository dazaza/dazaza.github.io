[{"url": "http://www.atxiu.com", "title": "\u5f71\u50cf\u79c0atxiu", "tags": "", "name": "imbowen", "posttime": "2010-09-19 22:08:23", "ip": "121.52.211.73", "mark": 0, "note": "\u4e0a\u6d77\u7684\u4e00\u4e2a\u5f88\u5b9e\u5728\u7684\u5f71\u50cf\u7f51\u7ad9\uff0c\u91cc\u9762\u6709\u5f88\u591a\u4e0d\u9519\u7684\u5f71\u50cf\u4f5c\u54c1\uff0c\u503c\u5f97\u501f\u9274\u53c2\u8003", "imagename": "", "infoid": 365175, "category": "culture_photograph", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "culture", "via": null, "real_tags": null}, {"url": "http://tech.qq.com/a/20100919/000238.htm", "title": "\u4f20Facebook\u6b63\u5728\u7814\u53d1\u624b\u673a\u548c\u81ea\u4e3b\u64cd\u4f5c\u7cfb\u7edf_\u79d1\u6280_\u817e\u8baf\u7f51", "tags": "web2.0 facebook ", "name": "geekzhang", "posttime": "2010-09-19 18:37:04", "ip": "117.40.196.173", "mark": 0, "note": "\u5317\u4eac\u65f6\u95f49\u670819\u65e5\u6d88\u606f\uff0c\u636e\u7f8e\u56fd\u8457\u540d\u535a\u5ba2\u7f51\u7ad9TechCrunch\u62a5\u9053\uff0c\u76ee\u524dFacebook\u5f88\u53ef\u80fd\u6b63\u5728\u5f00\u53d1\u4e00\u6b3e\u624b\u673a\uff0c\u5e76\u4e14\u8fd0\u884c\u7684\u662f\u81ea\u5df1\u7684\u624b\u673a\u64cd\u4f5c\u7cfb\u7edf\u3002\r\n\r\n\u6709\u6d88\u606f\u79f0\uff0c\u8fd9\u662f\u7ee7Facebook\u63a8\u51fa\u624b\u673a\u5e94\u7528\u7a0b\u5e8f\u4e4b\u540e\u53c8\u4e00\u91cd\u5927\u7684\u9879\u76ee\uff0c\u4ece\u800c\u4f7f\u5f97\u8be5\u516c\u53f8\u80fd\u591f\u5b8c\u5168\u63a7\u5236\u7f51\u7ad9\u66f4\u65b0\u4e0e\u624b\u673a\u7684\u540c\u6b65\u3002\u8be5\u6d88\u606f\u542c\u8d77\u6765\u4f3c\u4e4e\u6709\u4e9b\u7a81\u7136\uff0c\u8fd9\u548c\u53bb\u5e74\u66fe\u4f20\u51fa\u8c37\u6b4c\u5c06\u5f00\u53d1\u624b\u673a\u5982\u51fa\u4e00\u8f99\uff0c\u4e0d\u8fc7\u8c37\u6b4c\u540e\u6765\u7684\u786e\u63a8\u51fa\u4e86\u81ea\u5df1\u7684\u667a\u80fd\u624b\u673aNexus One\u3002\u8be5\u77e5\u60c5\u4eba\u58eb\u79f0\uff0cFacebook\u5df2\u7ecf\u610f\u8bc6\u5230iPhone\u548cAndroid\u5e73\u53f0\u7ed9\u5b83\u5e26\u6765\u7684\u5de8\u5927\u538b\u529b\u3002\r\n\r\n\u53e6\u4e00\u65b9\u9762\uff0cFacebook\u5f88\u6709\u53ef\u80fd\u7814\u53d1\u81ea\u5df1\u7684\u64cd\u4f5c\u7cfb\u7edf\uff0c\u7136\u540e\u518d\u8ba9\u7b2c\u4e09\u65b9\u7684\u624b\u673a\u5382\u5546\u8fdb\u884c\u751f\u6210\u3002\u8fd9\u5e76\u4e0d\u662f\u4ec0\u4e48\u65b0\u9c9c\u4e8b\u7269\uff0c\u56e0\u4e3a\u82f9\u679c\u548c\u8c37\u6b4c\u65e9\u5c31\u8fd9\u4e48\u505a\u4e86\u3002\u8be5\u77e5\u60c5\u4eba\u58eb\u8868\u793a\uff0cFacebook\u624b\u673a\u9879\u76ee\u7531\u4e54\u4f11\u4f0a\u7279(Joe Hewitt)\u548c\u9a6c\u4fee\u5e15\u5e15\u5947\u6cfc\u65af(Matthew Papakipos)\u8d1f\u8d23\u3002\u76ee\u524d\uff0c\u8be5\u9879\u76ee\u5904\u5728\u4fdd\u5bc6\u9636\u6bb5\uff0c\u751a\u81f3\u672c\u516c\u53f8\u5927\u90e8\u5206\u7684\u5458\u5de5\u90fd\u4e0d\u77e5\u60c5\u3002\r\n\r\n\u4f11\u4f0a\u7279\u6b64\u524d\u66fe\u53c2\u4e0e\u8fc7Firefox\u6d4f\u89c8\u5668\u7684\u5f00\u53d1\uff0c\u8fd8\u66fe\u5728Parakey\u516c\u53f8\u4efb\u804c\uff0c\u8be5\u516c\u53f8\u57282007\u5e74\u88abFacebook\u6536\u8d2d\u3002Facebook\u5728iPhone\u4e0a\u5168\u90e8\u7684Web\u5e94\u7528\u5747\u7531\u4f11\u4f0a\u7279\u5f00\u53d1\uff0c\u6240\u4ee5\u4ed6\u5bf9\u64cd\u4f5c\u7cfb\u7edf\u548c\u624b\u673a\u5747\u975e\u5e38\u719f\u6089\u3002\u800c\u5e15\u5e15\u5947\u6cfc\u65af\u540c\u6837\u62e5\u6709\u6df1\u539a\u7684\u624b\u673a\u884c\u4e1a\u80cc\u666f\uff0c\u4ed6\u66fe\u8d1f\u8d23\u8fc7\u8c37\u6b4cChrome\u64cd\u4f5c\u7cfb\u7edf\u7684\u5f00\u53d1\uff0c\u5e76\u4e8e\u4eca\u5e746\u6708\u8df3\u69fd\u52a0\u76df\u4e86Facebook\u3002\u5e15\u5e15\u5947\u6cfc\u65af\u539f\u672c\u5728\u8c37\u6b4c\u6709\u5f88\u5927\u7684\u53d1\u5c55\u6f5c\u529b\uff0c\u4e4b\u6240\u4ee5\u8df3\u69fd\u5230Facebook\uff0c\u5f88\u53ef\u80fdFacebook\u80fd\u8ba9\u4ed6\u53c2\u4e0e\u5230\u81ea\u5df1\u771f\u6b63\u611f\u5174\u8da3\u7684\u9879\u76ee\uff0c\u6bd4\u5982\u8bf4\u624b\u673a\u3002\r\n\r\n\u81f3\u4e8e\u8fd9\u6b3e\u624b\u673a\u7684\u5916\u89c2\u4ee5\u53ca\u4e0a\u5e02\u65f6\u95f4\uff0c\u76ee\u524d\u90fd\u8fd8\u6ca1\u6709\u4ec0\u4e48\u6d88\u606f\u3002\u4