[{"url": "http://www.vikilife.com/2011/07/12/eggshell-carving.html", "title": "\u7cbe\u7f8e\u7684\u86cb\u96d5-\u5fae\u5947\u751f\u6d3b", "tags": "", "name": "vikilife", "posttime": "2011-07-13 13:50:00", "ip": "114.222.40.238", "mark": 0, "note": "\u8001\u5b9e\u8bf4\u8fd9\u4e2a\u5e76\u4e0d\u662f\u4ec0\u4e48\u7a00\u5947\u73a9\u610f\uff0c\u4f46\u5c0f\u5f1f\u8fd8\u662f\u88ab\u8fd9\u7cbe\u6e5b\u7684\u6280\u827a\u6298\u670d\u4e86\uff0c\u5b83\u4eec\u51fa\u81ea\u827a\u672f\u5bb6Brian Baity\u4e4b\u624b\uff0c\u8bdd\u8bf4\u6211\u4eec\u672c\u571f\u7684\u86cb\u96d5\u5f3a\u4eba\u5e94\u8be5\u4e5f\u4e0d\u5728\u5c11\u6570\u5427\u3002", "imagename": "50c74ecfca924ab7947ff2f443d2edcf.jpg", "infoid": 461950, "category": "culture_art", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "culture", "via": null, "real_tags": null}, {"url": "http://fotomen.cn/2011/07/spain/", "title": "\u79df\u4e2a\u9633\u53f0 \u770b\u5954\u725b! | \u6444\u5f71\u4e4b\u53cb", "tags": "\u6444\u5f71 \u65c5\u6e38 \u52a8\u7269 \u98ce\u5149 ", "name": "fotomen", "posttime": "2011-07-13 13:40:38", "ip": "218.249.83.129", "mark": 0, "note": "\u6bcf\u5e74\u56e0\u5954\u725b\u8282\u800c\u6765\u5230\u6f58\u666e\u6d1b\u7eb3\u7684\u6e38\u5ba2\u8d85\u8fc7150\u4e07\u4eba\uff0c\u4eba\u867d\u591a\u4f46\u62cd\u7167\u7684\u597d\u4f4d\u7f6e\u5374\u76f8\u5f53\u5c11\uff0c\u56e0\u4e3a\u5954\u725b\u8def\u7ebf\u4e24\u65c1\u4f1a\u67b6\u8d77\u4e24\u5c42\u6728\u680f\uff0c\u53ea\u6709\u8bb0\u8005\u624d\u80fd\u5230\u524d\u6392\u7684\u4f4d\u7f6e\u62cd\u7167\u3002\u6240\u4ee5\u5927\u8857\u4e24\u65c1\u7684\u79c1\u4eba\u9633\u53f0\uff0c\u4fbf\u6210\u4e86\u5954\u725b\u8282\u62cd\u7167\u7684\u201c\u98ce\u6c34\u5b9d\u5730\u201d\u3002\u6bcf\u5e74\u5954\u725b\u8282\uff0c\u5f53\u5730\u5c45\u6c11\u90fd\u4f1a\u51fa\u79df\u9633\u53f0\u3002\u4e00\u4e2a\u9633\u53f0\u5206\u62104\u4e2a\u4f4d\u79df\uff0c\u6bcf\u4e2a\u4f4d\u5b50\u653630\u523075\u6b27\u5143\u3002", "imagename": "b54294e9db804937a252d347a2406eb1.jpg", "infoid": 461944, "category": "life_travel", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "life", "via": null, "real_tags": ["\u6444\u5f71", "\u65c5\u6e38", "\u52a8\u7269", "\u98ce\u5149"]}, {"url": "http://jdxi.net/post/sheng-huo-gou-xue.html", "title": "\u751f\u6d3b\u5c31\u662f\u5982\u6b64\u7684\u72d7\u8840\u5267", "tags": "\u751f\u6d3b \u72d7\u8840 \u96f7\u4eba \u7b11\u8bdd ", "name": "wangweimei", "posttime": "2011-07-13 11:54:23", "ip": "113.95.11.55", "mark": 0, "note": "\u5c0f\u65f6\u5019\uff0c\u6709\u56de\u8fc7\u751f\u65e5\uff0c\u9a91\u5355\u8f66\u8f7d\u7740\u5f1f\u5f1f\u51fa\u53bb\u6e38\u73a9\u3002\u5f88\u4e0d\u5e78\uff0c\u649e\u4e0a\u6469\u6258\u8f66\uff0c\u8f7b\u4f24\u3002\u8f66\u574f\u4e86\uff0c\u6015\u5bb6\u4eba\u9a82\uff0c\u638f\u51fa\u4e24\u4eba\u8eab\u4e0a\u6240\u6709\u8d22\u4ea7\u4fee\u597d\u4e86\u3002\u7ed3\u679c\u5230\u4e86\u5bb6\u91cc\u59b9\u59b9\u9012\u6765\u4e00\u5f20\u660e\u4fe1\u7247\uff0c\u4e0a\u9762\u5199\u7740\uff1a\u54e5\u54e5\u751f\u65e5\u5feb\u4e50\uff0c\u795d\u4f60\u5e74\u5e74\u6709\u4eca\u65e5\u5c81\u5c81\u6709\u4eca\u671d\u3002\u6211\u548c\u5f1f\u5f1f\u76f8\u89c6\u8bb8\u4e45\u5fcd\u7740\u4f24\u75db\u9ed8\u9ed8\u5730\u8d70\u5f00\u4e86\u3002\r\n\u9694\u58c1\u6709\u4e2a\u7537\u7684\uff0c\u6700\u8fd1\u8ff7\u4e0a\u4e86GM\u6b4c\u66f2\uff0c\u4ec0\u4e48\u300a\u6ca1\u6709GCD\u5c31\u6ca1\u6709\u65b0\u4e2d\u56fd\u300b\u300a\u793e\u4f1a\u4e3b\u4e49\u597d\u300b\u300a\u6211\u6709\u7231\u5317\u4eactian~an-door\u300b\uff0c\u8bf8\u5982\u6b64\u7c7b\uff0c\u6ca1\u4e8b\u5c31\u5728\u90a3\u5e72\u568e\u3002\r\n\u6211\u4e0d\u80dc\u5176\u70e6\uff0c\u7ec8\u4e8e\u6572\u95e8\u8fdb\u5165\uff1a\u54e5\u4eec\u4f60\u548b\u8001\u5531\u8fd9\u4e9b\u6b4c\uff0c\u5531\u4e9b\u6d41\u884c\u6b4c\u66f2\u4e0d\u884c\u5417\uff1f\r\n\u90a3\u54e5\u4eec\u8bf4\uff1a\u4f60\u4e0d\u77e5\u9053\u554a\uff1f\u73b0\u5728\u91cd\u5e86\u9881\u5e03\u65b0\u653f\u7b56\uff0c\u56da\u72af\u5531\u7ea2\u6b4c\u53ef\u4ee5\u51cf\u5211\u554a\u3002\r\n\u6211\u4e0d\u4ee5\u4e3a\u7136\u5730\u8bf4\uff1a\u90a3\u4f60\u53c8\u4e0d\u662f\u56da\u72af\u3002\r\n\u90a3\u54e5\u4eec\u8d70\u51fa\u5c4b\u6765\u770b\u4e86\u4e00\u4e0b\u6211\u7684\u623f\u95e8\uff0c\u7136\u540e\u7b11\u7b11\u8bf4\uff1a\u5f88\u5feb\u5c31\u662f\u4e86\u3002\r\n\u5973\u540c\u5b66A\u5ac1\u4eba\uff0c\u56e0\u4e3a\u5173\u7cfb\u5f88\u94c1\uff0c\u6211(\u6211\u662f\u7537\u7684\uff09\u4e00\u5927\u65e9\u5c31\u8d76\u5230\u5979\u5bb6\r\n\u65b0\u5a18\u5b50\u6b63\u5728\u5367\u5ba4\u6362\u5a5a\u7eb1\uff0c\u6211\u968f\u624b\u628a\u73a9\u51e0\u4e0a\u4e00\u76d2\u6e05\u51c9\u6cb9\uff0c\u7136\u540e\u8bef\u5165\u773c\u4e2d\r\n\u6211\u8fde\u5fd9\u8981\u53bb\u536b\u751f\u95f4\u6d17\u6d17\uff0cA\u5979\u5988\u5988\u770b\u5230\uff0c\u51b2\u4e0a\u6765\u4e00\u4e2a\u718a\u62b1\uff0c\u53f7\u5555\u5927\u54ed\uff0c\u8fb9\u54ed\u8fb9\u8bf4\uff1a\u963f\u59e8\u61c2\u4f60\u7684\u5fc3\u60c5\uff0c\u963f\u59e8\u4e5f\u559c\u6b22\u4f60\uff0c\u53ef\u662f\u5c0fA\u5979\u60f3\u4e0d\u901a\u554a\r\n\u6211\u773c\u6cea\u54d7\u54d7\u5730\r\n\u8eab\u7a7f\u5a5a\u7eb1\u7684A\u51fa\u73b0\u5728\u5367\u5ba4\u95e8\u53e3\uff0c\u5e7d\u6028\u5730\u8bf4\uff1a\u4e3a\u4ec0\u4e48\u4e0d\u65e9\u70b9\u544a\u8bc9\u6211\r\n\u6211\u5185\u725b\u6ee1\u9762\r\nA\u7684\u7238\u7238\u770b\u5230\uff0c\u8fde\u5fd9\u8bf4\uff1a\u611f\u60c5\u6ef4\u4e8b\u60c5\u4e0d\u597d\u8bf4\u6ef4\u5c0fA\u8fd8\u6709\u4e2a\u8868\u59b9\r\n\u751f\u6d3b\u5c31\u50cf\u72d7\u8840\u5267\r\n\u4e0a\u4e2a\u6708\uff0c\u5355\u4f4d\u6709\u4e2a\u540c\u4e8b\u56e0\u4e3a\u8f66\u7978\u53bb\u4e16\u4e86\uff0c\u539f\u5148\u5355\u4f4d\u7ed9\u4ed6\u914d\u7684\u7535\u8111\u5c31\u7ed9\u4e86\u6211\u7528\u3002\r\n\u6628\u5929\u665a\u4e0a\uff0c\u6211\u5728\u516c\u53f8\u52a0\u73ed\uff0c\u7535\u8111\u53d1\u751f\u4e86\u6545\u969c\uff0c\u7ed9\u8d1f\u8d23\u6280\u672f\u7684\u540c\u4e8b\u6253\u7535\u8bdd\u6c42\u52a9\u3002\u90a3\u4e2a\u540c\u4e8b\u8bf4\u5e72\u8106\u7528QQ\u7ed9\u6211\u8fdc\u7a0b\u63a7\u5236\u4e00\u4e0b\u3002\r\n\u90a3\u4f1a\u513f\u6211\u4e0d\u7528\u63d2\u624b\uff0c\u5c31\u8d77\u6765\u53bb\u5916\u9762\u63a5\u6c34\u4e86\u3002\r\n\u6211\u7684\u9886\u5bfc\u7ecf\u8fc7\u529e\u516c\u5ba4\uff08\u6211\u540e\u6765\u624d\u77e5\u9053\u5f53\u65f6\u4ed6\u4e5f\u6ca1\u8d70\uff09\uff0c\u770b\u5230\u6211\u7684\u7535\u8111\u5c4f\u5e55\u4e0a\uff0c\u9f20\u6807\u6307\u9488\u98a4\u98a4\u5dcd\u5dcd\u5730\u81ea\u5df1\u4e0d\u65ad\u6253\u5f00\u4e00\u4e2a\u53c8\u4e00\u4e2a\u6587\u4ef6\u5939\uff0c\u7acb\u9a6c\u4ea7\u751f\u4e86\u90a3\u4e2a\u901d\u53bb\u7684\u540c\u4e8b\u53c8\u56de\u6765\u7684\u9519\u89c9\uff0c\u7b49\u6211\u56de\u5230\u529e\u516c\u5ba4\uff0c\u770b\u5230\u9886\u5bfc\u7684\u624b\u90fd\u662f\u98a4\u6296\u7684\uff0c\u8138\u8272\u715e\u767d\u3002\r\n\u4eca\u5929\u9886\u5bfc\u75c5\u4e86\uff0c\u4e00\u5929\u90fd\u6ca1\u6765\uff0c\u6211\u8fd8\u5728\u7ea0\u7ed3\u8be5\u4e0d\u8be5\u544a\u8bc9\u4ed6\u771f\u76f8\uff0c\r\n\u4e00\u4f4d\u8457\u540d\u7684\u5fc3\u810f\u624b\u672f\u533b\u751f\u7684\u6469\u6258\u8f66\u574f\u4e86\uff0c\u9001\u5230\u4fee\u7406\u90e8\u7ecf\u8fc7\u68c0\u67e5\u662f\u5f15\u64ce\u574f\u4e86\uff0c\u4fee\u7406\u5de5\u719f\u7ec3\u7684\u628a\u5f15\u64ce\u62c6\u4e0b\u6765\u4fee\u597d\u53c8\u88c5\u4e0a\uff0c\u5bf9\u533b\u751f\u8bf4\uff1a\u5f15\u64ce\u5c31\u662f\u6469\u6258\u8f66\u7684\u5fc3\u810f\uff0c\u6211\u4eec\u90fd\u662f\u4fee\u7406\u5fc3\u810f\u7684\uff0c\u53ef\u662f\u6536\u5165\u7684\u5dee\u8ddd\u4e3a\u4ec0\u4e48\u8fd9\u4e48\u5927\uff1f\u533b\u751f\u60f3\u4e86\u60f3\u5bf9\u4fee\u7406\u5de5\u8bf4\uff1a\u4f60\u8bd5\u8bd5\u5728\u5f15\u64ce\u8fd0\u8f6c\u7684\u60c5\u51b5\u4e0b\u4fee\u5b83\u3002\r\n\u592b\u59bb\u4fe9\u901b\u8857\uff0c\u78b0\u5230\u8001\u5a46\u7684\u524d\u7537\u53cb\uff0c\r\n\u8001\u516c\u95ee\uff1a\u8fd9\u662f\u8c01\u554a\uff1f\r\n\u8001\u5a46\u7b54\uff1a\u4e0b\u9762\u5355\u4f4d\u7684\u5148\u8fdb\u5de5\u4f5c\u8005\r\n\u5728\u4e00\u5c0f\u5403\u5e97\r\n\u590f\u5929\uff0c\u5f88\u70ed\r\n\u5dee\u4e0d\u591a\u670940\u5ea6\u5de6\u53f3\u5427\r\n\u4e00\u5973\u8bf4\uff1a\u8001\u677f\uff0c\u7ed9\u6211\u6765\u74f6\u996e\u6599\r\n\u8001\u677f\u8bf4\uff1a\u8981\u4e0d\u8981\u51c9\u7684\u5440\uff1f\r\n\u6b64\u5973\u975e\u5e38\u6c14\u5fff\u7684\u8bf4\uff1a\u4f60\u4e0d\u77e5\u9053\u5973\u4eba\u6709\u51e0\u5929\u4e0d\u8212\u670d\u5417\uff1f\uff01\r\n\u8001\u677f\u65e0\u8010\u7684\u9053\uff1a\u8c01\u77e5\u9053\u554a\uff0c\u4f60\u53c8\u6ca1\u628a\u536b\u751f\u5dfe\u8d34\u5728\u8138\u4e0a\u3002\r\n\u8bdd\u8bf4\u524d\u51e0\u5929\u54e5\u51e0\u4e2a\u4e2d\u5348\u4e0b\u73ed\u53bb\u4e2a\u6c34\u997a\u5e97\u5403\u997a\u5b50\uff0c\u70b9\u4e863\u79cd\u9985\u6c34\u997a\uff0c\u4e00\u6837\u534a\u65a4\u3002\u8fc7\u4e86\u4f1a\u670d\u52a1\u5458\u7aef\u4e86\u4e00\u76d8\u997a\u5b50\u4e0a\u6765\uff0c\u4e00\u54e5\u4eec\u95ee\u8fd9\u76d8\u662f\u4ec0\u4e48\u9985\u7684\uff0c\u53ea\u89c1\u670d\u52a1\u5458\u6de1\u5b9a\u7684\u62ff\u8d77\u7b77\u5b50\uff0c\u5403\u4e86\u4e00\u4e2a\r\n\u5929\u5802\u7684\u95e8\u574f\u4e86\uff0c\u62db\u6807\u91cd\u4fee\u3002\u5370\u5ea6\u4eba\uff1a\u53ea\u89813\u5343\u5757\u5c31\u5f04\u597d\uff0c\u7406\u7531\u662f\u6750\u6599\u8d391\u5343\uff0c\u4eba\u5de5\u8d39\u75281\u5343\uff0c\u6211\u81ea\u5df1\u8d5a1\u5343\uff1b\u53c8\u6765\u4e2a\u5fb7\u56fd\u4eba\uff0c\u5fb7\u56fd\u4f6c\uff1a\u89816\u5343\u5757\uff0c\u7406\u7531\u561b\uff0c\u6750\u6599\u8d392\u5343\uff0c\u4eba\u5de5\u8d392\u5343\uff0c\u81ea\u5df1\u8d5a2\u5343\uff1b\u6700\u540e\u8dd1\u6765\u4e00\u4e2a\u4e2d\u56fd\u4eba\uff0c\u4e2d\u56fd\u4eba\uff1a\u8fd9\u4e2a\u89819\u5343\u5757\uff0c3\u5343\u5757\u7ed9\u4f60\uff0c3\u5343\u5757\u6211\u7684\uff0c\u5269\u4e0b3\u5343\u7ed9\u90a3\u5370\u5ea6\u4eba\uff01\r\n\u5979\u4e0b\u73ed\u56de\u5bb6\uff0c\u4ed6\u5750\u5728\u6c99\u53d1\u4e0a\u3002\r\n\u9762\u65e0\u8868\u60c5\u5730\u62bd\u7740\u70df\uff0c\u7a81\u7136\u4ed6\u5f00\u53e3\u4e86\uff1a\u5582\uff0c\u6211\u8bf4\uff0c\u6211\u4eec\u50cf\u8fd9\u6837\u540c\u5c45\u4e24\u5e74\u4e86\uff0c\u4f60\u4e0d\u89c9\u5f97\u538c\u5026\u5417?\r\n\u5979\u505c\u4e0b\u4e86\u6b63\u6362\u7740\u62d6\u978b\u7684\u624b\uff0c\u8f6c\u8fc7\u8eab\u6123\u6123\u7684\u770b\u7740\u4ed6\uff1a\u4f60\u8bf4\uff0c\u4ec0\u4e48?\r\n\u4ed6\u8fd8\u662f\u4e00\u6837\u9762\u65e0\u8868\u60c5\uff1a\u6211\u8bf4\uff0c\u6211\u538c\u5026\u4e86\u3002\r\n\u5979\u7684\u773c\u6cea\u6d41\u4e86\u51fa\u6765\uff0c\u65e0\u52a9\u5730\u80cc\u8fc7\u8eab\u64e6\u62ed\u3002\r\n\u4e00\u4e2a\u6e29\u6696\u7684\u8eab\u4f53\u7a81\u7136\u62b1\u4f4f\u5979\uff1a\u4e0d\u5982\uff0c\u6211\u4eec\u7ed3\u5a5a\u597d\u5417?\r\n\u5904\u957f\u5bf9\u526f\u5904\u957f\u8bf4\uff1a\u54b1\u4eec\u5c40\u957f\u5c31\u662f\u4e2a\u540a\u3002\u6b63\u597d\u5c40\u957f\u63a8\u95e8\u8fdb\u6765\u542c\u89c1\u4e86\uff0c\u987f\u65f6\u5927\u6012\u8bf4\uff1a\u6211\u662f\u4e2a\u540a\uff0c\u4f60\u4eec\u662f\u4ec0\u4e48\uff1f\r\n\u5904\u957f\u8d76\u7d27\u8bf4\uff1a\u540a\u6bdb\uff0c\u540a\u6bdb\u3002\u7d27\u7d27\u56e2\u7ed3\u5728\u60a8\u5468\u56f4\u3002\r\n\u5341\u4e00\u957f\u5047\u56de\u6765\u7684\u5f53\u665a\uff0c\u67d0\u5973\u5728\u5176\u7537\u670b\u53cb\u5bbf\u820d\u7559\u5bbf\u3002\u7b2c\u4e8c\u5929\u6e05\u6668\uff0c\u6b64\u4e8c\u4eba\u88ab\u5bbf\u820d\u540c\u5b66\u7d27\u6025\u9001\u5f80\u6821\u533b\u9662\uff0c\u7ecf\u6821\u533b\u8be2\u95ee\u540e\uff0c\u8bca\u65ad\u75c5\u4f8b\u586b\u5199\u5982\u4e0b\uff1a\u5973\u5b69\u56e0\u8131\u6c34\u5bfc\u81f4\u660f\u53a5\uff0c\u7537\u751f\u56e0\u66b4\u996e\u66b4\u98df\u5bfc\u81f4\u6d88\u5316\u4e0d\u826f\uff01\r\n\u65e9\u4e0a\u5750\u516c\u4ea4\u78b0\u5230\u4e00\u4e2a\u6363\u86cb\u7684\u5c0f\u841d\u8389.\u5728\u4e00\u4e2a\u7ad9\u724c\uff0c\u4e0a\u6765\u4e00\u4e2a\u624b\u673a\u7535\u5b50\u4e66\u8ff7\u5934\u90fd\u4e0d\u62ac\uff0c\u521a\u4e0a\u8f66\u5934\u4e5f\u4e0d\u62ac\u51c6\u5907\u6295\u5e01\uff0c\u53ea\u89c1\u5c0f\u841d\u8389\u7528\u6807\u51c6\u7684\u666e\u901a\u8bdd\u8bf4\uff1a\u5c0a\u656c\u7684\u987e\u5ba2\u60a8\u597d\uff0c\u4e0a\u8f66\u8bf7\u60a8\u6295\u5e01\uff0c\u6295\u5e01\u540e\u8bf7\u60a8\u4e0b\u8f66\u3002\u53ea\u89c1\u624b\u673a\u54e5\u6295\u5b8c\u94b1\u540e\u8f6c\u8eab\u4e0b\u8f66\u8d70\u4e86......\u8f66\u4e2d\u53ea\u5269\u4e0b\u51cc\u4e71\u7684\u53f8\u673a\u8ddf\u4f17\u4eba...\r\n\u4eca\u5929pol.ice\u6293\u5230\u4e00\u4e2a\u5236\u4f5c\u6bd2\u98df\u54c1\u7684\u5c0f\u8d29\r\n\u95ee\uff1a\u4f60\u5b57\u90fd\u4e0d\u8ba4\u8bc6\uff0c\u5728\u54ea\u91cc\u5b66\u7684\u6bd2\u98df\u54c1\u7684\u5236\u4f5c\u65b9\u6cd5\uff1f\r\n\u7b54\uff1a\u56e0\u4e3a\u4ffa\u5173\u6ce8\u65b0\u95fb\r\n\u6012\uff1a\u597d\u597d\u56de\u7b54\uff0c\u8ddf\u65b0\u95fb\u6709\u4ec0\u4e48\u5173\u7cfb\r\n\u7b54\uff1a\u5236\u4f5c\u7528\u65b9\u5f0f\u548c\u8fc7\u7a0b\u90fd\u662f\u65b0\u95fb\u91cc\u6559\u7684\r\n\u4e09\u4e2a\u4eba\u88ab\u56f0\u5728\u5c71\u6d1e\u6700\u5148\u8981\u5e72\u5565\uff0c\u6211\u8bf4\u627e\u6c34\uff0c\u5979\u4e25\u8083\u7684\u544a\u8bc9\u6211\u6211\u9519\u4e86\uff0c\u9996\u5148\u5e94\u8be5\u6210\u7acbparty\u652f\u90e8\r\n\u661f\u671f\u5929\u628a\u53d8\u5f62\u91d1\u521a1\u30012\u91cd\u6e29\u4e86\u4e00\u904d\uff0c\u610f\u72b9\u672a\u5c3d\uff0c\u665a\u4e0a\u7761\u524d\u8d9f\u5e8a\u5934\u628a\u73a9599\u5927\u6d0b\u4e70\u6765\u7684\u7535\u5f71\u7248\u64ce\u5929\u67f1\u73a9\u5177\uff0c\u73a9\u4e86\u534a\u4e2a\u949f\u5934\u60f3\u7761\u4e86\uff0c\u5c31\u628a\u5b83\u653e\u5728\u5e8a\u8fb9\u5730\u4e0b\r\n\u661f\u671f\u4e00\u4e00\u65e9\u88ab\u9633\u5149\u523a\u9192\uff0c\u9760\uff01\u53cc\u4f11\u65e5\u5173\u6389\u7684\u95f9\u94c3\u5fd8\u8bb0\u8c03\u56de\u6765\uff0c\u7761\u8fc7\u5934\u4e86\uff01\u8d76\u7d27\u4e00\u4e2a\u8349\u9c7c\u6253\u633a\u8df3\u4e0b\u5e8a\u3002\u5494\uff01\u811a\u75bc\uff0c\u8e29\u64ce\u5929\u67f1\u4e0a\u4e86\uff0c\u5212\u51fa\u4e00\u6761\u53e3\u5b50\uff1b\u5fc3\u75bc\uff0c599\u5927\u6d0b\u8e29\u65ad\u4e86\uff01\u6765\u4e0d\u53ca\u9ed8\u54c0\uff0c\u7b80\u5355\u6b62\u8840\u5305\u624e\u4e00\u4e0b\u8d76\u7d27\u4e0a\u73ed\u53bb\r\n\u7d27\u8d76\u6162\u8d76\u8fd8\u662f\u8fdf\u5230\u4e86\uff0c\u867d\u8bf4\u54e5\u7684\u811a\u662f\u771f\u75bc\uff0c\u4f46\u4e3a\u4e86\u63a9\u76d6\u8fdf\u5230\u7684\u4e8b\u5b9e\u8fd8\u5f97\u518d\u88c5\u5f97\u5389\u5bb3\u70b9\u3002\u4e8e\u662f\u54e5\u9f87\u7740\u7259\uff0c\u54a7\u7740\u5634\uff0c\u4e00\u7638\u4e00\u62d0\u6276\u5899\u632a\u8fdb\u4e86\u529e\u516c\u5ba4\uff0c\u5927\u4f19\u90fd\u62ac\u5934\u770b\u7740\u54e5\uff0c\u679c\u7136\u6709\u4eba\u95ee\uff1a\u4eca\u5929\u600e\u4e48\u8fdf\u4e86\uff1f\u54e5\u75db\u82e6\u5730\u4ece\u7259\u7f1d\u91cc\u6324\u51fa\u4e00\u53e5\uff1a\u6211\u7684\u64ce\u5929\u67f1\u65ad\u4e86\u54e5\u8fd8\u6ca1\u8bf4\u5b8c\uff0c\u4e0d\u8fc7\u5927\u4f19\u5df2\u7ecf\u9f50\u5237\u5237\u597d\u5947\u5730\u671d\u54e5\u7684\u88c6\u90e8\u770b\u53bb\uff0c\u88c6\u90e8\u770b\u53bb\uff01\u524d\u5934\u95ee\u8bdd\u90a3\u4f4d\u5e7d\u5e7d\u5730\u8bf4\uff1a\u90fd\u65ad\u4e86\uff0c\u8fd8\u575a\u6301\u6765\u4e0a\u73ed\u554a\uff01\uff01\r\n\u4eca\u513f\u6536\u5230\u4e00\u6761\u77ed\u4fe1\uff1a\u4eca\u65e512\u70b931\u5206\u5f00\u59cb\u8d77\uff0c\u6211\u8001\u5a46\u5c31\u8981\u5f00\u59cb\u966a\u522b\u4eba\u7684\u8001\u516c\u7761\u5566\uff0c\u6211\u8fd8\u5f97\u5e78\u798f\u7684\u4f3a\u5019\u7740\u6d17\u6f31\u66f4\u8863\u6c90\u6d74\uff0c\u6ca1\u529e\u6cd5\u4ed6\u5e26\u67aa\u6765\u7684\u3002\u770b\u4e86\u767e\u601d\u4e0d\u5f97\u5176\u89e3\uff0c\u548b\u4f1a\u6709\u8fd9\u4e48\u8d31\u7684\u4eba\u3002\u540e\u6765\u4e00\u770b\u53d1\u4fe1\u4eba\uff0c\u6211\u52d2\u4e2a\u53bb\uff0c\u751f\u4e2a\u513f\u5b50\u5c45\u7136\u6709\u8fd9\u6837\u62a5\u559c\u7684\uff01\uff01\r\n\u4f60\u966a\u7740\u4f60\u7684\u5cb3\u7236\u6765\u533b\u9662\u770b\u75c5\uff0c\u7adf\u8fce\u9762\u78b0\u89c1\u4f60\u7684\u59d0\u592b\u4e5f\u966a\u4ed6\u7684\u5cb3\u7236\u6765\u533b\u9662\u770b\u75c5\u3002\u8fd9\u65f6\u4ed6\u7684\u5cb3\u7236\u8fd8\u7b11\u54c8\u54c8\u5730\u8d70\u8fc7\u6765\u8ddf\u4f60\u7684\u5cb3\u7236\u8bf4\uff1a\u597d\u5728\u6211\u4e5f\u6709\u4e00\u4e2a\u5973\u513f\uff01\r\n\u4e00\u4e2a\u7537\u751f\u4e0d\u6ee1\u5973\u53cb\u51fa\u8f68\uff0c\u8ddf\u8e2a\u5979\u5230**\uff0c\u770b\u5230\u5979\u548c\u5225\u7684\u7537\u751f\u537f\u537f\u6211\u6211\uff0c\u624b\u91cc\u62ff\u7740\u4e00\u74f6\u4e0d\u660e\u6db2\u4f53\u51b2\u4e0a\u524d\uff1a\u6211\u8981\u628a\u59b3\u6bc0\u5bb9\uff01\u770b\u59b3\u600e\u4e48\u5077\u5403\uff01\u8bf4\u5b8c\u5c31\u5c06\u6db2\u4f53\u5f80\u5973\u751f\u8138\u4e0a\u6cfc\u3002\u9694\u58c1\u7684\u4eba\u770b\u5230\u5979\u88ab\u6bc0\u5bb9\u4e86\uff0c\u5168\u7ed9\u5413\u8dd1\u3002\u5973\u751f\u5f88\u5bb3\u6015\uff0c\u4f46\u5947\u602a\u8fc7\u4e86\u597d\u4e00\u9635\u5b50\u90fd\u6c92\u6709\u523a\u75db\u611f\uff0c\u5c31\u95ee\uff1a\u4f60\u6cfc\u7684\u662f\u4ec0\u4e48\uff1f\u7537\u751f\u8bf4\uff1a\u662f\u5378\u5986\u6db2\uff01\r\n\u832b\u832b\u5b87\u5b99\u4e2d\uff0c\u6709\u4e00\u79cd\u795e\u5947\u7684\u751f\u7269\uff0c\u8fd9\u79cd\u751f\u7269\u4e0d\u73a9\u6e38\u620f\uff0c\u4e0d\u804aqq\uff0c\u5929\u5929\u5c31\u77e5\u9053\u5b66\u4e60\uff0c\u56de\u56de\u5e74\u7ea7\u7b2c\u4e00\u3002\u8fd9\u79cd\u751f\u7269\u53ef\u4ee5\u4e5d\u95e8\u529f\u8bfe\u540c\u6b65\u5b66\uff0c\u5988\u5988\u518d\u4e5f\u4e0d\u7528\u62c5\u5fc3\u4ed6\u7684\u5b66\u4e60\u4e86\u3002\u3002\u8fd9\u79cd\u751f\u7269\u53eb\u505a\u522b\u4eba\u5bb6\u5b69\u5b50\u3002\u3002\u8fd9\u79cd\u751f\u7269\u8003\u6e05\u534e\uff0c\u671b\u5317\u5927\uff0c\u80fd\u8003\u7855\u58eb\u535a\u58eb\uff0c\u5723\u6597\u58eb\uff0c\u8fd8\u80fd\u5347\u7ea7\u9ec4\u91d1\u3002\u767d\u91d1\u3002\u548c\u6c34\u6676\u7ea7\uff0c\u4ed6\u4e0d\u770b\u661f\u5ea7\uff0c\u4e0d\u770b\u6f2b\u753b\uff0c\u770b\u5230\u7535\u8111\u5c31\u60f3\u9a82\u5a18\u3002\u3002\u3002\u4ed6\u662f\u56e2\u5458\u3001party\u5458\u3001\u516c\u52a1\u5458\uff0c\u5c06\u6765\u8fd8\u53ef\u80fd\u77e5\u9053\u5730\u7403\u4e3a\u4ec0\u4e48\u8fd9\u4e48\u5706\u3002\u8fd9\u79cd\u751f\u7269\u957f\u5f97\u597d\u770b\uff0c\u5199\u5b57\u597d\u770b\uff0c\u6210\u7ee9\u5355\u4e5f\u597d\u770b\uff0c\u5c31\u8fde\u4ed6\u7684\u624b\u6307\u7532\u90fd\u662f\u53cc\u773c\u76ae\u7684\u3002\u3002\u3002\u8fd9\u79cd\u751f\u7269\u6bcf\u5929\u53ea\u82b110\u5757\u94b1\u90fd\u89c9\u5f97\u5962\u4f88\u6d6a\u8d39\u548c\u72af\u7f6a\uff0c\u8fd9\u5c31\u662f\u611f\u52a8\u4e2d\u56fd2011\uff0c\u5341\u5927\u4eba\u7269\u4e4b---\u522b\u4eba\u5bb6\u5b69\u5b50==\u6211\u6d3b\u4e8620\u6765\u5e74\uff0c\u4e00\u76f4\u751f\u6d3b\u5728\u8fd9\u79cd\u4e0d\u660e\u751f\u7269\u7684\u9634\u5f71\u4e4b\u4e0b\u3002\