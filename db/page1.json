5e76\u672a\u5c31\u6b64\u5b8c\u7ed3\uff0c\u4e00\u4e9b\u524dMeeGo\u56e2\u961f\u6210\u5458\u7ec4\u6210\u4e86\u65b0\u7684\u521b\u4e1a\u516c\u53f8Jolla\u5e76\u5c06MeeGo\u91cd\u751f\u4e3aSailfish OS\uff0c\u73b0\u5728\u8fd9\u6b3e\u642d\u8f7d\u5168\u65b0Sailfish OS\u7684\u667a\u80fd\u624b\u673a\u7ec8\u4e8e\u9762\u4e16\u4e86\u30025\u670821\u65e5\u96f6\u70b930\u5206\uff0cJolla\u5728\u82ac\u5170\u8d6b\u5c14\u8f9b\u57fa\u6b63\u5f0f\u53d1\u5e03\u4e86\u9996\u6b3e\u642d\u8f7d\u5168\u65b0Sailfish\u5e73\u53f0\u7684Jolla\u624b\u673a\uff0c\u8be5\u624b\u673a\u652f\u6301 Android\u5e94\u7528\uff0c\u552e\u4ef7\u4e3a399\u6b27\u5143\uff0c\u5c06\u4e8e\u4eca\u5e74\u5e95\u5168\u9762\u4e0a\u5e02\u3002\r\nJolla\u624b\u673a\u6700\u5177\u7279\u8272\u7684\u662f\u91c7\u7528\u4e86\u7279\u522b\u7684\u5e95\u677f\u8bbe\u8ba1\uff0c\u5b83\u5141\u8bb8\u534a\u8fb9\u673a\u8eab(\u540e\u76d6)\u4e0e\u53e6\u4e00\u534a\u673a\u8eab\u5206\u79bb\u3002\u8be5\u673a\u6709\u8bb8\u591a\u5f69\u8272\u7684\u5851\u6599\u540e\u76d6\uff0c\u6709\u6de1\u84dd\u3001\u7eff\u3001\u767d\u548c\u6a58\u8272\u53ef\u4f9b \u9009\u62e9\u3002\u7528\u6237\u53ef\u4ee5\u6539\u53d8\u8be5\u624b\u673a\u7684\u540e\u76d6\uff0c\u800cSailfish\u7cfb\u7edf\u80fd\u8bc6\u522b\u540e\u76d6\u7684\u989c\u8272\u800c\u6539\u53d8\u7528\u6237\u754c\u9762\u4e3b\u9898\u3002Jolla\u5c06\u8be5\u529f\u80fd\u79f0\u4e4b\u4e3a\u201cThe Other Half\u201d\uff0c\u901a\u8fc7\u201c\u53e6\u4e00\u534a\u201d\u8ba9\u624b\u673a\u53d8\u5f97\u66f4\u751f\u52a8\uff0c\u66f4\u5177\u7279\u8272\u3002\r\n\u914d\u7f6e\u65b9\u9762\uff0cJolla\u624b\u673a\u91c7\u75284.5\u82f1\u5bf8\u5c4f\u3001\u642d\u8f7d\u53cc\u6838\u5904\u7406\u5668\u3001\u540e\u7f6e800\u4e07\u50cf\u7d20\u6444\u50cf\u5934\u3001\u62e5\u6709\u53ef\u62c6\u5378\u7535\u6c60\u8bbe \u8ba1\u3001\u652f\u63014G LTE\u7f51\u7edc\uff0c\u5b83\u7684\u5b58\u50a8\u7a7a\u95f4\u4e3a16GB\uff0c\u652f\u6301microSD\u5361\u6269\u5145\u3002Jolla\u624b\u673a\u5c06\u4e8e\u4eca\u5e74\u5e95\u6b63\u5f0f\u4e0a\u5e02\uff0c\u552e\u4ef7399\u6b27(\u7ea6\u5408\u4eba\u6c11\u5e013160\u5143)\u3002\u76ee\u524d\u8be5\u673a\u5df2 \u5f00\u653e\u9884\u8ba2\uff0c\u9884\u8ba2\u7528\u6237\u5c06\u6709\u673a\u4f1a\u5f97\u5230\u9650\u91cf\u7248\u7684\u540e\u76d6\u201cThe Other Half\u201d\u3002\u6b64\u524dJolla\u66fe\u5411\u5a92\u4f53\u53d1\u653e\u9080\u8bf7\u51fd\uff0c\u79f0\u5c06\u4e8e5\u6708\u521d\u5728\u5317\u4eac\u53ec\u5f00\u53d1\u5e03\u4f1a\uff0c\u5411\u4e2d\u56fd\u6d88\u8d39\u8005\u4ecb\u7ecd\u8fd9\u6b3eSailfish\u7cfb\u7edf\u3002\u4f46\u540e\u6765\u56e0\u6545\u63a8\u8fdf\uff0c\u73b0\u5728\u770b\u6765\u4f30 \u8ba1\u8981\u7b49\u624b\u673a\u4e0a\u5e02\u7684\u65f6\u4e00\u8d77\u53d1\u5e03\u4e86\u3002", "imagename": "39f3c5e5-4da9-4fea-aa0b-de4f2c5d589c.jpg", "infoid": 768882, "category": "technology_gadgets", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": "http://www.oschina.net/news/46392/jolla-make-first-sailfish-phone", "real_tags": ["jolla"]}, {"url": "http://news.mydrivers.com/1/284/284481.htm", "title": "\u513f\u7ae5\u4e13\u7528DIY\u7535\u8111", "tags": "DIY \u7535\u8111", "name": "geekzhang", "posttime": "2013-11-28 08:45:00", "ip": null, "mark": 0, "note": "\u8fd9\u5957\u53eb\u505aKano\u7684\u7535\u8111\u65e8\u5728\u8ba9\u513f\u7ae5\u4e86\u89e3PC\uff0c\u5e76\u8ba9DIY\u7535\u8111\u53d8\u5f97\u50cf\u73a9\u4e50\u9ad8\u79ef\u6728\u4e00\u6837\u5bb9\u6613\u548c\u6709\u8da3\u3002\r\nKano\u7531\u5341\u591a\u4e2a\u90e8\u4ef6\u7ec4\u6210\uff0c\u5305\u62ec\u57fa\u4e8eARM\u7684\u5fae\u578b\u7535\u8111\u4e3b\u677f\u3001\u5e26\u89e6\u6478\u677f\u7684\u952e\u76d8\u3001\u7535\u6e90\u3001Wi-Fi\u6a21\u5757\u3001\u626c\u58f0\u5668\u3001DIY\u5916\u58f3\u3001Kano OS\u53ca8GB\u5bb9\u91cfSD\u5361\u7b49\uff0c\u513f\u7ae5\u901a\u8fc7\u8bf4\u660e\u4e66\u7684\u6307\u5bfc\u53ef\u4ee5\u4e00\u6b65\u4e00\u6b65\u6253\u9020\u51fa\u4e00\u6b3e\u5fae\u578b\u7535\u8111\u3002\u6839\u636e\u4e0d\u540c\u7684\u5e74\u9f84\u6bb5\u8fd9\u5957DIY\u5957\u4ef6\u4e5f\u5206\u4e3a\u4e0d\u540c\u7684\u7b49\u7ea7\uff0c\u6bcf\u4e2a\u7b49\u7ea