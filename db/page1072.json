\u6b3e\u5b8c\u5168\u514d\u8d39\u7684 P2P/BT/\u7535\u9a74 \u70b9\u64ad\u8f6f\u4ef6\uff1b\u96c6\u4e0b\u8f7d\u3001\u64ad\u653e\u3001\u641c\u7d22\u7b49\u4f17\u591a\u529f\u80fd\u4e8e\u4e00\u8eab\uff1b\u53ea\u9700\u901a\u8fc75 - 10 \u5206\u949f\u5de6\u53f3\u7684\u7f13\u51b2\u5373\u53ef\u8fb9\u4e0b\u8f7d\u8fb9\u89c2\u770b\u5404\u7c7b\u5f71\u89c6\u8282\u76ee\uff0c\u540c\u65f6\u5b83\u96c6\u6210\u4e86\u5168\u65b0\u64ad\u653e\u5f15\u64ce\uff0c\u7528\u6237\u65e0\u9700\u53e6\u5916\u6253\u5f00\u64ad\u653e\u5668\uff0c\u5373\u53ef\u540c\u65f6\u89c2\u770b\u3002\r\n[\u6458\u8981]  \u901a\u8fc7 TTL \u5f00\u53d1\u5c0f\u7ec4\u548c\u90e8\u5206\u7f51\u53cb\u7684\u5171\u540c\u52aa\u529b\uff0c\u672c\u6b21\u53d1\u5e03\u7684 ToToLook 2007 Beta3 \u7248\u672c\u4e00\u6b21\u6027\u589e\u52a0\u4e864 \u5957\u76ae\u80a4\uff01\u5e0c\u671b\u901a\u8fc7\u7f51\u53cb\u6295\u7968\u7684\u5f62\u5f0f\uff0c\u9009\u51fa 3 \u5957\u76ae\u80a4\u4f5c\u4e3a ToToLook 2007 \u6b63\u5f0f\u7248\u672c\u7684\u9ed8\u8ba4\u76ae\u80a4\u3002\u76f8\u5bf9\u4e8e Beta2 \uff0c\u65b0\u7248\u5728\u7a33\u5b9a\u6027\uff0cUI \u64cd\u4f5c\u5904\u7406\uff0c\u9891\u9053\u66f4\u65b0\u7b49\u65b9\u9762\u505a\u4e86\u8f83\u5927\u7684\u6539\u52a8\uff0c\u6b22\u8fce\u5927\u5bb6\u4e0b\u8f7d\u5b89\u88c5\u4f7f\u7528\uff01\r\n   \u65b0\u7248\u66f4\u65b0\u5982\u4e0b\uff1a\r\n- \u65b0\u589e\uff1a\u6dfb\u52a0\u8fd1 20 \u591a\u4e2a\u5206\u7c7b\u9891\u9053\uff0c\u63d0\u4f9b\u667a\u80fd\u9891\u9053\u540c\u6b65\u529f\u80fd\uff0c\u53ca\u65f6\u9891\u9053\u66f4\u65b0\r\n- \u65b0\u589e\uff1a\u65b0\u589e 4 \u5957\u9753\u4e3d\u76ae\u80a4\u4f9b\u53c2\u8003\uff0c\u5207\u5408\u66f4\u591a\u7528\u6237\u7684\u4f7f\u7528\u559c\u597d\r\n- \u65b0\u589e\uff1a\u6dfb\u52a0\u4efb\u52a1\u5b8c\u6210\u7684\u4fe1\u606f\u63d0\u793a\u53ca\u5c4f\u5e55\u622a\u56fe\u5b8c\u6210\u540e\u7684\u7684\u81ea\u52a8\u63d0\u793a\r\n- \u5b8c\u5584\uff1a\u8c03\u6574\u4e86\u76ae\u80a4 UI \u7684\u5e03\u5c40\uff0c\u7279\u522b\u662f\u64ad\u653e\u5668\u63a7\u5236\u90e8\u5206\uff0c\u63d0\u4f9b\u66f4\u7075