u6b64\u52a8\u8d77\u6765\uff1b<BR>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;2.\u65b0\u589e\u4e86\u7fa4\u81ea\u5b9a\u4e49\u5934\u50cf\uff0c\u4e3a\u7fa4\u8bbe\u7f6e\u4e0e\u4f17\u4e0d\u540c\u4e2a\u6027\u5934\u50cf\uff1b<BR>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;3.\u65b0\u589e\u4e86\u597d\u53cb\u95f4\u9001\u793c\u8bb8\u613f\u529f\u80fd\uff0c\u60a8\u8bb8\u613f\uff0c\u6211\u9001\u793c\uff1b<BR>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;4.\u79bb\u7ebf\u6d88\u606f\u652f\u6301\u81ea\u5b9a\u4e49\u56fe\u7247,\u53d1\u9001\u56fe\u7247\u4e0d\u518d\u53d7\u9650\uff1b<BR>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;5.\u65b0\u589e\u4e86\u5404\u79cd\u4e1a\u52a1\u56fe\u6807\u652f\u6301\u7b49\u7ea7\u5c55\u73b0\uff1b<BR>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;6.\u65b0\u589e\u624b\u673a\u4e34\u65f6\u4f1a\u8bdd\u529f\u80fd\uff0c\u65b9\u4fbf\u4e0e\u4e0d\u5728\u7ebf\u7684\u62cd\u62cd\u5356\u5bb6\u8054\u7edc\uff1b<BR>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;7.\u65b0\u589e\u4e86\u81ea\u5b9a\u4e49\u5206\u7ec4\u652f\u6301\u62d6\u62fd\u529f\u80fd\uff1b<BR>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;8.\u65b0\u589e\u4e86\u7fa4\u5185\u97f3\u4e50\u5206\u4eab\u529f\u80fd,\u597d\u97f3\u4e50\u5927\u5bb6\u5206\u4eab\uff1b<BR>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;9.\u65b0\u589e\u901b\u62cd\u62cd\u7f51\u72b6\u6001\uff0c\u8ba9\u597d\u53cb\u4e00\u8d77\u6765\u53c2\u8c0b\u3002</DIV>\r\n<DIV class=exp-name><BR>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\u6b22\u8fce\u60a8\u968f\u540e\u5bf9&nbsp;QQ2008&nbsp;\u6b63\u5f0f\u7248\u8bd5\u7528\u53cd\u9988<A href=\"http://exp.qq.com/cgi-bin/present/tec_cgi_dl_report?plan_id=108&amp;xurl=http://support.qq.com/bbszt.html#01,0,1,2,0,20,0\" target=_blank>\u8ba8\u8bba\u533a</A>\u53d1\u8868\u610f\u89c1\uff0c\u60a8\u53cd\u6620\u7684\u6bcf\u4e2a\u95ee\u9898\u90fd\u4f1a\u6709\u4e13\u4eba\u8ddf\u8fdb\u3002\u8ba9\u6211\u4eec\u4e00\u540c\u628a\u5c5e\u4e8e\u4f60\u6211\u7684QQ\u6253\u9020\u6210\u4e00\u6b3e\u4f18\u79c0\u7684\u5373\u65f6\u901a\u4fe1\u8f6f\u4ef6\u3002</DIV>\r\n<DIV class=exp-name><BR>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<