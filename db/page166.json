[{"url": "http://jdxi.net/post/zi-shi.html", "title": "\u8bf7\u62bd\u51fa\u4e24\u5206\u949f\u6765\u770b\u89c6\u9891\uff1a\u6b63\u786e\u7684\u4e0a\u7f51\u59ff\u52bf", "tags": "\u4e0a\u7f51 \u59ff\u52bf ", "name": "wangweimei", "posttime": "2011-04-15 13:22:53", "ip": "113.95.40.253", "mark": 0, "note": "\u8bf7\u5927\u5bb6\u62bd\u51fa\u4e24\u5206\u949f\u7684\u65f6\u95f4\uff0c\u6765\u770b\u4e00\u4e0b\u8fd9\u4e2a\u89c6\u9891\uff0c\u5982\u4f55\u7528\u6b63\u786e\u7684\u59ff\u52bf\u6765\u4f7f\u7528\u7b14\u8bb0\u672c\u6216\u8005\u53f0\u5f0f\u673a\u3002\u77e5\u6613\u884c\u96be\uff0c\u5f88\u591a\u4e8b\u60c5\u6211\u4eec\u90fd\u6e05\u695a\u4f46\u662f\u4e0d\u5bb9\u6613\u505a\u5230\u3002\u5c3d\u91cf\uff0c\u4e60\u60ef\u4e00\u4e0b\uff0c\u7136\u540e\u6210\u81ea\u7136\u3002", "imagename": "915cb514cd04468bb3f1f5ee2102f4b3.jpg", "infoid": 417169, "category": "videos_tech-stuff", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "videos", "via": null, "real_tags": ["\u4e0a\u7f51", "\u59ff\u52bf"]}, {"url": "http://jdxi.net/post/mo-qi.html", "title": "\u6beb\u65e0\u9ed8\u5951\u7684\u4f60\u6765\u6bd4\u5212\u6211\u6765\u731c", "tags": "\u4f60\u6765\u6bd4\u5212\u6211\u6765\u731c \u9ed8\u5951 ", "name": "wangweimei", "posttime": "2011-04-15 12:20:08", "ip": "113.95.40.253", "mark": 0, "note": "\u4f30\u8ba1\u90a3\u4e2a\u5973\u7684\u4e00\u5b9a\u662f\u628a\u8fd9\u6e38\u620f\u5f53\u6210\u771f\u5fc3\u8bdd\u5927\u5192\u9669\u6765\u73a9\u4e86\u3002\u3002\u3002", "imagename": "d6a4201dbecb4d5cbb5e0da622838fe7.jpg", "infoid": 417161, "category": "videos_comedy", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "videos", "via": null, "real_tags": ["\u4f60\u6765\u6bd4\u5212\u6211\u6765\u731c", "\u9ed8\u5951"]}, {"url": "http://jdxi.net/post/qi-da-nei.html", "title": "\u77a0\u76ee\u7ed3\u820c\uff01\u770b\u8fd9\u628a\u5e74\u7eaa\u7684\u9f50\u8fbe\u5185\u600e\u4e48\u7f9e\u8fb1\u5e74\u8f7b\u95e8\u5c06", "tags": "\u9f50\u8fbe\u5185 \u5e74\u8f7b \u7f9e\u8fb1 \u8db3\u7403 \u9