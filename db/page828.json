cf\u7406\u5c06\u7ec4\u5efa\u56e2\u961f\u201c\u4e3aWindows Mobile\u63a8\u51fa\u5e02\u573a\u670d\u52a1\u201d\uff0c\u5177\u4f53\u5185\u5bb9\u5982\u4e0b\uff1a</P>\r\n<P>\u3000\u3000\u00b7\u901a\u8fc7\u89c4\u5b9a\u4ea7\u54c1\u4f9b\u5e94\u3001\u5b9a\u4ef7\u3001\u5546\u4e1a\u6a21\u5f0f\u53ca\u653f\u7b56\uff0c\u4f7fWindows Mobile\u5e02\u573a\u6210\u4e3a\u5f00\u53d1\u4eba\u5458\u5e0c\u671b\u5206\u53d1Windows Mobile\u5e94\u7528\u53ca\u901a\u8fc7Windows Mobile\u5e94\u7528\u8d5a\u94b1\u7684\u573a\u6240\u3002</P>\r\n<P>\u3000\u3000\u00b7\u901a\u8fc7\u660e\u786e\u5546\u4e1a\u6a21\u5f0f\u548c\u5173\u952e\u5143\u7d20\u7684\u804c\u8d23\u4f7f\u5f00\u53d1\u4eba\u5458\u83b7\u5f97\u6700\u4f73\u4f53\u9a8c\uff0c\u5e76\u901a\u8fc7\u5fae\u8f6f\u63d0\u4f9b\u7684\u670d\u52a1\u8fbe\u5230\u8d5a\u94b1\u76ee\u7684\u3002</P>\r\n<P>\u3000\u3000\u00b7\u505a\u597d\u56e2\u961f\u534f\u4f5c\u5de5\u4f5c\uff0c\u4e3a\u4eca\u5e74\u79cb\u5b63\u5411\u5f00\u53d1\u56e2\u961f\u63a8\u51fa\u4ea7\u54c1\u505a\u597d\u51c6\u5907\u3002</P>\r\n<P>\u3000\u3000\u00b7\u505a\u597d\u56e2\u961f\u534f\u4f5c\u5de5\u4f5c\uff0c\u4e3a\u63a8\u51faWindows Mobile\u5e02\u573a\u670d\u52a1\u505a\u597d\u5404\u76f8\u5173\u5229\u76ca\u65b9\u7684\u5de5\u4f5c\u3002</P>\r\n<P>\u3000\u3000\u5fae\u8f6f\u4ee3\u8868\u6ca1\u6709\u5bf9\u6b64\u53d1\u8868\u8bc4\u8bba\u3002</P>\r\n<P>\u3000\u3000Windows Mobile\u662f\u4e00\u6b3e\u5e94\u7528\u4e8e\u667a\u80fd\u624b\u673a\u7684\u8f6f\u4ef6\u64cd\u4f5c\u7cfb\u7edf\u3002\u667a\u80fd\u624b\u673a\u56e0\u5177\u6709\u7535\u5b50\u90ae\u4ef6\u6536\u53d1\u3001\u4e0a\u7f51\u3001\u97f3\u4e50\u53ca\u5176\u5b83\u4e92\u8054\u7f51\u670d\u52a1\u7684\u529f\u80fd\u800c\u65e5\u76ca\u6d41\u884c\u3002\u636eNPD\u62a5\u9053\uff0c\u4eca\u5e74\u7b2c\u4e00\u5b63\u5ea6\u667a\u80fd\u624b\u673a\u5728\u7f8e\u56fd\u624b\u673a\u5e02\u573a\u9500\u552e\u4e2d\u5360\u4e8617%\u7684\u6bd4\u4f8b\uff0c\u6bd4\u53bb\u5e74\u540c\u671f\u589e\u957f\u4e8610%\u3002</P>\r\n<P>\u3000\u3000\u5fae\u8f6f\u4e00\u76f4\u81f4\u529b\u4e8e\u901a\u8fc7\u5bf9\u667a\u80fd\u624b\u673a\u9700\u6c42\u7684\u4e0d\u65ad\u589e\u957f\u6765\u8d5a\u94b1\u3002\u4eca\u5e74\u5e74\u521d\uff0c\u5fae\u8f6f\u53d1\u5e03\u4e86Windows Mobile 6.1\u7248\u672c\u7684\u64cd\u4f5c\u7cfb\u7edf\u3002\u8be5\u7248\u672c\u5305\u62ec\u4e00\u6b3e\u5347\u7ea7\u540e\u7684\u6d4f\u89c8\u5668\uff0c\u53ef\u4ee5\u4f7f\u901a\u8fc7\u624b\u673a\u4e0a\u7f51\u83b7\u5f97\u7684\u4f53\u9a8c\u4e0e\u901a\u8fc7\u7535\u8111\u83b7\u5f97\u7684\u4f53\u9a8c\u76f8\u5f53\u3002</P>\r\n<P>\u3000\u3000\u5c3d\u7ba1\u9884\u6d4bWindows Mobile 6.1\u4f1a\u51fa\u73b0\u5f3a\u52b2\u589e\u957f\uff0c\u4f46\u5fae\u8f6f\u4ecd\u7136\u9762\u4e34\u7740\u8270\u96be\u7684\u7ade\u4e89\uff0c\u968f\u7740\u7ade\u4e89\u6fc0\u70c8\u7a0b\u5ea6\u7684\u52a0\u5267\uff0c\u5fae\u8f6f\u8981\u6269\u5927\u5e02\u573a\u4efd\u989d\u5c06\u975e\u5e38\u56f0\u96be\u3002</P>\r\n<P>\u3000\u3000\u82f9\u679c\u5728\u63a8\u51fa\u65b0\u7248<SPAN class=articleLink><A href=\"http://digi.it.sohu.com/s2007/iphone/\" target=_blank>iPhone</A></SPAN>\u624b\u673a\u65f6\uff0c\u5f00\u4e86App Store\u8f6f\u4ef6\u5546\u5e97\uff0c\u53d6\u5f97\u5de8\u5927\u6210\u529f\u3002\u82f9\u679c\u8f6f\u4ef6\u5546\u5e97\u5f00\u5f20\u7b2c\u4e00\u4e2a\u6708\u5c31\u8fdb\u5e103000\u4e07\u7f8e\u5143\u3002\u800c\u4e14\uff0c\u91c7\u7528\u8c37\u6b4cAndroid\u64cd\u4f5c\u7cfb\u7edf\u7684\u624b\u673a\u5f88\u5feb\u5c31\u4f1a\u4e0a\u5e02\u3002</P>\r\n<P>\u6765\u6e90\uff1aCNET</P>", "imagename": null, "infoid": 88453, "category": "technology_internet", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["windows", "mobile", "\u8f6f\u4ef6\u5546\u5e97", "\u5fae\u8f6f", "\u624b\u673a"]}, {"url": null, "title": "Google\u624b\u673a\u53d1\u552e\u65f6\u95f4\u6572\u5b9a \u552e\u4ef7199\u7f8e\u5143", "tags": "Google \u624b\u673a HTC Dream Android ", "name": "yinyin", "posttime": "2008-09-01 10:16:17", "ip": "117.88.34.32", "mark": 2, "note": "<P>\u9996\u6b3eGoogle\u624b\u673a\u4ece2005\u5e74\u7b2c\u4e00\u6b21\u63d0\u51fa\u59c