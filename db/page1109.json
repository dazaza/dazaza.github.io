[{"url": "http://sisea.blogspot.com/2007/06/blog-post_05.html", "title": "\u53ea\u97006\u5206\u949f\u5c31\u80fd\u6d4b\u51fa\u4f60\u7684\u6253\u5b57\u901f\u5ea6\u600e\u4e48\u6837\u3002", "tags": "", "name": "sisea", "posttime": "2007-06-05 09:29:32", "ip": "222.188.46.202", "mark": 21, "note": "\u53ea\u97006\u5206\u949f\u5c31\u80fd\u6d4b\u51fa\u4f60\u7684\u6253\u5b57\u901f\u5ea6\u600e\u4e48\u6837\u3002", "imagename": "", "infoid": 21561, "category": "technology_games", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": null}, {"url": "http://pkunews.pku.edu.cn/Show_News.asp?Newsid=114723&zt=&zid=", "title": "\u79d1\u5b66\u5bb6\u9996\u6b21\u89e3\u5bc6\u690d\u7269\u82b1\u5e8f\u673a\u5236", "tags": "\u690d\u7269 \u82b1\u5e8f ", "name": "cacard", "posttime": "2007-06-05 08:41:03", "ip": "221.14.253.218", "mark": 5, "note": "\u82b1\u5e8f\u662f\u6307\u690d\u7269\u5f00\u82b1\u7684\u6392\u5217\u65b9\u5f0f\uff0c\u81ea\u7136\u754c\u4e2d\u5927\u7ea6\u6709\u6570\u5343\u79cd\u82b1\u5e8f\u8303\u4f8b\u3002\u957f\u671f\u4ee5\u6765\uff0c\u79d1\u5b66\u5bb6\u4eec\u4ee5\u4e3a\u82b1\u5e8f\u7684\u4e0d\u540c\u5f62\u5f0f\u662f\u7531\u5b8c\u5168\u4e0d\u540c\u7684\u673a\u5236\u9020\u6210\u7684\uff0c\u4f46\u662f5\u670824\u65e5\u5728\u7ebf\u53d1\u8868\u7684\u300a\u79d1\u5b66\u300b\u6742\u5fd7\u5728\u7ebf\u53d1\u8868\u7684\u4e00\u7bc7\u6587\u7ae0\u6307\u51fa\uff0c\u4e0d\u540c\u82b1\u5e8f\u5176\u5b9e\u53ea\u662f\u540c\u4e00\u673a\u5236\u4e0d\u540c\u65b9\u9762\u7684\u5f71\u54cd\u7ed3\u679c\u3002\r\n\r\n\u7814\u7a76\u4eba\u5458\u9610\u8ff0\u4e86\u9020\u6210\u82b1\u5e8f\u5dee\u5f02\u7684\u6570\u5b66\u6a21\u578b\u3001\u5206\u5b50\u9057\u4f20\u673a\u5236\u4ee5\u53ca\u8fdb\u5316\u8fc7\u7a0b\u3002\u8bba\u6587\u7b2c\u4e00\u4f5c\u8005\u3001\u52a0\u62ff\u5927\u5361\u5c14\u52a0\u91cc\u5927\u5b66\uff08University of Calgary\uff09\u7684\u8ba1\u7b97\u673a\u79d1\u5b66\u5bb6Przemyslaw Prusinkiewicz\u8868\u793a\uff0c\u201c\u6700\u65b0\u7684\u7814\u7a76\u63d0\u