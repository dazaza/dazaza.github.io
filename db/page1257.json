e8e\u5408\u4f5c\u7684\u95ee\u9898,\u66fe\u60ca\u6709\u5f88\u591a\u670b\u53cb\u6765\u8be2\u95ee\u53ef\u80fd\u7684\u65b9\u5f0f.\u6211\u4eec\u4e5f\u5728\u63a2\u7d22\u8fd9\u65b9\u9762\u7684\u9053\u8def,\u6bd4\u5982\u8c61donews\u7684InOut,\u5c31\u662f\u4e00\u4e2a\u503c\u5f97\u501f\u9274\u7684\u65b9\u5f0f.\u4f46\u662f,\u73b0\u4ee3\u7684\u641c\u7d22\u5f15\u64ce\u5df2\u7ecf\u628a\u8fd9\u79cd\u5b8c\u5168\u662f\u8fde\u63a5\u7684\u9875\u9762\u5c4f\u853d\u6389\u4e86,\u6240\u4ee5InOut\u5bf9\u4e8e\u7f51\u7ad9\u7684\u5b9e\u9645\u4f5c\u7528\u5b9e\u5728\u662f\u8ba9\u4eba\u6000\u7591.\u5982\u679c\u60a8\u6709\u4ec0\u4e48\u597d\u7684\u60f3\u6cd5,\u53ef\u4ee5\u548c\u6211\u4eec\u4e00\u8d77\u5546\u8ba8.\u540c\u65f6,\u6211\u4eec\u4e5f\u5e0c\u671b\u6269\u5927\u5408\u4f5c\u5173\u7cfb,\u51e1\u662f\u4efb\u4f55\u4e92\u5229\u7684\u8054\u76df\u90fd\u5728\u6211\u4eec\u7684\u63a2\u7d22\u4e4b\u5217.\r\n\r\n\u5f53\u7136,\u9876\u554a\u7f51\u76ee\u524d\u8fd8\u53ea\u662f\u4e00\u4e2a\u5f88\u5c0f\u7684\u7f51\u7ad9,\u6211\u4eec\u5e0c\u671b\u901a\u8fc7\u60a8\u6211\u7684\u52aa\u529b,\u8ba9\u5b83\u9010\u6b65\u5b8c\u5584\u8d77\u6765.", "imagename": "e31903a7-0995-4078-8075-89d28b497036.gif", "infoid": 5016, "category": "technology_web2", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["dingr", "\u9876\u554a"]}, {"url": "http://tech.sina.com.cn/i/2006-08-22/16001097939.shtml", "title": "15\u5e7415\u4e2a\u7f51\u7ad9\u6539\u53d8\u4e16\u754c_\u4e92\u8054\u7f51_\u79d1\u6280\u65f6\u4ee3_\u65b0\u6d6a\u7f51", "tags": "\u6539\u53d8 15 \u7f51\u7ad9 ", "name": "jack2005", "posttime": "2006-08-23 09:18:54", "ip": "61.52.28.47", "mark": 9, "note": "1991\u5e748\u6708\uff0c\u7f8e\u56fd\u6b63\u5f0f\u5c06\u4e92\u8054\u7f51\u6280\u672f\u7531\u519b\u7528\u8f6c\u4e3a\u6c11\u7528\uff0c\u7531\u6b64\u5f15\u53d1\u4e86\u5168\u7403\u4e92\u8054\u7f51\u70ed\u6f6e\uff0c\u4eba\u7c7b\u751f\u6d3b\u5f00\u59cb\u4e86\u5929\u7ffb\u5730\u8986\u7684\u53d8\u5316\u3002\u672c\u5468\u51fa\u724