[{"url": "http://www.pencilmation.com/index.html", "title": "12\u4e2a\u94c5\u7b14\u5c0f\u4eba\u52a8\u753b", "tags": "\u6709\u8da3\u3000\u52a8\u753b\u3000 ", "name": "hackyourmind", "posttime": "2006-11-23 11:31:28", "ip": "60.195.183.65", "mark": 12, "note": "\u6211\u559c\u6b22 pencilmation 1 &amp; 2 ,\u975e\u5e38\u6709\u8da3\uff0e", "imagename": "a8021042-89d3-4705-b58d-d5e012fea79d.jpg", "infoid": 9499, "category": "technology_other", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u6709\u8da3\u3000\u52a8\u753b"]}, {"url": "http://www.7ke.net.cn/read.php/545.htm", "title": "\u7f51\u901a\u63a8\u5927\u4f17\u7535\u8bdd\u5957\u9910 \u56fa\u8bdd\u6708\u79df\u8d39\u5c06\u53d6\u6d88", "tags": "\u7f51\u901a ", "name": "7ke", "posttime": "2006-11-23 10:23:04", "ip": "60.1.22.155", "mark": 5, "note": "\u4e89\u6267\u591a\u5e74\u7684\u56fa\u5b9a\u7535\u8bdd\u6708\u79df\u8d39\u95ee\u9898,\u4eca\u540e\u5c06\u6709\u671b\u5728\u5404\u5730\u9646\u7eed\u6210\u4e3a\u5386\u53f2.\u8bb0\u8005\u6628\u5929\u4ece\u4e2d\u56fd\u7f51\u901a\u83b7\u6089,\u4e00\u79cd\u540d\u4e3a\u201c\u5927\u4f17\u7535\u8bdd\u201d\u7684\u56fa\u8bdd\u5957\u9910\u4e1a\u52a1\u5df2\u915d\u917f\u6210\u5f62,\u5e76\u4e0b\u53d1\u901a\u77e5\u81f3\u5404\u7701\u5206\u516c\u53f8.\u6309\u7167\u7f51\u901a\u5e02\u573a\u90e8\u5bf9\u8fd9\u4e00\u65b0\u5957\u9910\u7684\u89c4\u5212,\u56fa\u5b9a\u7535\u8bdd\u7528\u6237\u4e5f\u5c06\u80fd\u591f\u50cf\u4f7f\u7528\u624b\u673a\u90a3\u6837,\u9009\u62e9\u4e0d\u540c\u4ef7\u4f4d\u7684\u8d44\u8d39\u5957\u9910,\u540c\u65f6\u8fd8\u80fd\u591f\u51cf\u514d\u56fa\u8bdd\u6708\u79df\u8d39.\u76ee\u524d,\u4e1c\u5317\u5730\u533a\u5df2\u5f00\u59cb\u63a8\u884c\u8fd9\u9879\u4e1a\u52a1,\u4f46\u5317\u4eac\u5730\u533a\u6682\u65f6\u8fd8\u6ca1\u6709\u51fa\u53f0\u8be5\u4e1a\u52a1\u7684\u65f6\u95f4\u8868.", "imagename": "", "infoid": 9497, "category": "technology_internet", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u7f51\u901a"]}, {"url": "http://www.youtube.com/watch?v=7zU8SZQLDJw", "title": "\u89c6\u9891\uff1aSky News\u773c\u4e2d\u7684\u4e2d\u56fd\u95ee\u9898\uff01", "tags": "\u793e\u4f1a \u4e2d\u56fd \u95ee\u9898 \u4eba\u6743 \u89c6\u9891 \u8bb0\u8005 \u73b0\u5b9e \u63ed\u9732 Sky News tyranny china ", "name": "dujunday", "posttime": "2006-11-22 21:46:13", "ip": "60.186.60.146", "mark": 10, "note": "Sky News\u7684\u8bb0\u8005\u62cd\u6444\u7684\u4e00\u6bb5\u89c6\u9891\u53cd\u6620\u4e86\u4e2d\u56fd\u7684\u4eba\u6743\u95ee\u9898\uff0c\u73b0\u5b9e\u65e0\u5948\u554a\u3002\u5728ZF\u770b\u6765\uff0c\u4e3a\u4e86\u8ba9\u4e00\u90e8\u5206\u4eba\u5148\u5bcc\u8d77\u6765\u800c\u727a\u7272\u53e6\u4e00\u90e8\u5206\u4eba\u7684\u57fa\u672c\u4eba\u6743\uff0c\u8fd9\u4f3c\u4e4e\u8fde\u8ba8\u8bba\u7684\u5fc5\u8981\u90fd\u6ca1\u6709\u4e86\u3002\r\n\r\n\u53e6\uff1a\u8fd9\u6761\u6d88\u606f\u4f1a\u6210\u4e3a&quot;\u5783\u573e&quot;\u4fe1\u606f\u4e48\uff1f:P", "imagename": "7f09ca83-011e-4756-9dd3-e49152650f01.jpg", "infoid": 9486, "category": "videos_news", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "videos", "via": null, "real_tags": ["\u793e\u4f1a", "\u4e2d\u56fd", "\u95ee\u9898", "\u4eba\u6743", "\u89c6\u9891", "\u8bb0\u8005", "\u73b0\u5b9e", "\u63ed\u9732", "sky", "news", "tyranny", "china"]}, {"url": "http://news.sina.com.cn/s/2006-11-22/174311588482.shtml", "title": "\u5149\u68cd\u8282\uff1a\u4e0a\u6d77\u201c\u60c5\u4fa3\u53bb\u6b7b\u56e2\u201d\u5728\u884c\u52a8_\u65b0\u95fb\u4e2d\u5fc3_\u65b0\u6d6a\u7f51", "tags": "\u4e9a\u6587\u5316 \u53bb\u6b7b\u53bb\u6b7b\u56e2 ", "name": "shizhao", "posttime": "2006-11-22 19:59:51", "ip": "210.72.12.72", "mark": 8, "note": "\u4ed6\u4eec\u90fd\u662f\u5355\u8eab\u7537\u5973\uff0c\u5374\u5728\u60c5\u4fa3\u5982\u7ec7\u7684\u8857\u5934\u9ad8\u558a\u7740\u201c\u60c5\u4fa3\u53bb\u6b7b\u201d\u7684\u53e3\u53f7\u300211\u670811\u65e5\uff0c\u4e00\u7fa4\u81ea\u79f0\u201c\u60c5\u4fa3\u53bb\u6b7b\u53bb\u6b7b\u56e2\u20