3\u548c\u6295\u7968\u3002\n    * Web \u7ad9\u70b9\u548c Web \u95e8\u6237\n      \u793e\u533a\u901a\u5e38\u90fd\u6709\u4f20\u7edf\u7684 Web \u7ad9\u70b9\u548c Web \u95e8\u6237\uff0c\u7528\u4e8e\u4f20\u9012\u66f4\u591a\u9759\u6001\u4fe1\u606f\u6216\u53ef\u63a7\u4fe1\u606f\u3002Web \u7ad9\u70b9\u5bf9\u4e8e\u975e\u6210\u5458\u6765\u8bf4\u53ef\u80fd\u5c31\u662f\u793e\u533a\u7684\u95e8\u9762\uff0c\u5b83\u8fd8\u80fd\u4e3a\u793e\u533a\u6210\u5458\u63d0\u4f9b Web \u5e94\u7528\u7a0b\u5e8f\u3002\n    * \u7ec4\u4ef6\uff08Groupware\uff09\n      \u7ec4\u4ef6\u5305\u62ec\u56e2\u961f\u534f\u4f5c\u4ee5\u53ca\u4ee5\u6587\u6863\u4e3a\u4e2d\u5fc3\u7684\u7cfb\u7edf\uff0c\u5982 Lotus&#174; Domino&#174;\u3001Lotus Domino Document Manager \u548c Lotus QuickPlace&#174;\u3002\u8fd9\u4e9b\u5de5\u5177\u901a\u5e38\u652f\u6301\u66f4\u4e3a\u5173\u952e\u7684\u4e1a\u52a1\u8fc7\u7a0b\uff0c\u5176\u4e2d\u9700\u8981\u4e25\u683c\u7684\u6587\u6863\u63a7\u5236\u548c\u53ef\u5f3a\u5236\u5b9e\u65bd\u7684\u4e1a\u52a1\u7b56\u7565\u3002\n\n\u6709\u4eba\u66fe\u5c1d\u8bd5\u8fc7\u7528 wiki \u6765\u627f\u62c5\u8bba\u575b\u7684\u89d2\u8272\uff0c\u4f46 wiki \u6709\u7740\u4e0e\u751f\u4ff1\u6765\u7684\u81ea\u7531\uff0c\u65e0\u6cd5\u6ee1\u8db3\u4fdd\u6301\u65f6\u95f4\u987a\u5e8f\u3001\u5206\u9694\u8bdd\u9898\u4ee5\u53ca\u4f7f\u67d0\u4eba\u8f7b\u677e\u8ddf\u968f\u8ba8\u8bba\u8fdb\u5c55\u7684\u9700\u6c42\u3002\u6b64\u5916\uff0c\u7531\u4e8e blog \u7684\u8ba8\u8bba\u7531 blog \u6240\u6709\u8005\u63a7\u5236\uff0c\u56e0\u6b64\u5b83\u4e5f\u65e0\u6cd5\u627f\u62c5\u8fd9\u4e00\u4efb\u52a1\u3002\u8bc4\u8bba\u8005\u662f\u65e0\u6cd5\u5f00\u542f\u65b0\u8bdd\u9898\u7684\u3002\u540c\u6837\uff0c\u51fa\u4e8e\u5176\u5185\u5bb9\u7ba1\u7406\u65b9\u5f0f\u7684\u539f\u56e0\uff0cWeb \u7ad9\u70b9\u548c\u7ec4\u4ef6\u901a\u5e38\u4e5f\u65e0\u6cd5\u62c5\u8d1f\u8d77 wiki \u6240\u626e\u6f14\u7684\u89d2\u8272\u3002\u4e0e\u9762\u5411\u5185\u5bb9\u7684\u7ba1\u7406\u65b9\u5f0f\u4e0d\u540c\uff0cwiki \u4ee5\u793e\u533a\u4e2d\u4e2a\u4eba\u7684\u52a8\u6001\u5185\u5bb9\u4e3a\u57fa\u7840\uff0c\u652f\u6301\u7ad9\u70b9\u5185\u5bb9\u548c\u7ed3\u6784\u7684\u6709\u673a\u6f14\u8fdb\u3002\u5b83\u5141\u8bb8\u534f\u4f5c\u8005\u540c\u65f6\u8fc5\u901f\u5730\u66f4\u6539\u5185\u5bb9\uff0c\u800c\u4e0d\u4f1a\u5e26\u6765\u8fdb\u7a0b\u6216\u5de5\u4f5c\u6d41\u5f00\u9500\u3002\u5c3d\u7ba1\u8fd9\u79cd\u7279\u70b9\u8feb\u4f7f\u793e\u533a\u53bb", "imagename": "", "infoid": 9482, "category": "technology_web2", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["wiki"]}, {"url": null, "title": "diglog\u9700\u8981\u4e00\u4e2a\u600e\u6837\u7684\u6c1b\u56f4?", "tags": "diglog", "name": "diglog", "posttime": "2006-11-22 16:47:44", "ip": "221.14.253.245", "mark": 27, "note": "<P><A href=\"\">diglog</A> \u5199\u9053 \"</P><BR>\r\n<P>\u7531\u4e8e\u6700\u8fd1\u7ad9\u957f\u6ca1\u6709\u65f6\u95f4\u7ba1\u7406\u4ee5\u53ca\u7528\u6237\u63d0\u4ea4\u4fe1\u606f\u6570\u91cf\u7684\u589e\u52a0,\u51fa\u73b0\u4e86\u4e00\u4e9b\u95ee\u9898:\u5783\u573e\u4fe1\u606f\u589e\u591a,\u591a\u6570blogger\u5927\u91cf\u63d0\u4ea4\u81ea\u5df1\u7f51\u7ad9\u6ca1\u6709\u4ef7\u503c\u7684\u94fe\u63a5,\u8fd8\u6709\u4e00\u4e9b\u7f51\u7ad9\"\u6bcf\u7bc7\u5fc5dig\u8fc7\u6765\",\u90a3\u5e72\u8106\u4f60\u7ed9\u6211\u4eecRSS\u6e90,\u6211\u4eec\u805a\u5408\u8fc7\u6765\u5f97\u4e86!!\u53ef\u80fd\u4f60\u4eec\u662f\u4e3a\u4e86\u5206\u4eab\u4f60\u4eec\u7684\"\u53d1\u73b0\",\u4f46\u662f,\u6211\u4eec\u8fd9\u91cc\u4e0d\u662f\u5206\u4eab\u4e00\u4e9b\"\u8f6c\u8f7d\u5185\u5bb9\",\"\u65e0\u804a\u5185\u5bb9\",\"\u5783\u573e\u5185\u5bb9\". </P>\r\n<P>\u867d\u7136\u7f51\u7528\u6237\u6570\u91cf\u8d8a\u591a\u8d8a\u597d,\u4f46\u6211\u4eec\u5e76\u4e0d\u662f\u8fd9\u6837,\u56e0\u4e3adiglog\u505a\u7684\u662fdigg,\u6211\u4eec\u7684\u539f\u5219\u5c31\u662f\"\u5438\u6536\u8d21\u732e\u597d\u5185\u5bb9\u7684\u7528\u6237,\u575a\u51b3\u62d2\u7edd\u8d21\u732e\u5783\u573e\u7684\u7528\u6237,\u5c01\u6740!\u6ca1\u6709\u4ec0\u4e48\u8bdd\u597d\u8bb2,\u6beb\u4e0d\u5ba2\u6c14\u7684\u8bf4,\u4e00\u8fb9\u51c9\u5feb\u53bb!\",\u6211\u4eec\u4e0d\u60f3\u8ba9diglog\u53d8\u6210365key\u90a3\u6837\u7684\u968f\u5904\u5145\u65a5\u7740\u5783\u573e\u7528\u6237\u548c\u5783\u573e\u5185\u5bb9. </P>\r\n<P>\u53ef\u4ee5\u63d0\u4ea4\u81ea\u5df1\u7684\u535a\u5ba2\u94fe\u63a5\u5230diglog,\u6211\u4eec\u5341\u4e8c\u5206\u6b22\u8fce,\u4f46\u662f,\"\u4e00\u5473\u63d0\u4ea4,\u53cd\u590d\u63d0\u4ea4\"\u7684\u8bdd,\u5f88\u591adiglog\u7684\u53c2\u4e0e\u8005\u4f1a\u611f\u5230\u538c\u70e6,\u751a\u81f3\u611f\u5230\"\u4e0d\u516c\u5e73\",\u8fd9\u6837\u4f1a\u641e\u574fdiglog\u7684\u6c14\u6c1b.</P>\r\n<P>&nbsp;\u5199blog\u6001\u5ea6\u7684\u95ee\u9898\u5c31\u4e0d\u8bf4\u4e86,\u4e2d\u56fd\u5927\u591a\u6570\u4eba\u6839\u672c\u5c31\u6ca1\u6709\u5fc5\u8981\u5199\u4ec0\u4e48blog,\u6bcf\u7bc7blog\u4e0d\u5c31\u662f\u4e09\u8a00\u4e24\u8bed\u5417?\u4e0d\u5c31\u662f\u4e00\u4e2a\u56fe\u7247\u5417?\u4e0d\u5c31\u662f\u4e00\u4e2a\u5c0f\u5c0f\u7684\u53d1\u73b0\u5417?\u4e0d\u5c31\u662f\u8f6c\u8f7d\u70b9\u4e1c\u897f\u5417?\u4e0d\u5c31\u662f\u60f3\u8ba9\u522b\u4eba\u77e5\u9053\u4f60\u90a3\u70b9\u4e1c\u897f\u5417?\u6b63\u662f\u8fd9\u4e2a\u539f\u56e0,\u6839\u672c\u5c31\u6ca1\u6709\u5fc5\u8981\u5199blog,\u8fc7\u6765dig\u6b63\u5408\u9002,\u4e00\u4e2a\u94fe\u63a5+\u4e09\u8a00\u4e24\u8bed\u7684\u63cf\u8ff0+\u4e00\u4e2a\u7b80\u5355\u7684\u56fe\u7247!\u5c31\u8fd9\u4e9b\u4e86! </P><BR>\r\n<P>\u8bdd\u8bed\u6709\u4e9b\u5730\u65b9\u4e0d\u5f53\u548c\u504f\u6fc0,\u89c1\u8c05!\"</P>", "imagename": null, "infoid": 9476, "category": "technology_other", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["diglog"]}, {"url": "http://blog.egotong.com/html/code.php.dvbbs.net.v1.0.0.html", "title": "\u52a8\u7f51\u8bba\u575bPHP v1.0.0\u6b63\u5f0f\u7248(\u9644\u5347\u7ea7\u5305)", "tags": "\u52a8\u7f51\u8bba\u575b ", "name": "ramble", "posttime": "2006-11-22 15:37:23", "ip": "218.79.196.36", "mark": 5, "note": "PHP\u7248\u5728\u4e00\u5b9a\u7a0b\u5ea6\u4e0a\u6211