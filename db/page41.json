ec6bd337223b.jpg", "infoid": 495290, "category": "culture_photograph", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "culture", "via": null, "real_tags": null}, {"url": "http://fotomen.cn/2011/09/mike-yama/", "title": "\u9ea6\u514b\u30fb\u5c71\u4e0b\uff1a\u4e2d\u56fd\u6444\u5f71\u5e08\u4f5c\u54c1\u592a\u5047", "tags": "\u6444\u5f71 \u4eba\u50cf", "name": "fotomen", "posttime": "2011-09-26 09:32:29", "ip": "218.249.83.129", "mark": 0, "note": "\u5934\u53d1\u7070\u767d\u53c8\u8737\u66f2\uff0c\u8eab\u6750\u5fae\u5fae\u53d1\u798f\uff0c\u8457\u540d\u6444\u5f71\u5e08\u9ea6\u514b&#183\uff1b\u5c71\u4e0b\u7aef\u5750\u5728\u90a3\u2015\u2015\u5317\u4eac\u5fb7\u7a3b\u6559\u80b2\u673a\u6784\u7684\u5de5\u4f5c\u4eba\u5458\u90fd\u79f0\u4ed6\u4e3a\u5927\u5e08\u3002\u4f5c\u4e3a\u5fb7\u7a3b\u53d1\u8d77\u768450\u4f4d\u884c\u4e1a\u5927\u5e08\u7684\u4e00\u4efd\u5b50\uff0c\u5c71\u4e0b\u5df2\u63a5\u53d7\u590d\u65e6\u5927\u5b66\u4e0a\u6d77\u89c6\u89c9\u827a\u672f\u5b66\u9662\u9881\u53d1\u7684\u6559\u6388\u8058\u4e66\uff0c\u5e76\u4e0e\u5de5\u4f5c\u4eba\u5458\u4e00\u540c\u53c2\u89c2\u8003\u5bdf\u4e86\u4ed6\u4f4d\u4e8e\u5fb7\u7a3b\u4e0a\u6d77\u521b\u610f\u4ea7\u4e1a\u96c6\u7fa4\u7684\u5de5\u4f5c\u5ba4\u3002\u6628\u65e5\uff0c\u4ed6\u63a5\u53d7\u4e86\u6caa\u4e0a\u5a92\u4f53\u7684\u91c7\u8bbf\u3002\u4f5c\u4e3a\u552f\u4e00\u4e00\u4e2a\u4e3a\u300a\u56fd\u5bb6\u5730\u7406\u6742\u5fd7\u300b\u670d\u52a1\u8d85\u8fc730\u5e74\u7684\u6444\u5f71\u5e08\uff0c\u5e74\u8fc760\u7684\u5c71\u4e0b\u5c06\u628a\u7ecf\u9a8c\u4f20\u6388\u7ed9\u6caa\u4e0a\u7684\u5b66\u751f\u4eec\u3002\u800c\u4f5c\u4e3a\u4e00\u4e2a\u4e1a\u5185\u524d\u8f88\uff0c\u4ed6\u4e5f\u540c\u6837\u5173\u6ce8\u4e2d\u56fd\u6444\u5f71\u4eba\u58eb\u7684\u4f5c\u54c1\uff0c\u5e76\u76f4\u8a00\u4e0d\u8bb3\u5730\u6307\u51fa\u4ed6\u4eec\u7684\u4f5c\u54c1\u592a\u5047\u3002\r\n\r\n\u9ea6\u514b&#183\uff1b\u5c71\u4e0b\u662f\u7528\u7167\u7247\u8bb0\u5f55\u6545\u4e8b\u7684\u4eba\uff0c\u4ed6\u4e3a\u7f8e\u56fd\u300a\u56fd\u5bb6\u5730\u7406\u6742\u5fd7\u300b\u62cd\u6444\u7684\u9009\u9898\u5305\u62ec\uff1a\u300a\u9a6c\u53ef&#183\uff1b\u6ce2\u7f57\u300b\u3001\u300a\u957f\u57ce\u300b\u3001\u300a\u6e44\u516c\u6cb3\u300b\u3001\u300a\u90d1\u548c\u4e0b\u897f\u6d0b\u300b\u7b49\u5bcc\u6709\u5386\u53f2\u6df1\u5ea6\u7684\u5927\u578b\u9898\u6750\u3002\u56e0\u4e3a\u751a\u5c11\u6709\u4eba\u4f1a\u6177\u6168\u5230\u7ed9\u5e74\u8f7b\u4eba\u6d89\u8db3\u9ad8\u7aef\u6444\u5f71\u5708\u7684\u673a\u4f1a\uff0c\u4e8e\u662f\u5317\u4eac\u5fb7\u7a3b\u96c6\u56e2\u5c31\u521b\u529e\u4e86\u4e00\u4e2a\u5927\u5e08\u5de5\u4f5c\u5ba4\uff0c\u5438\u7eb3\u4e86\u6765\u81ea\u52a8\u6f2b\u3001\u5efa\u7b51\u3001\u5de5\u4e1a\u3001\u6444\u5f71\u7b49\u884c\u4e1a\u768450\u4f4d\u5927\u5e08\uff0c\u8bf7\u4ed6\u4eec\u6765\u4e2d\u56fd\u5e38\u9a7b\uff0c\u4e3a\u4ed6\u4eec\u9009\u62d4\u5b66\u751f\uff0c\u8ba9\u5b66\u751f\u8ddf\u968f\u5927\u5e08\u5de5\u4f5c\u5e76\u83b7\u5f97\u70b9\u62e8\u3002\u5c71\u4e0b\u5e0c\u671b\u501f\u6b64\u673a\u4f1a\u628a\u81ea\u5df1\u591a\u5e74\u7684\u7ecf\u9a8c\u4f20\u6388\u7ed9\u5b66\u751f\u4eec\uff0c\u201c\u6211\u7684\u7ecf\u9a8c\u662f\uff0c\u6444\u5f71\u4e00\u5b9a\u8981\u8d70\u5230\u91ce\u5916\u8fdb\u884c\u5b9e\u8df5\uff0c\u518d\u56de\u6559\u5ba4\u8fdb\u884c\u5c55\u793a\uff0c\u5927\u5bb6\u4e00\u8d77\u5206\u6790\u662f\u5426\u6709\u53e6\u5916\u7684\u62cd\u6444\u65b9\u6cd5\uff0c\u7136\u540e\u91cd\u65b0\u62cd\u8fc7\u3002\u53ea\u9700\u4e00\u5468\u7684\u5b9e\u8df5\uff0c\u4ed6\u4eec\u7684\u5b66\u4e60\u6548\u679c\u5c06\u5448\u66f2\u7ebf\u4e0a\u5347\u201d\u3002\r\n\r\n\u8c08\u5230\u4e2d\u56fd\u6444\u5f71\u5e08\u7684\u6444\u5f71\u4f5c\u54c1\uff0c\u5c71\u4e0b\u8bf4\uff1a\u201c\u6211\u5728\u4e2d\u56fd\u89c2\u5bdf\u5f88\u4e45\uff0c\u53d1\u73b0\u4e2d\u56fd\u6444\u5f71\u5e08\u62cd\u7684\u4e1c\u897f\u662f\u5047\u7684\uff0c\u8fc7\u5ea6\u6280\u5de7\u6027\u7684\u4e1c\u897f\u592a\u591a\uff0c\u5927\u591a\u662f\u6446\u62cd\u548c\u8bbe\u8ba1\u7684\u573a\u666f\uff0c\u800c\u4f5c\u4e3a\u4e00\u4e2a\u56fd\u9645\u6444\u5f71\u5e08\u662f\u4e0d\u80fd\u9884\u7f6e\u573a\u666f\u7684\uff0c\u4e00\u5b9a\u8981\u628a\u771f\u5b9e\u7684\u4e1c\u897f\u7ed9\u5927\u5bb6\u3002\u6211\u4e3a\u300a\u56fd\u5bb6\u5730\u7406\u6742\u5fd7\u300b\u5de5\u4f5c\u90fd\u8981\u63d0\u524d\u627f\u8bfa\uff0c\u6240\u62cd\u6444\u7684\u90fd\u662f\u771f\u5b9e\u7684\u573a\u666f\uff0cPS\uff08photoshop\uff09\u8fd9\u79cd\u6280\u672f\u5c3d\u91cf\u4e0d\u7528\u3002\u6bd4\u5982\uff0c\u6211\u7b2c\u4e00\u6b21\u770b\u5230\u4e5d\u5be8\u6c9f\u662f\u5728\u4e66\u4e2d\uff0c\u89c9\u5f97\u90a3\u5f20\u56fe\u7247\u597d\u7f8e\uff0c\u53ef\u662f\u5230\u90a3\u91cc\u53d1\u73b0\u6839\u672c\u4e0d\u662f\u90a3\u4e2a\u6837\u5b50\u7684\uff0c\u7167\u7247\u90fd\u88ab\u8fc7\u5ea6PS\u4e86\u3002\u6211\u60f3\u4f20\u9012\u7ed9\u4e2d\u56fd\u5b66\u751f\u7684\u662f\uff0c\u4e0d\u662f\u4e3a\u8c01\u5de5\u4f5c\u5c31\u7b26\u5408\u8c01\u7684\u6807\u51c6\uff0c\u6211\u5f88\u60f3\u628a\u8ffd\u6c42\u5b9e\u9645\u62cd\u6444\u7684\u7cbe\u795e\u4f20\u9012\u7ed9\u4ed6\u4eec\uff0c\u751a\u81f3\u662f\u4e2d\u56fd\u7684\u6444\u5f71\u5e08\u4eec\u201d\u3002\r\n\r\n\u4f5c\u4e3a\u5f53\u4ee3\u8457\u540d\u6444\u5f71\u5927\u5e08\u4e4b\u4e00\uff0c\u9ea6\u514b&#183\uff1b\u5c71\u4e0b\u4ece1979\u5e74\u5f00\u59cb\u6210\u4e3a\u7f8e\u56fd\u300a\u56fd\u5bb6\u5730\u7406\u6742\u5fd7\u300b\u7684\u56fa\u5b9a\u64b0\u7a3f\u4eba\u548c\u7b7e\u7ea6\u6444\u5f71\u5e08\uff0c\u81f3\u4eca\u5df2\u7ecf32\u5e74\uff0c\u4ed62001\u5e74\u520a\u767b\u5728\u300a\u56fd\u5bb6\u5730\u7406\u6742\u5fd7\u300b\u4e0a\u7684\u300a\u4e2d\u56fd\u4e4b\u65c5\u300b\u83b7\u5f97\u8be5\u6742\u5fd7\u6700\u4f73\u6545\u4e8b\u5956\u548c\u6700\u4f73\u6444\u5f71\u5956\uff0c\u201c\u300a\u56fd\u5bb6\u5730\u7406\u6742\u5fd7\u300b\u7ed9\u4e86\u6444\u5f71\u5e08\u5145\u8db3\u7684\u65f6\u95f4\u3001\u91d1\u94b1\u548c\u60c5\u611f\uff0c\u5374\u6ca1\u7ed9\u4e00\u6b21\u5141\u8bb8\u5931\u8d25\u7684\u673a\u4f1a\u3002\u5982\u679c\u4f60\u7684\u4f5c\u54c1\u88ab\u5426\u5b9a\u4e86\uff0c\u5c31\u4e0d\u4f1a\u518d\u6709\u7b2c\u4e8c\u6b21\u673a\u4f1a\uff0c\u6240\u4ee5\u6444\u5f71\u5e08\u8981\u5c3d\u6700\u5927\u7684\u52aa\u529b\u5b8c\u6210\u597d\u5de5\u4f5c\u201d\u3002\u9ea6\u514b&#183\uff1b\u5c71\u4e0b\u8bf4\u81ea\u5df1\u62cd\u6444\u4e00\u4e2a\u4e13\u9898\u6700\u5c11\u75286\u4e2a\u793c\u62dc\uff0c\u6700\u957f\u5982\u300a\u90d1\u548c\u300b\u7528\u4e86\u4e24\u5e74\uff1b\u62cd\u6444\u4e00\u5f20\u201c\u6536\u5272\u201d\u7528\u4e09\u4e2a\u5c0f\u65f6\uff1b\u6bcf\u5e74\u67096\u4e2a\u6708\u662f\u5728\u5916\u9762\u5de5\u4f5c\uff0c\u548c\u5bb6\u4eba\u8054\u7cfb\u53ea\u80fd\u7528\u6d77\u4e8b\u536b\u661f\u7535\u8bdd\u548c\u7f51\u7edc\u89c6\u9891\u3002\u5c71\u4e0b\u8bf4\uff1a\u201c\u4f60\u4eec\u770b\u5230\u7684\u5f88\u53ef\u80fd\u662f\u6700\u540e\u4e00\u4ee3\u6444\u5f71\u5e08\uff0c\u4e0d\u4f1a\u518d\u6709\u8fd9\u6837\u7684\u5de5\u4f5c\u6a21\u5f0f\uff0c\u4e00\u5207\u90fd\u53ef\u4ee5\u5728\u7f51\u7edc\u83b7\u5f97\u3002\u4e13\u4e1a\uff0c\u5df2\u7ecf\u88ab\u6280\u672f\u627c\u6740\u4e86\u3002\u8d8a\u6765\u8d8a\u591a\u7684\u6444\u5f71\u5de5\u4f5c\u5ba4\u5f00\u8d77\u6765\uff0c\u8d8a\u6765\u8d8a\u591a\u7684\u7167\u7247\u4ee5\u65b0\u5a92\u4f53\u827a\u672f\u7684\u5f62\u5f0f\u8d70\u8fdb\u7f8e\u672f\u9986\u2026\u2026\u201d", "imagename": "38a82f6a6e7543e1b8a6556a773ddc1d.jpg", "infoid": 495045, "category": "culture_people", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "culture", "via": null, "real_tags": ["\u6444\u5f71", "\u4eba\u50cf"]}, {"url": "http://xjeek.com/?p=1603", "title": "\u901a\u8fc7\u65f6\u5149\u7684\u96a7\u9053\u2013\u827a\u672f\u4eba\u50cf\u62fc\u5e16", "tags": "\u521b\u610f \u8bbe\u8ba1 \u65f6\u5c1a \u827a\u672f \u6444\u5f71", "name": "jasmine8gu", "posttime": "2011-09-25 23:03:50", "ip": "174.112.19.4", "mark": 0, "note": "\u8fd9\u4e00\u7ec4\u4f5c\u54c1\u6765\u81ea\u745e\u5178\u7684\u827a\u672f\u5bb6George Chamoun. \u6bcf\u4e00\u5e45\u56fe\u50cf\u90fd\u662f\u7531\u4e0d\u540c\u7684\u4eba\u7ec4\u6210, \u5e76\u4e14\u6765\u81ea\u4e0d\u540c\u7684\u65f6\u4ee3.\u636e\u4f5c\u8005\u8bf4\u8981\u82b1\u5927\u91cf\u7684\u65f6\u95f4\u5bfb\u627e\u627e\u5408\u9002\u7684\u7167