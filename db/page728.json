7ad9\u8fd8\u662f\u7535\u5b50\u5546\u52a1", "tags": "\u5e03\u6613\u7f51 \u793e\u533a\u7f51\u8d2d", "name": "movtimes", "posttime": "2008-12-02 09:38:29", "ip": "60.217.218.15", "mark": 3, "note": "\u521d\u8bc6\u5e03\u6613\u7f51\u65f6\uff0c\u662f\u7ecf\u670b\u53cb\u4ecb\u7ecd\u3002\u7b2c\u4e00\u5370\u8c61\u7ed9\u6211\u7684\u53ea\u662f\u4e00\u4e2a\u666e\u901a\u7684web2.0\u793e\u533a\u3002\u7b80\u5355\u7684\u7ed3\u6784\u5b89\u6392\uff0c\u793e\u533a\u3001\u57ce\u5e02\u3001\u901b\u8857\u3002\u5728\u6d4f\u89c8\u8fc7\u540e\u624d\u53d1\u73b0\u662f\u6697\u85cf\u7384\u673a\u7684\u3002\u793e\u533a\u91cc\u9762\u7684\u5185\u5bb9\u662f\u9ecf\u5408\u6027\u975e\u5e38\u9ad8\u7684\u6e38\u620f\u97f3\u4e50\u6587\u5b57\u56fe\u7247\u53ca\u95ee\u9898\u70b9\u70b9\u540d\uff0c\u4e92\u52a8\u6027\u6bd4\u8f83\u5f3a\u7684\u5e94\u8be5\u662f\u95ee\u9898\u70b9\u70b9\u540d\uff0c\u6709\u8da3\u7b80\u5355\u3002\u5f88\u5bb9\u6613\u5f15\u8d77\u7f51\u7ad9\u7684\u6df1\u5ea6\u9605\u8bfb.\u5c45\u5e03\u6613\u7684\u6570\u636e\u7edf\u8ba1,\u9875\u9762\u65f6\u95f4\u6700\u957f\u7684\u8981\u6570\u6e38\u620f\u9875\u9762,\u552f\u4e00\u4e0d\u8db3\u7684\u5bf9\u65b9\u662f\u6ca1\u6709\u4ea7\u751f\u6df1\u5ea6\u7684\u73a9\u5bb6\u4e92\u52a8.\u9875\u9762\u6e38\u620f\u4e0e\u5927\u578b\u7f51\u6e38,\u5f53\u7136\u662f\u5404\u6709\u5229\u5f0a\u7684.\u4ece\u6574\u4e2a\u6e38\u620f\u5e02\u573a\u53bb\u770b,\u4e24\u8005\u4e5f\u662f\u4e0d\u53ef\u6216\u7f3a\u7684.\u5728\u9884\u6d4b\u4e2d\u56fd\u7f51\u7edc\u6e38\u620f\u4ea7\u4e1a\u53d1\u5c55\u8d8b\u52bf\u65f6\u79f0\uff0c\u4eca\u5e74\u5c06\u662f\u7f51\u9875\u6e38\u620f\u5e02\u573a\u89c4\u6a21\u201c\u4e95\u55b7\u201d\u7684\u4e00\u5e74\uff0c\u589e\u957f\u7387\u5c06\u4f1a\u8fbe\u5230400%\uff0c\u7528\u6237\u89c4\u6a21\u5c06\u4ee5260%\u7684\u589e\u957f\u7387\u98d9\u5347.\u9875\u9762\u6e38\u620f\u6d3b\u6cfc/\u7b80\u5355,\u79cd\u7c7b\u8f83\u591a,\u66f4\u9002\u5408\u73b0\u4ee3\u4eba\u7684\u751f\u6d3b\u6d88\u9063.\u5f00\u5fc3\u7f51\u4e0e\u5e03\u6613\u7f51\u7684\u6e38\u620f\u6848\u4f8b\u4e5f\u8bc1\u660e\u4e86\u5e02\u573a\u7684\u9700\u6c42.\u518d\u6765\u770b\u4e0b\u57ce\u5e02\u7248\u5757,\u6bcf\u4e2a\u57ce\u5e02\u7684\u7528\u6237\u80fd\u7b2c\u4e00\u65f6\u95f4\u4e86\u89e3\u5230\u8fd9\u4e2a\u57ce\u5e02\u7684\u7528\u6237\u52a8\u6001,\u5c0f\u7ec4/\u5e7f\u64ad/\u6d3b\u52a8/\u540d\u4eba\u5802/\u7269\u54c1,\u57ce\u5e02\u7248\u5757\u66f4\u8d34\u8fd1\u4e8e\u771f\u5b9e.\u7528\u6237\u53ef\u4ee5\u5168\u65b9\u4f4d\u7684\u4ea7\u751f\u4e92\u52a8.\u8fd9\u662f\u5176\u4ed6\u793e\u533a\u6240\u4e0d\u80fd\u771f\u6b63\u89e3\u51b3\u7684\u95ee\u9898.\u4e2a\u4eba\u6700\u770b\u597d\u7684\u662f\u57ce\u5e02\u91cc\u7684\u6d3b\u52a8\u4e0e\u7269\u54c1.\u5bf9\u4e8e&amp;quot\uff1b\u7269\u54c1&amp;quot\uff1b\u7248\u5757,\u5176\u5b9e\u5c31\u662f\u540c\u57ce\u7684\u5206\u7c7b\u4fe1\u606f.\u800c\u5e03\u6613\u4fa7\u91cd\u7684\u4ec5\u4ec5\u662f\u7269\u54c1.\u8fd9\u70b9\u611f\u89c9\u4e0d\u591f\u5168\u9762.\u540d\u4eba\u5802\u662f\u5e03\u6613\u6bd4\u8f83\u7279\u6b8a\u7684\u7248\u5757,\u8fd9\u91cc\u7684\u540d\u4eba\u90fd\u5c5e\u4e8e\u672c\u57ce\u5e02,\u4f46\u53ea\u6709\u90e8\u5206\u4eba\u80fd\u591f\u4ea7\u751f\u660e\u661f\u6548\u5e94\u7684\u4f20\u64ad\u6269\u6563.\u901b\u8857,B2C,\u4e0d\u540c\u4e8e\u963f\u91cc\u5df4\u5df4,\u5f53\u5f53\u7f51.\u56e0\u4e3a\u4ed6\u4eec\u662f\u540c\u57ce\u7684.\u89e3\u51b3\u4e86\u7535\u5b50\u5546\u52a1\u7684\u4e24\u4e2a\u81f4\u547d\u7f3a\u70b9,\u4fe1\u4efb\u53ca\u914d\u9001.\u6dd8\u5b9d\u7ebf\u4e0b\u5b9e\u4f53\u5e97\u53ca\u5404\u79cd\u652f\u4ed8\u5e73\u53f0\u4e5f\u53ea\u662f\u89e3\u51b3\u4e86\u4fe1\u4efb\u95ee\u9898.\r\n\r\n\u4e00\u76f4\u5728\u601d\u8003\u5e03\u6613\u7f51\u7684\u6a21\u5f0f\u5230\u5e95\u662f\u5c5e\u4e8e\u4ec0\u4e48,\u793e\u4ea4\u7f51\u7edc,B2C\u7684\u5546\u57ce,\u8fd8\u662f\u793e\u533a\u7535\u5b50\u5546\u52a1,\u8fd8\u662f\u4ec0\u4e48?\u6216\u8bb8\u5e03\u6613\u5e94\u8be5\u6709\u4e00\u4e2a\u65b0\u7684\u6a21\u5f0f\u540d\u79f0.\u4ed6\u6709\u793e\u533a/\u57ce\u5e02(\u540c\u57ce)/\u5206\u7c7b\u4fe1\u606f/\u5546\u57ce...\r\n\r\n\u5185\u5bb9\u53ca\u6a21\u5f0f,\u5e03\u6613\u7f51\u628aweb2.0\u7684\u5e02\u573a\u4ef7\u503c\u662f\u5426\u653e\u5230\u4e86\u6700\u5927?\r\n\r\n\u5185\u5bb9\u89c9\u5f97\u4e86\u7f51\u7ad9\u5e02\u573a\u4ef7\u503c\u5b9a\u4f4d,\u4ed4\u7ec6\u7684\u89c2\u5bdf\u8fd9\u4e9b\u793e\u4ea4\u7f51\u7edc\u670d\u52a1\u7684\u521d\u521b\u56e2\u961f\u4f60\u4f1a\u53d1\u73b0\uff0c\u56e2\u961f\u672c\u8eab\u4ece\u54ea\u4e2a\u793e\u4f1a\u9636\u5c42\uff08\u6216\u65cf\u7fa4\uff09\u51fa\u8eab\u7684\uff0c\u6df1\u523b\u7684\u5f71\u54cd\u8fd9\u4e2a\u793e\u4ea4\u7f51\u7edc\u7684\u65cf\u7fa4\u8d70\u5411\u3002\r\n\r\n\u3000\u3000\u793e\u4ea4\u7f51\u7edc\u59cb\u7ec8\u5e26\u7740\u5782\u76f4\u6027\u7684\u672c\u8d28\uff0c\u7f51\u7edc\u95f4\u4f9d\u65e7\u5b58\u5728\u9694\u9602\u4e0e\u4e0d\u4e92\u901a\u6027\uff0c\u6bcf\u4e2a\u4eba\u5fc5\u987b\u8981\u62e5\u6709\u591a\u9762\u5b54\u624d\u80fd\u5e94\u5bf9\u5404\u81ea\u7f51\u7edc\u4e2d\u7684\u89d2\u8272\u3002\u5e03\u6613\u7f51\u7684\u672a\u6765\u662f\u5426\u63a8\u51fa\u5f00\u653e\u5e73\u53f0,\u5f00\u653e\u5e73\u53f0\u662f\u5426\u80fd\u6709\u6548\u7684\u7f13\u89e3\u8fd9\u4e00\u75c7\u7ed3\uff0c\u62ed\u76ee\u4ee5\u5f85\u3002", "imagename": "", "infoid": 107818, "category": "technology_web2", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u5e03\u6613\u7f51", "\u793e\u533a\u7f51\u8d2d"]}, {"url": "http://my.dongua.com/photo/blog!entry/2693.entry", "title": "\u65e5\u672c\u7684\u996d\u76d2\u8bbe\u8ba1\u6587\u5316 (20P)", "tags": "\u996d\u76d2 ", "name": "lomomo", "posttime": "2008-12-02 09:22:00", "ip": "219.136.215.61", "mark": 3, "note": "\u770b\u6765\u65e5\u672c\u4eba\u5728\u53ef\u7231\u65b9\u9762\u771f\u7684\u597d\u6709\u5929\u8d4b\uff0c\u8fde\u5403\u4e2a\u996d\u76d2\u90fd\u8981\u5f04\u5f97\u8fd9\u4e48\u53ef\u7231\u3002", "imagename": "65d09af8cb8b4ce99642419706e1f312.jpg", "infoid": 107810, "category": "technology_design", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u996d\u76