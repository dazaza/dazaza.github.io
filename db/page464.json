[{"url": "http://www.dubox.cn/show.php?tid=273", "title": "30\u591a\u4e2a\u6f02\u4eae\u7684\u8868\u683c\u8bbe\u8ba1\u548c\u4e00\u4e9b\u76f8\u5173\u7684javascript_\u8bbe\u8ba1/\u521b\u610f", "tags": "\u8868\u683c ", "name": "royan", "posttime": "2009-08-03 10:09:25", "ip": "218.86.36.219", "mark": 0, "note": "\u8868\u683c\u662f\u4e00\u79cd\u5f88\u597d\u7684\u7ec4\u7ec7\u548c\u4ecb\u7ecd\u4fe1\u606f\u7684\u65b9\u5f0f,\u6211\u4eec\u5f88\u591a\u5730\u65b9\u90fd\u4f1a\u7528\u5230\u4ed6,\u5982\u679c\u4ef7\u683c,\u670d\u52a1,\u4ea7\u54c1\u7b49.\u5b83\u53ef\u4ee5\u6839\u636e\u4e0d\u540c\u7684\u5185\u5bb9,\u66f4\u597d\u7684\u5b89\u6392\u6570\u636e\u7684\u663e\u793a..", "imagename": "668893c466a84a778222c5e0faa6cd8e.png", "infoid": 217170, "category": "technology_design", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u8868\u683c"]}, {"url": "http://news.163.com/09/0802/13/5FNC3QPL000120GR.html", "title": "\u4e1a\u4f59\u5929\u6587\u5b66\u5bb6\u4e5f\u6709\u5927\u53d1\u73b0", "tags": "\u6728\u661f \u5929\u6587\u5b66\u5bb6 \u5730\u7403 \u5b87\u5b99 ", "name": "303729213", "posttime": "2009-08-02 17:04:04", "ip": "113.104.16.102", "mark": 0, "note": "http://www.mov99.cn 2009-08-02 12:43:00\u3000\u6765\u6e90: \u7f51\u6613\r\n       7\u6708\u4e0b\u65ec\uff0c\u6728\u661f\u906d\u9047\u5176\u4ed6\u661f\u4f53\u649e\u51fb\uff0c\u5728\u5357\u6781\u9644\u8fd1\u843d\u4e0b\u9ed1\u8272\u75a4\u6591\uff0c\u649e\u51fb\u5904\u4e0a\u7a7a\u7684\u6728\u661f\u5927\u6c14\u5c42\u51fa\u73b0\u4e00\u4e2a\u5730\u7403\u5927\u5c0f\u7684\u7a7a\u6d1e\u3002\u6709\u610f\u601d\u7684\u662f\u7387\u5148\u89c2\u6d4b\u5230\u8fd9\u6b21\u6728\u661f\u649e\u51fb\u7684\u5e76\u975e\u4e13\u4e1a\u5929\u6587\u5b66\u5bb6\uff0c\u800c\u662f\u6765\u81ea\u4e8e\u6fb3\u5927\u5229\u4e9a\u7684\u4e00\u4f4d\u5929\u6587\u5b66\u7231\u597d\u8005\u5b89\u4e1c\u5c3c&#183\uff1b\u97e6\u65af\u5229\uff0c\u4ed6\u901a\u8fc7\u8bbe\u5728\u81ea\u5df1\u5bb6\u540e\u9662\u7684\u4e00\u53f0\u671b\u8fdc\u955c\u62cd\u6444\u5230\u6728\u661f\u906d\u649e\u7684\u7167\u7247\uff0c\u5e76\u5c06\u5176\u516c\u4e4b\u4e8e\u7f51\u4e0a\u3002\u4e1a\u4f59\u5929\u6587\u7231\u597d\u8005\u600e\u4e48\u4f1a\u8d85\u8d8a\u4e13\u4e1a\u5929\u6587\u5b66\u5bb6\uff1f\u5176\u5b9e\uff0c\u4e1a\u4f59\u5929\u6587\u7231\u597d\u8005\u6709\u7740\u81ea\u8eab\u7684\u4f18\u52bf\uff0c\u4ed6\u4eec\u80fd\u957f\u65f6\u95f4\u8ddf\u8e2a\u4e00\u4e2a\u661f\u4f53\uff0c\u540c\u65f6\u4ed6\u4eec\u4e5f\u53ef\u4ee5\u4e13\u7528\u4e00\u53f0\u671b\u8fdc\u955c\uff0c\u56e0\u6b64\u5728\u832b\u832b\u5b87\u5b99\u4e2d\u53ea\u8981\u4f60\u8fd0\u6c14\u591f\u597d\uff0c\u4e1a\u4f59\u5929\u6587\u7231\u597d\u8005\u4e5f\u4f1a\u6709\u60ca\u4eba\u53d1\u73b0\u3002\r\n\r\n\u3000\u3000\u5728\u81ea\u5bb6\u540e\u9662\u89c2\u6d4b\u5230\u6728\u661f\u649e\u51fb\r\n\r\n\u3000\u3000\u6728\u661f\u65b0\u51fa\u73b0\u7684\u8fd9\u5904\u7a7a\u6d1e\u7531\u6fb3\u5927\u5229\u4e9a\u4e1a\u4f59\u5929\u6587\u7231\u597d\u8005\u5b89\u4e1c\u5c3c&#183\uff1b\u97e6\u65af\u5229\u4e8e\u672c\u670820\u65e5\u4e0a\u5348\u4ece\u6fb3\u5927\u5229\u4e9a\u6700\u521d\u89c2\u6d4b\u53d1\u73b0\u3002\u7f8e\u56fd\u822a\u5929\u5c40\u4f4d\u4e8e\u52a0\u5229\u798f\u5c3c\u4e9a\u5dde\u7684\u55b7\u6c14\u63a8\u8fdb\u5b9e\u9a8c\u5ba4\u968f\u540e\u5c55\u5f00\u89c2\u6d4b\u6d3b\u52a8\uff0c\u5e76\u501f\u52a9\u8bbe\u4e8e\u590f\u5a01\u5937\u7684\u7a7a\u95f4\u7ea2\u5916\u671b\u8fdc\u8bbe\u5907\u6355\u6349\u5230\u4e86\u6728\u661f\u7a7a\u6d1e\u53ca\u75a4\u75d5\u9759\u6001\u753b\u9762\u3002\r\n\r\n\u3000\u3000\u97e6\u65af\u5229\u73b0\u5e7444\u5c81\uff0c\u6b63\u4e1a\u662f\u4e00\u540d\u8ba1\u7b97\u673a\u7a0b\u5e8f\u7f16\u5199\u5458\u3002\u6839\u636e\u6fb3\u5927\u5229\u4e9a\u5a92\u4f53\u62a5\u9053\uff0c\u97e6\u65af\u5229\u4ece\u5c0f\u5c31\u559c\u6b22\u5929\u6587\u89c2\u6d4b\uff0c\u6b64\u6b21\u53d1\u73b0\u6728\u661f\u7a7a\u6d1e\u7684\u5de5\u5177\u662f\u67b6\u8bbe\u5728\u4ed6\u5bb6\u540e\u9662\u5185\u7684\u4e00\u53f014\uff0e5\u82f1\u5bf8\u6298\u53cd\u5c04\u671b\u8fdc\u955c\u3002\r\n\r\n\u3000\u3000\u5176\u5b9e\uff0c\u97e6\u65af\u5229\u5dee\u70b9\u9519\u8fc7\u8fd9\u6b21\u5b9d\u8d35\u673a\u4f1a\u3002\u5c31\u5728\u4ed6\u89c2\u6d4b\u5230\u649e\u51fb\u524d\u7684\u51e0\u4e2a\u5c0f\u65f6\uff0c\u7531\u4e8e\u5929\u6c14\u6761\u4ef6\u5f88\u7cdf\u7cd5\uff0c\u4ed6\u5dee\u70b9\u5c31\u628a\u671b\u8fdc\u955c\u5173\u6389\uff0c\u4e0d\u8fc7\u540e\u6765\u6539\u53d8\u4e86\u4e3b\u610f\uff0c\u53ea\u662f\u81ea\u5df1\u4f11\u606f\u4e86\u534a\u4e2a\u5c0f\u65f6\uff0c\u800c\u6ca1\u6709\u8ba9\u671b\u8fdc\u955c\u4f11\u606f\uff0c\u671b\u8fdc\u955c\u4e0a\u7684\u6210\u50cf\u8bbe\u5907\u7ee7\u7eed\u8fd0\u8f6c\u3002\u5f53\u97e6\u65af\u5229\u56de\u6765\u7684\u65f6\u5019\uff0c\u4ed6\u53d1\u73b0\u6728\u661f\u7684\u5357\u6781\u533a\u57df\u4e0a\u6709\u4e00\u4e2a\u9ed1\u70b9\uff0c\u201c\u6211\u76f8\u4fe1\u5df2\u7ecf\u89c2\u5bdf\u5230\u65b0\u7684\u4e1c\u897f\uff0c\u5728\u4e24\u5929\u4e4b\u524d\u6211\u66fe\u7ecf\u62cd\u6444\u8fc7\u649e\u51fb\u533a\u57df\u7684\u7167\u7247\uff0c\u5f53\u65f6\u6ca1\u6709\u53d1\u73b0\u4efb\u4f55\u5f02\u5e38\u7684\u9ed1\u70b9\uff0c\u4f46\u73b0\u5728\u5df2\u7ecf\u6709\u4e86\u3002\u201d\u97e6\u65af\u5229\u5728\u7f51\u7edc\u4e0a\u520a\u767b\u7684\u62cd\u6444\u8bb0\u5f55\u4e2d\u8fd9\u6837\u5199\u9053\u3002\u97e6\u65af\u5229\u8bf4\uff0c\u4e00\u5f00\u59cb\u539f\u672c\u8fd8\u4ee5\u4e3a\u201c\u9ed1\u70b9\u201d\u662f\u6728\u661f\u7684\u201c\u6781\u66b4\u201d\uff0c\u4f46\u968f\u7740\u6728\u661f\u81ea\u8f6c\uff0c\u4ed6\u53d1\u73b0\u9ed1\u70b9\u4e3a\u7acb\u4f53\u7a7a\u6d1e\u72b6\uff0c\u968f\u5373\u63a8\u7ffb\u4e86\u201c\u6781\u66b4\u201d\u731c\u6d4b\u8f6c\u800c\u5224\u5b9a\u4e3a\u649e\u51fb\u75d5\u8ff9\u3002\r\n\r\n\u3000\u3000\u4e1a\u4f59\u5929\u6587\u7231\u597d\u8005\u6709\u4e0d\u5c11\u4f18\u52bf\r\n\r\n\u3000\u3000\u6728\u661f\u88ab\u649e\u51fa\u5730\u7403\u5927\u4e2a\u6d1e\uff0c\u8fd9\u4e5f\u7b97\u5f97\u4e0a\u662f\u4e2a\u6bd4\u8f83\u5c11\u89c1\u7684\u5929\u8c61\u5947\u89c2\u3002\u4eba\u4eec\u597d\u5947\u7684\u662f\u4e3a\u4ec0\u4e48\u4e0d\u662f\u4e13\u4e1a\u673a\u6784\u800c\u662f\u4e00\u4e2a\u4e1a\u4f59\u5929\u6587\u7231\u597d\u8005\u9996\u5148\u89c2\u6d4b\u5230\u8fd9\u4e00\u5929\u8c61\uff0c\u90a3\u4e9b\u4e13\u4e1a\u5929\u6587\u5b66\u5bb6\u5230\u5e95\u90fd\u5e72\u4ec0\u4e48\u53bb\u4e86\uff1f\u4ed6\u4eec\u7684\u90a3\u4e9b\u8017\u8d44\u6570\u767e\u4e07\u7f8e\u5143\u7684\u5929\u6587\u671b\u8fdc\u955c\u96be\u9053\u90fd\u6210\u4e86\u6446\u8bbe\uff1f\r\n\r\n\u3000\u3000\u8fd9\u5176\u5b9e\u662f\u4e13\u4e1a\u5929\u6587\u5b66\u5bb6\u548c\u4e1a\u4f59\u5929\u6587\u7231\u597d\u8005\u826f\u6027\u4e92\u52a8\u5e76\u4ea7\u751f\u534f\u540c\u6548\u5e94\u7684\u4e00\u4e2a\u5f88\u597d\u7684\u4f8b\u5b50\u3002\u4e13\u4e1a\u5929\u6587\u5b66\u5bb6\u6709\u81ea\u5df1\u7684\u4f18\u52bf\uff0c\u4e1a\u4f59\u5929\u6587\u7231\u597d\u8005\u4e5f\u6709\u4e13\u4e1a\u5929\u6587\u5b66\u5bb6\u6240\u4e0d\u5177\u5907\u7684\u7279\u70b9\u3002\u9996\u5148\u662f\u4e1a\u4f59\u5929\u6587\u7231\u597d\u8005\u7684\u6570\u91cf\u8981\u6bd4\u4e13\u4e1a\u5929\u6587\u5b66\u5bb6\u591a\u5f97\u591a\uff0c\u4ed6\u4eec\u5206\u5e03\u5728\u4e16\u754c\u7684\u6bcf\u4e2a\u89d2\u843d\u3002\u5176\u6b21\uff0c\u5bf9\u4e8e\u5f88\u591a\u6280\u672f\u95e8\u69db\u8f83\u4f4e\u3001\u4f46\u9700\u8981\u957f\u671f\u8ddf\u8e2a\u7684\u4e00\u4e9b\u5929\u6587\u89c2\u6d4b\u800c\u8a00\uff0c\u4e1a\u4f59\u5929\u6587\u7231\u597d\u8005\u7684\u4f18\u52bf\u66f4\u660e\u663e\uff0c\u4ed6\u4eec\u80fd\u5c06\u81ea\u5df1\u7684\u671b\u8fdc\u955c\u957f\u65f6\u95f4\u7d27\u76ef\u67d0\u4e2a\u76ee\u6807\uff0c\u8981\u591a\u957f\u6709\u591a\u957f\uff0c\u800c\u4e13\u4e1a\u5929\u6587\u5b66\u5bb6\u5e76\u975e\u4eba\u624b\u6709\u4e00\u53f0\u671b\u8fdc\u955c\uff0c\u4e0d\u540c\u7684\u5929\u6587\u5b66\u5bb6\u6709\u4e0d\u540c\u7684\u4efb\u52a1\uff0c\u5728\u4e13\u6ce8\u5ea6\u65b9\u9762\u8981\u900a\u8272\u4e00\u4e9b\u3002\r\n\r\n\u3000\u3000\u7c7b\u4f3c\u7684\u4f8b\u5b50\u4e0d\u80dc\u679a\u4e3e\r\n\r\n\u3000\u3000\u9664\u4e86\u97e6\u65af\u5229\u4e4b\u5916\uff0c\u7c7b\u4f3c\u7684\u4f8b\u5b50\u6709\u4e0d\u5c11\uff0c\u6709\u7684\u662f\u78b0\u5de7\u53d1\u73b0\uff0c\u6709\u7684\u5219\u76f8\u5f53\u4e13\u4e1a\u3002\u6bd4\u5982\u5361\u7f57\u7433&#183\uff1b\u6469\u5c14\uff0c\u5979\u5728\u53bb\u5e7411\u6708\u7684\u65f6\u5019\u53d1\u73b0\u4e86\u4e00\u9897\u8d85\u7ea7\u65b0\u661f\uff0c\u5f53\u65f6\u5979\u8fd8\u53ea\u670914\u5c81\uff0c\u7b97\u5f97\u4e0a\u662f\u53d1\u73b0\u8d85\u7ea7\u65b0\u661f\u6700\u5e74\u8f7b\u7684\u4eba\u3002\u800c\u7f8e\u56fd\u5eb7\u6d85\u72c4\u683c\u5dde\u7684\u5929\u6587\u7231\u597d\u8005\u8fd1\u65e5\u5728\u5229\u7528SDSS\u56fe\u50cf\u6570\u636e\u5e93\u9274\u522b\u661f\u7cfb\u65f6\u53d1\u73b0\u4e86\u4e00\u4e2a\u65b0\u661f\u7cfb\u56e2\uff0c\u8be5\u661f\u7cfb\u56e2\u76ee\u524d\u88ab\u547d\u540d\u4e3a\u201c\u7eff\u8c4c\u8c46\u201d\u3002\u8fd9\u4e00\u53d1\u73b0\u6709\u52a9\u4e8e\u5929\u6587\u5b66\u5bb6\u4e86\u89e3\u65e9\u671f\u5b87\u5b99\u4e2d\u6052\u661f\u662f\u5982\u4f55\u8bde\u751f\u5e76\u6f14\u5316\u6210\u661f\u7cfb\u7684\u3002\r\n\r\n\u3000\u3000\u636e\u62a5\u9053\uff0c\u8fd9\u4e2a\u661f\u7cfb\u56e2\u56e0\u4f53\u79ef\u8f83\u5c0f\u3001\u7eff\u5149\u8367\u8367\u800c\u5f97\u540d\u3002\u89c2\u6d4b\u8005\u53d1\u73b0\uff0c\u201c\u7eff\u8c4c\u8c46\u201d\u7684\u6052\u661f\u5f62\u6210\u7387\u60ca\u4eba\uff0c\u662f\u5df2\u77e5\u7684\u6240\u6709\u661f\u7cfb\u56e2\u4e2d\u6700\u9ad8\u7684\u3002\u5929\u6587\u7231\u597d\u8005\u4eec\u7ecf\u8fc7\u957f\u671f\u8ddf\u8e2a\u5728\u8be5\u661f\u7cfb\u56e2\u89c2\u6d4b\u5230250\u4e2a\u661f\u7cfb\uff0c\u5b83\u4eec\u8ddd\u79bb\u5730\u7403\u670915\u4ebf\u523050\u4ebf\u5149\u5e74\uff0c\u4f53\u79ef\u5927\u7ea6\u53ea\u6709\u94f6\u6cb3\u7cfb\u7684\u5341\u5206\u4e4b\u4e00\uff0c\u4f46\u5b83\u4eec\u7684\u6052\u661f\u8bde\u751f\u901f\u5ea6\u5374\u662f\u94f6\u6cb3\u7cfb\u768410\u500d\u3002\r\n\r\n\u3000\u3000\u5929\u6587\u5b66\u5bb6\u4ecb\u7ecd\u8bf4\uff0c\u5982\u6b64\u60ca\u4eba\u7684\u6052\u661f\u5f62\u6210\u7387\u5728\u5b87\u5b99\u65e9\u671f\u5404\u661f\u7cfb\u4e2d\u975e\u5e38\u666e\u901a\uff0c\u4f46\u5728\u4eca\u5929\u5374\u96be\u5f97\u4e00\u89c1\u3002\u901a\u8fc7\u89c2\u6d4b\u201c\u7eff\u8c4c\u8c46\u201d\u661f\u7cfb\u56e2\u7684\u5149\u8292\uff0c\u53ef\u4ee5\u65ad\u5b9a\u661f\u7cfb\u56e2\u4e2d\u6709\u591a\u5c11\u65b0\u6052\u661f\u6b63\u5728\u8bde\u751f\u3002\u5bf9\u201c\u7eff\u8c4c\u8c46\u201d\u661f\u7cfb\u56e2\u7684\u7814\u7a76\u4f1a\u5e2e\u52a9\u4eba\u4eec\u4e86\u89e3\u65e9\u671f\u5b87\u5b99\u5982\u4f55\u4ea7\u751f\u884c\u661f\uff0c\u4ee5\u53ca\u4e86\u89e3\u5305\u62ec\u94f6\u6cb3\u7cfb\u5728\u5185\u7684\u4f17\u591a\u661f\u7cfb\u662f\u600e\u6837\u53d1\u5c55\u6210\u578b\u7684\u3002\r\n\r\n\u3000\u3000\u4e13\u4e1a\u5929\u6587\u673a\u6784\u915d\u917f\u5bf9\u5176\u8fdb\u884c\u201c\u6536\u7f16\u201d\r\n\r\n\u3000\u3000\u6b63\u56e0\u4e3a\u4e1a\u4f59\u5929\u6587\u7231\u597d\u8005\u5bf9\u4e13\u4e1a\u5929\u6587\u5b66\u5bb6\u7684\u89c2\u6d4b\u80fd\u6709\u5e2e\u52a9\uff0c\u4e00\u4e9b\u4e13\u4e1a\u7684\u5929\u6587\u673a\u6784\u915d\u917f\u7740\u5c06\u4e1a\u4f59\u5929\u6587\u7231\u597d\u8005\u201c\u6536\u7f16\u201d\uff0c\u8ba9\u4ed6\u4eec\u53c2\u4e0e\u5230\u4e00\u4e9b\u91cd\u8981\u9879\u76ee\u7684\u89c2\u6d4b\u4e0a\u6765\uff0c\u6bd4\u5982\u7f8e\u56fd\u5b87\u822a\u5c40\u5df2\u7ecf\u9080\u8bf7\u4e1a\u4f59\u5929\u6587\u7231\u597d\u8005\u52a0\u5165\u6708\u7403\u89c2\u5bdf\u6d3b\u52a8\uff0c\u8fd9\u5c31\u662f\u7f8e\u56fd\u5b87\u822a\u5c40\u7684\u6708\u7403\u9668\u5751\u89c2\u6d4b\u4e0e\u9065\u611f\u536b\u661f\u8ba1\u5212\u3002\u9065\u611f\u536b\u661f\u5c06\u5728\u4eca\u5e7410\u6708\u649e\u51fb\u6708\u7403\u5357\u6781\u7684\u9668\u5751\uff0c\u8fd9\u4e00\u649e\u51fb\u5c06\u6fc0\u8d77\u5927\u91cf\u7684\u7269\u8d28\uff0c\u5176\u4e2d\u5f88\u53ef\u80fd\u5305\u62ec\u6709\u6c34\u7684\u6210\u5206\u3002\u7f8e\u56fd\u5b87\u822a\u5c40\u5df2\u7ecf\u9080\u8bf7\u4e1a\u4f59\u5929\u6587\u7231\u597d\u8005\u5728\u649e\u51fb\u53d1\u751f\u540e\u5bf9\u5176\u8fdb\u884c\u89c2\u6d4b\uff0c\u5e76\u5411\u5b87\u822a\u5c40\u63d0\u4f9b\u62cd\u6444\u5230\u7684\u7167\u7247\u4ee5\u53ca\u5176\u5b83\u89c2\u6d4b\u6570\u636e\uff0c\u8fd9\u6837\u53ef\u4ee5\u5145\u5b9e\u4ece\u4e13\u4e1a\u5929\u6587\u53f0\u548c\u592a\u7a7a\u671b\u8fdc\u955c\u4e0a\u83b7\u53d6\u7684\u89c2\u6d4b\u6570\u636e\u3002\r\n\r\n\u3000\u3000\u201c\u4e1a\u4f59\u5929\u6587\u7231\u597d\u8005\u7684\u8d21\u732e\u53ef\u80fd\u4f1a\u975e\u5e38\u91cd\u8981\uff0c\u201d\u7f8e\u56fd\u4e9a\u5229\u6851\u90a3\u5dde\u970d\u666e\u91d1\u65af\u5c71\u4e0a\u7684MMT\u5929\u6587\u53f0\u8d1f\u8d23\u4eba\u8d39\u65af&#183\uff1b\u7ef4\u62c9\u65af\u8bf4\u3002\u8be5\u5929\u6587\u53f0\u7531\u4e9a\u5229\u6851\u90a3\u5927\u5b66\u8d1f\u8d23\u7ba1\u7406\uff0c\u5b89\u88c5\u6709\u4e00\u4e2a6.5\u7c73\u53e3\u5f84\u7684\u671b\u8fdc\u955c\uff0c\u4e5f\u5c06\u53c2\u52a0\u5bf9\u8fd9\u6b21\u649e\u51fb\u884c\u52a8\u7684\u89c2\u6d4b\u3002\r\n\r\n\u3000\u3000\u6709\u4e86\u5f88\u597d\u7684\u8bbe\u5907\uff0c\u5904\u7684\u4f4d\u7f6e\u4e5f\u4e0d\u9519\uff0c\u5929\u7a7a\u4e5f\u6bd4\u8f83\u6e05\u723d\u7684\u8bdd\uff0c\u90a3\u4e48\u4e1a\u4f59\u5929\u6587\u5b66\u7231\u597d\u8005\u5c06\u4f1a\u5904\u4e8e\u4e00\u4e2a\u6bd4\u8f83\u6709\u5229\u7684\u4f4d\u7f6e\u6765\u89c2\u5bdf\u649e\u51fb\uff0c\u4e00\u65e6\u536b\u661f\u649e\u51fb\u51fa\u7684\u5c18\u57c3\u8dc3\u4e0a\u6708\u7403\u8868\u9762\uff0c\u90a3\u4e48\u5c31\u80fd\u89c2\u6d4b\u5f97\u5230\u3002\u5c18\u57c3\u7684\u7ed3\u6784\u548c\u5f62\u72b6\u5c06\u4f1a\u4e3a\u786e\u5b9a\u6708\u7403\u7269\u8d28\u7684\u6784\u6210\u63d0\u4f9b\u7ebf\u7d22\u3002\r\n\r\n\u3000\u3000\u6709\u60ca\u4eba\u53d1\u73b0\u7684\u673a\u4f1a\u5176\u5b9e\u633a\u5927\r\n\r\n\u3000\u3000\u9664\u4e86\u4e0a\u8ff0\u9879\u76ee\u4e4b\u5916\uff0c\u7f8e\u56fd\u5b87\u822a\u5c40\u8fd8\u9080\u8bf7\u4e86\u4e1a\u4f59\u5929\u6587\u7231\u597d\u8005\u62cd\u6444\u6708\u7403\u5357\u6781\u7684\u7167\u7247\uff0c\u76ee\u7684\u662f\u6536\u96c6\u6709\u5173\u8fd9\u4e2a\u533a\u57df\u7684\u5730\u56fe\u8d44\u6599\uff0c\u8fd9\u4e9b\u8d44\u6599\u6709\u52a9\u4e8e\u786e\u5b9a\u8be5\u533a\u57df\u7684\u5730\u8d28\u6784\u6210\u3002\r\n\r\n\u3000\u3000\u53e6\u5916\uff0c\u4e1a\u4f59\u5929\u6587\u7231\u597d\u8005\u5728\u8ffd\u8e2a\u8fd1\u5730\u5c0f\u884c\u661f\u4ee5\u53ca\u8ddd\u79bb\u592a\u9633\u4e0d\u8fdc\u7684\u6052\u661f\u65b9\u9762\u6709\u7740\u89c2\u6d4b\u4f18\u52bf\uff0c\u4ed6\u4eec\u80fd\u591f\u5e2e\u52a9\u5929\u6587\u5b66\u5bb6\u786e\u5b9a\u5c0f\u884c\u661f\u7684\u8fd0\u884c\u8f68\u9053\u4ee5\u53ca\u8ddf\u8e2a\u6052\u661f\u5149\u7ebf\u548c\u8f90\u5c04\u7684\u53d8\u5316\u3002\r\n\r\n\u3000\u3000\u201c\u4eca\u5929\u7684\u4e1a\u4f59\u5929\u6587\u7231\u597d\u8005\u80fd\u591f\u63d0\u4f9b\u5404\u79cd\u6709\u7528\u7684\u89c2\u6d4b\u6570\u636e\uff0c\u7279\u522b\u662f\u5f71\u8c61\u6570\u636e\uff0c\u5f88\u591a\u6570\u636e\u8ba9\u4eba\u5370\u8c61\u6df1\u523b\uff0c\u201d\u7f8e\u56fd\u5b87\u822a\u5c40\u8d1f\u8d23\u4e0e\u4e1a\u4f59\u5929\u6587\u5b66\u5bb6\u8054\u7edc\u7684\u5b98\u5458\u5e03\u83b1\u6069&#183\uff1b\u6234\u4f0a\u8bf4\u3002\u5929\u6587\u6444\u5f71\u5e08\u4e9a\u5f53&#183\uff1b\u5e03\u6d1b\u514b\u5219\u8ba4\u4e3a\uff1a\u201c\u4ed6\u4eec\u5728\u4e00\u4e9b\u6bd4\u8f83\u957f\u671f\u7684\u89c2\u6d4b\u9879\u76ee\u4e0a\u7279\u522b\u663e\u773c\u3002\u201d\r\n\r\n\u3000\u3000\u56e0\u6b64\uff0c\u5bf9\u4e8e\u4e1a\u4f59\u5929\u6587\u7231\u597d\u8005\u6765\u8bf4\uff0c\u4ed6\u4eec\u5df2\u7ecf\u6210\u4e3a\u5929\u6587\u89c2\u6d4b\u961f\u4f0d\u4e2d\u7684\u4e00\u652f\u5f3a\u5927\u529b\u91cf\u3002\u800c\u4e14\uff0c\u53ea\u8981\u4ed6\u4eec\u8fd0\u6c14\u6bd4\u8f83\u597d\uff0c\u80fd\u6709\u60ca\u4eba\u53d1\u73b0\u7684\u673a\u4f1a\u5176\u5b9e\u4e5f\u4e0d\u5c11\u3002\r\n\r\n\u3000\u3000 (\u672c\u6587\u6765\u6e90\uff1a\u65b0\u95fb\u665a\u62a5 )", "imagename": "1fb3e713901b4fd8bd81efcafffae8a1.jpg", "infoid": 216946, "category": "technology_internet", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u6728\u661f", "\u5929\u6587\u5b66\u5bb6", "\u5730\u7403", "\u5b87\u5b99"]}, {"url": "http://www.zhuaxiami.com/articles/0999vs1.html", "title": "0.999\u65e0\u9650\u5faa\u73af\u548c1\u7a76\u7adf\u54ea\u4e2a\u5927", "tags": "\u63a2\u7d22 ", "name": "wodezzz", "posttime": "2009-08-02 13:03:19", "ip": "122.7.214.67", "mark": 0, "note": "\u6700\u8fd1\u7f51\u7edc\u5728\u70ed\u8bae0.999\u65e0\u9650\u5faa\u73af\u548c1\u7684\u5927\u5c0f\u95ee\u9898\uff0c\u8d77\u56e0\u5982\u4e0b\uff1a\r\n\u6691\u671f\u505a\u5bb6\u6559\u7684\u897f\u5357\u5927\u5b66\u7814\u4e8c\u5b66\u751f\u6731\u5c0f\u52c7\u6700\u8fd1\u9047\u5230\u4e86\u4e00\u4e2a\u96be\u9898,\u5728\u5317\u789a\u4e0a\u521d\u4e2d\u7684\u5b66\u751f\u95ee\u4e86\u4ed6\u8fd9\u6837\u4e00\u4e2a\u95ee\u9898,\u201c0.99999\u65e0\u9650\u5faa\u73af\u548c1\u7a76\u7adf\u54ea\u4e2a\u5927?\u201d\u4ed6\u4e00\u5f00\u59cb\u4e0d\u5047\u601d\u7d22\u5730\u56de\u7b54:\u201c\u80af\u5b9a\u662f1\u5927.\u201d\u7ed3\u679c\u8fd9\u4e2a\u5b66\u751f\u544a\u8bc9\u4ed6:\u201c\u6709\u8001\u5e08\u8bf4\u662f\u4e00\u6837\u5927.\u201d\r\n\u4e8e\u662f\u4ed6\u4fbf\u5728\u67d0\u8bba\u575b\u53d1\u5e16\u6c42\u52a9\uff0c\u5f15\u8d77\u4e86\u5927\u5bb6\u7684\u8ba8\u8bba\u3002\u5148\u4e0d\u53bb\u8003\u8651\u8c01\u5927\uff0c\u53bb\u770b\u770b\u7f51\u53cb\u7684\u70ed\u8bae\u5427\uff0c\u5475\u5475\r\n1.\u672c\u6765\u8be5\u53d1100\u5143\u5de5\u8d44,\u5374\u53d1\u4e8699\u575799999\u2026\u2026,\u8001\u677f\u8bf4\u662f\u4e00\u6837\u7684,\u4f60\u5fc3\u91cc\u723d\u4e0d\u723d?\r\n2.\u4f60\u53bb\u94f6\u884c\u5b5899\u57579\u89d29\u5206,\u4f60\u558a\u7b97\u6210100\u5757,\u770b\u94f6\u884c\u5e72\u4e0d\u5e72?\r\n3.\u8fd9\u4e2a\u95ee\u9898\u4f53\u73b0\u5230\u54f2\u5b66\u4e0a\u5c31\u662f\u91cf\u53d8\u548c\u8d28\u53d8\u7684\u5173\u7cfb,\u91cf\u53d8\u53d1\u5c55\u5230\u4e00\u5b9a\u7a0b\u5ea6\u5fc5\u7136\u8981\u4ea7\u751f\u8d28\u53d8.\r\n4.\u770b\u4e86\u4e0a\u9762\u7684\u56de\u5e16\u611f\u89c9\u660e\u767d\u4e86\u4e00\u4e2a\u9053\u7406\u2026\u2026\u4e3a\u4ec0\u4e48\u90a3\u4e9b\u5356\u8863\u670d\u7684\u6807\u4ef7\u554a\u2026\u2026\u7535\u8111\u6807\u4ef7\u554a,\u4e00\u822c\u90fd\u6807\u4ef7199\u30011999\u800c\u4e0d\u6807200\u30012000\u2026\u2026\r\n5.0.9999\u7684\u65e0\u9650\u5faa\u73af\u662f\u201c\u8981\u591a\u8fd1\u5c31\u6709\u591a\u8fd1\u201d\u7684\u610f\u601d,\u662f\u4e00\u79cd\u7384\u4e4e\u8bed\u8a00.\u4ed6\u79f0,\u4e0d\u662f\u7edd\u5bf9\u610f\u4e49\u7684\u7b49\u4e8e,\u800c\u662f\u6781\u9650\u542b\u4e49\u4e0b\u7684\u201c\u7b49\u4e8e\u201d,\u8fd9\u4e2a\u201c\u7b49\u4e8e\u201d\u662f\u65e0\u9650\u8d8b\u8fd1\u7684\u610f\u601d.\r\n6.\u540c\u5b66\u7532:0.999999\u65e0\u9650\u5faa\u73af\u4e0e1\u4e00\u6837\u5927!\r\n\u540c\u5b66\u4e59:\u6211\u4eec\u53ef\u4ee5\u628a\u6570\u5b66\u4e0a\u7684\u5047\u8bbe\u95ee\u9898\u6362\u4f5c\u751f\u6d3b\u95ee\u9898,\u6bd4\u5982:\u4ece\u5934\u4e0a\u62d4\u6389\u4e00\u6839\u5934\u53d1\u540e,\u548c\u539f\u6765\u7684\u5934\u53d1\u6bd4\u4e00\u6837\u591a,\u53cd\u6b63\u4e5f\u770b\u4e0d\u51fa\u6765\u561b(\u65e0\u9650\u5faa\u73af\u7684\u6982\u5ff5\u53ef\u4ee5\u7406\u89e3\u4e3a\u5c0f\u6570\u70b9\u540e\u9762\u76849\u591a\u5230\u770b\u4e0d\u89c1).\u53ef\u4ee5\u8fd9\u6837\u4f5c\u6bd4\u8f83\u5417?\r\n\u540c\u5b66\u7532:\u53ef\u4ee5.\r\n\u540c\u5b66\u4e59:\u90a3\u4e5f\u5c31\u662f\u8bf4,\u4ece\u4f60\u7684\u5934\u53d1\u62d4\u6389\u4e00\u6839\u5934\u53d1\u5bf9\u4f60\u6765\u8bf4,\u6ca1\u5565\u5b50\u635f\u5931\u5570.\r\n\u540c\u5b66\u7532:\u662f\u7684.\r\n\u540c\u5b66\u4e59:\u90a3\u6211\u5f00\u59cb\u4ece\u4f60\u5934\u4e0a\u62d4\u5934\u53d1\u4e86.\r\n\u540c\u5b66\u7532:\u597d.\r\n\u540c\u5b66\u4e59:1\u6839.\r\n\u540c\u5b66\u7532:\u7ee7\u7eed.\r\n\u540c\u5b66\u4e59:2\u6839.\r\n\u540c\u5b66\u7532:\u7ee7\u7eed.\r\n\u540c\u5b66\u4e59:N\u6839\u2026\u2026\r\n\u540c\u5b66\u7532:\u4f60\u975e\u5f97\u628a\u8001\u5b50\u62d4\u6210\u845b\u4f18\u624d\u80af\u4f4f\u624b\u5417?\r\n\u7ed3\u8bba:\u5b9e\u8df5\u51fa\u771f\u77e5.\r\n7.\u663e\u7136\u662f\u4e00\u6837\u5927\u554a\uff01\u8fd9\u4e48\u83dc\u7684\u95ee\u9898\uff01\u5f88\u7b80\u5355\uff1a\u7528 1 \u51cf\u53bb 0.999...\u5faa\u73af\uff0c\u7ed3\u679c\u662f\u4ec0\u4e48\uff1f\u96f6\uff01\u4e3a\u4ec0\u4e48\uff1f\u56e0\u4e3a\u65e2\u7136\u65e0\u9650\u5faa\u73af\uff0c0.000...0001\u6700\u540e\u9762\u8fd9\u4e2a 1 \u5c31\u6c38\u8fdc\u51fa\u4e0d\u6765\uff01", "imagename": "", "infoid": 216893, "category": "life_general-knowl