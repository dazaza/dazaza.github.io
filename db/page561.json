[{"url": "http://www.redbots.cn/itnews/2009/03/09/8390.htm", "title": "[\u7ec4\u56fe]PC World\uff1a\u76d8\u70b9\u5341\u5927\u6700\u6d41\u884c\u4e0a\u7f51\u672c", "tags": "PC World \u6700\u6d41\u884c \u4e0a\u7f51\u672c Netbook ", "name": "hanyelv", "posttime": "2009-03-09 09:31:59", "ip": "58.212.22.241", "mark": 2, "note": "\u300aPC World\u300b\u6742\u5fd7\u7f51\u7edc\u7248\u65e5\u524d\u8bc4\u51fa\u4e86\u5f53\u524d\u6700\u6d41\u884c\u768410\u5927\u4e0a\u7f51\u672c\uff0c\u534e\u7855\u6613PC 1000HE\u3001\u5b8f\u7881Aspire ONE AOD150\u548c\u8054\u60f3Ideapad S10\u8dfb\u8eab\u4e09\u5f3a\u3002", "imagename": "6b65171b9b054b718194c6ecee0bb817.jpg", "infoid": 129702, "category": "technology_internet", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["pc", "world", "\u6700\u6d41\u884c", "\u4e0a\u7f51\u672c", "netbook"]}, {"url": "http://bjnahan.net/post/930.htm", "title": "\u72ec\u7acb\u7f51\u5e97\u521b\u4e1a PHP\u5f00\u6e90\u7a0b\u5e8f\u5927\u7f57\u5217", "tags": "PHP\u5f00\u6e90 \u7f51\u5e97 \u521b\u4e1a \u7535\u5b50\u5546\u52a1 ", "name": "fearless", "posttime": "2009-03-09 09:02:45", "ip": "125.33.11.159", "mark": 2, "note": "\u7ecf\u6d4e\u65f6\u5c40\u4e0d\u666f\u6c14\uff0c\u5927\u591a\u4eba\u90fd\u5728\u4e1c\u6233\u897f\u6233\u7684\uff0c\u60f3\u627e\u70b9\u94f6\u5b50\u91d1\u5b50\u3002\u5176\u5b9e\u5c31\u7b97\u7ecf\u6d4e\u5f88\u9ad8\u4ea2\u7684\u65f6\u5019Fearless\u5c31\u53d1\u73b0\u4e00\u7279\u6709\u610f\u601d\u7684\u73b0\u8c61\uff0c\u51e0\u4e4e\u6240\u6709\u7684\u670b\u53cb\u90fd\u4f1a\u5230\u7f51\u7edc\u4e0a\u53bb\u641e\u4e2a\u5c0f\u5e97\u9762\uff0c\u770b\u6765\u5927\u5bb6\u5bf9\u505a\u70b9\u5c0f\u751f\u610f\u90fd\u8fd8\u86ee\u6709\u5174\u8da3\u3002\u65e2\u7136\u6709\u5174\u8da3\uff0c\u65e2\u7136\u8981\u505a\u6211\u4eec\u5c31\u505a\u5f97\u6f02\u4eae\u70b9\u3002\uff08\u4e0d\u662f\u770b\u4e0a\u53bb\u7684\u6f02\u4eae\uff0c\u522b\u8bef\u4f1a\uff0c\u6211\u6307\u7684\u662f\u8ba4\u771f\u70b9\uff01\uff09\u672c\u6587\u53ea\u9002\u5408\u7acb\u5fd7\u5efa\u8bbe\u72ec\u7acb\u7535\u5b50\u5546\u52a1\u7cfb\u7edf\u7684\u670b\u53cb\uff0c\u5c31\u662f\u5355\u72ec\u5f00\u4e00\u4e2a\u7f51\u5e97\uff0c\u4e0d\u548c\u6dd8\u5b9d\u3001\u62cd\u62cd\u3001\u6709\u554a\u7b49\u4f17\u7f51\u5546\u4e3a\u4f0d\uff0c\u5982\u679c\u89c9\u5f97\u5b8c\u5168\u6ca1\u660e\u767d\u600e\u4e48\u56de\u4e8b\uff0c\u5efa\u8bae\u8fd8\u662f\u53bb\u7c7b\u6dd8\u5b9d\u7ad9\u70b9\u6ce8\u518c\u4e2a\u8d26\u53f7\uff0c\u65e5\u540eFearless\u4f1a\u5728A\u7ea7\u6559\u7a0b\u91cc\u53d1\u5e03\u4e00\u70b9\u76f8\u5173\u5e97\u9762\u88c5\u4fee\u7684\u62d9\u89c1\u3002\r\n\r\n\u72ec\u7acb\u7f51\u5e97\u7684\u597d\u5904\u4e0d\u8a00\u800c\u55bb\uff0c\u53ef\u4ee5\u6709\u72ec\u7acb\u7684\u54c1\u724c\u3001\u81ea\u6709\u4e3b\u6743\u3001\u81ea\u6709\u4ea7\u6743\uff0c\u4e0d\u5bc4\u4eba\u7bf1\u4e0b\u2026\u2026\u7b49\u7b49\u7b49\u3002\u4f46\u54b1\u4e5f\u4e0d\u80fd\u5ffd\u7565\u52a3\u52bf\uff0c\u4eba\u6c14\u4e0a\u53ef\u80fd\u5c31\u4e0d\u53ca\u5728\u7c7b\u6dd8\u5b9d\u7684\u5927\u5356\u573a\u4e86\uff0c\u800c\u4e14\u5c31\u7b97\u4f60\u5f88\u8ba4\u771f\u5f88\u52aa\u529b\uff0c\u534a\u5e74\u5230\u4e00\u5e74\u7684\u65f6\u95f4\u91cc\u7edd\u5bf9\u4e0d\u4f1a\u6709\u592a\u9ad8\u7684\u4eba\u6c14\uff0c\u53ef\u80fd\u7b49\u4f60\u7edd\u671b\u6216\u8005\u653e\u5f03\u7684\u65f6\u5019\uff0c\u4eba\u6c14\u6765\u4e86\u3002\u6240\u4ee5\u554a\uff0c\u5982\u679c\u6240\u552e\u5546\u54c1\u4e0d\u662f\u7279\u522b\u7684\u7279\u522b\u7684\u7279\u522b\u2026\u2026\u7684\u670b\u53cb\u8981\u5efa\u8bbe\u72ec\u7acb\u7f51\u5e97\uff0c\u6211\u8fd8\u662f\u6301\u4e0d\u8d5e\u6210\u4e5f\u4e0d\u53cd\u5bf9\u7684\u6001\u5ea6\uff0c\u81ea\u5df1\u614e\u91cd\u884c\u4e8b\u3002\u4ea7\u54c1\u6709\u7279\u8272\u3001\u5e02\u573a\u4e0a\u7a00\u7f3a\u7d27\u4fcf\u7684\u73a9\u610f\u513f\uff0c\u53cc\u624b\u52a0\u53cc\u811a\u8d5e\u6210\u3002\r\n\r\n\u81f3\u4e8e\u6709\u8d44\u6e90\u53c8\u6709\u592a\u591a\u987e\u8651\u548c\u90a3\u4e9b\u8c8c\u4f3c\u7684\u9ad8\u4eba\u4eec\uff0c\u60a8\u5c31\u514d\u5f00\u5c0a\u53e3\u4e86\uff0c\u5f53\u5e74\u4eac\u4e1c\u5546\u57ce\u521a\u4e0a\u7684\u65f6\u5019\u6307\u624b\u5212\u811a\u7684\u4eba\u591a\u5927\u53d1\u4e86\uff0c\u73b0\u5728\u4eba\u5bb6\u505a\u5f97\u4e0d\u4e5f\u633a\u4e0d\u9519\u7684\u4e48\u3002OK\u4e86\uff0c\u767d\u8bdd\u4e86\u534a\u5929\uff0c\u5f00\u59cb\u5165\u6b63\u9898\u5427\u3002\r\n\r\n \r\n\r\n\u72ec\u7acb\u7f51\u5e97\u521b\u4e1a \u51fa\u53e3\u6d77\u5916 \u8fdb\u519b\u56fd\u9645\r\n\r\n\u5982\u679c\u4e00\u7684E\u6587\u6c34\u51c6\u8fd8\u53ef\u4ee5\uff0c\u53c8\u6709\u4e00\u5b9a\u7684\u53ef\u51fa\u53e3\u8d44\u6e90\uff0c\u56fd\u9645\u5e02\u573a\u65e0\u7591\u662f\u6700\u597d\u7684\u9009\u62e9\u3002\u5f53\u7136\u5982\u679c\u662f\u4e00\u4e9b\u7279\u8272\u5de5\u827a\u54c1\u4e5f\u662f\u7edd\u4f73\u5546\u673a\uff0cFearless\u5c31\u8ba4\u8bc6\u4e00\u4f4d\u5728\u8861\u6c34\u753b\u9f3b\u70df\u58f6\u7684\u54e5\u4eec\u513f\uff0c\u6708\u5165\u81f3\u5c11\u5343\u4f59\u7f8e\u5200\uff0c\u5bf9\u4e8e\u751f\u6d3b\u5728\u4e09\u7ebf\u57ce\u5e02\u4ed6\uff0c\u8fd9\u5df2\u7ecf\u5f88\u53ef\u89c2\u4e86\u3002\u73b0\u5728\u4ecb\u7ecd\u4e00\u4e9b\u6d77\u5916\u7684\u72ec\u7acb\u7f51\u5e97PHP\u5f00\u6e90\u7a0b\u5e8f\u7ed9\u5927\u5bb6\uff0c\u4ee5\u4fbf\u5907\u6218\u3002\r\n\r\nPHP\u5f00\u6e90\u7f51\u5e97\u7a0b\u5e8f ZenCart\r\nZen Cart\u662f\u4e00\u4e2a\u7528\u6237\u53cb\u597d\uff0c\u5f00\u6e90\u7684\u8d2d\u7269\u8f66\u7cfb\u7edf\u3002\u5b83\u5177\u6709\uff1a\u6613\u4e8e\u5b89\u88c5\u3001\u591a\u79cd\u6d88\u8d39\u8005\u6a21\u5f0f\u3001\u4e0d\u9650\u76ee\u5f55\u6df1\u5ea6\u3001\u591a\u79cd\u9500\u552e\u4e0e\u6298\u6263\u6a21\u5f0f\u3001\u591a\u79cd\u5c55\u793a\u65b9\u5f0f\u3001XHTML\u6a21\u677f\u7cfb\u7edf\u3001\u591a\u6a2a\u5e45\u5e7f\u544a\u63a7\u5236\u5668\u3001newsletter\u7ba1\u7406\u5668\u7b49\u7279\u70b9\u3002\r\n\r\n \r\n\r\nPHP\u5f00\u6e90\u7f51\u5e97\u7a0b\u5e8f phpShop\r\nphpShop\u662f\u4e00\u4e2a\u57fa\u4e8ePHP\u7684\u7f51\u4e0a\u5546\u5e97\u7cfb\u7edf\u3002phpShop\u867d\u7136\u6bd4\u5176\u5b83\u7f51\u4e0a\u8d2d\u7269\u7cfb\u7edf\u7b80\u5355\uff0c\u800c\u4e14\u529f\