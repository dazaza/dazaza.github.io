[{"url": "http://my.dongua.com/wewa/blog!entry/3729.entry", "title": "20\u4e2a\u521b\u610f\u975e\u51e1\u7684\u5e7f\u544a", "tags": "\u521b\u610f\u5e7f\u544a ", "name": "lomomo", "posttime": "2008-10-17 12:08:55", "ip": "219.136.97.59", "mark": 2, "note": "\u5bf9\u4e8e\u4efb\u4f55\u4ea7\u54c1\u800c\u8a00\uff0c\u4f9d\u9760\u5e7f\u544a\u521b\u610f\u5438\u5f15\u6d88\u8d39\u8005\u7684\u6ce8\u610f\uff0c\u662f\u5fc5\u987b\u7684\u9500\u552e\u624b\u6bb5\u3002\u4e0b\u9762\u5c31\u8ba9\u6211\u4eec\u770b\u770b20\u4e2a\u521b\u610f\u975e\u51e1\uff0c\u8ba9\u4f60\u4e00\u89c1\u96be\u5fd8\u7684\u5e7f\u544a\u3002\u5176\u4e2d\uff0c\u6709\u56fd\u9645\u77e5\u540d\u7684\u54c1\u724c\uff0c\u4e5f\u6709\u5bf9\u6211\u4eec\u6765\u8bf4\u5f88\u964c\u751f\u7684\u4ea7\u54c1\uff0c\u4f46\u5b83\u4eec\u7684\u5e7f\u544a\u5728\u521b\u610f\u65b9\u9762\uff0c\u5168\u90fd\u662f\u4e00\u6d41\u7684", "imagename": "af8798de13674c1582dda60239f9d864.jpg", "infoid": 96929, "category": "technology_design", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u521b\u610f\u5e7f\u544a"]}, {"url": "http://www.lothings.com/", "title": "\u4e50\u65b0\u58eb  - \u4e50\u65b0\u51b3\u5b9a\u751f\u6d3b", "tags": "\u4e50\u65b0\u58eb \u751f\u6d3b\u5bb6\u5c45 \u4e2a\u6027 \u7b80\u7ea6 \u81ea\u7531 \u521b\u610f", "name": "yinyin", "posttime": "2008-10-17 11:51:58", "ip": "222.128.48.207", "mark": 2, "note": "\u4e50\u65b0\u58eb-Lothings\u662f\u4e00\u4e2a\u81f4\u529b\u4e8e\u63d0\u9ad8\u4eba\u4eec\u751f\u6d3b\u54c1\u8d28\u7684\u7f51\u7ad9,\u5176\u6210\u5458\u6765\u81ea\u4e16\u754c\u5404\u5730.\u300c\u6211\u4eec\u70ed\u7231\u751f\u6d3b!\u300d\u4e50\u65b0\u58eb\u4eec\u603b\u662f\u8fd9\u4e48\u8bf4.\u4e8b\u5b9e\u4e0a,\u6211\u4eec\u5e0c\u671b\u66f4\u591a\u7684\u4eba\u80fd\u591f\u62e5\u6709\u5c5e\u4e8e\u4ed6\u4eec\u81ea\u5df1\u7684Wonderful Life.\u5f53\u7136\u5982\u679c\u5728\u8fd9\u9014\u4e2d\u60a8\u6709\u4ec0\u4e48\u7591\u60d1\u7684\u8bdd,\u8bf7\u4e0d\u59a8\u5230\u4e50\u65b0\u58eb\u6765