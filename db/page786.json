7ecd\u8fc7\u4e00\u6b3e\u201c\u6c7d\u8f66\u7684\u8868\u60c5\u201d\uff0c\u65e2\u7136\u6c7d\u8f66\u80fd\u6709\u8868\u60c5\uff0c\u4e3a\u4f55\u4e0d\u80fd\u518d\u6765\u70b9\u624b\u52bf\u5462\uff1f", "imagename": "292307834a2b45429ee8ce9a81f3816f.gif", "infoid": 96885, "category": "technology_design", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u624b\u52bf", "\u6c7d\u8f66"]}, {"url": null, "title": "\u6700\u5bcc\u6709\u79d1\u6280\u516c\u53f8", "tags": "\u79d1\u6280 \u516c\u53f8 ", "name": "yinyin", "posttime": "2008-10-17 09:04:39", "ip": "222.128.48.207", "mark": 1, "note": "<P>\u7f8e\u56fd\u7845\u8c37\u7684\u503a\u52a1\u5371\u673a\u4ece\u4f55\u800c\u6765\uff1f\u91d1\u878d\u5371\u673a\u7684\u51b2\u51fb\u4e0d\u53ef\u907f\u514d\uff0c\u4f46\u9664\u4e86\u79fb\u52a8\u8fd0\u8425\u5546Alltel\u548cNextel\u7684\u4ea7\u54c1\u9500\u91cf\u53ef\u80fd\u56e0\u7ecf\u6d4e\u5bd2\u6d41\u51cf\u5c11\u5916\uff0c\u51bb\u7ed3\u4fe1\u8d37\u5e02\u573a\u5bf9IT\u516c\u53f8\u4e1a\u52a1\u7684\u76f4\u63a5\u5f71\u54cd\u751a\u5fae\u3002 <BR><BR>\u8fd9\u662f\u56e0\u4e3aIT\u4e1a\u7684\u9886\u8896\u4eec\u5411\u6765\u559c\u6b22\u56e4\u79ef\u5de8\u989d\u73b0\u91d1\uff0c\u4ee5\u9632\u5e02\u573a\u7684\u98ce\u5439\u8349\u52a8\u5bf9\u73b0\u91d1\u6d41\u52a8\u5e26\u6765\u51b2\u51fb\u3002\u5728\u9ec4\u91d1\u65f6\u671f\uff0c\u6d3b\u8dc3\u7684\u80a1\u4e1c\u5bf9\u4ed6\u4eec\u8fd9\u79cd\u5c0f\u5bb6\u5b50\u6c14\u6028\u58f0\u8f7d\u9053\uff0c\u4f46\u5982\u4eca\uff0c\u8fc7\u53bb\u56e4\u79ef\u73b0\u91d1\u7684IT\u516c\u53f8\u65e5\u5b50\u66f4\u597d\u8fc7\uff0c\u4e5f\u4e3a\u9ad8\u4e3e\u6536\u8d2d\u5927\u65d7\u521b\u9020\u4e86\u6761\u4ef6\u3002 <BR><BR>\u5fae\u8f6f\u5c31\u66fe\u662f\u4e00\u5bb6\u8fdd\u80cc\u80a1\u4e1c\u610f\u613f\u7684\u516c\u53f8\u3002\u6bd4\u5c14\u00b7\u76d6\u8328(Bill Gates)\u5728\u638c\u7ba1\u8fd9\u5bb6\u516c\u53f8\u65f6\uff0c\u62c5\u5fc3\u5e02\u573a\u4e0d\u5229\u53d8\u5316\uff0c\u559c\u6b22\u5c06\u76f8\u5f53\u4e8e\u516c\u53f8\u4e00\u5e74\u652f\u51fa\u7684\u73b0\u91d1\u90fd\u7559\u5728\u8eab\u8fb9\uff0c\u4e0d\u662f\u73b0\u7528\u73b0\u53bb\u94f6\u884c\u63d0\u53d6\u3002\u5982\u4eca\uff0c\u5fae\u8f6f\u5bf9\u73b0\u91d1\u7684\u63a7\u5236\u4e0d\u518d\u5982\u6b64\u82db\u523b\uff0c\u4ed6\u4eec\u5c06\u5176\u4e2d\u4e00\u90e8\u5206\u5f53\u4f5c\u7ea2\u5229\u53d1\u7ed9\u80a1\u4e1c\uff0c\u51e0\u5e74\u6765\u8ba9\u80a1\u4e1c\u83b7\u5f97320\u4ebf\u7f8e\u5143\u56de\u62a5\u3002\u5e78\u8fd0\u7684\u662f\uff0c\u5fae\u8f6f\u672a\u80fd\u4ee5440\u4ebf\u7f8e\u5143\u6210\u529f\u6536\u8d2d\u96c5\u864e\uff0c\u5426\u5219\uff0c\u50cf\u91d1\u878d\u5e02\u573a\u73b0\u5728\u8fd9\u6837\u9677\u5165\u52a8\u8361\u7684\u72b6\u51b5\uff0c\u8fd9\u7b14\u4ea4\u6613\u53ef\u80fd\u4f1a\u4ee4\u5fae\u8f6f\u9677\u5165\u7f3a\u4e4f\u73b0\u91d1\u3001\u80cc\u8d1f\u5de8\u989d\u503a\u52a1\u7684\u56f0\u5883\u3002 <BR><BR>\u5373\u4fbf\u5982\u6b64\uff0c\u5fae\u8f6f\u7684\u8d44\u4ea7\u8d1f\u503a\u8868\u4e5f\u4e0d\u518d\u662f\u9ad8\u79d1\u6280\u516c\u53f8\u4e2d\u6700\u597d\u7684\u3002\u73b0\u91d1\u7a76\u7adf\u638c\u63e1\u5728\u54ea\u4e9b\u516c\u53f8\u7684\u624b\u4e2d\uff1fValleywag\u6839\u636e\u96c5\u864e\u8d22\u7ecf\u7684\u6570\u636e\uff0c\u8bc4\u9009\u51fa\u5168\u7403\u6700\u5bcc\u6709\u7684\u5341\u5927\u79d1\u6280\u516c\u53f8\u3002 <BR><BR><STRONG>1\u3001\u4e2d\u56fd\u79fb\u52a8</STRONG> <BR><BR>\u73b0\u91d1\uff1a310\u4ebf\u7f8e\u5143 <BR><BR>\u4e2d\u56fd\u7684\u77f3\u6cb9\u3001\u94a2\u94c1\u548c\u91d1\u878d\u5de8\u5934\u90fd\u5728\u7eb7\u7eb7\u6295\u8d44\u6d77\u5916\uff0c\u4f5c\u4e3a\u4e2d\u56fd\u9886\u5148\u7684\u7535\u4fe1\u8fd0\u8425\u5546\uff0c\u4e2d\u56fd\u79fb\u52a8\u4e3a\u4ec0\u4e48\u4e0d\u6548\u4eff\u5462\uff1f <BR><BR><STRONG>2\u3001\u601d\u79d1</STRONG> <BR><BR>\u73b0\u91d1\uff1a262\u4ebf\u7f8e\u5143 <BR><BR>\u601d\u79d1\u5bf9\u4e8e\u516c\u53f8\u73b0\u6709\u7684\u73b0\u91d1\u50a8\u5907\u6781\u4e3a\u5f97\u610f\uff0c\u5176\u6295\u8d44\u5173\u7cfb\u4e3b\u7ba1\u5728\u535a\u5ba2\u66fe\u8c08\u5230\u8fd9\u4e00\u70b9\u3002\u4e0d\u8fc7\u6295\u8d44\u8005\u5bf9\u601d\u79d1\u6536\u8d2d\u793e\u4ea4\u7f51\u7edc\u7684\u5947\u602a\u4e3e\u52a8\u663e\u5f97\u6ca1\u6709\u4efb\u4f55\u4fe1\u5fc3\uff0c\u6bd5\u7adf\u793e\u4ea4\u7f51\u7ad9\u540c\u601d\u79d1\u8fd0\u884c\u826f\u597d\u7684\u4e3b\u4e1a\u7535\u4fe1\u8bbe\u5907\u751f\u4ea7\u4e4b\u95f4\u6ca1\u6709\u8054\u7cfb\u3002\u63d0\u9192\u601d\u79d1\u8d1f\u8d23\u5e76\u8d2d\u7684\u56e2\u961f\uff1a\u4e0d\u8981\u4ec5\u4ec5\u56e0\u4e3a\u6709\"\u7f51\u7edc\"\u4e00\u8bcd\uff0c\u4f60\u4eec\u5c31\u60f3\u628a\u793e\u4ea4\u7f51\u7ad9\u6536\u5165\u9ebe\u4e0b\u3002 <BR><BR><STRONG>3\u3001\u5fae\u8f6f</STRONG> <BR><BR>\u73b0\u91d1\uff1a212\u4ebf\u7f8e\u5143 <BR><BR>\u4eca\u5e74\u521d\u5fae\u8f6f\u8ba1\u5212\u4ee5440\u4ebf\u7f8e\u5143\u5927\u624b\u7b14\u6536\u8d2d\u96c5\u864e\uff0c\u5f53\u65f6\u63d0\u4f9b\u7684\u65b9\u6848\u662f\u4e00\u534a\u73b0\u91d1\uff0c\u4e00\u534a\u80a1\u7968\u3002\u4e00\u65e6\u8fd9\u7b14\u4ea4\u6613\u6210\u4ea4\uff0c\u8fd9\u53ef\u80fd\u4f1a\u8017\u5c3d\u5fae\u8f6f\u6240\u6709\u73b0\u91d1\u50a8\u5907\uff0c\u5e76\u80cc\u8d1f\u503a\u52a1\u3002\u73b0\u5728\u770b\u6765\uff0c\u4ea4\u6613\u544a\u5439\u5bf9\u5fae\u8f6f\u6765\u8bf4\u771f\u662f\u518d\u5e78\u8fd0\u4e0d\u8fc7\u7684\u4e8b\u4e86\u3002 <BR><BR><STRONG>4\u3001\u82f9\u679c</STRONG> <BR><BR>\u73b0\u91d1\uff1a207\u4ebf\u7f8e\u5143 <BR><BR>20\u4e16\u7eaa90\u5e74\u4ee3\uff0c\u82f9\u679c\u51e0\u4e4e\u82b1\u5149\u4e86\u6240\u6709\u7684\u73b0\u91d1\u3002\u4ece\u5f53\u524d\u60c5\u51b5\u6765\u770b\uff0c\u82f9\u679c\u77ed\u671f\u5185\u4e0d\u4f1a\u518d\u906d\u9047\u8fd9\u79cd\u5371\u9669\u3002\u867d\u7136\u505a\u4e8b\u4e00\u8d2f\u4e0d\u4e8b\u58f0\u5f20\u7684\u82f9\u679c\u4ece\u672a\u8fdb\u884c\u8fc7\u5927\u89c4\u6a21\u6536\u8d2d\uff0c\u4f46\u662f\u597d\u7684\u65f6\u673a\u5230\u6765\u65f6\uff0c\u6050\u6015\u82f9\u679c\u4f1a\u6539\u53d8\u8fd9\u4e00\u60ef\u4f8b\u3002 <BR><BR><STRONG>5\u3001\u8c37\u6b4c </STRONG><BR>\u73b0\u91d1\uff1a127\u4ebf\u7f8e\u5143 <BR><BR>\u8c37\u6b4c\u80a1\u7968\u8fd1\u671f\u5f00\u59cb\u8d70\u8f6f\uff0c\u8fd9\u53ef\u80fd\u610f\u5473\u7740\u8c37\u6b4c\u4f1a\u52a8\u7528\u66f4\u591a\u73b0\u91d1\u800c\u975e\u80a1\u7968\u8fdb\u884c\u6536\u8d2d\u3002 <BR><BR><STRONG>6\u3001\u82f1\u7279\u5c14</STRONG> <BR><BR>\u73b0\u91d1\uff1a120\u4ebf\u7f8e\u5143 <BR><BR>\u82f1\u7279\u5c14\u7684\u82af\u7247\u5de5\u5382\u9700\u8981\u6570\u5341\u4ebf\u7f8e\u5143\u7684\u6295\u8d44\uff1b\u5206\u6790\u5e08\u4f30\u8ba1\uff0c\u82f1\u7279\u5c14\u4f1a\u5c06\u73b0\u91d1\u7528\u4e8e\u82af\u7247\u751f\u4ea7\u6295\u8d44\uff0c\u800c\u975e\u7528\u4e8e\u6536\u8d2d\u5c0f\u578b\u79d1\u6280\u516c\u53f8\u3002 <BR><BR><STRONG>7\u3001\u8bfa\u57fa\u4e9a</STRONG> <BR><BR>\u73b0\u91d1\uff1a108\u4ebf\u7f8e\u5143 <BR><BR>\u540c\u601d\u79d1\u4e00\u6837\uff0c\u8bfa\u57fa\u4e9a\u4e5f\u6e34\u671b\u8fdb\u519b\u4e92\u8054\u7f51\u9886\u57df\uff0c\u8fd9\u5bb6\u516c\u53f8\u5c24\u5176\u5bf9\u535a\u5ba2\u548c\"\u751f\u6d3b\u76f4\u64ad\"(lifecasting)\u611f\u5174\u8da3\u3002\u8bfa\u57fa\u4e9a\u53ef\u80fd\u9ad8\u4e3e\u6536\u8d2d\u5927\u65d7\uff0c\u5bf9Six Apart\u3001Automattic\u6216Tumblr\u8fdb\u884c\u6536\u8d2d\u3002 <BR><BR><STRONG>8\u3001\u6234\u5c14</STRONG> <BR><BR>\u73b0\u91d1\uff1a90\u4ebf\u7f8e\u5143 <BR><BR>\u5018\u82e5\u6210\u529f\u5c06\u5176PC\u5de5\u5382\u51fa\u552e\uff0c\u6234\u5c14\u624b\u4e2d\u5c06\u638c\u63e1\u66f4\u591a\u73b0\u91d1\u3002\u5728\u60e0\u666e\u4e0d\u65ad\u4ece\u5176\u624b\u4e2d\u593a\u53d6\u5e02\u573a\u4efd\u989d\u65f6\uff0c\u5916\u754c\u8ba4\u4e3a\u6234\u5c14\u53ef\u80fd\u4f1a\u91c7\u53d6\u8fd9\u9879\u63aa\u65bd\u3002\u6234\u5c14\u7684\u6536\u8d2d\u76ee\u6807\u662f\u8f6f\u4ef6\u548c\u76f8\u5173\u670d\u52a1\u516c\u53f8\u3002 <BR><BR><STRONG>9\u3001\u6469\u6258\u7f57\u62c9</STRONG> <BR><BR>\u73b0\u91d1\uff1a72\u4ebf\u7f8e\u5143 <BR><BR>\u5728\u89e3\u51b3\u597d\u516c\u53f8\u624b\u673a\u4e1a\u52a1\u906d\u9047\u7684\u6311\u6218\u4e4b\u524d\uff0c\u6469\u6258\u7f57\u62c9\u5f88\u96be\u5bf9\u5916\u5c55\u5f00\u5927\u89c4\u6a21\u6536\u8d2d\u3002 <BR><BR><STRONG>10\u3001\u53f0\u79ef\u7535</STRONG> <BR><BR>\u73b0\u91d1\uff1a70\u4ebf\u7f8e\u5143 <BR><BR>AMD\u5e02\u503c\u4ec5\u4e3a26\u4ebf\u7f8e\u5143\uff0c\u800c\u53f0\u79ef\u7535\u4e00\u76f4\u5728\u4e3aAMD\u751f\u4ea7\u82af\u7247\uff0c\u65e2\u7136\u73b0\u91d1\u6570\u91cf\u8fdc\u8fdc\u8d85\u8fc7AMD\uff0c\u4e3a\u4f55\u4e0d\u5c06\u5176\u6536\u8d2d\uff1f<BR></P>\r\n<P>&nbsp;</P>\r\n<P>\u9a71\u52a8\u4e4b\u5bb6</P>", "imagename": null, "infoid": 96884, "category": "technology_internet", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u79d1\u6280", "\u516c\u53f8"]}, {"url": null, "title": "Facebook\u56fe\u7247\u91cf\u7834\u767e\u4ebf\u5f20 \u8d85\u8d8aFlickr\u7b49\u7f51\u7ad9", "tags": "Facebook Flickr ", "name": "yinyin", "posttime": "2008-10-17 09:02:44", "ip": "222.128.48.207", "mark": 1, "note": "\u636e\u56fd\u5916\u5a92\u4f53\u62a5\u9053\uff0c\u5c3d\u7ba1Facebook\u672c\u8d28\u4e0a\u5e76\u4e0d\u662f\u4e00\u4e2a\u7167\u7247\u5206\u4eab\u7f51\u7ad9\uff0c\u4f46\u76ee\u524d\u5374\u62e5\u6709\u6570\u91cf\u5927\u5f97\u60ca\u4eba\u7684\u56fe\u7247\u5b58\u50a8\u6570\u91cf\u3002\u8fd9\u4e00\u6570\u5b57\u751a\u81f3\u8d85\u8fc7\u4e86\u65b0\u95fb\u96c6\u56e2\u65d7\u4e0b\u7684\u7167\u7247\u5206\u4eab\u7f51\u7ad9Photobucket\u548c\u96c5\u864e\u65d7\u4e0b\u7684Flickr\u3002\r\n<P>\u3000\u3000\u672c\u5468\u4e8c\u665a\u4e9b\u65f6\u5019\uff0cFacebook\u7684\u5de5\u7a0b\u5e08\u9053\u683c\u00b7\u8d1d\u5f17(Doug Beaver)\u5728\u4ed6\u7684\u535a\u5ba2\u4e0a\u58f0\u79f0\uff0cFacebook\u7167\u7247\u603b\u6570\u5df2\u7a81\u7834100\u4e07\u4e08\uff0c\u8fd9\u5bb6\u793e\u4ea4\u7f51\u7ad9\u5728\u4eca\u5e748\u6708\u7684\u65f6\u5019\u66fe\u5ba3\u5e03\u6d3b\u8dc3\u7528\u6237\u8d85\u8fc71\u4ebf\u4eba\u3002</P>\r\n<P>\u3000\u3000\u800c\u53e6\u4e00\u65b9\u9762\uff0c\u65b0\u95fb\u96c6\u56e2\u65d7\u4e0b\u7684\u56fe\u7247\u7f51\u7ad9Photobucket\u5468\u4e09\u4e0a\u5348\u56fe\u7247\u603b\u6570\u4e3a\u63a5\u8fd162\u4ebf\u5f20\uff0c\u96c5\u864e\u65d7\u4e0b\u7684Flickr\u4e0d\u5230\u4e00\u5e74\u524d\u624d\u8fbe\u523020\u4ebf\u5f20\u3002</P>\r\n<P>\u3000\u3000CNET\u8457\u540d\u535a\u5ba2\u5361\u7f57\u7433\u00b7\u9ea6\u5361\u9521(Caroline McCarthy)\u5219\u6307\u51fa\uff0c\u5c3d\u7ba1Facebook\u73b0\u5728\u770b\u8d77\u6765\u7684\u786e\u5f88\u6d41\u884c\uff0c\u4f46\u540c\u6837\u4e5f\u9762\u4e34\u7740\u95ee\u9898\u3002Facebook\u4e3a\u6bcf\u4e00\u5f20\u7167\u7247\u5b58\u50a84\u79cd\u4e0d\u540c\u7684\u5927\u5c0f\u89c4\u683c\uff0c\u8fd9\u610f\u5473\u7740\u9700\u8981\u670d\u52a1\u5668\u6765\u5b58\u50a8\u8d85\u8fc7400\u4ebf\u5f20\u7167\u7247\uff0c\u8fd9\u9700\u8981\u5927\u91cf\u7684\u5b58\u50a8\u8bbe\u5907----\u867d\u7136\u5b58\u50a8\u8bbe\u5907\u73b0\u5728\u4fbf\u5b9c\uff0c\u4f46\u4e5f\u5e76\u4e0d\u662f\u53ef\u4ee5\u514d\u8d39\u4f7f\u7528\u3002</P>\r\n<P>\u3000\u3000\u4eca\u5e745\u6708\uff0cFacebook\u66fe\u501f\u67651\u4ebf\u7f8e\u5143\u7528\u4e8e\u63d0\u5347\u670d\u52a1\uff0c\u5c3d\u7ba1\u8be5\u516c\u53f8\u662f\u98ce\u6295\u673a\u6784\u7684\u5ba0\u513f\uff0c\u4f46\u5b83\u7684\u8425\u6536\u4f55\u65f6\u80fd\u8d76\u4e0a\u670d\u52a1\u5668\u7684\u5f00\u652f\u5c1a\u4e0d\u5f97\u77e5\u3002Facebook\u521b\u59cb\u4eba\u9a6c\u514b\u00b7\u624e\u514b\u535a\u683c(Mark Zuckerberg)\u66fe\u5728\u4e0a\u5468\u8868\u793a\uff0c\u516c\u53f8\u4e89\u53d6\u5728\u4e09\u5e74\u5185\u76c8\u5229\u3002</P>\r\n<P>&nbsp;</P>\r\n<P>\u65b0\u6d6a\u79d1\u6280</P>", "imagename": null, "infoid": 96883, "category": "technology_web2", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["facebook", "flickr"]}, {"url": "http://www.pctutu.com/support/viewtopic.html?topicid=116972", "title": "\u8d85\u7ea7\u5154\u5b50\u250a 2008.10 \u250a \u5341\u5468\u5e74\u7eaa\u5ff5\u7248", "tags": "\u8d85\u7ea7\u5154\u5b50 ", "name": "yinyin", "posttime": "2008-10-17 08:54:17", "ip": "222.128.48.207", "mark": 2, "note": "\u66f4\u65b0\u5bc4\u8bed\uff1a\u4eca\u5e74\u662f\u8d85\u7ea7\u5154\u5b50 10\u5468\u5e74\u7eaa\u5ff5\uff0c\u63a8\u51fa\u6700\u65b0\u8d85\u7ea7\u5154\u5b50\u65b0\u6210\u5458\u53cd\u5f39