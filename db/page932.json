5168\u65b0\u7684\u7528\u6237\u6ce8\u518c\u4f53\u7cfb\u548c\u7528\u6237\u4f7f\u7528\u754c\u9762\uff0c\u5e76\u542f\u52a8\u65b0\u7684\u5e73\u53f0\u67b6\u6784\u8bbe\u8ba1\uff0c\u52a0\u901f\u4e16\u754c\u7684\u6539\u53d8\u548c\u5347\u7ea7\uff1a \r\n\r\n\u25cf \u91c7\u7528\u65b0\u7684\u7528\u6237\u540d\u4f53\u7cfb\uff0c\u65b9\u4fbf\u548c\u4fc3\u8fdb\u5168\u7403\u591a\u8bed\u79cd\u5c45\u6c11\u7684\u8bc6\u522b\u548c\u4ea4\u6d41\u3002\r\n\u7528\u6237\u540d\u4f53\u7cfb\u662f\u865a\u62df\u4e16\u754c\u5185\u793e\u4ea4\u548c\u4fe1\u7528\u7684\u57fa\u7840\uff0c\u4e5f\u662f\u5c45\u6c11\u5b9d\u8d35\u7684\u65e0\u5f62\u8d44\u4ea7\u3002\u4fe1\u7528\u4f53\u7cfb\u548c\u8d44\u4ea7\u4f53\u7cfb\uff0c\u662f\u672a\u6765\u865a\u62df\u4e16\u754c\u7e41\u8363\u7684\u57fa\u77f3\u4e4b\u4e00\u3002\u56e0\u6b64\uff0c\u4e3a\u4e86\u8fce\u63a5\u672a\u6765\u5927\u89c4\u6a21\u591a\u8bed\u79cd\u7528\u6237\u7684\u5165\u9a7b\uff0c\u5efa\u7acb\u548c\u7528\u6237\u540d\u5173\u8054\u7684\u4fe1\u7528\u4f53\u7cfb\uff0cHiPiHi\u4ece\u201c\u793e\u4f1a\u521d\u663e\u201d\u9636\u6bb5\u5f00\u59cb\uff0c\u5728\u5145\u5206\u8003\u8651OpenID\u3001\u56fd\u9645\u5316\u3001\u7528\u6237\u6ce8\u518c\u4f53\u9a8c\u3001\u4ee5\u53ca\u6ce8\u518c\u8d44\u6e90\u4e0e\u7528\u6237\u4e2a\u6027\u7684\u8bf8\u591a\u9700\u6c42\u57fa\u7840\u4e0a\uff0c\u542f\u7528\u5168\u65b0\u7684\u7528\u6237\u540d\u4f53\u7cfb\u3002\r\n\r\n\u25cf \u63a8\u51fa\u66f4\u5177\u7279\u8272\u548c\u4eba\u6027\u5316\u7684\u7528\u6237\u754c\u9762\uff0c\u5e26\u6765\u7115\u7136\u4e00\u65b0\u7684\u4f7f\u7528\u4f53\u9a8c\u3002\r\nHiPiHi\u4e16\u754c\u65b0\u63a8\u51fa\u7684\u7528\u6237\u754c\u9762\uff0c\u91c7\u7528\u6e05\u65b0\u7684\u94f6\u7070\u8272\u5916\u89c2\uff0c\u91cd\u65b0\u8bbe\u8ba1\u548c\u6574\u5408\u4e86\u5404\u79cd\u529f\u80fd\u6392\u5217\u548c\u64cd\u4f5c\u6307\u793a\uff0c\u5e26\u7ed9\u7528\u6237\u66f4\u52a0\u7b80\u660e\u4fbf\u6377\u7684\u4f7f\u7528\u4f53\u9a8c\u3002\u540c\u65f6\uff0c\u5f62\u8c61\u5316\u7684\u56fe\u6807\u6309\u952e\u4ee3\u66ff\u4e86\u6587\u5b57\u8bf4\u660e\uff0c\u4e0d\u4ec5\u4f7f\u5f97\u529f\u80fd\u64cd\u4f5c\u66f4\u52a0\u4eba\u6027\u5316\u3001\u66f4\u5177\u4ea4\u4e92\u6027\uff0c\u4e5f\u65b9\u4fbf\u4e86\u975e\u4e2d\u6587\u7528\u6237\u7684\u7406\u89e3\u548c\u4f7f\u7528\u3002\u5728\u4f18\u5316\u539f\u6709\u529f\u80fd\u64cd\u4f5c\u7684\u540c\u65f6\uff0c\u201c\u793e\u4f1a\u521d\u663e\u201d\u754c\u9762\u4e2d\u8fd8\u7279\u522b\u589e\u52a0\u4e86\u5728\u7ebf\u4eba\u5458\u540d\u79f0\u5217\u8868\uff0c\u5f15\u5bfc\u548c\u4fc3\u8fdb\u7528\u6237\u4e4b\u95f4\u5b9e\u65f6\u7684\u4ea4\u6d41\u548c\u4e92\u52a8\u3002\r\n\r\n\u25cf \u589e\u52a0\u52a8\u6001\u81ea\u7136\u690d\u7269\u7cfb\u7edf\uff0c\u4e0d\u65ad\u4f18\u5316\u548c\u5b8c\u5584\u521b\u9020\u529f\u80fd\uff0c\u542f\u52a8\u793e\u4f1a\u7ecf\u6d4e\u4f53\u7cfb\u3002\r\n\u6625\u82b1\u79cb\u6708\uff0c\u51ac\u96ea\u590f\u971c\uff0c\u7eff\u6811\u6447\u66f3\uff0cHiPiHi\u4e16\u754c\u6709\u7740\u548c\u771f\u5b9e\u4e16\u754c\u540c\u6837\u7684\u65f6\u7a7a\u53d8\u5e7b\u548c\u81ea\u7136\u7f8e\u666f\u3002\u8054\u5408\u521b\u9020\u3001\u4eba\u7269\u6302\u8f7d\u7cfb\u7edf\u3001\u521d\u7ea7\u811a\u672c\u7f16\u5199\u3001\u793e\u56e2\u804a\u5929\u2026\uff0c\u5df2\u6709\u7684\u521b\u9020\u529f\u80fd\u6b63\u5728\u4e0d\u65ad\u4f18\u5316\u548c\u5b8c\u5584\uff0c\u5e73\u53f0\u7684\u64cd\u4f5c\u548c\u4f7f\u7528\u4e5f\u66f4\u7a33\u5b9a\u548c\u6d41\u7545\u3002\u62e5\u6709\u3001\u653e\u5f03\u3001\u51fa\u552e\u3001\u642c\u8fc1\u571f\u5730\uff0c\u5c45\u6c11\u4e4b\u95f4\u7684\u7269\u7269\u4ea4\u6362\u2026\u571f\u5730\u6743\u9650\u548c\u4fe1\u606f\u7ba1\u7406\u529f\u80fd\uff0c\u5f3a\u5316\u57fa\u4e8e\u80cc\u5305\u7684\u7269\u54c1\u4ea4\u6362\u529f\u80fd\uff0c\u865a\u62df\u7ecf\u6d4e\u4f53\u7cfb\u8fd0\u8f6c\u4e4b\u95e8\u6b63\u5728\u5f90\u5f90\u5f00\u542f\u3002\r\n\r\n\u25cf \u6b63\u5728\u5f62\u6210\u3001\u65e5\u76ca\u4e30\u5bcc\u7684\u591a\u5143\u5316\u7684\u865a\u62df\u4e16\u754c\u6587\u5316\u548c\u4ef7\u503c\u89c2\u3002\r\nHiPiHi\u865a\u62df\u4e16\u754c\u5185\u7b2c\u4e00\u4e2a\u7531\u5c45\u6c11\u81ea\u53d1\u5021\u8bae\u3001\u81ea\u4e3b\u5efa\u8bbe\u7684\u516c\u5171\u793e\u533a\u201c\u539f\u70b9\u9547\u201d\uff0c\u6b63\u5728\u65e9\u671f\u5c45\u6c11\u7684\u70ed\u60c5\u63a8\u52a8\u4e0b\u7b79\u5907\u3001\u5c55\u5f00\uff1bHiPiHi\u4e16\u754c\u5185\u7535\u89c6\u53f0\uff0c\u8bb2\u8ff0\u5c45\u6c11\u81ea\u5df1\u7684\u6545\u4e8b\uff1b\u5c45\u6c11\u6d3b\u52a8\u548c\u660e\u661f\u5c42\u51fa\u4e0d\u7a77\uff0c\u201c\u8bf4\u5427\u201d\u4e2d\u6c47\u805a\u4e16\u754c\u70ed\u70b9\u8bdd\u9898\u2026 \r\n\r\n\u25cf \u542f\u52a8\u65b0\u7684\u5e73\u53f0\u67b6\u6784\u8bbe\u8ba1\u3002\r\n\u201c\u793e\u4f1a\u521d\u663e\u201d\u9636\u6bb5\u7684HiPiHi\u4e16\u754c\uff0c\u5728\u7ee7\u7eed\u5b8c\u5584\u73b0\u6709\u529f\u80fd\u548c\u63a8\u52a8\u865a\u62df\u4e16\u754c\u793e\u533a\u5efa\u8bbe\u7684\u540c\u65f6\uff0c\u5f00\u59cb\u542f\u52a8\u8bbe\u8ba1\u65b0\u7684\u5e73\u53f0\u4f53\u7cfb\u67b6\u6784\u3002HiPiHi\u5c06\u8054\u5408\u5305\u62ecIntel\u548cIBM\u5728\u5185\u7684\u5168\u7403IT\u4ea7\u4e1a\u7684\u6218\u7565\u5408\u4f5c\u4f19\u4f34\uff0c\u5171\u540c\u8bbe\u8ba1\u548c\u63a8\u52a8\u4e00\u4e2a\u5168\u9762\u5f00\u653e\u3001\u9ad8\u5ea6\u53ef\u6269\u5c55\u3001\u4e92\u8054\u4e92\u901a\u7684\u771f\u6b63\u610f\u4e49\u4e0a\u7684\u865a\u62df\u4e16\u754c\uff0c\u4e3a\u865a\u62df\u4e16\u754c\u7684\u5168\u9762\u8fdb\u5165\u5e02\u573a\u4e3b\u6d41\u5e94\u7528\u5efa\u7acb\u4e00\u4e2a\u575a\u5b9e\u7684\u57fa\u7840\u3002\r\n\r\n\u201c\u5929\u4e0a\u4e00\u5929\uff0c\u4e16\u4e0a\u4e00\u5e74\u201d\uff0c\u5728\u8fd9\u77ed\u6682\u800c\u53c8\u6f2b\u957f\u7684\u4e00\u5e74\u91cc\uff0c\u4ece\u5f00\u5929\u8f9f\u5730\uff0c\u5973\u5a32\u9020\u4eba\u3001\u5929\u5de5\u9020\u7269\u5230\u793e\u4f1a\u521d\u663e\uff0c4\u4e07\u591a\u7684\u65e9\u671f\u5c45\u6c11\u548cHiPiHi\u56e2\u961f\u4e00\u9053\u5171\u540c\u89c1\u8bc1HiPiHi\u4e16\u754c\u8fd9\u5757\u865a\u62df\u5927\u9646\u8bde\u751f\u548c\u6f14\u5316\u7684\u5386\u53f2\u8f68\u8ff9\u3002\u4ece\u4eca\u5929\u5f00\u59cb\uff0c\u66f4\u591a\u7684\u65b0\u5c45\u6c11\u5c06\u8fdb\u5165\u8fd9\u7247