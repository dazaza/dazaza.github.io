1a\u8fc7Microsoft Silverlight\uff0c\u4f46\u54b1\u4eec\u53ef\u4ee5\u5148\u8fbe\u6210\u4e00\u4e2a\u5171\u8bc6\uff1aSilverlight\u548cAIR\u6709\u5f02\u66f2\u540c\u5de5\u4e4b\u5999\u3002\u4e0d\u70b9\u7684\u662f\uff1a\u5b83\u4eec\u4e0d\u662f\u4e00\u4e2a\u5988\u751f\u7684\u3002\u82b1\u4e86\u8fd9\u4e48\u591a\u529f\u592b\u4e86\u89e3 Silverlight\uff0c\u63a5\u4e0b\u6765\uff0c\u54b1\u4eec\u53ef\u4ee5\u6765\u770b\u770bDeepZoomPix\u4e86\u3002\r\n\r\n\u3000\u3000Deepzoompix\u662f\u6765\u81ea\u5fae\u8f6f\u7684\u4ea4\u4e92\u5f0f\u7535\u5b50\u76f8\u518c\uff0c\u5b83\u80fd\u7ed9\u4f60\u4e0d\u540c\u4e00\u822c\u7684\u89c6\u89c9\u4eab\u53d7\uff01\u5728MIX09\u5927\u4f1a\u4e0a\uff0c\u5fae\u8f6f\u9664\u4e86\u5ba3\u5e03Silverlight 3.0 beta\u4e4b\u5916\uff0c\u8fd8\u6f14\u793a\u4e86\u4e00\u4e9b\u5176\u5b83\u5f15\u4eba\u6ce8\u76ee\u7684\u65b0\u4ea7\u54c1\u548c\u65b0\u6280\u672f\uff0c\u5176\u4e2d\u4e4b\u4e00\u5c31\u662fDeepzoompix\uff0c\u4e00\u4e2a\u5229\u7528Silverlight\u4e2dDeepZoom\u6280\u672f\u6253\u9020\u7684\u522b\u5177\u4e00\u683c\u7684\u7535\u5b50\u76f8\u518c\u3002\r\n\r\n\u3000\u3000Deepzoompix\u76ee\u524d\u8fd8\u5728Alpha\u6d4b\u8bd5\uff0c\u4e0d\u8fc7\u5927\u5bb6\u53ef\u4ee5\u901a\u8fc7Window Live ID\u767b\u5f55\u62a2\u5148\u4eab\u7528\u3002\u5fae\u8f6f\u91cd\u62f3\u63a8\u51faDeepzoompix\uff0c\u662f\u5e0c\u671b\u4e3a\u7528\u6237\u63d0\u4f9b\u4e00\u79cd\u65b0\u7684\u3001\u66f4\u5177\u4ea4\u4e92\u6027\u7684\u7535\u5b50\u76f8\u518c\u3002\r\n\r\nimage\r\n\r\n\u3000\u3000\u5927\u5bb6\u53ef\u4ee5\u8bd5\u8bd5\u7528Deepzoompix\u4ee5\u4e00\u79cd\u524d\u6240\u672a\u6709\u7684\u65b9\u5f0f\u6765\u6d4f\u89c8\u522b\u4eba\u4e0a\u4f20\u7684\u56fe\u7247\uff0c\u4efb\u4f55\u4eba\u90fd\u53ef\u4ee5\u4f53\u9a8c\u4e00\u628aDeepzoompix\u6709\u591a\u9177\u3002\u652f\u6301\u5355\u5f20\u56fe\u7247\u7684\u6d4f\u89c8\u3001\u64ad\u653e\uff0c\u62d6\u62fd\u7b49\u64cd\u4f5c\u3002\u5bf9\u4e8e\u591a\u5f20\u56fe\u7247\u6216\u4e13\u8f91\u76f8\u518c\uff0cDeepzoompix\u80fd\u8ba9\u4f60\u4ee5\u7279\u6709\u7684Sideshow\u65b9\u5f0f\u6d4f\u89c8\u56fe\u7247\uff0c\u5176\u8fd1\u4e4e\u5b8c\u7f8e\u7684\u5448\u73b0\u65b9\u5f0f\u7edd\u5bf9\u4f1a\u7ed9\u4f60\u89c6\u89c9\u4e0a\u5f3a\u5927\u7684\u51b2\u51fb\uff0c\u8ba9\u4f60\u771f\u6b63\u7684\u5f97\u5230\u4eab\u53d7\uff01Deepzoompix Slideshow \u63a7\u5236\u4e5f\u662f\u53ef\u5708\u53ef\u70b9\uff0c\u82e5\u5e72\u5f20\u56fe\u7247\u53ef\u4ee5\u4ee5\u591a\u79cd\u53e0\u653e\u7ec4\u5408\u65b9\u5f0f\u4efb\u610f\u9009\u62e9\uff0c\u81ea\u52a8\u64ad\u653e\u9009\u62e9\uff0c\u9f20\u6807\u62d6\u62c9\u63a7\u5236\u7b49\u7b49\uff0c\u4f1a\u7ed9\u4f60\u5168\u65b0\u7684\u4f53\u9a8c\uff01\r\n\r\nimage\r\n\r\n\u3000\u3000\u5982\u679c\u4f60\u6709\u4e00\u4e2aLive ID\uff0c\u4f60\u4e5f\u53ef\u4ee5\u628a\u4f60\u7684\u7167\u7247\u4e0a\u4f20\u7ed9\u5927\u5bb6\u5206\u4eab\u3002\u4e0d\u8fc7\u8981\u63d0\u9192\u5927\u5bb6\uff0c\u53ef\u80fd\u662f\u56e0\u4e3a\u6d4b\u8bd5\u671f\u7684\u539f\u56e0\uff0c\u6240\u4e0a\u4f20\u7684\u56fe\u7247\u6ca1\u6709\u6743\u9650\u8bbe\u7f6e\u529f\u80fd\u3002\u4e5f\u5c31\u662f\u8bf4\u4f60\u4e0a\u4f20\u7684\u56fe\u7247\u5c06\u88ab\u4efb\u4f55\u4eba\u6d4f\u89c8\u5230\u3002\u6240\u4ee5\u5728\u4f60\u4f53\u9a8c\u4e4b\u524d\uff0c\u4e0d\u8981\u628a\u4f60\u7684\u79c1\u5bc6\u56fe\u7247\u4f20\u4e0a\u53bb\u4e86\u3002\u5728\u5b98\u65b9\u770b\u5230\u6709\u5173Deepzoompix\u76f8\u518c\u7684\u66f4\u591a\u8bf4\u660e\uff0c\u6bd4\u5982\u76f8\u518c\u7a7a\u95f4\u3001\u7167\u7247\u5927\u5c0f\u9650\u5236\u3001\u6d41\u91cf\u9650\u5236\u7b49\u7b49\uff0c\u4f46\u5c31\u76ee\u524d\u800c\u8a00\uff0c\u57fa\u672c\u7684\u56fe\u7247\u4e0a\u4f20\u5012\u662f\u7545\u901a\u65e0\u963b\u3002\r\n\r\nimage\r\n\r\n\u3000\u3000\u5c31\u8fde\u4e0a\u4f20\u529f\u80fd\uff0c\u90fd\u505a\u5f97\u5982\u6b64\u4e4b\u9177\u3002\u5982\u679c\u8981\u628a\u4f60\u7684\u56fe\u7247\u5206\u4eab\u7ed9\u4f60\u7684\u670b\u53cb\uff0c\u5728\u4e0a\u4f20\u5b8c\u6210\u540e\u4f1a\u6709\u5206\u4eab\u4ee3\u7801\u3002\u590d\u5236\u4ee3\u7801\uff0c\u7c98\u8d34\u5230\u4f60\u7684\u535a\u5ba2\u4e2d\uff0c\u4f60\u7684\u670b\u53cb\u5c31\