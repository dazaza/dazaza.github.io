4a\u4e9a\u6d32\u676f\u7684\u6240\u6709\u7cbe\u5f69\u77ac\u95f4\u3002\r\n\r\n2007\u5e747\u67087\u65e5\u81f329\u65e5\u4e9a\u6d32\u8db3\u7403\u6700\u9ad8\u7ea7\u522b\u8d5b\u4e8b\u2014\u2014\u4e9a\u6d32\u676f\u5373\u5c06\u5728\u4e1c\u5357\u4e9a\u7684\u5370\u5ea6\u5c3c\u897f\u4e9a\u3001\u8d8a\u5357\u3001\u9a6c\u6765\u897f\u4e9a\u548c\u6cf0\u56fd\u8054\u5408\u4e3e\u884c\uff0c\u4e2d\u56fd\u56fd\u5bb6\u961f\u5c06\u4ee3\u8868\u4e2d\u56fd\u5f81\u6218\u4e9a\u6d32\u676f\uff0c\u5728\u8fd9\u5168\u4e9a\u6d32\u77a9\u76ee\u7684\u65f6\u523b\uff0c\u4e2d\u56fd\u9886\u5148\u7684\u65b0\u5a92\u4f53\u3001\u641c\u7d22\u53ca\u79fb\u52a8\u589e\u503c\u670d\u52a1\u516c\u53f8\u641c\u72d0\u516c\u53f8\uff08NASDAQ\uff1aSOHU\uff09\u5c06\u72ec\u5bb6\u89c6\u9891\u64ad\u62a5\u4e9a\u6d32\u676f\u7cbe\u5f69\u8d5b\u4e8b\uff0c\u6210\u4e3a\u4e9a\u6d32\u676f\u5386\u53f2\u4e0a\u9996\u5bb6\u8fdb\u884c\u89c6\u9891\u76f4\u64ad\u7684\u7f51\u7edc\u5a92\u4f53\u3002\u5373\u65e5\u8d77\uff0c\u767b\u5f552007\u4e9a\u6d32\u676f\u7f51\u7ad9\uff08http://asiancup2007.sohu.com/\uff09\uff0c\u5168\u6c11\u5171\u4eab\u4e9a\u6d32\u676f\u72c2\u6b22\u76db\u5bb4\uff0c\u8ba9\u4e2d\u56fd\u4ebf\u4e07\u89c2\u4f17\u4e0e\u4e16\u754c\u4f53\u80b2\u540c\u884c\u3002\r\n\r\n\u3000\u3000\u56db\u5e74\u4e00\u6b21\u7684\u4e9a\u6d32\u676f\u662f\u5168\u4e9a\u6d32\u6700\u9876\u7ea7\u7684\u7684\u8db3\u7403\u76db\u4f1a\uff0c\u662f\u5168\u4e16\u754c\u7403\u8ff7\u77a9\u76ee\u7684\u72c2\u6b22\u5e86\u5178\u3002\u60dc\u522b2004\u5e74\u5317\u4eac\u4e9a\u6d32\u676f\u540e\uff0c\u4e2d\u56fd\u56fd\u5bb6\u961f\u518d\u6b21\u95ea\u8000\u767b\u573a\uff0c\u641c\u72d0\u4f5c\u4e3a\u552f\u4e00\u4eab\u6709\u91c7\u8bbf\u6743\u548c\u72ec\u5bb6\u62cd\u6444\u6743\u76ca\u7684\u7f51\u7edc\u5a92\u4f53\uff0c\u5c06\u5168\u7a0b\u62a5\u9053\u8d5b\u51b5\uff0c\u51ed\u501f\u5176\u9876\u5c16\u7684\u4e92\u8054\u7f51\u6280\u672f\u548c\u6210\u719f\u7684\u7f51\u7edc\u5e94\u7528\uff0c\u72ec\u5bb6\u89c6\u9891\u76f4\u64ad\u4e9a\u6d32\u676f\u7684\u6bcf\u4e00\u4e2a\u7cbe\u5f69\u77ac\u95f4\u3002\u641c\u72d0\u4f53\u80b2\u5c06\u4e3a\u4e2d\u56fd\u7403\u8ff7\u4f20\u9012\u524d\u65b9\u8d5b\u573a\u4e0a\u7cbe\u5f69\u8d5b\u4e8b\u56fe\u6587\u62a5\u9053\uff0c\u7cbe\u5f69\u8fdb\u7403\u89c6\u9891\u96c6\u9526\uff0c\u7403\u5458\u89c6\u9891\u96c6\u9526\u7b49\u7b49\uff0c\u4e00\u7f51\u6253\u5c3d\u4e9a\u6d32\u676f32\u573a\u7cbe\u5f69\u8d5b\u4e8b\u5185\u5916\u7684\u6bcf\u4e00\u4e2a\u52a8\u611f\u77ac\u95f4\u3002\r\n\r\n\u3000\u3000\u641c\u72d0\u96c6\u5965\u8fd0\u5b98\u7f51\u3001\u4e2d\u56fd\u4e4b\u961f\u5b98\u7f51\u3001\u4e2d\u8d85\u5b98\u7f51\u3001\u4e2d\u56fd\u8db3\u534f\u5b98\u7f51\u56db\u5927\u72ec\u5bb6\u8d44\u6e90\u4e8e\u4e00\u8eab\uff0c\u5728\u4e9a\u6d32\u676f\u6218\u706b\u9891\u71c3\u4e4b\u9645\uff0c\u641c\u72d0\u4f53\u80b2\u7cbe\u5fc3\u5236\u4f5c\u4e86\u4e2d\u56fd\u56fd\u5bb6\u961f\u6bcf\u4f4d\u7403\u5458\u5728\u4e2d\u8d85\u3001\u4e9a\u51a0\u3001\u571f\u4f26\u676f\u3001\u4e9a\u6d32\u676f\u7b49\u5404\u5927\u8d5b\u4e8b\u4e0a\u7684\u7cbe\u5f69\u89c6\u9891\u96c6\u9526\uff0c\u65e2\u662f\u56fd\u811a\u4eec\u7eff\u8335\u573a\u4e0a\u6218\u7ee9\u7684\u56de\u987e\uff0c\u4e5f\u662f\u5bf92007\u4e9a\u6d32\u676f\u7684\u7f8e\u597d\u5c55\u671b\u3002\u6700\u65b0\u3001\u6700\u5168\u3001\u6700\u6743\u5a01\u7684\u8d5b\u7a0b\u5b89\u6392\u3001\u7403\u961f\u9635\u5bb9\u3001\u6559\u7ec3\u3001\u573a\u6b21\u7b49\u6743\u5a01\u8d5b\u4e8b\u8d44\u8baf\u6c47\u805a\u4e8e\u641c\u72d0\u4f53\u80b2\uff0c\u6bcf\u573a\u6bd4\u8d5b\u7684\u6bcf\u6b21\u8fdb\u7403\u3001\u70b9\u7403\u5c04\u95e8\u3001\u7403\u5458\u88ab\u7f5a\u4e0b\u573a\u4ee5\u53ca\u6709\u5173\u5355\u573a\u6bd4\u8d5b\u7684\u603b\u7ed3\u6027\u8bc4\u8bba\u89c6\u9891\u3001\u7cbe\u5f69\u77ac\u95f4\u96c6\u9526\u4ee5\u53ca\u7efc\u5408\u62a5\u9053\u7b49\uff0c\u90fd\u5c06\u4ee5\u5c0f\u4e13\u9898\u7684\u5f62\u5f0f\u7ed9\u51fa\u7cbe\u5f69\u526a\u8f91\u3002\u5c4a\u65f6\uff0c\u7403\u8ff7\u4eec\u53ef\u4ee5\u6bcf\u5929\u968f\u65f6\u968f\u5730\u6253\u5f00\u4e92\u8054\u7f51\uff0c\u70b9\u51fb\u6536\u770b\u7ecf\u8fc7\u7cbe\u5fc3\u7f16\u8f91\u7684\u5f53\u5929\u6bd4\u8d5b\u7684\u7cbe\u5f69\u77ac\u95f4\u548c\u8d5b\u4e8b\u89c6\u9891\uff0c\u4e0d\u4f1a\u9057\u6f0f\u4efb\u4f55\u4e00\u5904\u7cbe\u5f69\u3002\r\n\r\n\u3000\u3000\u641c\u72d0\u6210\u529f\u7684\u89c6\u9891\u64ad\u62a5\u4e862006\u5e74\u5fb7\u56fd\u4e16\u754c\u676f\uff0c\u5176\u6210\u719f\u7684\u7f51\u7edc\u6280\u672f\u548c\u7f51\u7edc\u5e94\u7528\u5f81\u670d\u4e86\u6d77\u5185\u5916\u5e7f\u5927\u7f51\u6c11\u30022007\u4e9a\u6d32\u676f\u671f\u95f4\uff0c\u641c\u72d0\u4e0e\u534e\u5965\u5f3a\u5f3a\u8054\u624b\uff0c\u6d3e\u51fa\u7531\u6587\u5b57\u8bb0\u8005\u3001\u6444\u5f71\u8bb0\u8005\u548c\u89c6\u9891\u8bb0\u8005\u7ec4\u6210\u7684\u6700\u4f73\u62a5\u9053\u9635\u5bb9\uff0c\u8ddf\u968f\u4e2d\u56fd\u56fd\u5bb6\u961f\u4e00\u540c\u51fa\u5f81\uff0c\u6587\u5b57\u8bb0\u8005\u548c\u6444\u5f71\u8bb0\u8005\u4e0d\u4ec5\u5c06\u7b2c\u4e00\u65f6\u95f4\u62a5\u9053\u6700\u6743\u5a01\u3001\u6700\u5168\u9762\u7684\u4e9a\u6d32\u676f\u72ec\u5bb6\u8d44\u8baf\uff0c\u89c6\u9891\u8bb0\u8005\u5c06\u76f4\u63a5\u62cd\u6444\u6bd4\u8d5b\u5b9e\u51b5\u8fdb\u884c\u64ad\u51fa\uff0c\u5e7f\u5927\u7f51\u6c11\u5c06\u548c\u641c\u72d0\u524d\u7ebf\u8bb0\u8005\u56e2\u5171\u4eab\u7eff\u8335\u573a\u4e0a\u6bcf\u4e00\u4e2a\u7cbe\u5f69\u7684\u77ac\u95f4\u3002\u540c\u65f6\uff0c\u641c\u72d0\u8bb0\u8005\u56e2\u5c06\u72ec\u5bb6\u8d34\u8eab\u91c7\u8bbf\u56fd\u5bb6\u961f\u961f\u5458\u548c\u6559\u7ec3\uff0c\u72ec\u5bb6\u62a5\u9053\u8d5b\u573a\u5185\u5916\u7684\u70b9\u70b9\u6ef4\u6ef4\u3002\r\n\r\n\u3000\u3000\u4e9a\u6d32\u676f\u8d5b\u573a\u4e0a\u4e0d\u4ec5\u6709\u641c\u72d0\u5f3a\u5927\u7684\u62a5\u9053\u56e2\u961f\uff0c\u8fd8\u6709\u641c\u72d0\u5f3a\u5927\u7684\u535a\u5ba2\u9635\u5bb9\uff0c\u8054\u5408\u56fd\u811a\u3001\u641c\u72d0\u8bc4\u8bba\u56e2\u3001\u6587\u4f53\u660e\u661f\u52a9\u5a01\u56e2\u3001\u7403\u8ff7\u53d1\u70e7\u53cb\uff0c\u4e0d\u5206\u663c\u591c\u770b\u3001\u542c\u3001\u8bc4\u3001\u8bf4\uff0c\u5171\u540c\u89c1\u8bc1\u8d5b\u573a\u4e0a\u7684\u98ce\u4e91\u65f6\u523b\u3002\u636e\u6089\uff0c\u674e\u94c1\u3001\u674e\u91d1\u7fbd\u3001\u97e9\u9e4f\u7b49\u51e0\u4e4e\u5168\u90e8\u7684\u56fd\u5bb6\u961f\u961f\u5458\u548c\u4e2d\u8d85\u4e00\u7ebf\u961f\u5458\u7684\u72ec\u5bb6\u535a\u5ba2\u843d\u6237\u641c\u72d0\uff0c\u7ec4\u6210\u5f3a\u5927\u7684\u8db3\u7403\u660e\u661f\u535a\u5ba2\u5708http://sports.sohu.com/s2007/football-star/\uff0c\u4e0e\u5e7f\u5927\u7403\u8ff7\u4e00\u540c\u5206\u4eab\u4ed6\u4eec\u6bcf\u5929\u8bad\u7ec3\u6bd4\u8d5b\u7684\u771f\u60c5\u5b9e\u611f\u3002\r\n\r\n\u3000\u3000\u5f20\u658c\u3001\u5218\u5efa\u5b8f\u3001\u6bb5\u6684\u7b49\u592e\u89c6\u540d\u5634\u548c\u5189\u96c4\u98de\u3001\u90dd\u6d2a\u519b\u7b49\u77e5\u540d\u4f53\u80b2\u8bc4\u8bba\u5458\u5728\u641c\u72d0\u72ec\u5bb6\u5f00\u535a\uff0c\u5e76\u5728\u641c\u72d0\u7684\u4e9a\u6d32\u676f\u4e13\u9898\u4e2d\u5f00\u8bbe\u72ec\u5bb6\u4e13\u680f\u8fdb\u884c\u8d5b\u4e8b\u70b9\u8bc4\u3002\u592e\u89c6\u8457\u540d\u4e3b\u6301\u4eba\u767d\u5ca9\u677e\u5c06\u5728\u641c\u72d0\u8fdb\u884c\u4e9a\u6d32\u676f\u8d5b\u4e8b\u7684\u72ec\u5bb6\u70b9\u8bc4\u3002\u5e7f\u5927\u7f51\u53cb\u53ef\u968f\u65f6\u767b\u5f55\u4e13\u5bb6\u540d\u5634\u535a\u5ba2\u5708\uff08http://sports.sohu.com/s2006/pinglunyuanblog/ \uff09\uff0c\u4e0e\u4e13\u5bb6\u540d\u5634\u4eec\u5171\u540c\u7545\u8c08\u8d5b\u573a\u4e0a\u7684\u98ce\u4e91\u65f6\u523b\u3002\u540c\u65f6\uff0c\u4f17\u591a\u4e13\u5bb6\u548c\u540d\u5634\u4eec\u8fd8\u5c06\u505a\u5ba2\u641c\u72d0\u89c6\u9891\u8bbf\u8c08\u95f4\uff0c\u4e0e\u5e7f\u5927\u7403\u8ff7\u5728\u7f51\u4e0a\u9762\u5bf9\u9762\u7684\u4ea4\u6d41\u4e92\u52a8\u3002\u660e\u661f\u8db3\u7403\u961f\u7403\u5458\u666f\u5c97\u5c71\u3001\u5b59\u6960\u3001\u7f57\u4e2d\u65ed\u3001\u7fbd\u6cc9\u3001\u5e38\u5bbd\u7b49\u5a31\u4e50\u660e\u661f\u548c\u5404\u5927\u9879\u76ee\u7684\u4e16\u754c\u51a0\u519b\u9ad8\u654f\u3001\u4e50\u9759\u5b9c\u3001\u5360\u65ed\u521a\u3001\u5b59\u798f\u660e\u3001\u53f6\u51b2\u3001\u590f\u714a\u6cfd\u7b49\u7ec4\u6210\u6587\u4f53\u660e\u661f\u52a9\u5a01\u56e2\u4e5f\u5c06\u5728\u6bd4\u8d5b\u671f\u95f4\u505a\u5ba2\u641c\u72d0\uff0c\u4e0e\u7f51\u53cb\u4e00\u8d77\u4f83\u8c08\u4e9a\u6d32\u676f\u3002\r\n\r\n\u3000\u3000\u641c\u72d0\u57fa\u4e8e\u5f3a\u5927\u7684\u641c\u72d7\u641c\u7d22\u5f15\u64ce\u6280\u672f\uff0c\u81ea\u4e3b\u7814\u53d1\u4e86\u4e3b\u9898\u641c\u7d22\u4ea7\u54c1\u201c\u641c\u7d22\u4e9a\u6d32\u676f\u201d\uff08\u4e3b\u9898\u641c\u7d22\u9875\u9762\uff08http://product.sports.sohu.com/search/\uff09\uff0c\u6b64\u4ea7\u54c1\u662f\u641c\u72d7\u5f3a\u5927\u7684\u6280\u672f\u4e0e\u641c\u72d0\u65b0\u95fb\u5185\u5bb9\u7684\u5f3a\u529b\u7ed3\u5408\uff0c\u5176\u96c6\u5408\u4e86\u65b0\u95fb\u3001\u8d44\u8baf\u3001\u56fe\u7247\u3001\u89c6\u9891\u3001\u535a\u5ba2\u3001\u8bba\u575b\u7b49\u6a21\u5757\uff0c\u51ed\u501f\u641c\u72d0\u95e8\u6237\u77e9\u9635\u7684\u5f3a\u5927\u8d44\u6e90\u548c\u641c\u72d7\u641c\u7d22\u5f15\u64ce\u5c06\u6240\u6709\u4e0e\u4e9a\u6d32\u676f\u6709\u5173\u7684\u5185\u5bb9\u90fd\u4e00\u7f51\u6253\u5c3d\u3002\r\n\r\n\u3000\u3000\u51ed\u501f\u641c\u72d0\u95e8\u6237\u77e9\u9635\u7684\u5f3a\u5927\u8d44\u6e90\uff0c\u641c\u72d0\u793e\u533a\u548cchinaren\u6821\u56ed\u793e\u533a\u8fd8\u4e3a\u4e9a\u6d32\u676f\u5f00\u8f9f\u4e86\u4e3b\u9898\u4e13\u533a\uff0c\u5e76\u5f00\u5c55\u6709\u5956\u7cbe\u5f69\u3001\u6709\u5956\u5f81\u6587\u3001\u8db3\u7403\u5b9d\u8d1d\u8bc4\u9009\u7b49\u5f62\u5f0f\u591a\u6837\u7684\u7ebf\u4e0a\u4e92\u52a8\u6d3b\u52a8\uff0c\u7403\u8ff7\u4e0d\u4f46\u6709\u673a\u4f1a\u8d62\u5f97\u624b\u673a\u548cMP3\u7b49\u7cbe\u7f8e\u5927\u793c\uff0c\u8fd8\u6709\u673a\u4f1a\u8d62\u53d6\u56fd\u5bb6\u961f\u7403\u5458\u7684\u7b7e\u540d\u7403\u8863\u3001\u7403\u978b\u548c\u8db3\u7403\u7b49\u5e78\u8fd0\u5927\u5956\u3002\u636e\u6089\uff0c\u641c\u72d0\u5728\u81ea\u4e3b\u7814\u53d1\u7684\u7f51\u6e38\u300a\u5929\u9f99\u516b\u90e8\u300b\u4e2d\u9576\u5d4c\u4e9a\u6d32\u676f\u8d5b\u4e8b\u4e13\u9898\u4e92\u52a8\u73af\u8282\uff0c\u6e38\u620f\u7528\u6237\u53c2\u4e0e\u641c\u72d0\u4f53\u80b2\u4e9a\u6d32\u676f\u4e92\u52a8\u6d3b\u52a8\u53ef\u4ee5\u8d62\u53d6\u865a\u62df\u6e38\u620f\u88c5\u5907\uff0c\u4e5f\u6709\u673a\u4f1a\u83b7\u5f97\u641c\u72d0\u4f53\u80b2\u63d0\u4f9b\u7684\u7cbe\u7f8e\u5956\u54c1\u3002\u73b0\u5728\u8d77\uff0c\u53ea\u8981\u62e5\u6709\u641c\u72d0\u7684\u5e10\u53f7\uff0c\u5c31\u80fd\u5728\u641c\u72d0\u90ae\u7bb1\u4e2d\u6536\u5230\u5173\u4e8e\u53c2\u4e0e\u4e9a\u6d32\u676f\u6d3b\u52a8\u7684\u90ae\u4ef6\uff0c\u540c\u65f6\uff0c\u641c\u72d0\u901a\u8fc7\u5f62\u5f0f\u5404\u5f02\u7684\u7ebf\u4e0a\u6d3b\u52a8\u53f7\u53ec\u6700\u5e7f\u6cdb\u7684\u7f51\u6c11\u79ef\u6781\u53c2\u4e0e\uff0c\u4e3a\u4e2d\u56fd\u8db3\u7403\u5450\u558a\u52a9\u5a01\u3002\r\n\r\n\u3000\u3000\u641c\u72d0\u4f5c\u4e3a2008\u5317\u4eac\u5965\u8fd0\u4f1a\u4e92\u8054\u7f51\u5185\u5bb9\u670d\u52a1\u8d5e\u52a9\u5546\uff0c\u6b64\u6b21\u62a5\u9053\u4e9a\u6d32\u676f\u4e0d\u4ec5\u662f\u6280\u672f\u548c\u7f51\u7edc\u670d\u52a1\u4e0a\u7684\u4e00\u6b21\u5b9e\u6218\u6f14\u7ec3\uff0c\u66f4\u662f\u8de8\u5a92\u4f53\u62a5\u9053\u8d44\u6e90\u6574\u5408\u7684\u4e00\u6b21\u5168\u9762\u878d\u5408\u3002\u641c\u72d0\u643a\u624b\u5965\u8fd0\u5a92\u4f53\u8054\u76df\u8054\u624b\u51fa\u51fb\u4e9a\u6d32\u676f\uff0c\u4e0e\u5168\u56fd16\u5bb6\u6838\u5fc3\u5e73\u9762\u5a92\u4f53\u5f3a\u5f3a\u8054\u5408\uff0c\u53d1\u6325\u5404\u81ea\u8d44\u6e90\u4f18\u52bf\uff0c\u6253\u9020\u6700\u7cbe\u5f69\u7684\u8d5b\u4e8b\u4e13\u9898\uff0c\u9664\u4e86\u65b0\u95fb\u62a5\u9053\u65b9\u9762\u7684\u8d44\u6e90\u5171\u4eab\u5916\uff0c\u641c\u72d0\u8fd8\u8054\u540816\u5bb6\u62a5\u7eb8\u5a92\u4f53\u8054\u5408\u4e3e\u529e\u4e92\u52a8\u6709\u5956\u6d3b\u52a8\uff0c\u8fbe\u5230\u524d\u6240\u672a\u6709\u7684\u6d3b\u52a8\u89c4\u6a21\u3002\u540c\u65f6\u641c\u72d0\u4e0eBTV\u7684\u300a\u7eff\u8335\u4f20\u771f\u300b\u548c\u300a\u8db3\u7403100\u5206\u300b\u680f\u76ee\u3001\u300a\u4f53\u80b2\u753b\u62a5\u300b\u3001\u300a\u4f53\u80b2\u65b0\u62a5\u300b\u3001\u5168\u56fd30\u5bb6\u5e7f\u64ad\u5a92\u4f53\u8054\u76df\u7b49\u5404\u5a92\u4f53\u72ec\u5bb6\u5408\u4f5c\uff0c\u8054\u5408\u63a8\u51fa\u641c\u72d0\u4e9a\u6d32\u676f\u4e13\u9898\u62a5\u9053\uf