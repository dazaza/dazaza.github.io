1fa\u6b63\u9762\u6311\u6218. \r\n\u3000\u3000\u8be5\u670d\u52a1\u540d\u4e3aMySpaceTV,\u4e3b\u8981\u76ee\u6807\u662f\u63d0\u4f9b\u4e00\u4e2a\u5bb6\u7528\u89c6\u9891\u548c\u4e13\u4e1a\u4ea7\u54c1\u7f51\u7edc\u5e73\u53f0,\u201c\u6211\u4eec\u7684\u8282\u76ee\u6765\u6e90\u5341\u5206\u4e30\u5bcc,\u4eceNBC\u548c\u4f5b\u514b\u65af\u4e0a\u7684\u4e13\u4e1a\u7535\u89c6\u548c\u65b0\u95fb\u89c6\u9891,\u5230\u5bb6\u7528\u6444\u50cf\u673a\u62cd\u6444\u7684\u6ed1\u7a3d\u5bb6\u5ead\u5f55\u50cf,\u6216\u8005\u662f\u8fd0\u52a8\u5c11\u5e74\u4eec\u7684\u6781\u9650\u6ed1\u96ea\u8fd0\u52a8.\u201dMySpace\u516c\u53f8\u526f\u603b\u88c1\u6770\u592b\u5148\u751f\u5728\u63a5\u53d7\u6cd5\u65b0\u793e\u91c7\u8bbf\u7684\u8fc7\u7a0b\u4e2d\u8868\u793a,\u201c\u4e92\u8054\u7f51\u89c6\u9891\u670d\u52a1\u6b63\u5728\u8fce\u6765\u5927\u7206\u70b8.\u201d\r\n\r\n\r\n\r\n        \u7f51\u7ad9\u7684\u5730\u5740\u4e3awww.myspacetv.com,\u76ee\u524d\u4ecd\u7136\u51fa\u4e8e\u03b2\u6d4b\u8bd5\u7248,\u76ee\u524d\u5c06\u5411\u5168\u7403\u8303\u56f4\u6240\u6709\u7528\u6237\u5f00\u653e,\u4e3b\u8981\u652f\u6301\u4e03\u79cd\u8bed\u8a00.\u636e\u6089,\u8be5\u7f51\u7ad9\u5e0c\u671b\u590d\u5236MySpace\u5728\u793e\u4ea4\u7f51\u7edc\u9886\u57df\u7684\u6210\u529f,\u540e\u8005\u5728\u7f8e\u56fd\u672c\u571f\u5e02\u573a\u7684\u7528\u6237\u6570\u91cf,\u751a\u81f3\u8d85\u8fc7\u6240\u6709\u7ade\u4e89\u5bf9\u624b\u7684\u603b\u548c,\u4e0e\u6b64\u540c\u65f6\u636e\u4ea7\u4e1a\u7edf\u8ba1\u62a5\u544a,\u5176\u5728\u5168\u7403\u8303\u56f4\u7684\u6d41\u884c\u7a0b\u5ea6\u4e5f\u662f\u6700\u9ad8\u7684.\r\n\r\n\u3000\u3000\u6beb\u65e0\u7591\u95ee,\u6b64\u6b21MySpaceTV\u670d\u52a1\u7684\u77db\u5934\u76f4\u63a5\u5bf9\u51c6\u4e86Google\u65d7\u4e0b\u7684\u89c6\u9891\u5171\u4eab\u7f51\u7ad9YouTube,\u5728\u4eca\u5e74\u7b2c\u4e00\u5b63\u5ea6\u4e2d,YouTube\u5728\u7f8e\u56fd\u672c\u571f\u4e92\u8054\u7f51\u89c6\u9891\u5e02\u573a\u7684\u5360\u6709\u7387\u8fbe\u5230\u4e86\u6050\u6016\u768470\uff05.\u800c\u636e\u7f51\u7edc\u7814\u7a76\u673a\u6784comScore\u63d0\