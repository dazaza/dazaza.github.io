1a\u7684\u7a0b\u5e8f\u5458\u6765\u8bf4\uff0c\u4e0d\u7b97\u662f\u4e00\u4ef6\u8f7b\u677e\u7684\u4e8b\u60c5\uff0c\u66f4\u4e0d\u8981\u8bf4\u572812\u4e2a\u5c0f\u65f6\u5185\u5b8c\u6210\u4e00\u6b3e\u5e94\u7528\u7684\u5f00\u53d1\uff0c\u4f46\u662f\u5728\u5370\u5ea6\u5c3c\u897f\u4e9a\u5c31\u51fa\u73b0\u4e86\u4e00\u4f4d\u7a0b\u5e8f\u795e\u7ae5\u3002\r\n\u3000\u3000FahmaWaluyaRosmansyah\u662f\u4e00\u4f4dSymbian\u5e94\u7528\u5f00\u53d1\u7684\u7231\u597d\u8005\uff0c\u4eca\u5e74\u53ea\u670912\u5c81\uff0c\u4ed6\u4f1a\u5728\u7a7a\u95f2\u65f6\u95f4\u5236\u4f5c\u624b\u673a\u8f6f\u4ef6\u3002Fahma\u5f00\u53d1\u7684\u5e94\u7528\u4e3b\u8981\u9488\u5bf9\u548c\u4ed6\u5e74\u9f84\u5dee\u4e0d\u591a\u7684\u5b66\u751f\uff0c\u4ee5\u5e2e\u52a9\u4ed6\u4eec\u5b66\u4e60\u82f1\u8bed\u548c\u57fa\u672c\u7684\u6570\u5b66\u77e5\u8bc6\u3002\r\n\u3000\u3000Fahma\u4e8e1998\u5e74\u5728\u5370\u5ea6\u5c3c\u897f\u4e9a\u51fa\u751f\uff0c\u4e0e\u5176\u4ed695\u540e\u5b69\u5b50\u4e00\u6837\uff0c\u4ed6\u4ece\u5c0f\u5c31\u5728\u7535\u8111\u6e38\u620f\u3001\u4e3b\u673a\u3001\u624b\u673a\u7684\u966a\u4f34\u4e2d\u957f\u5927\u3002\u5728\u5c0f\u5b665\u5e74\u7ea7\u7684\u65f6\u5019\uff0cFahma\u5f00\u59cb\u5b66\u4e60\u5982\u4f55\u4f7f\u7528AdobeFlash\u8fdb\u884c\u5f00\u53d1\uff0c\u540c\u5e74\uff0c\u4ed6\u5236\u4f5c\u4e86\u7b2c\u4e00\u6b3e\u540d\u4e3a\u300aBAHANA\u300b\u7684\u5e94\u7528\u8f6f\u4ef6\u3002\u300aBAHANA\u300b\u53ef\u4ee5\u6559\u5b69\u5b50\u4eec\u5b66\u4e60\u62fc\u97f3\u3001\u6570\u5b57\u548c\u989c\u8272\uff0c\u8fd9\u4e00\u5207\u90fd\u5728\u8bfa\u57fa\u4e9aE71\u4e0a\u8fdb\u884c\u3002\r\n\u3000\u3000\u5728Fahma\u4e0a\u516d\u5e74\u7ea7\u65f6\uff0c\u5c31\u5df2\u7ecf\u5f00\u53d1\u4e865\u6b3e\u624b\u673a\u8f6f\u4ef6\uff0c\u6709\u4e00\u4e2a\u5df2\u7ecf\u5728\u8bfa\u57fa\u4e9aOvi\u5546\u5e97\u63d0\u4f9b\u4e0b\u8f7d\u3002\u5176\u4e2d\u4e00\u6b3e\u300aENRICH\u300b\u53ef\u4ee5\u8ba9\u5b69\u5b50\u4eec\u5c06\u5370\u5c3c\u8bed\u8a00\u4e2d\u5355\u8bcd\u7ffb\u8bd1\u6210\u82f1\u6587\uff0c\u8fd8\u4f1a\u6709\u9b45\u529b\u7684\u56fe\u