591f\u5c06\u76f8\u540c\u7684\u6587\u4ef6\u5373\u65f6\u81ea\u52a8\u540c\u6b65\u5230PC\u3001\u624b\u673a\u548cWeb\u7aef\u3002 \u888b\u9f20 \u662f\u4e00\u6b3e\u7c7bDropbox\u7684\u4e91\u5b58\u50a8\u670d\u52a1\uff0c\u7528\u4e8e\u6587\u4ef6\u7ba1\u7406\u4ee5\u53ca\u5907\u4efd\uff1b\u5b83\u53ef\u4ee5\u5c06\u76f8\u540c\u6587\u4ef6\u5373\u65f6\u81ea\u52a8\u7684\u540c\u6b65\u81f3PC\u3001\u624b\u673a\u3001Web\u7b49\u591a\u4e2a\u5e73\u53f0\uff0c\u771f\u6b63\u5b9e\u73b0\u8de8\u5e73\u53f0\u7684\u4f7f\u7528\u3002\u888b\u9f20\u5c06\u4e0d\u53d7\u9650\u4e8e\u65f6\u95f4\uff0c\u5730\u70b9\uff0c\u8bbe\u5907\uff0c\u53ea\u8981\u6709\u7f51\u7edc\uff0c\u53ef\u4ee5\u5728\u4efb\u4f55\u65f6\u95f4\uff0c\u4efb\u4f55\u5730\u70b9\uff0c\u4efb\u4f55PC\u6216\u624b\u673a\u5bf9\u6587\u4ef6\u8fdb\u884c\u7ba1\u7406\u53ca\u5907\u4efd\u3002\u76ee\u524d\uff0c\u888b\u9f20\u652f\u63012GB\u7684\u514d\u8d39\u7a7a\u95f4\u5bb9\u91cf\uff0c\u540c\u65f6\u8fd8\u5c06\u652f\u6301\u5728\u624b\u673a\u95f4\u3001PC\u95f4\u540c\u6b65\u901a\u8baf\u5f55\uff1b\u800c\u66f4\u591a\u5e73\u53f0\u4e5f\u5c06\u4f1a\u5728\u4e0d\u4e45\u7684\u5c06\u6765\u76f8\u7ee7\u63a8\u51fa\u3002 \u4e2d\u56fd\u7684\u4e91\u5b58\u50a8\u5e02\u573a\u5c06\u4f1a\u6709\u7740\u5b83\u72ec\u7279\u7684\u53d1\u5c55\u673a\u9047\uff0c\u6269\u5c55\u6027\u548c\u7075\u6d3b\u6027\u66f4\u5f3a\u7684\u4e1a\u52a1\u6a21\u5f0f\u6ce8\u5b9a\u5c06\u4f1a\u662f\u90a3\u4e9b\u5c06\u91cd\u70b9\u653e\u5728\u9762\u5411\u666e\u901a\u7528\u6237\u7684\u8f6f\u4ef6\u548c\u8bbe\u5907\u4e0a\u7684\u4ea7\u54c1\u3002\u6211\u76f8\u4fe1\uff0c\u6211\u4eec\u6240\u771f\u6b63\u9700\u8981\u7684\u80af\u5b9a\u4e0d\u662fS3\u3001Google\u548cIBM\u4e91\uff0c\u800c\u662f\u90a3\u4e9b\u80fd\u591f\u88ab\u666e\u901a\u7528\u6237\u6240\u6d88\u8d39\u548c\u83b7\u53d6\u7684\u57fa\u7840\u6027\u4e91\u670d\u52a1\u3002\u5728\u8fd9\u91cc\uff0c\u9664\u4e86\u6211\u4eec\u6240\u719f\u77e5\u7684Dropbox\u548cSugarSync\u4ee5\u5916\uff0c\u56fd\u5185\u4e5f\u5df2\u7ecf\u6709\u8d8a\u6765\u8d8a\u591a\u7684\u5382\u5546\u7eb7\u7eb7\u8b