[{"url": "http://it.sohu.com/20070829/n251851393.shtml", "title": "\u96c5\u864e\u660e\u65e5\u63a8\u65b0\u7248\u641c\u7d22 9\u670810\u65e5\u63a8yahoo.cn\u90ae\u7bb1", "tags": "\u96c5\u864e ", "name": "yiwu", "posttime": "2007-08-30 17:21:55", "ip": "60.191.227.44", "mark": 6, "note": "8\u670829\u65e5\uff0c\u641c\u72d0IT\u83b7\u6089\uff0c\u4e2d\u56fd\u96c5\u864e\u5c06\u5728\u660e\u65e5\u63a8\u51fa\u65b0\u7248\u5168\u80fd\u641c\u7d22\u3002\u76ee\u524d\u7684yahoo.cn\u663e\u793a\u4e3abeta\u7248\u3002\u641c\u72d0IT\u540c\u65f6\u83b7\u6089\uff0cyahoo.cn\u90ae\u7bb1\u5c06\u57289\u670810\u65e5\u6b63\u5f0f\u5bf9\u5916\u5f00\u653e\u6ce8\u518c\uff0c\u76ee\u524d\u4ec5\u5728\u5185\u90e8\u8fdb\u884c\u6d4b\u8bd5......", "imagename": "", "infoid": 28580, "category": "technology_internet", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u96c5\u864e"]}, {"url": "http://my.donews.com/andyyu/2007/07/25/%e5%ae%83%e5%b1%b1%e4%b9%8b%e7%9f%b3%ef%bc%9a%e8%80%81%e5%a5%b8%e5%b7%a8%e7%8c%be%e7%9a%84%e9%98%bf%e9%87%8c%e5%b7%b4%e5%b7%b4%e4%ba%a7%e5%93%81%e5%88%97%e8%a1%a", "title": "\u5b83\u5c71\u4e4b\u77f3\uff1a\u8001\u5978\u5de8\u733e\u7684\u963f\u91cc\u5df4\u5df4\u4ea7\u54c1\u5217\u8868\u7ffb\u9875\u8bbe\u8ba1", "tags": "\u963f\u91cc\u5df4\u5df4 \u8bbe\u8ba1 ", "name": "wivan2006", "posttime": "2007-08-30 17:04:52", "ip": "221.201.161.87", "mark": 5, "note": "\u6700\u5927\u7684\u4f18\u52bf\u662f\u65e0\u8bba\u7ffb\u5230\u54ea\u4e00\u9875\uff0c\u59cb\u7ec8\u663e\u793a\u7b2c\u4e00\u9875\u7684\u94fe\u63a5\uff0c\u96f7\u6253\u4e0d\u52a8\uff0c\u56e0\u4e3a\u8fd9\u662f\u4ed8\u8d39\u6700\u591a\u7684\u5ba2\u6237\u9875\u9762\u2026\u2026\u81f3\u4e8e\u6392\u540d\u9760\u540e\u7684\uff0c\u867d\u7136SEO\u7684\u89d2\u5ea6\u8ba4\u4e3a\u663e\u793a\u591a\u51e0\u6761\u66f4\u6709\u610f\u601d\uff0c\u4f46\u963f\u91cc\u8ba4\u4e3a\u4e00\u53e3\u6c14\u663e\u793a\u592a\u591a\u540e\u9762\u7684\u94fe\u63a5\u4e0d\u5229\u4e8e\u9760\u524d\u9762\u7684\u5217\u8868\u70b9\u51fb\u7387\uff0c\u6240\u4ee5\u5f53\u524d\u9875\u9762\u4ee5\u540e\u7684\u53ea\u80fd\u663e\u793a\u51e0\u6761\u3002\u81f3\u4e8e\u4eba\u4eec\u5e38\u89c1\u7684\u201d\u6700\u540e\u4e00\u9875\u201d\uff0c\u5bf9\u4e0d\u8d77\uff0c\u6392\u5728\u6700\u540e\u4e00\u9875\u8c01\u8fd8\u7406\u4f60\u5440\uff0c\u6839\u672c\u4e0d\u7ed9\u673a\u4f1a\u3002", "imagename": "", "infoid": 28579, "category": "technology_internet", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u963f\u91cc\u5df4\u5df4", "\u8bbe\u8ba1"]}, {"url": "http://www.cnbeta.com/articles/37686.htm", "title": "\u300a\u7f51\u7edc\u5b89\u5168\u6cd5\u300b\u5c06\u6210\u63d0\u6848", "tags": "\u7f51\u7edc\u5b89\u5168\u6cd5 ", "name": "wivan2006", "posttime": "2007-08-30 17:02:13", "ip": "221.201.161.87", "mark": 9, "note": "\u56fd\u5bb6\u8ba1\u7b97\u673a\u7f51\u7edc\u5e94\u6025\u6280\u672f\u5904\u7406\u534f\u8c03\u4e2d\u5fc3\u9ec4\u6f84\u6e05\u526f\u4e3b\u4efb\u8868\u793a,\u201c\u7ecf\u6d4e\u5229\u76ca\u201d\u5df2\u7ecf\u6210\u4e3a\u75c5\u6bd2\u7b49\u6076\u610f\u7a0b\u5e8f\u5236\u9020\u8005\u6700\u5927\u7684\u9a71\u52a8\u529b,\u6076\u610f\u7a0b\u5e8f\u5236\u9020\u8005\u5df2\u7ecf\u4e0d\u518d\u662f\u4ee5\u70ab\u8000\u81ea\u5df1\u7684\u6280\u672f\u4e3a\u76ee\u7684,\u4e5f\u4e0d\u518d\u662f\u5355\u6253\u72ec\u6597,\u800c\u662f\u7ed3\u6210\u4e86\u56e2\u4f19,\u6709\u7684\u4eba\u8d1f\u8d23\u76d7\u53d6\u94f6\u884c\u6216\u7f51\u6e38\u8d26\u53f7,\u6709\u7684\u4eba\u8d1f\u8d23\u9500\u8d43,\u4ece\u800c\u5f62\u6210\u4e86\u4e00\u6574\u6761\u9ed1\u8272\u4ea7\u4e1a\u94fe.\r\n\r\n\u3000\u3000\u9488\u5bf9\u8fd9\u4e2a\u95ee\u9898,\u4ee5\u5317\u4eac\u91d1\u5c71\u8f6f\u4ef6CEO\u96f7\u519b\u4e3a\u4ee3\u8868\u7684\u4e1a\u5185\u4eba\u58eb\u63d0\u51fa,\u5c3d\u7ba1\u5305\u62ec\u91d1\u5c71\u5728\u5185\u7684\u5b89\u5168\u5382\u5546\u5bf9\u6076\u610f\u7a0b\u5e8f\u90fd\u4e00\u81f4\u6301\u8c34\u8d23\u6001\u5ea6,\u5e76\u4e0d\u65ad\u5b8c\u5584\u89e3\u51b3\u65b9\u6848\u5bf9\u6076\u610f\u7a0b\u5e8f\u8fdb\u884c\u67e5\u6740,\u4f46\u73b0\u5728\u5404\u53cd\u75c5\u6bd2\u5382\u5546\u5bf9\u6728\u9a6c\u7684\u67e5\u6740\u7f3a\u4e4f\u6cd5\u5f8b\u652f\u6301,\u8fd9\u4e5f\u662f\u6b64\u7c7b\u6076\u610f\u7a0b\u5e8f\u7316\u7357\u7684\u91cd\u8981\u539f\u56e0\u4e4b\u4e00.\u56e0\u6b64,\u9488\u5bf9\u6076\u610f\u7a0b\u5e8f\u7684\u7acb\u6cd5\u5df2\u662f\u8feb\u5728\u7709\u776b.\u5e94\u5bf9\u6765\u81ea\u4e1a\u754c\u7684\u547c\u58f0,\u56fd\u5bb6\u76f8\u5173\u90e8\u59d4\u8868\u793a\u5c06\u8054\u5408\u5728\u5927\u4f1a\u4e0a\u4ea4\u63d0\u6848,\u7763\u4fc3\u300a\u7f51\u7edc\u5b89\u5168\u6cd5\u300b\u5c3d\u5feb\u51fa\u53f0.", "imagename": "", "infoid": 28578, "category": "technology_software", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u7f51\u7edc\u5b89\u5168\u6cd5"]}, {"url": "http://www.cnbeta.com/articles/37697.htm", "title": "\u6c83\u8fbe\u4e30\u5728\u82f1\u56fd\u5347\u7ea7  \u5f15\u51657.2M\u79fb\u52a8\u5bbd\u5e26", "tags": "\u6c83\u8fbe\u4e30 HSPA\u7f51\u7edc ", "name": "wivan2006", "posttime": "2007-08-30 17:00:49", "ip": "221.201.161.87", "mark": 6, "note": "\u4e16\u754c\u6700\u5927\u79fb\u52a8\u8fd0\u8425\u5546\u6c83\u8fbe\u4e30\u5728\u82f1\u56fd\u5347\u7ea7\u5176HSDPA\u7f51\u7edc,\u7528\u6237\u81ea9\u67083\u65e5\u53ef\u4ee5\u8d2d\u5f977.2Mbps\u7684\u6570\u636e\u4e0a\u7f51\u5361,\u578b\u53f7\u5305\u62ec\u4e00\u6b3e\u4e09\u9891\u6bb5USB modem\u548c\u4e24\u6b3eExpress\u6570\u636e\u5361,\u4f46\u9700\u8981\u7b7e\u8ba218\u4e2a\u6708\u7684\u670d\u52a1\u5408\u540c,\u8d39\u752849\u82f1\u9551(\u7ea6\u5408743\u5143\u4eba\u6c11\u5e01)\u8d77.\r\n\u5c31\u8425\u4e1a\u989d\u800c\u8a00,\u6c83\u8fbe\u4e30\u662f\u4e16\u754c\u6700\u5927\u79fb\u52a8\u8fd0\u8425\u5546,2007\u8d22\u5e74\u8425\u6536617\u4ebf\u7f8e\u5143.\u5347\u7ea7\u5b8c\u6210\u540e,\u5728\u4f26\u6566\u548c\u4e3b\u8981\u822a\u7a7a\u6e2f,\u5178\u578b\u7684\u4e0b\u8f7d\u901f\u7387\u5c06\u8fbe1.7\uff5e5.5Mbps;\u4e0a\u4f20\u901f\u73871.44Mbps,\u8fd9\u5f15\u5165\u4e86HSUPA\u6280\u672f.\r\n\r\n\r\n\r\n\u6c83\u8fbe\u4e30\u82f1\u56fd\u5728\u4e00\u5e74\u524d\u90e8\u7f72\u4e86HSDPA,\u5f53\u65f6\u652f\u63011.8Mbps\u7684\u4e0b\u8f7d\u901f\u7387,\u5728\u4f26\u6566\u4f7f\u7528\u4e00\u822c\u4e0d\u4f1a\u8d85\u8fc71.4Mbps,\u4e0a\u4f20\u901f\u7387384Kbps.\u76f8\u5bf9\u4e00\u5e74\u524d,\u6c83\u8fbe\u4e30\u7684\u79fb\u52a8\u4e0a\u7f51\u8d44\u8d39\u5df2\u7ecf\u5927\u5927\u964d\u4f4e,\u5f53\u65f6\u7528\u6237\u652f\u4ed899\u82f1\u9551\u53ef\u83b7\u5f97\u4e00\u5f20\u6570\u636e\u5361,\u6708\u79df95\u82f1\u9551\u4e0d\u9650\u6d41\u91cf.", "imagename": "", "infoid": 28577, "category": "technology_internet", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u6c83\u8fbe\u4e30", "hspa\u7f51\u7edc"]}, {"url": "http://www.cnbeta.com/articles/37702.htm", "title": "\u8c37\u6b4c\u5168\u7403\u6700\u5927\u6570\u636e\u4e2d\u5fc3\u63ed\u79d8 \u9884\u8ba1\u82b1\u8d396\u4ebf\u7f8e\u5143", "tags": "\u8c37\u6b4c \u6570\u636e\u4e2d\u5fc3 ", "name": "wivan2006", "posttime": "2007-08-30 16:59:30", "ip": "221.201.161.87", "mark": 6, "note": "\u8c37\u6b4c\u5728\u7f8e\u56fd\u591a\u4e2a\u5dde\u90fd\u5728\u5efa\u8bbe\u6570\u636e\u4e2d\u5fc3\uff0c\u800c\u4f4d\u4e8e\u4fc4\u52d2\u5188\u5dde\u8fbe\u52d2\u65af\u5e02(Dalles)\u54e5\u4f26\u6bd4\u4e9a\u6cb3\u7554\u7684\u6570\u636e\u4e2d\u5fc3\u662f\u6700\u8fd1\u624d\u6295\u5165\u4f7f\u7528\u7684\u4e00\u5bb6\uff0c\u6700\u8fd1\uff0c\u8c37\u6b4c\u9996\u6b21\u9080\u8bf7\u5a92\u4f53\u8bb0\u8005\u53c2\u89c2\u4e86\u8fd9\u5ea7\u5728\u5916\u4eba\u773c\u4e2d\u9887\u4e3a\u795e\u79d8\u7684\u6570\u636e\u4e2d\u5fc3\u3002\u6839\u636e\u8c37\u6b4c\u516c\u5e03\u7684\u96f6\u661f\u6570\u636e\uff0c\u5176\u4fee\u5efa\u4e00\u5ea7\u5927\u578b\u6570\u636e\u4e2d\u5fc3\u7684\u8d39\u7528\u7ea6\u4e3a6\u4ebf\u7f8e\u5143\uff0c\u9700\u96c7\u7528100-200\u540d\u5458\u5de5\u3002\r\n   2005\u5e74\u521d\uff0c\u8fbe\u52d2\u65af\u5e02\u653f\u5e9c\u6279\u51c6\u4e86\u8c37\u6b4c187\u4e07\u7f8e\u5143\u8d2d\u4e7030\u82f1\u4ea9\u5