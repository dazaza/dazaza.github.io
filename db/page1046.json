5206\u516c\u53f8\u786e\u8ba4,\u62df\u5bf9\u5bb6\u5ead\u7528\u6237\u5bbd\u5e26\u5305\u6708\uff0f\u5305\u5e74\u7528\u6237\u5b9e\u884c\u4e0a\u7f51\u65f6\u95f4\u9650\u5236,\u5b9e\u884c\u4e0a\u7f51\u65f6\u95f4\u9650\u5236\u540e,\u666e\u901a\u7528\u6237\u4e3a240\u5c0f\u65f6\uff0f\u6708,\u8d85\u51fa\u90e8\u5206\u63092\u5206\uff0f\u6bcf\u5206\u949f\u6536\u53d6,\u8d85\u51fa\u8d44\u8d39\u5c01\u9876\u6bcf\u670848\u5143.\u5609\u5174\u7535\u4fe1\u7279\u522b\u8bf4\u660e,\u6b64\u9879\u653f\u7b56\u6709\u5229\u4e8e\u7f51\u6c11\u5408\u7406\u5b89\u6392\u5de5\u4f5c\u751f\u6d3b\u65f6\u95f4,\u9632\u6b62\u7f51\u6e38\u6c89\u8ff7,\u6709\u5229\u4e8e\u5065\u5eb7\u4e0a\u7f51.(\u300a\u7535\u8111\u5546\u60c5\u62a5\u300b8\u670828\u65e5)\r\n\u8fd9\u5e74\u5934,\u6da8\u4ef7\u53f8\u7a7a\u89c1\u60ef,\u50cf\u725b\u8089\u9762\u3001\u65b9\u4fbf\u9762\u6da8\u4ef7,\u5c3d\u7ba1\u8bae\u8bba\u7eb7\u7eb7,\u4f46\u522b\u4eba\u6bd5\u7adf\u8fd8\u662f\u4ee5\u539f\u6750\u6599\u6210\u672c\u7b49\u7406\u7531\u4e0a\u6da8,\u603b\u4e0d\u81f3\u4e8e\u79bb\u9898\u4e07\u91cc,\u81ea\u6211\u62d4\u9ad8.\u8bbe\u60f3,\u4ed6\u4eec\u79f0\u4e3a\u4e86\u8ba9\u6d88\u8d39\u8005\u5408\u7406\u5b89\u6392\u996e\u98df,\u9632\u6b62\u5403\u9762\u6c89\u8ff7,\u6709\u5229\u4e8e\u8425\u517b\u5747\u8861\u4e3a\u7531\u800c\u6da8\u4ef7,\u4fdd\u8bc1\u53ef\u88ab\u5455\u5410\u58f0\u6df9\u6ca1,\u8f7b\u6613\u8dfb\u8eab\u53f2\u4e0a\u6700\u6076\u5fc3\u7684\u6da8\u4ef7\u7406\u7531\u4e4b\u4e00.", "imagename": "00d025287ecc4401935d177bfec00c05.gif", "infoid": 28565, "category": "technology_internet", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u7535\u4fe1", "\u5bbd\u5e26\u5305\u6708", "\u6da8\u4ef7"]}, {"url": "http://www.zhuaxia.com/item/477069656", "title": "Anothr\uff08\u54ea\u5412\uff09\u66f4\u65b0\u673a\u5668\u4eba\u548cweb\u7ad9", "tags": "Anothr \u54ea\u5412 ", "name": "wivan2006", "posttime": "2007-08-30 16:23:35", "ip": "221.201.161.87", "mark": 7, "note": "Anothr\u6700\u8fd1\u505a\u4e86\u7cfb\u5217\u66f4\u65b0\uff0c\u54ea\u5412\u673a\u5668\u4eba\u548c\u7f51\u7ad9\u540c\u65f6\u5347\u7ea7\u4e86\uff0c\u5176\u4e2d\u673a\u5668\u4eba\u66f4\u65b0\u5305\u62ec\u65b0\u589e\u6307\u4ee4\u3001\u67e5\u8be2\u529f\u80fd\u6539\u8fdb\u4ee5\u53ca\u589e\u52a0\u6587\u7ae0\u6536\u85cf\u529f\u80fd\u3002\r\n\r\n\u867d\u7136\u5c1d\u8bd5Anothr\u975e\u5e38\u7b80\u5355\uff0c\u53ea\u9700\u8981\u5728IM\u589e\u52a0\u76f8\u5e94\u7684\u673a\u5668\u4eba\u4f5c\u4e3a\u597d\u53cb\u5373\u53ef\uff0c\u4f46\u662f\u5bf9\u8be5\u673a\u5668\u4eba\u7684\u63a7\u5236\u548c\u7ba1\u7406\u5305\u542b\u4e86\u4e00\u7cfb\u5217\u6307\u4ee4\u2014\u2014\u8fd9\u4e9b\u6307\u4ee4\u5982\u679c\u5728Dos\u5e74\u4ee3\u6216\u8005Telnet\u65f6\u4ee3\u663e\u5f97\u5e76\u4e0d\u56f0\u96be\uff0c\u4f46\u662f\u5bf9\u4e8e\u73b0\u5728web\u57f9\u517b\u8d77\u6765\u7684\u4e92\u8054\u7f51\u7528\u6237\u6765\u8bf4\uff0c\u5c31\u5341\u5206\u56f0\u96be\u4e86\u3002\r\n\r\n\u6240\u4ee5\uff0cweb\u7ba1\u7406\u4e0e\u673a\u5668\u4eba\u7ba1\u7406\u7684\u914d\u5408\u3001\u540c\u6b65\u5c31\u5341\u5206\u91cd\u8981\u3002\r\n\r\n\u54ea\u5412\u6b64\u6b21\u66f4\u65b0\u5305\u62ec\u4e86web\u90e8\u5206\uff0c\r\n\r\n\u9605\u8bfb\u9891\u9053\uff1a \r\n\u672a\u6295\u9012\u8bb0\u5f55\u53ef\u6309\u5929\u67e5\u770b \r\n\u5b8c\u5584\u4e86\u5927\u91cf\u7684\u9605\u8bfb\u7ec6\u8282\uff1a\u6587\u7ae0\u6536\u85cf\u3001\u53ea\u770b\u6807\u9898\u3001\u56de\u5230\u9875\u9762\u9876\u90e8\u3001\u6587\u7ae0\u53ef\u6298\u6298\u53e0\u7b49 \r\n\u4e2a\u4eba\u5206\u4eab\u9875\u9762\uff0c\u589e\u52a0\u4e86\u4e66\u7b7e\u3001\u6536\u85cf\u3001\u5fc3\u60c5\u5206\u4eab3\u4e2a\u5b50\u9875\u9762\uff0c\u6bcf\u4e2a\u5b50\u9875\u9762\u5747\u652f\u6301RSS\u7684\u8f93\u51fa\u3002\u5fc3\u60c5\u5206\u4eab\uff0c\u5fc5\u987b\u8981\u5230\u8bbe\u7f6e\u9875\u9762\u628a\u5fc3\u60c5\u8bbe\u7f6e\u4e3a\u201c\u5171\u4eab\u201d\u624d\u4f1a\u751f\u6548\u3002 \r\nTag\u9891\u9053\uff1a\u652f\u6301\u76f8\u5173tag\u7684\u663e\u793a \r\n\u5f88\u663e\u7136\uff0c\u901a\u8fc7Anothr\u83b7\u5f97\u4e86\u7528\u6237\u4e4b\u540e\uff0c\u5e0c\u671b\u8fd9\u4e9b\u7528\u6237\u80fd\u6709\u66f4\u5927\u7684\u4ef7\u503c\uff0c\u90a3\u4e48\u5c06\u4ed6\u4eec\u7684\u6ce8\u610f\u529b\u8f6c\u79fb\u5230web\u7aef\uff0c\u5b9e\u73b0\u66f4\u591a\u884c\u4e3a\u5c31\u662f\u5fc5\u7136\u4e4b\u4e3e\u3002", "imagename": "21bac27f9d3d40dabba2ebea46aee282.gif", "infoid": 28561, "category": "technology_web2", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["anothr", "\u54ea\u5412"]}, {"url": "http://www.cnbeta.com/articles/37690.htm", "title": "\u201c\u7535\u5b50\u62a5\u7eb8\u201d\u5f00\u53d1\u6210\u529f \u5185\u85cfWindows\u53ef\u4e0a\u7f51", "tags": "\u7535\u5b50\u62a5\u7eb8 Windows ", "name": "wivan2006", "posttime": "2007-08-30 16:09:14", "ip": "221.201.161.87", "mark": 6, "note": "\u8fd9\u6b3e\u540d\u4e3aFLEPia\u7684\u201c\u7535\u5b50\u7eb8\u201d\u6709A4\u548cA5\u4e24\u79cd\u5c3a\u5bf8,\u539a\u5ea6\u5747\u4e3a12\u6beb\u7c73,\u6700\u591a\u53ef\u4ee5\u8fde\u7eed\u4f7f\u752850\u4e2a\u5c0f\u65f6.\u5176\u6700\u5927\u7684\u7279\u70b9\u662f\u666e\u901a\u7b14\u8bb0\u672c\u7535\u8111\u7684\u6db2\u6676\u753b\u9762\u5728\u6ca1\u6709\u7535\u6e90\u7684\u60c5\u51b5\u4e0b\u65e0\u6cd5\u663e\u793a,\u800c\u201c\u7535\u5b50\u7eb8\u201d\u5373\u4fbf\u5207\u65ad\u7535\u6e90,\u4e5f\u80fd\u957f\u65f6\u95f4\u8fde\u7eed\u663e\u793a\u753b\u9762,\u8fd9\u5c31\u5982\u540c\u62a5\u7eb8\u4e00\u822c,\u53ef\u4ee5\u6ee1\u8db3\u4efb\u4f55\u573a\u5408\u7684\u9605\u8bfb\u9700\u6c42.\r\n       \u636e\u6089,FLEPia\u662f\u5e26\u6709\u5f69\u8272\u201c\u7535\u5b50\u7eb8\u201d\u7684\u53ef\u643a\u5e26\u4fe1\u606f\u7ec8\u7aef\u88c5\u7f6e\u9996\u6b21\u5728\u5168\u7403\u5b9e\u73b0\u5546\u54c1\u5316,\u7136\u800c\u9ad8\u6602\u7684\u4ef7\u683c\u96be\u514d\u8ba9\u4eba\u671b\u800c\u5374\u6b65.\u76ee\u524dA5\u673a\u79cd\u7684\u4ef7\u683c\u4e3a15\u4e07\u65e5\u5143,A4\u673a\u79cd\u5219\u4e3a25\u4e07\u65e5\u5143,\u5bcc\u58eb\u901a\u5e0c\u671b\u5728\u6b63\u5f0f\u6279\u91cf\u751f\u4ea7\u540e,\u5c06\u6700\u7ec8\u7684\u4ea7\u54c1\u4ef7\u683c\u5206\u522b\u964d\u81f34\u4e07\u65e5\u5143\u548c6\u4e07\u65e5\u5143.", "imagename": "", "infoid": 28556, "category": "technology_hardware", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u7535\u5b50\u62a5\u7eb8", "windows"]}, {"url": "http://www.caogenmba.com/Read/Detail.asp?pid=5185", "title": "\u53f0\u5e74\u8f7b\u4eba\u73a9\u521b\u610f\u6708\u8d5a\u767e\u4e07 &quot;\u5927\u4fbf&quot;\u624b\u673a\u5ea7\u5927\u5356", "tags": "\u6708\u8d5a\u767e\u4e07 &quot \u5927\u4fbf&quot \u624b\u673a\u5ea7 ", "name": "wivan2006", "posttime": "2007-08-30 15:34:01", "ip": "221.201.161.87", "mark": 5, "note": "28\u5c81\u7684David\u7a81\u53d1\u5947\u60f3\u7528\u6bdb\u5dfe\u5e03\u505a\u6210\u201c\u4fbf\u4fbf\u201d\u9020\u578b\u7684\u624b\u673a\u5ea7\uff0c\u4e0a\u5934\u8fd8\u9ecf\u6709\u82cd\u8747\uff0c\u56e0\u4e3a\u505a\u5f97\u5f88\u903c\u771f\uff0c\u5438\u5f15\u5f88\u591a\u5e74\u8f7b\u4eba\u6ce8\u610f\uff0c\u6210\u4e86\u73b0\u5728\u4e2d\u90e8\u5730\u533a\u6700\u70ed\u5356\u7684\u4ea7\u54c1\uff0c\u8fd9\u4e2a\u53ef\u7231\u7684\u624b\u673a\u5ea7\u4e5f\u8ba9David\u8d5a\u8fdb\u4e86\u4ed6\u4eba\u751f\u7684\u7b2c\u4e00\u4e2a100\u4e07(\u65b0\u53f0\u5e01)\u3002", "imagename": "bff71b8ba29544559743a702dd5a0442.jpg", "infoid": 28554, "category": "life_fashion", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "life", "via": null, "real_tags": ["\u6708\u8d5a\u767e\u4e07", "&quot", "\u5927\u4fbf&quot", "\u624b\u673a\u5ea7"]}]