u4eec\u8bf4\u4eca\u5e74\u8981\u63a8\u51fa\u4e00\u6b3e\u65b0\u6e38\u620f \uff0c\u800c\u5f88\u5bb9\u6613\u60f3\u5230\u8fd9\u80af\u5b9a\u5c31\u662f\u300a\u661f\u9645\u4e89\u97382\u300b\uff0c\u90a3\u4e48\u4e0b\u4e00\u4e2a\u7a76\u7adf\u662f\u4ec0\u4e48\u6e38\u620f\u5462\uff1f", "imagename": "", "infoid": 125864, "category": "technology_games", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u66b4\u96ea", "\u6697\u9ed1", "\u661f\u9645\u4e89\u9738"]}, {"url": "http://www.xtit.net/post/nettu/", "title": "\u7f51\u5546\u56fe\u7247\u5b58\u50a8\u4e2d\u5fc3\uff1a\u7f51\u56fe Nettu.CN\u4e0a\u7ebf\uff01", "tags": "\u56fe\u7247 \u5b58\u50a8 \u670d\u52a1 \u5546\u4e1a ", "name": "xjyzhenai", "posttime": "2009-02-19 17:22:46", "ip": "222.243.160.36", "mark": 2, "note": "\u8fd1\u65e5\uff0c\u4e00\u6b3e\u540d\u4e3a\u201c\u7f51\u56fe(www.nettu.cn)\u201d\u7684\u4e13\u4e1a\u5546\u7528\u56fe\u7247\u5b58\u50a8\u670d\u52a1\u4e0a\u7ebf\u3002\u5b98\u65b9\u5bf9\u4e8e\u7f51\u56fe\u7684\u5b9a\u4f4d\u662f\u201c\u7f51\u5546\u56fe\u7247\u5b58\u50a8\u4e2d\u5fc3\u201d\uff0c\u610f\u4e3a\u7f51\u7edc\u5546\u4eba\u4e13\u7528\u7684\u56fe\u7247\u5b58\u50a8\u670d\u52a1\u3002\r\n\r\n\u3000\u3000\u7f51\u56fe\u4e00\u53cd\u6210\u89c4\u5730\u6253\u7834\u56fe\u7247\u5b58\u50a8\u670d\u52a1\u514d\u8d39\u7684\u8fd0\u8425\u6a21\u5f0f\uff0c\u7f51\u56fe\u4e0d\u63d0\u4f9b\u514d\u8d39\u670d\u52a1\uff0c\u8fd9\u5728\u5f88\u5927\u7a0b\u5ea6\u4e0a\u53cd\u5e94\u5b98\u65b9\u505a\u597d\u9ad8\u8981\u6c42\u7684\u5546\u7528\u56fe\u7247\u5b58\u50a8\u670d\u52a1\u7684\u4fe1\u5fc3\u3002\r\n\r\n \u867d\u7136\u7f51\u4e0a\u6797\u7acb\u7684\u514d\u8d39\u76f8\u518c\u3001\u514d\u8d39\u56fe\u7247\u5b58\u50a8\u670d\u52a1\u8ba9\u7f51\u6c11\u4fdd\u5b58\u81ea\u5df1\u559c\u6b22\u7684\u7167\u7247\u3001\u622a\u56fe\uff0c\u81ea\u5df1\u65f6\u5e38\u6253\u5f00\u770b\u770b\uff0c\u6216\u4e0e\u670b\u53cb\u4eec\u5206\u4eab\u7684\u786e\u662f\u975e\u5e38\u65b9\u4fbf\u3002\u4f46\u4e00\u65e6\u56fe\u7247\u7528\u4e8e\u5546\u4e1a\uff0c\u4e8b\u60c5\u5c31\u4e0d\u662f\u90a3\u4e48\u7b80\u5355\u4e86\uff01\r\n\r\n\u3000\u3000\u5546\u4e1a\u56fe\u7247\uff0c\u5bf9\u56fe\u7247\u5b58\u50a8\u7684\u8981\u6c42\u975e\u5e38\u9ad8\u3002\u6bd4\u5982\u6dd8\u5b9d\u3001\u62cd\u62cd\u3001\u6709\u554a\u7b49\u7f51\u7edc\u8d2d\u7269\u5e73\u53f0\uff0c\u5546\u5bb6\u7684\u4ea7\u54c1\u8bf4\u660e\u56fe\u7247\u88ab\u5927\u91cf\u5c55\u793a\u3002\u56e0\u4e3a\u56fe\u7247\u8bbf\u95ee\u91cf\u5de8\u5927\uff0c\u56fe\u7247\u6570\u91cf\u591a\uff0c\u56e0\u6b64\u5bf9\u4e8e\u56fe\u7247\u5b58\u50a8\u670d\u52a1\u7684\u8f6f\u786c\u4ef6\u652f\u6301\u8981\u6c42\u975e\u5e38\u9ad8\u3002\u800c\u5546\u7528\u56fe\u7247\u5b58\u50a8\u670d\u52a1\u7684\u6027\u80fd\u76f4\u63a5\u5f71\u54cd\u5ba2\u6237\u5bf9\u4e8e\u7f51\u7edc\u5356\u5bb6\u53ca\u5176\u4ea7\u54c1\u7684\u7b2c\u4e00\u5370\u8c61\u3002\r\n\r\n\u3000\u3000\u7f51\u56fe\u4e3a\u4e86\u6253\u9020\u9ad8\u6548\u800c\u7a33\u5b9a\u7684\u5546\u4e1a\u56fe\u7247\u5b58\u50a8\u670d\u52a1\uff0c\u8c03\u7528\u4e86\u5206\u5e03\u4e8e\u5168\u56fd\u5404\u7701\u7684200\u591a\u53f0\u8282\u70b9\u670d\u52a1\u5668\uff0c\u7ec4\u6210\u4e86\u4e00\u4e2a\u5b8f\u5927\u7684\u5185\u5bb9\u5206\u53d1\u7f51\u7edc\u3002\u6240\u4ee5\uff0c\u65e0\u8bba\u8bbf\u95ee\u8005\u8eab\u5728\u4f55\u5904\uff0c\u4ed6\u603b\u80fd\u8bbf\u95ee\u7f51\u7edc\u7ed3\u6784\u4e2d200\u591a\u53f0\u8282\u70b9\u670d\u52a1\u5668\u4e2d\u79bb\u4ed6\u6700\u8fd1\u7684\u90a3\u53f0\uff0c\u7f51\u56fe\u7684\u5185\u5bb9\u5206\u53d1\u7cfb\u7edf\u8fd8\u4f1a\u667a\u80fd\u5730\u9009\u62e9\u6700\u5feb\u7684\u670d\u52a1\u5668\u7ed9\u6bcf\u4e00\u4f4d\u8bbf\u95ee\u8005\u3002\u8fd9\u6837\u5c31\u6700\u5927\u7a0b\u5ea6\u7684\u8282\u7701\u4e86\u56fe\u7247\u4f20\u8f93\u901f\u5ea6\uff0c\u6240\u6709\u8bbf\u95ee\u8005\u5c06\u5bf9\u4f7f\u7528\u4e86\u7f51\u56fe\u56fe\u7247\u5b58\u50a8\u670d\u52a1\u7684\u7f51\u7edc\u5546\u5bb6\u5f62\u6210\u826f\u597d\u7684\u53e3\u7891\u3002\r\n\r\nimage\r\n\r\n \u4ece\u7f51\u7edc\u62d3\u6251\u7ed3\u6784\u800c\u8a00\uff0c\u6570