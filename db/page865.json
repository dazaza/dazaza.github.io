/2008-07/11/xin_2930705110953687546828.jpg\" border=0></P>\r\n<P align=center>\u5c0f\u670b\u53cb\u5728\u7f51\u5e97\u8d2d\u7269 \uff08\u8d44\u6599\u56fe\u7247\uff09 &nbsp;&nbsp;&nbsp;&nbsp;</P>\r\n<P>&nbsp;&nbsp;&nbsp;&nbsp;\u4e13\u5bb6\u79f0\u8fd9\u79cd\u4e3e\u63aa\u53ef\u80fd\u627c\u6740\u4fe1\u606f\u5316\uff0c\u5236\u7ea6\u7535\u5b50\u5546\u52a1\u53d1\u5c55 \r\n<P>&nbsp;&nbsp;&nbsp;&nbsp;\u672c\u6708\u521d\u5317\u4eac\u5de5\u5546\u5c40\u53d1\u5e03\u7684\u7535\u5b50\u5546\u52a1\u76d1\u7ba1\u610f\u89c1\u6628\u65e5\u8fdb\u4e00\u6b65\u660e\u786e\u2014\u2014\u8be5\u610f\u89c1\u4e0d\u4ec5\u4ec5\u6d89\u53ca\u5317\u4eac\u7684\u7535\u5b50\u5546\u52a1\u7f51\u7ad9\uff0c\u8fd8\u5c06\u628a\u5728\u6dd8\u5b9d\u3001\u6613\u8da3\u7b49\u5e73\u53f0\u4e0a\u5f00\u7f51\u5e97\u7684\u5317\u4eac\u5356\u5bb6\u7eb3\u5165\u76d1\u7ba1\u8303\u56f4\uff0c\u8fd9\u518d\u6b21\u5f15\u8d77\u4e13\u5bb6\u3001\u7f51\u6c11\u548c\u7f51\u4e0a\u5356\u5bb6\u7684\u6fc0\u70c8\u8ba8\u8bba\u3002\u8bb0\u8005\u6628\u65e5\u4ece\u6211\u5e02\u5de5\u5546\u90e8\u95e8\u83b7\u77e5\uff0c\u6211\u5e02\u5c06\u7d27\u8ddf\u5317\u4eac\u5de5\u5546\u7684\u6b65\u4f10\uff0c\u6700\u8fdf\u4e8e10\u6708\u6267\u884c\u8be5\u89c4\u5b9a\uff0c\u540c\u6837\u5c06\u76d1\u7ba1\u6211\u5e02\u7684\u6dd8\u5b9d\u3001\u6613\u8da3\u5356\u5bb6\u3002 \r\n<P>&nbsp;&nbsp;&nbsp;&nbsp;\u65b0\u89c4\u3000\u5317\u4eac\u4e0b\u6708\u6267\u884c \r\n<P>&nbsp;&nbsp;&nbsp;&nbsp;\u672c\u6708\u521d\uff0c\u5317\u4eac\u5e02\u5de5\u5546\u5c40\u5728\u5b98\u65b9\u7f51\u7ad9\u516c\u5e03\u6b63\u5f0f\u7684\u7535\u5b50\u5546\u52a1\u76d1\u7ba1\u610f\u89c1\uff0c\u610f\u89c1\u8868\u660e\u4ece\u4eca\u5e748\u67081\u65e5\u8d77\uff0c\u8425\u5229\u6027\u7684\u7f51\u5e97\u5fc5\u987b\u5148\u53d6\u5f97\u8425\u4e1a\u6267\u7167\u540e\u624d\u80fd\u7ecf\u8425\uff0c\u5bf9\u4e8e\u5df2\u529e\u7406\u8425\u4e1a\u6267\u7167\u7684\u4f01\u4e1a\u6216\u8005\u4e2a\u4f53\u6237\u6240\u5f00\u7684\u7f51\u5e97\uff0c\u5982\u8d85\u51fa\u539f\u767b\u8bb0\u6ce8\u518c\u7ecf\u8425\u8303\u56f4\uff0c\u4e5f\u987b\u529e\u7406\u76f8\u5173\u53d8\u66f4\u767b\u8bb0\u3002\u670d\u52a1\u5546\u4e00\u65e6\u88ab\u53d1\u73b0\u672a\u6838\u67e5\u8eab\u4efd\u800c\u4e3a\u65e0\u7167\u7ecf\u8425\u8005\u63d0\u4f9b\u4e86\u670d\u52a1\uff0c\u5c06\u53d7\u5904\u7f5a\u3002 \r\n<P>&nbsp;&nbsp;&nbsp;&nbsp;\u636e\u4e86\u89e3\uff0c\u65e9\u5728\u4eca\u5e74\u4e09\u6708\u63d0\u51fa\u5f81\u6c42\u610f\u89c1\u7684\u65f6\u5019\uff0c\u5317\u4eac\u5de5\u5546\u5b98\u5458\u66fe\u8868\u793a\u8be5\u610f\u89c1\u4e3b\u8981\u9488\u5bf9\u4e2a\u4eba\u5f00\u8bbe\u7535\u5b50\u5546\u52a1\u7f51\u7ad9\u7684\u884c\u4e3a\uff0c\u5e76\u4e0d\u9002\u7528\u4e8e\u6dd8\u5b9d\u3001\u6613\u8da3\u7b49\u8bbe\u5728\u5317\u4eac\u4e4b\u5916\u7684\u5168\u56fd\u6027\u7535\u5b50\u5546\u52a1\u5927\u5e73\u53f0\u3002\u6628\u65e5\u6709\u5317\u4eac\u5a92\u4f53\u62a5\u9053\uff0c\u5317\u4eac\u5de5\u5546\u7ba1\u7406\u5c40\u5de5\u4f5c\u4eba\u5458\u8868\u793a\uff0c\u53ea\u8981\u662f\u5317\u4eac\u672c\u5730\u7684\u7528\u6237\u6ce8\u518c\u7f51\u5e97\u6216\u8005\u5728\u6dd8\u5b9d\u6613\u8da3\u4e0a\u5f00\u5e97\uff0c\u90fd\u9700\u8981\u5230\u5f53\u5730\u5de5\u5546\u7ba1\u7406\u5c40\u6ce8\u518c\u767b\u8bb0\u3002 \r\n<P>&nbsp;&nbsp;&nbsp;&nbsp;\u5e94\u5bf9\u3000\u6dd8\u5b9d\u6613\u8da3\u7740\u624b\u7814\u7a76 \r\n<P>&nbsp;&nbsp;&nbsp;&nbsp;\u6b64\u524d\u4e00\u76f4\u8ba4\u4e3a\u6b64\u610f\u89c1\u4e0e\u5df1\u65e0\u5173\uff0c\u6ca1\u60f3\u5230\u5317\u4eac\u5de5\u5546\u5c40\u7a81\u7136\u628a\u6dd8\u5b9d\u3001\u6613\u8da3\u7b49\u7f51\u8d2d\u5e73\u53f0\u4e0a\u5728\u5317\u4eac\u5f00\u7f51\u5e97\u7684\u5356\u5bb6\u4e5f\u7eb3\u5165\u4e86\u76d1\u7ba1\u8303\u7574\uff0c\u6dd8\u5b9d\u7f51\u76f8\u5173\u4eba\u58eb\u6628\u65e5\u5411\u8bb0\u8005\u8868\u793a\u6dd8\u5b9d\u4e00\u76f4\u5728\u52aa\u529b\u6784\u5efa\u8bda\u4fe1\u4f53\u7cfb\uff0c\u800c\u5de5\u5546\u6ce8\u518c\u4e5f\u662f\u8bda\u4fe1\u4f53\u7cfb\u7684\u4e00\u73af\u3002\u201c\u539f\u6765\u8bf4\u4e0d\u6d89\u53ca\u6dd8\u5b9d\u3001\u6613\u8da3\u7b49\u56fd\u5185\u5927\u7535\u5b50\u5546\u52a1\u5e73\u53f0\uff0c\u4f46\u662f\u4eca\u5929\u53c8\u53d1\u751f\u4e86\u53d8\u5316\uff0c\u6211\u4eec\u8868\u793a\u5bc6\u5207\u5173\u6ce8\u3002\u201d \r\n<P>&nbsp;&nbsp;&nbsp;&nbsp;\u6613\u8da3\u76f8\u5173\u8d1f\u8d23\u4eba\u4e5f\u8868\u793a\uff0c\u76ee\u524d\u7f51\u7ad9\u6b63\u5728\u7814\u7a76\u5305\u62ec\u600e\u6837\u754c\u5b9a\u7f51\u5e97\u7ecf\u8425\u662f\u8425\u5229\u7684\u6240\u6709\u610f\u89c1\u95ee\u9898\uff0c\u201c\u5927\u5bb6\u80af\u5b9a\u90fd\u5728\u7814\u7a76\u5462\u3002\u201d \r\n<P>&nbsp;&nbsp;&nbsp;&nbsp;\u91cd\u5e86\u3000\u4e0b\u534a\u5e74\u5c06\u529e\u6267\u7167 \r\n<P>&nbsp;&nbsp;&nbsp;&nbsp;\u6211\u5e02\u5de5\u5546\u5c40\u4e8e\u4e0a\u6708\u521d\u53d1\u5e03\u300a\u5173\u4e8e\u5f00\u5c55\u7535\u5b50\u5546\u52a1\u76d1\u7ba1\u7684\u5de5\u4f5c\u610f\u89c1\u300b\uff08\u5f81\u6c42\u610f\u89c1\u7a3f\uff09\uff0c\u79f0\u6211\u5e02\u5c06\u52a0\u5f3a\u7535\u5b50\u5546\u52a1\u7ecf\u8425\u8005\u7684\u5e02\u573a\u4e3b\u4f53\u51c6\u5165\u76d1\u7ba1\uff0c\u5373\u4ee5\u8425\u5229\u4e3a\u76ee\u7684\u5229\u7528\u4e92\u8054\u7f51\u4ece\u4e8b\u7535\u5b50\u5546\u52a1\u7ecf\u8425\u6d3b\u52a8\u7684\uff0c\u5e94\u5f53\u4f9d\u6cd5\u767b\u8bb0\u6ce8\u518c\uff0c\u9886\u53d6\u8425\u4e1a\u6267\u7167\u540e\uff0c\u65b9\u53ef\u4ece\u4e8b\u7f51\u4e0a\u7ecf\u8425\u6d3b\u52a8\u3002 \r\n<P>&nbsp;&nbsp;&nbsp;&nbsp;\u6628\u65e5\uff0c\u5e02\u5de5\u5546\u5c40\u7535\u5b50\u76d1\u7ba1\u5904\u8d1f\u8d23\u4eba\u5411\u8bb0\u8005\u8bc1\u5b9e\uff0c\u6211\u5e02\u5c06\u4e8e9\u6708\u4e0b\u65ec\u621610\u6708\u6b63\u5f0f\u53d1\u5e03\u7535\u5b50\u5546\u52a1\u76d1\u7ba1\u5de5\u4f5c\u610f\u89c1\uff0c\u5728\u91cd\u5e86\u529e\u6267\u7167\u5f00\u7f51\u5e97\u6700\u8fdf\u5c06\u4e8e10\u6708\u6267\u884c\uff0c\u201c\u6211\u4eec\u624d\u4ece\u5317\u4eac\u53d6\u7ecf\u56de\u6765\uff0c\u6dd8\u5b9d\u3001\u6613\u8da3\u5e73\u53f0\u4e0a\u5728\u6211\u5e02\u7ecf\u8425\u7684\u7f51\u5e97\u4e5f\u9700\u8981\u6ce8\u518c\u3002\u201d\u8be5\u8d1f\u8d23\u4eba\u8fd8\u4ecb\u7ecd\u79f0\uff0c\u5de5\u5546\u5c40\u7684\u76d1\u7ba1\u5e73\u53f0\u6b63\u5728\u7d27\u9523\u5bc6\u9f13\u5730\u5f00\u53d1\u4e2d\uff0c\u201c\u4e0e\u5317\u4eac\u7684\u5927\u4f53\u4e00\u6837\uff0c\u53d1\u5e03\u4f1a\u4e0a\u5c06\u516c\u5e03\u7ec6\u8282\u3002\u201d \r\n<P>&nbsp;&nbsp;&nbsp;&nbsp;\u58f0\u97f3 \r\n<P>&nbsp;&nbsp;&nbsp;&nbsp;\u4e13\u5bb6\uff1a\u662f\u5728\u627c\u6740\u4fe1\u606f\u5316 \r\n<P>&nbsp;&nbsp;&nbsp;&nbsp;\u6b64\u6b21\u300a\u610f\u89c1\u300b\u7684\u53d1\u5e03\u4e5f\u5f15\u5f97\u793e\u4f1a\u5404\u754c\u4e13\u5bb6\u7684\u70ed\u70c8\u8ba8\u8bba\uff0c\u7edd\u5927\u591a\u6570\u4e13\u5bb6\u7684\u6001\u5ea6\u662f\u4e2d\u56fd\u7535\u5b50\u5546\u52a1\u5e02\u573a\u4f9d\u7136\u5904\u4e8e\u57f9\u80b2\u671f\uff0c\u5e94\u8be5\u8fd8\u662f\u4ee5\u5f15\u5bfc\u4e3a\u4e3b\uff0c\u89c4\u8303\u4e3a\u8f85\u3002 \r\n<P>&nbsp;&nbsp;&nbsp;&nbsp;\u5317\u4eac\u90ae\u7535\u5927\u5b66\u6559\u6388\u961a\u51ef\u529b\u76f4\u8a00\uff0c\u8be5\u610f\u89c1\u5728\u6267\u884c\u548c\u754c\u5b9a\u4e0a\u5c06\u5b58\u5728\u5f88\u5927\u95ee\u9898\u3002\u4ed6\u8bf4\uff1a\u201c\u8425\u4e1a\u989d\u5927\u7684\u4e0d\u4e00\u5b9a\u662f\u8425\u5229\u7684\uff0c\u8425\u4e1a\u989d\u5c0f\u7684\u4e5f\u4e0d\u4e00\u5b9a\u662f\u975e\u8425\u5229\u7684\u3002\u201d\u8457\u540d\u4e92\u8054\u7f51\u4e13\u5bb6\u5415\u4f2f\u671b\u66f4\u662f\u5728\u535a\u5ba2\u4e2d\u4e25\u5389\u6307\u8d23\u65b0\u89c4\uff0c\u79f0\u8fd9\u4e0d\u662f\u5728\u4fc3\u8fdb\u800c\u662f\u5728\u627c\u6740\u4fe1\u606f\u5316\u3002\u4ed6\u8bf4\u8fd9\u610f\u5473\u7740\u90a3\u4e9b\u6ca1\u6709\u5176\u4ed6\u5de5\u4f5c\u7684C2C\u5356\u5bb6\uff0c\u5927\u591a\u6570\u90fd\u5c06\u91cd\u65b0\u56de\u5230\u5931\u4e1a\u961f\u4f0d\u4e2d\u53bb\u3002 </P>\r\n<P>\u6765\u81ea\uff1a\u65b0\u534e\u7f51 <A href=\"http://www.cq.xinhuanet.com/business/2008-07/11/content_13786666.htm\">http://www.cq.xinhuanet.com/business/2008-07/11/content_13786666.htm</A></P>", "imagename": null, "infoid": 77744, "category": "technology_internet", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u7f51\u5e97", "\u5de5\u5546\u6ce8\u518c"]}, {"url": "http://maitianmayi.cn/useful/duangou.html#diglog-739e4f2170884f6f81f118379d025bde", "title": "\u77ed\u8d2d\u7f51\uff1a\u77ed\u4fe1\u8d2d\u7269\u7f51\u7ad9", "tags": "\u4e66\u7c4d \u77ed\u4fe1 \u8d2d\u7269 ", "name": "hooooooo", "posttime": "2008-07-14 22:05:24", "ip": "121.100.128.160", "mark": 3, "note": "\u77ed\u8d2d\u7f51\u662f\u7231\u5fb7\u5a01\u8f6f\u4ef6\u4eca\u5e74\u5f00\u53d1\u7684\u4e00\u4e2a\u4ea7\u54c1\uff0c\u4e3b\u8981\u662f\u901a\u8fc7\u77ed\u4fe1\u8d2d\u4e70\u4ea7\u54c1\uff0c\u76ee\u524d\u4e3b\u63a8\u4e66\u7c4d\u7c7b\uff0c\u5df2\u7ecf\u548cjoyo\u8c08\u597d\u5408\u4f5c\u3002\u7528\u6237\u5728\u770b\u5230\u559c\u6b22\u7684\u4e66\u65f6\uff0c\u53ea\u9700\u8981\u628a\u4e66\u7c4d\u7684ISBN\u53d1\u9001\u5230\u6307\u5b9a\u7684\u53f7\u7801\uff0c\u5c31\u53ef\u4ee5\u83b7\u5f97\u8be5\u4e66\u5728\u77ed\u8d2d\u7f51\u7684\u6700\u65b0\u62a5\u4ef7\uff0c\u5e76\u4e14\u4eab\u6709\u514d\u8d39\u9001\u8d27\u4e0a\u95e8\uff0c\u8d27\u5230\u4ed8\u6b3e\u670d\u52a1\u3002", "imagename": "a64f8d06c79648af81a9cc3e19978ce5.jpg", "infoid": 77738, "category": "technology_web2", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u4e66\u7c4d", "\u77ed\u4fe1", "\u8d2d\u7269"]}]