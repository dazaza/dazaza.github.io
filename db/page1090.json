": "f5b0916f185649d193541ebebfb2c5bb.jpg", "infoid": 23711, "category": "technology_apple", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["iphone", "\u82f9\u679c", "apple"]}, {"url": "http://mobile.msn.com.cn", "title": "MSN\u63a8\u65b0\u7248\u79fb\u52a8Messenger3.0", "tags": "MSN Messenger \u624b\u673a", "name": "yinyin", "posttime": "2007-06-30 09:26:32", "ip": "221.6.227.244", "mark": 6, "note": "6\u670829\u65e5,\u5fae\u8f6fMSN\u6b63\u5f0f\u53d1\u5e03\u79fb\u52a8Messenger3.0\u7248\u672c,\u4e3a\u5e7f\u5927\u7684\u4e2d\u56fd\u624b\u673a\u7528\u6237\u63d0\u4f9b\u529f\u80fd\u66f4\u4e3a\u5f3a\u5927,\u5185\u5bb9\u66f4\u4e30\u5bcc,\u901f\u5ea6\u66f4\u5feb\u6377\u7684\u79fb\u52a8\u5373\u65f6\u901a\u4fe1\u670d\u52a1. \u65b0\u7248\u79fb\u52a8Messenger3.0\u5ba2\u6237\u7aef\u63d0\u4f9b\u514d\u8d39\u4e0b\u8f7d\u548c\u4f7f\u7528,\u7528\u6237\u53ea\u9700\u652f\u4ed8GPRS\u6570\u636e\u901a\u4fe1\u8d39\u7528,\u5c31\u53ef\u4ee5\u5b9e\u73b0\u901a\u8fc7\u624b\u673a\u767b\u5f55\u548c\u4f7f\u7528Messenger,\u4e0e\u597d\u53cb\u8fdb\u884c\u5b9e\u65f6\u5373\u65f6\u901a\u4fe1,\u53d1\u9001\u6587\u5b57\u3001\u56fe\u7247\u3001\u58f0\u97f3\u4ee5\u53ca\u7ebf\u4e0a\u7167\u50cf,\u6253\u7834\u4e86Messenger\u4f7f\u7528\u7684\u65f6\u95f4\u548c\u7a7a\u95f4\u7684\u9650\u5236. \u6b64\u6b21\u65b0\u7248\u672c\u79fb\u52a8Messenger\u7684\u63a8\u51fa,\u5fae\u8f6fMSN\u643a\u624b\u5185\u5bb9\u5408\u4f5c\u4f19\u4f34\u7a7a\u4e2d\u7f51\u3001\u5e94\u7528\u89e3\u51b3\u65b9\u6848\u5408\u4f5c\u4f19\u4f34PICA(\u76ae\u5494)\u4ee5\u53ca\u5206\u4f17\u65e0\u7ebf,\u5171\u540c\u6253\u9020\u57fa\u4e8e\u79fb\u52a8Messenger\u7684\u521b\u65b0\u79fb\u52a8\u5e94\u7528\u5e73\u53f0,\u5728\u4e3a\u7528\u6237\u63d0\u4f9b\u4f18\u8d28\u7684\u79fb\u52a8\u5373\u65f6\u901a\u4fe1\u548c\u4e30\u5bcc\u7684\u79fb\u52a8\u5185\u5bb9\u4f53\u9a8c\u7684\u540c\u65f6,\u6253\u9020\u521b\u65b0\u7684\u79fb\u52a8\u5e7f\u544a\u89e3\u51b3\u65b9\u6848,\u4e3a\u4f01\u4e1a\u5f00\u8f9f\u5d2d\u65b0\u7684\u8425\u9500\u62d3\u5c55\u5e73\u53f0\u3002\u7528\u6237\u53ef\u4ee5\u767b\u5f55http://mobile.msn.com.cn\u4e0b\u8f7d\u6700\u65b0\u7684\u7248\u672c,\u4e5f\u53ef\u4ee5\u77ed\u4fe1,\u53d1\u90016\u5230816815\u901a\u8fc7\u624b\u673a\u4e0b\u8f7d\u6700\u65b0\u7684\u7248\u672c\u514d\u8d39\u8bd5\u7528\u3002", "imagename": "28e7a346ce434bbcb137c1d10a038e68.jpg", "infoid": 23707, "category": "technology_software", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["msn", "messenger", "\u624b\u673a"]}]