3a\u4fc3\u8fdb\u5f00\u6e90\u8282\u6d41 \u7f51\u4e0a\u8bb0\u8d26\u4eba\u6570\u589e\u5341\u500d", "tags": "\u8d26\u5ba2 \u7f51\u7edc\u8d26\u672c ", "name": "fenqu", "posttime": "2009-02-03 18:30:10", "ip": "220.176.16.140", "mark": 2, "note": "\u8fd9\u4e2a\u6625\u8282\uff0c\u4eba\u4eec\u66f4\u61c2\u5f97\u7cbe\u6253\u7ec6\u7b97\u4e86\u3002\u6628\u65e5\uff0c\u8bb0\u8005\u4ece\u56fd\u5185\u51e0\u5bb6\u5927\u578b\u8bb0\u8d26\u7f51\u7ad9\u83b7\u6089\uff0c\u6625\u8282\u671f\u95f4\uff0c\u6bcf\u5929\u90fd\u6709\u6570\u5341\u4e07\u4eba\u4e0a\u7f51\u8bb0\u5f55\u81ea\u5df1\u7684\u5f00\u9500\uff0c\u8bf7\u5ba2\u5403\u996d\u53d1\u538b\u5c81\u94b1\u6210\u4e3a\u5f00\u652f\u6700\u5927\u7684\u9879\u76ee\u3002\u636e\u6089\uff0c\u548c\u534a\u5e74\u524d\u76f8\u6bd4\uff0c\u8bb8\u591a\u8bb0\u8d26\u7f51\u7684\u4f1a\u5458\u6570\u91cf\u7ffb\u4e86\u4e24\u756a\uff0c\u4e14\u6d3b\u8dc3\u5ea6\u8fbe\u5230\u4e86\u5386\u53f2\u6700\u9ad8\u6c34\u5e73\u3002\r\n\r\n\u3000\u3000\u6625\u8282\u82b1\u8131\u534a\u5e74\u79ef\u84c4\r\n\r\n\u3000\u3000\u201c\u8d22\u5ba2\u5728\u7ebf\u201d\u662f\u76ee\u524d\u5168\u56fd\u62e5\u6709\u4f1a\u5458\u6570\u91cf\u6700\u591a\u7684\u4e13\u4e1a\u8bb0\u8d26\u7f51\u7ad9\u4e4b\u4e00\u3002\u6628\u65e5\uff0c\u8bb0\u8005\u5728\u8be5\u7f51\u7ad9\u770b\u5230\uff0c\u6625\u8282\u4e03\u5929\uff0c\u6bcf\u5929\u767b\u5f55\u7f51\u7ad9\u8bb0\u8d26\u7684\u4eba\u6570\u90fd\u8d85\u8fc710\u4e07\u3002\u8d26\u5ba2\u5c0f\u5f3a\u516c\u5e03\u81ea\u5df1\u7684\u6625\u8282\u6d88\u8d39\u8d26\u5355\u663e\u793a\uff1a\u7d2f\u8ba1\u6d88\u8d3913550\u5143\uff0c\u5176\u4e2d\u4e00\u4e07\u5143\u662f\u5b5d\u656c\u53cc\u65b9\u7236\u6bcd\u7684\uff0c\u5269\u4e0b\u76843550\u5143\u4e2d\uff0c\u9664\u4e86\u7ed9\u5c0f\u5b69\u53d1\u7684\u538b\u5c81\u94b1\uff0c\u5c31\u662f\u8bf7\u5ba2\u5403\u996d\u82b1\u6389\u4e86\u3002\u8d22\u5ba2\u5728\u7ebf\u8d1f\u8d23\u4eba\u4ecb\u7ecd\uff0c\u8fc7\u5e74\u4e03\u5929\u82b1\u8131\u534a\u5e74\u79ef\u84c4\u7684\u4eba\u4e0d\u5728\u5c11\u6570\uff0c\u800c\u8bf7\u5ba2\u5403\u996d\u3001\u53d1\u538b\u5c81\u94b1\u5360\u636e\u4e86\u5f00\u9500\u5927\u534a\u3002\u4e2d\u56fd\u8d26\u5ba2\u7f51\u3001\u5b9d\u8d1d\u8bb0\u8d26\u7f51\u7b49\u56fd\u5185\u6570\u5bb6\u4e13\u4e1a\u8bb0\u8d26\u7f51\u7ad9\u7c97\u7565\u7edf\u8ba1\uff0c\u6625\u8282\u671f\u95f4\u4e0a\u7f51\u8bb0\u8d26\u7684\u4eba\u6bcf\u5929\u90fd\u6709\u6570\u5341\u4e07\uff0c\u800c\u53bb\u5e74\u6625\u8282\uff0c\u6700\u591a\u65f6\u4e5f\u53ea\u6709\u4e00\u4e24\u4e07\u4eba\uff0c\u4eca\u5e74\u589e\u52a0\u4e86\u5341\u500d\u5de6\u53f3\u3002\r\n\r\n\u3000\u3000\u7f51\u4e0a\u8bb0\u8d26\u4f1a\u5458\u91cf\u6fc0\u589e\r\n\r\n\u3000\u3000\u636e\u201c\u8d22\u5ba2\u5728\u7ebf\u201d\u4ecb\u7ecd\uff0c\u8be5\u7f51\u7ad92008\u5e747\u67081\u65e5~11\u670830\u65e5\u671f\u95f4\uff0c\u6ce8\u518c\u4f1a\u5458\u6570\u91cf\u4e3a19\u4e07\u591a\u4eba\uff0c\u800c\u57282008\u5e741\u67081\u65e5~6\u670831\u65e5\u671f\u95f4\uff0c\u4f1a\u5458\u6570\u91cf\u8fd8\u4e0d\u52305.7\u4e07\u4eba\uff0c\u76f8\u5f53\u4e8e4\u4e2a\u6708\u65f6\u95f4\u5185\u5c31\u7ffb\u4e86\u4e24\u756a\u591a\u3002\u636e\u6089\uff0c\u8be5\u7f51\u7ad9\u4ece2007\u5e741\u6708\u6210\u7acb\u81f3\u4eca\uff0c\u4f1a\u5458\u603b\u6570\u4e3a27.42\u4e07\u4eba\uff0c2008\u5e74\u4e0b\u534a\u5e74\u589e\u957f\u7684\u4eba\u6570\u5360\u636e\u4e8670%\u7684\u6bd4\u4f8b\u3002\u9664\u4e86\u201c\u8d22\u5ba2\u5728\u7ebf\u201d\uff0c\u8bb0\u8005\u4e86\u89e3\u5230\uff0c\u4e2d\u56fd\u8d26\u5ba2\u7f51\u3001\u5b9d\u8d1d\u8bb0\u8d26\u7f51\u7b49\uff0c\u5728\u53bb\u5e74\u4e0b\u534a\u5e74\u7684\u65f6\u95f4\u5185\uff0c\u4f1a\u5458\u6570\u91cf\u90fd\u51fa\u73b0\u4e86\u7ffb\u756a\uff0c\u800c\u4e14\u65b0\u589e\u4f1a\u5458\u7684\u6d3b\u8dc3\u5ea6\u8fbe\u5230\u4e8630%\uff0c\u4e3a\u5386\u53f2\u6700\u9ad8\u503c\u3002\r\n\r\n\u3000\u3000\u5371\u673a\u4fc3\u4f7f\u5f00\u6e90\u8282\u6d41\r\n\r\n\u3000\u3000\u8bb0\u8005\u4e86\u89e3\u5230\uff0c\u8bb0\u8d26\u4eba\u5458\u4e2d\uff0c\u5c24\u5176\u4ee5\u516c\u53f8\u804c\u5458\u5c45\u591a\uff0c\u5927\u5230\u4e70\u8f66\u4e70\u623f\uff0c\u5c0f\u5230\u4e70\u83dc\u6253\u7684\uff0c\u7b