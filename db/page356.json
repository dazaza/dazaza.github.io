u5907\u7ade\u4e89\u7684\u4e0b\u4e00\u4e2a\u6218\u573a\uff0c\u8bb8\u591a\u8bbe\u5907\u5236\u9020\u5546\u548c\u5fae\u8f6f(Microsoft)\u3001\u8c37\u6b4c\u4ee5\u53caResearch In Motion\u5728\u8fd9\u573a\u4e89\u593a\u4e2d\u4e0e\u82f9\u679c\u8f83\u91cf\u3002\r\n\r\n\u636e\u5fb7\u610f\u5fd7\u94f6\u884c(Deutsche Bank)\u8868\u793a\uff0ciPad\u5df2\u6210\u4e3a\u82f9\u679c\u975e\u5e38\u6210\u529f\u7684\u4ea7\u54c1\uff0c\u4f7f\u8be5\u516c\u53f8\u5728\u5168\u7403\u7b14\u8bb0\u672c\u548c\u5176\u4ed6\u4fbf\u643a\u5f0f\u7535\u8111\u5e02\u573a\u4e0a\u4ece\u6392\u540d\u7b2c7\u5347\u81f3\u7b2c3\u540d\u3002\r\n\r\n\u6469\u6258\u7f57\u62c9\u5c06\u5e73\u677f\u7535\u8111\u4e0e\u7535\u89c6\u7ed3\u5408\u5728\u4e00\u8d77\uff0c\u662f\u76f8\u5bf9\u4e8e\u5176\u4ed6\u5f00\u53d1\u5546\u7684\u4e00\u4e2a\u5173\u952e\u7ade\u4e89\u4f18\u52bf\u3002\r\n\r\n\u636e\u53d7\u4f17\u8ddf\u8e2a\u4f01\u4e1a\u5c3c\u5c14\u68ee(Nielsen)\u8868\u793a\uff0c\u5c3d\u7ba1\u82f9\u679c\u7684\u5e73\u677f\u7535\u8111\u548c\u624b\u673a\u9500\u91cf\u5f3a\u52b2\uff0c\u4f46\u4eca\u5e74\u59346\u4e2a\u6708\uff0c\u8fd0\u884c\u8c37\u6b4cAndroid\u64cd\u4f5c\u7cfb\u7edf\u7684\u8bbe\u5907\u5728\u7f8e\u56fd\u53d6\u5f97\u4e8627%\u7684\u5e02\u573a\u4efd\u989d\uff0c\u8d85\u8fc7iPhone\u624b\u673a23%\u7684\u5e02\u573a\u4efd\u989d\u3002\r\n\r\n\u4e0e\u9884\u8ba1\u5c06\u4e0a\u5e02\u7684\u4f17\u591a\u5e73\u677f\u7535\u8111\u4e00\u6837\uff0c\u6469\u6258\u7f57\u62c9\u7684\u5e73\u677f\u7535\u8111\u65e8\u5728\u89e3\u51b3\u4eba\u4eec\u773c\u4e2diPad\u7684\u5176\u4ed6\u4e0d\u8db3\u4e4b\u5904\u3002\r\n\r\n\u5b83\u5c06\u652f\u6301Adobe Flash\uff0c\u8fd9\u6b3e\u8f6f\u4ef6\u652f\u6301\u7ea690%\u7684\u7f51\u7edc\u89c6\u9891\u3002\u82f9\u679c\u5728\u5176iPhone\u548ciPad\u8bbe\u5907\u4e0a\u652f\u6301\u7684\u662f\u53e6\u4e00\u79cd\u683c\u5f0f\u5373HTML 5\u3002\r\n\r\n\u6469\u6258\u7f57\u62c9\u7684\u8bbe\u5907\u4f30\u8ba1\u5c06\u4f1a\u6bd4iPad\u66f4\u8584\u66f4\u8f7b\uff0c\u80fd\u8ba9\u7528\u6237\u4e0e\u9644\u8fd1\u7684\u8bbe\u5907\u5171\u4eab\u5176\u65e0\u7ebf