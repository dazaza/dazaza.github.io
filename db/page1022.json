aries.org/", "title": "Worldcat\uff1a\u53ef\u4ee5\u5728\u4e16\u754c\u5404\u5730\u7684\u4e00\u4e07\u591a\u6240\u56fe\u4e66\u9986\u4e2d\u641c\u7d22\u8d85\u8fc710\u4ebf\u79cd\u8d44\u6599", "tags": "worldcat \u56fe\u4e66\u9986 \u8d44\u6599 ", "name": "maker", "posttime": "2007-10-21 21:49:40", "ip": "219.153.131.101", "mark": 6, "note": "\u5728\u8fd9\u91cc\u4f60\u4f1a\u53d1\u73b0\u53ef\u4ee5\u4e0b\u8f7d\u8bb8\u8bb8\u591a\u591a\u7684\u56fe\u4e66\uff0c\u97f3\u4e50\uff0c\u89c6\u9891\uff0c\u6587\u7ae0\u548c\u5176\u4ed6\u8d85\u591a\u7684\u8d44\u6599\u4f9b\u4f60\u4e0b\u8f7d\uff01\uff01", "imagename": "ed59e14e328743bbb8c9620f77d8f985.gif", "infoid": 31888, "category": "culture_people", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "culture", "via": null, "real_tags": ["worldcat", "\u56fe\u4e66\u9986", "\u8d44\u6599"]}]