65e5\u4ff1\u589e\uff0c\u5e76\u4e14\u8d8a\u6765\u8d8a\u591a\u7684\u7231\u597d\u8005\u5df2\u7ecf\u4e3aAdobe AIR\u5f00\u53d1\u51fa\u4e86\u5404\u5f0f\u5404\u6837\u7684\u529f\u80fd\u3002", "imagename": "c61a06b8e0a8407fbd2d9ea3d02b772a.jpg", "infoid": 140220, "category": "technology_internet", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["adobe", "air"]}, {"url": "http://www.xtit.net/post/shengshengkan/", "title": "\u7701\u7701\u770b\uff1a\u5e2e\u60a8\u8282\u7701\u80fd\u6e90\uff0c\u52a9\u529b\u73af\u4fdd - \u9c9c\u751cIT.Net", "tags": "\u7701\u7535 \u8282\u80fd \u73af\u4fdd ", "name": "xjyzhenai", "posttime": "2009-04-15 12:58:01", "ip": "222.243.160.35", "mark": 2, "note": "\u80fd\u6e90\u95ee\u9898\u548c\u73af\u4fdd\u95ee\u9898\uff0c\u662f\u672c\u4e16\u7eaa\u6700\u91cd\u8981\u7684\u56fd\u9645\u95ee\u9898\u3002\u4eba\u4eec\u5bf9\u80fd\u6e90\u7684\u6d88\u8017\u5df2\u7ecf\u6210\u4e3a\u65e5\u76ca\u5f71\u54cd\u751f\u6d3b\u7684\u5173\u952e\u56e0\u7d20\u3002\u4f46\u662f\u80fd\u6e90\u6d88\u8017\u53ea\u662f\u6211\u4eec\u76ee\u524d\u770b\u5230\u7684\u4e00\u4e2a\u8868\u9762\u7684\u56f0\u6270\u95ee\u9898\u3002\u66f4\u4e3a\u4e25\u91cd\u7684\u662f\uff0c\u7531\u4e8e\u70ed\u529b\u53d1\u7535\u800c\u5bfc\u81f4\u7684\u5168\u7403\u53d8\u6696\u95ee\u9898\uff0c\u8ba9\u672c\u5df2\u4e0d\u582a\u91cd\u8d1f\u7684\u5730\u7403\u96ea\u4e0a\u52a0\u971c\u3002\u7531\u6fb3\u5927\u5229\u4e9a\u7684\u6089\u5c3c\u53d1\u8d77\u7684\u201c\u4e16\u754c1\u5c0f\u65f6\u201d\u6d3b\u52a8\uff0c\u5c31\u662f\u4e3a\u4e86\u5411\u4e16\u754c\u547c\u5401\u8282\u80fd\u51cf\u6392\uff0c\u51cf\u5c11\u70ed\u529b\u53d1\u7535\u7684\u6392\u653e\u3002\u4e0d\u77e5\u9053\u4f60\u60f3\u8fc7\u6ca1\u6709\uff1a\u8eab\u4e3a\u5e73\u6c11\u7684\u6211\u4eec\u80fd\u505a\u70b9\u4ec0\u4e48\uff1f\u4eca\u5929JarryJarry\u4e3a\u5927\u5bb6\u4ecb\u7ecd\u4e00\u6b3e\u8282\u80fd\u73af\u4fdd\u8f6f\u4ef6\uff1a\u7701\u7701\u770b\u3002\r\n\r\nimage \u3000\u3000\u7701\u7701\u770b\u662f\u5168\u7403\u9996\u6b3e\u4e2d\u6587\u516c\u76ca\u73af\u4fdd\u8f6f\u4ef6\uff0c\u76ee\u7684\u662f\u81ea\u52a8\u901a\u8fc7\u5e2e\u52a9\u7528\u6237\u7ba1\u7406\u663e\u793a\u5668\uff0c\u786c\u76d8\u7b49\u8017\u7535\u8bbe\u5907\uff0c\u8282\u7ea6\u7528\u7535\u5ef6\u957f\u7535\u8111\u5bff\u547d\u3002\u7701\u7701\u770b\u628a\u4f60\u8282\u7701\u4e0b\u6765\u7684\u7535\u80fd\u7528\u6570\u5b57\u8868\u793a\u51fa\u6765\uff0c\u5e76\u6298\u7b97\u6210\u8282\u7ea6\u4e86\u591a\u5c11\u6811\u6728\u548c\u77f3\u6cb9\uff0c\u8ba9\u4f7f\u7528\u8005\u8ba4\u8bc6\u5230\u8282\u7535\u4e0d\u4f46\u53ef\u4ee5\u964d\u4f4e\u80fd\u8017\uff0c\u540c\u65f6\u4e5f\u5728\u4e3a\u751f\u6001\u73af\u4fdd\u505a\u51fa\u8d21\u732e\uff01\r\n\r\nimage\r\n\r\n\u3000\u3000\u5148\u767b\u9646\u7701\u7701\u770b\u7684\u5b98\u65b9\u7f51\u7ad9http://www.shengshengkan.com\u4e0b\u8f7d\u8f6f\u4ef6\u3002\u7b2c\u4e00\u6b21\u8fd0\u884c\uff0c\u8f6f\u4ef6\u4f1a\u8ba9\u4f60\u6ce8\u518c\u4e00\u4e2a\u5e10\u53f7\uff0c\u7136\u540e\u767b\u9646\u3002\u8f6f\u4ef6\u7684\u4e3b\u754c\u9762\u5c06\u663e\u793a\u4f60\u7684\u8282\u80fd\u6210\u7ee9\uff0c\u4ee5\u53ca\u4f60\u6240\u52a0\u5165\u7684\u7701\u7535\u56e2\u961f\u8282\u80fd\u603b\u6210\u7ee9\u3002\r\n\r\nimage\r\n\r\n\u3000\u3000\u7701\u7701\u770b\u5de5\u5177\u7bb1\u63d0\u4f9b\u4e00\u7cfb\u5217\u5c0f\u5de5\u5177\uff0c\u53ef\u4ee5\u65b9\u4fbf\u7684\u8c03\u8282\u663e\u793a\u5668\u4eae\u5ea6\uff1b\u8f7b\u677e\u5173\u95ed\u4e0d\u5e38\u7528\u7684\u786c\u4ef6\u8bbe\u5907\uff08\u84dd\u7259\uff0c\u5149\u9a71\u7b49\uff09\u8282\u7701\u7535\u80fd\u6d88\u8017\uff1b\u8ba9\u7535\u8111\u5728\u6307\u5b9a\u7684\u65f6\u95f4\u5f00\u59cb\u4e0b\u8f7d\u6216\u8fd0\u884c\u7279\u5b9a\u8f6f\u4ef6\uff0c\u5b9a\u65f6\u81ea\u52a8\u5173\u673a\u7b49\u3002\u8fd8\u6709\u66f4\u591a\u65b9\u4fbf\u667a\u80fd\u7684\u5de5\u5177\u6b63\u5728\u5f00\u53d1\u4e2d\uff0c\u4ee5\u540e\u4f1a\u9010\u6b65\u52a0\u5165\u5de5\u5177\u7bb1\u3002\r\n\r\n\u3000\u3000\u4e2a\u4eba\u7684\u529b\u91cf\u6bd5\u7adf\u5fae\u5f31\uff0c\u66f4\u591a\u4eba\u53c2\u4e0e\u73af\u4fdd\u624d\u80fd\u6709\u6548\u51cf\u7f13\u6e29\u5ba4\u6548\u5e94\u5bf9\u5730\u7403\u7684\u5f71\u54cd\u3002\u73b0\u5728\u60a8\u53ef\u4ee5\u5efa\u7acb\u4e00\u4e2a\u7701\u7535\u56e2\u961f\uff0c\u62db\u52df\u6210\u5458\u8ba9\u670b\u53cb\u52a0\u5165\u60a8\u7684\u56e2\u961f\uff0c\u5171\u540c\u73af\u4fdd\u3002\u56e2\u961f\u7701\u7535\u6210\u7ee9\u53ef\u5728\u81ea\u5df1\u5ba2\u6237\u7aef\u548c\u7f51\u7ad9\u4e0a\u5b9e\u65f6\u663e\u793a\uff0c\u7701\u7535\u91cf\u548c\u56e2\u961f\u89c4\u6a21\u8fd8\u53ef\u53c2\u4e0e\u6392\u540d\uff0c\u83b7\u5f97\u5f70\u663e\u8363\u8a89\u7684\u56e2\u961f\u52cb\u7ae0\uff01  \r\n\r\n\u3000\u3000\u901a\u8fc7\u8bbe\u7f6e\uff0c\u7701\u7701\u770b\u8fd8\u53ef\u4ee5\u5728\u4f60\u7684MSN\u4e0a\u63d2\u5165\u8282\u80fd\u516c\u76ca\u4fe1\u606f\uff0c\u901a\u8fc7\u793e\u4f1a\u5316\u7f51\u7edc\u5ba3\u4f20\u8282\u80fd\u73af\u4fdd\u3002\r\n\r\n\u3000\u3000\u4e5f\u8bb8\uff0c\u81ea\u5df1\u4e3a\u8282\u80fd\u73af\u4fdd\u8d21\u732e\u4e00\u70b9\u70b9\u5fae\u8584\u7684\u529b\u91cf\u7b97\u4e0d\u4e0a\u4ec0\u4e48\uff0c\u4f46\u662f\uff0c\u5343\u5343\u4e07\u4e07\u4e2a\u4f60\u6211\u52a0\u8d77\u6765\u80fd\u8282\u7701\u591a\u5c11\u80fd\u6e90\uff0c\u51cf\u5c11\u591a\u5c11\u5e9f\u6c14\u6392\u653e\uff0c\u8282\u7ea6\u591a\u5c11\u81ea\u7136\u8d44\u6e90\u5462\uff1f\u7701\u7701\u770b\u901a\u8fc7\u8fd9\u79cd\u53e6\u7c7b\u7684\u65b9\u5f0f\u4e3a\u5168\u4e16\u754c\uff0c\u5168\u4eba\u7c7b\u7684\u8282\u80fd\u73af\u4fdd\u5de5\u7a0b\u8d21\u732e\u7740\u81ea\u5df1\u7684\u529b\u91cf\uff0c\u5e0c\u671b\u80fd\u6fc0\u53d1\u5927\u5bb6\u5728\u65e5\u5e38\u751f\u6d3b\u5f53\u4e2d\u4ee5\u66f4\u591a\u7684\u65b9\u5f0f\u6765\u8282\u7701\u80fd\u6e90\u3002\u4e0d\u8981\u5c0f\u770b\u90a3\u4e48\u4e00\u70b9\u70b9\u7684\u8282\u7ea6\uff0c\u5c0f\u5c0f\u7684\u6c34\u6ef4\u4e5f\u80fd\u6c47\u6210\u6c5f\u6cb3\uff0c\u6ce8\u5165\u5927\u6d77\u3002\u4e3a\u4e86\u8282\u80fd\uff0c\u6b64\u7ad9\u70b9\u751a\u81f3\u4f7f\u7528\u6df1\u8272\u80cc\u666f\uff0c\u964d\u4f4e\u6d4f\u89c8\u8005\u8ba1\u7b97\u673a\u80fd\u6e90\u6d88\u8017\u3002\u8ba9\u6211\u4eec\u60f3\u4e00\u60f3\uff0c\u6211\u4eec\u8fd8\u53ef\u4ee5\u505a\u4e9b\u4ec0\u4e48\uff1f\u5982\u679c\u4f60\u51b3\u5b9a\u4ece\u73b0\u5728\u5f00\u59cb\uff0c\u52a0\u5165\u8282\u80fd\u73af\u4fdd\u5927\u519b\u7684\u961f\u4f0d\uff0c\u8bf7\u5728\u672c\u6587\u540e\u7559\u4e0b\u8bc4\u8bba\uff0c\u5e76\u96c6\u601d\u5e7f\u76ca\uff0c\u628a\u4f60\u60f3\u5230\u7684\u8282\u80fd\u65b9\u6cd5\u7c98\u8d34\u5230\u8bc4\u8bba\u91cc\uff0c\u5168\u4eba\u7c7b\u5c06\u611f\u8c22\u4f60\uff01\r\n\r\n\uff08\u5982\u679c\u60a8\u7684\u535a\u5ba2/\u4e2a\u4eba\u7f51\u7ad9\u7684\u80cc\u666f\u662f\u6df1\u8272\u7684\uff0c\u60a8\u5c31\u62e5\u6709\u4e86\u4e00\u4e2a\u8282\u80fd\u73af\u4fdd\u7684\u7ad9\u70b9\u3002\u60a8\u53ef\u4ee5\u52a0\u5165\u7701\u7701\u770b\u2122\u300c\u7eff\u8272\u535a\u5ba2/\u7ad9\u70b9\u300d\u8ba1\u5212\uff09\r\n\r\n \r\n\r\n\u70b9\u51fb\u8fdb\u5165\uff1a\u7701\u7701\u770b\u5b98\u65b9\u7f51\u7ad9\r\n\r\nTechnorati \u6807\u7b7e: \u7701\u7535,\u8282\u80fd,\u73af\u4fdd", "imagename": "7fa80edb216940a180b50249c5586c57.png", "infoid": 140219, "category": "life_other", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "life", "via": null, "real_tags": ["\u7701\u7535", "\u8282\u80fd", "\u73af\u4fdd"]}, {"url": "http://go.taobao.com/", "title": "\u770b\u56fe\u8d2d \uff0d \u6dd8\u5b9d\u7f51 taobao.com", "tags": "\u770b\u56fe\u8d2d \u6dd8\u5b9d\u7f51 ", "name": "yinyin", "posttime": "2009-04-15 12:51:33", "ip": "221.130.253.136", "mark": 1, "note": "\u4e00\u3001\u4ec0\u4e48\u662f\u770b\u56fe\u8d2d\uff1f\u6709\u4ec0\u4e48\u529f\u80fd\uff1f\r\n\u9996\u9875\uff0c\u7b80\u6d01\u9875\u9762\u8ba9\u4f60\u4e00\u76ee\u4e86\u7136\uff0c\r\n\u70ed\u95e8\u641c\u7d22\u8bcd\u548c\u7f8e\u56fe\u63a8\u8350\uff0c\u8ba9\u4f60\u77e5\u9053\uff0c\r\n\u5de6\u4e0a\u89d2\u5de7\u8bbe\u6362\u80a4\u529f\u80fd\uff0c\u770b\u6211\u4e5f\u4e03\u5341\u4e8c\u53d8\uff01\r\n \r\n\r\n \r\n\u641c\u7d22\u5173\u952e\u5b57\u540e\uff0c\u8fdb\u5165\u89c6\u89c9\u9955\u992e\u5927\u9910\u3002\u3002\u3002\u3002\r\n\u50cf\u4e0d\u50cf\u5728\u770b\u6742\u5fd7\uff1f\u5927\u56fe\uff0c\u5c0f\u56fe\u968f\u610f\u5207\u6362\uff01\r\n \r\n\r\n \r\n \u770b\u5230\u559c\u6b22\u7684\u5b9d\u8d1d\uff1f\r\n\u5feb\u6765\u6bd4\u4ef7\u5427\uff01\r\n\u5973\u4eba\uff0c\u8d2d\u7269\u90fd\u662f\u7cbe\u660e\u7684\uff5e\r\n\u770b\u56fe\u8d2d\u628a\u5356\u540c\u4e00\u5b9d\u8d1d\u7684\u5546\u5bb6\uff0c\u7528\u201c\u56fd\u5185\u72ec\u5bb6\u8d85\u725b\u4e13\u5229\u6280\u672f\u201d\u5168\u90e8\u805a\u5408\u51fa\u6765\uff0c\r\n\u60f3\u4e70\u6700\u4fbf\u5b9c\u7684\uff1f\u4ef7\u683c\u6392\u5e8f\u5e2e\u4f60\u67e5\uff1b\r\n\u60f3\u4e70\u4fe1\u8a89\u9ad8\u7684\uff1f\u4fe1\u7528\u6392\u5e8f\u5e2e\u4f60\u9009\uff1b\r\n\u8fd8\u6709\u8d85\u591a\u8d85\u5168\u7684\u7ec6\u8282\u56fe\uff0c\u5728\u5f53\u524d\u9875\u9762\u5c31\u5b8c\u5168\u5c55\u73b0\u2014\u2014\u7701\u53bb\u4e00\u4e2a\u4e2a\u6253\u5f00\u8be6\u60c5\u9875\u7b49\u5f85\u56fe\u7247\u6253\u5f00\u7684\u6298\u78e8\u4eba\u7684\u65e0\u5948\u3002\u3002\u3002\r\n \r\n\r\n \r\n\u4e8c\u3001\u770b\u56fe\u8d2d\u53ea\u9488\u5bf9\u5973\u88c5\u5417\uff1f\r\n\u76ee\u524d\u53ea\u9488\u5bf9\u5973\u88c5\u7c7b\uff08\u5973\u88c5\u3001\u5973\u58eb\u7cbe\u54c1\uff09\u7684\u5b9d\u8d1d\uff0c\u672a\u6765\u4f1a\u652f\u6301\u66f4\u591a\u7684\u7c7b\u76ee\r\n \r\n\u4e09\u3001\u7528\u770b\u56fe\u8d2d\uff0c\u53ef\u4ee5\u5e2e\u6211\u505a\u4ec0\u4e48\uff1f\r\n\uff081\uff09\u5927\u56fe\u770b\u5973\u88c5\uff0c\u540c\u65f6\u53ef\u4ee5\u770b\u5230\u5b9d\u8d1d\u66f4\u591a\u7ec6\u8282\u56fe\r\n\uff082\uff09\u540c\u6b3e\u8863\u670d\u8d27\u6bd4\u4e09\u5bb6\u3001\u4e70\u5230\u6700\u79f0\u5fc3\u5982\u610f\u7684\u8863\u670d\r\n \r\n\u56db\u3001\u770b\u56fe\u8d2d\u4e0e\u4ee5\u524d\u7684\u641c\u7d22\u7ed3\u679c\u5927\u56fe\u5c55\u793a\u6709\u4ec0\u4e48\u4e0d\u540c\uff1f\r\n\uff081\uff09\u6700\u5927\u7684\u4f18\u70b9\u5c31\u662f\u540c\u6b3e\u8863\u670d\u91cd\u590d\u51fa\u73b0\u6982\u7387\u5927\u5927\u964d\u4f4e\uff0c\u70b9\u51fb\u4e00\u6b21\u5c31\u53ef\u4ee5\u770b\u5230\u6dd8\u5b9d\u91cc\u6240\u6709\u5356\u8fd9\u6b3e\u8863\u670d\u7684\u5356\u5bb6\u4fe1\u606f\u548c\u5e97\u94fa\u4fe1\u606f\r\n\uff082\uff09\u66f4\u52a0\u7f8e\u89c2\u7684\u754c\u9762\u8bbe\u8ba1\uff0c\u534e\u4e3d\u53c8\u65f6\u5c1a\uff0c\u6700\u9002\u5408\u201c\u8bfb\u56fe\u201d\u65f6\u4ee3\u65b0\u65b0\u4eba\u7c7b\u7684\u4f60\r\n \r\n\r\n \r\n\u4e94\u3001\u6211\u53ef\u4ee5\u4ece\u4ec0\u4e48\u5730\u65b9\u8fdb\u5165\u770b\u56fe\u8d2d\uff1f\r\n\u5728\u6d4f\u89c8\u5668\u5730\u5740\u680f\u8f93\u5165\uff1ahttp://go.taobao.com\uff0c\u5373\u53ef\u5f00\u59cb\u6109\u5feb\u7684\u770b\u56fe\u8d2d\u4e4b\u65c5\r\n \r\n\u516d\u3001\u5982\u4f55\u8ba9\u641c\u7d22\u5230\u7684\u5b9d\u8d1d\u56fe\u7247\u7ed3\u679c\u66f4\u51c6\u786e\uff1f \u600e\u4e48\u9009\u62e9\u641c\u7d22\u8bcd\uff1f\r\n\u5f53\u60a8\u8f93\u5165\u591a\u4e2a\u8bcd\u8bed\u641c\u7d22\uff08\u4e0d\u540c\u8bcd\u4e4b\u95f4\u7528\u4e00\u4e2a\u7a7a\u683c\u9694\u5f00\uff09\uff0c\u53ef\u4ee5\u83b7\u5f97\u66f4\u7cbe\u786e\u7684\u641c\u7d22\u7ed3\u679c\u3002\r\n\u5982\uff1a\u60f3\u641c\u201c\u97e9\u7248\u98ce\u8863\u201d\u65f6\uff0c\u5c1d\u8bd5\u641c\u201c\u98ce\u8863 \u97e9\u7248\u4f1a\u6bd4\u201c\u97e9\u7248\u98ce\u8863\u201d\u5f97\u5230\u66f4\u597d\u7684\u7ed3\u679c\u3002\r\n\u6216\u8005\u5c1d\u8bd5\u4f7f\u7528\u6211\u4eec\u63a8\u8350\u7684\u70ed\u95e8\u8bcd\u3001\u70ed\u95e8\u5546\u54c1\uff0c\u5b9e\u65f6\u638c\u63e1\u6d41\u884c\u98ce\u5411\u3002\r\n \r\n\u4e03\u3001\u770b\u56fe\u8d2d\u6709\u4ec0\u4e48\u4f7f\u7528\u6280\u5de7\uff1f\r\n1.    \u53ef\u4ee5\u4f7f\u7528\u9f20\u6807\u6eda\u8f6e\u6d4f\u89c8\u56fe\u7247\r\n2.    \u53ef\u4ee5\u4f7f\u7528\u952e\u76d8\u5de6\u53f3\u65b9\u5411\u952e\u6d4f\u89c8\u4e0a\u4e00\u5f20\u6216\u4e0b\u4e00\u5f20\u56fe\u7247\uff0cPageDown\u5411\u4e0b\u7ffb\u9875\uff0cPageUp\u5411\u4e0a\u7ffb\u9875\r\n3.    \u9875\u9762\u5de6\u4e0a\u89d2\u53ef\u4ee5\u5b9e\u73b0\u767d\u8272\u76ae\u80a4\u548c\u9ed1\u8272\u76ae\u80a4\u7684\u81ea\u52a8\u5207\u6362\r\n\r\n \r\n\u5c0f\u8d34\u58eb\uff1a\u4f7f\u7528Firefox\u3001Safari\u6d4f\u89c8\u5668\u6d4f\u89c8\u56fe\u7247\u6548\u679c\u66f4\u4f73\u3002\r\n \r\n\u516b\u3001\u5728\u5957\u56fe\u91cc\u6211\u53ef\u4ee5\u770b\u5230\u54ea\u4e9b\u5185\u5bb9\uff1f\r\n\u4ee5\u7f29\u7565\u56fe\u7684\u65b9\u5f0f\uff0c\u5217\u51fa\u540c\u4e00\u4e2a\u5356\u5bb6\u5b9d\u8d1d\u8be6\u60c5\u9875\u4e2d\u7684\u5176\u5b83\u56fe\u7247\uff0c\u901a\u8fc7\u7ec6\u8282\u56fe\u3001\u5b9e\u62cd\u56fe\u3001\u6a21\u7279\u56fe\u7b49\u591a\u79cd\u89d2\u5ea6\u4e3a\u60a8\u5168\u65b9\u4f4d\u7684\u5c55\u793a\u8fd9\u4e2a\u5b9d\u8d1d\uff08\u5982\u4e0b\u56fe\uff09\r\n \r\n \r\n \r\n \r\n\u4e5d\u3001\u770b\u56fe\u8d2d\u641c\u7d22\u7ed3\u679c\u9875\u9762\u662f\u6309\u4ec0\u4e48\u6392\u5e8f\u7684\uff1f\r\n\u641c\u7d22\u7ed3\u679c\u662f\u6309\u7167\u5b9d\u8d1d\u7ed3\u675f\u65f6\u95f4\u524d\u540e\u6392\u5e8f\uff0c\u5373\u5c06\u7ed3\u675f\u7684\u5b9d\u8d1d\u6392\u5728\u524d\u9762\u3002 \r\n \r\n \r\n\u5341\u3001\u6211\u53ef\u4ee5\u7528\u201c\u6211\u8981\u6bd4\u4ef7\u201d\u505a\u4ec0\u4e48\uff1f\r\n\u505a\u4e2a\u7cbe\u660e\u7684\u4e70\u5bb6\uff0c\u70b9\u51fb\u201c\u6211\u8981\u6bd4\u4ef7\u201d\uff0c\u5c31\u80fd\u5b9e\u73b0\u201c\u8d27\u6bd4\u6570\u5bb6\u201d\u7684\u613f\u671b\u2014\u2014\u51fa\u552e\u540c\u4e00\u4ef6\u5b9d\u8d1d\u7684\u4e0d\u540c\u5356\u5bb6\u4fe1\u606f\u4ee5\u53ca\u4ef7\u683c\u4f1a\u4e00\u76ee\u4e86\u7136\uff0c\u8ba9\u60a8\u5728\u6dd8\u5b9d\u8d1d\u7684\u8fc7\u7a0b\u4e2d\u66f4\u723d\u66f4\u65b9\u4fbf\uff01\r\n\u5341\u4e00\u3001\u600e\u4e48\u4f7f\u7528\u6bd4\u4ef7\u529f\u80fd\u5462\uff1f\r\n\u7b2c\u4e00\u6b65. \u5728\u641c\u7d22\u7ed3\u679c\u9875\u4e2d\u5355\u51fb\u201c\u6211\u8981\u6bd4\u4ef7\u201d\u3001\u201c\u5171\u6709**\u76f8\u5173\u5356\u5bb6\u201d\u6216\u8005\u56fe\u7247\uff0c\u5373\u53ef\u8fdb\u5165\u6bd4\u4ef7\u9875\u9762\r\n \r\n\r\n \r\n\u7b2c\u4e8c\u6b65.\u5728\u4e2d\u95f4\u6bd4\u4ef7\u9875\u53ef\u4ee5\uff1a\r\na.       \u67e5\u770b\u66f4\u591a\u5b9d\u8d1d\u7ec6\u8282\u56fe\u7247\uff0c\u5355\u51fb\u540e\u5373\u5728\u4e0b\u9762\u5927\u56fe\u4e2d\u5c55\u793a\r\nb.       \u5207\u6362\u4e0d\u540c\u5356\u5bb6\uff0c\u8f7b\u677e\u5b9e\u73b0\u8d27\u6bd4\u591a\u5bb6\r\nc.       \u9009\u62e9\u6309\u7167\u4fe1\u8a89\u6392\u5e8f\u6216\u8005\u4ef7\u683c\u6392\u5e8f\uff0c\u66f4\u5feb\u66f4\u51c6\u627e\u5230\u5fc3\u4eea\u5b9d\u8d1d\r\nd.       \u5355\u51fb\u201c\u67e5\u770b\u8be6\u60c5\u201d\u6309\u94ae\u5373\u53ef\u8fdb\u5165\u5b9d\u8d1d\u8be6\u60c5\u9875\u8d2d\u4e70\u5b9d\u8d1d\u4e86\r\n \r\n\r\n\u5341\u4e8c\u3001\u5356\u540c\u6b3e\u5b9d\u8d1d\u7684\u5356\u5bb6\u662f\u6309\u4ec0\u4e48\u6392\u5e8f\u7684\uff1f\r\n\u9ed8\u8ba4\u7684\u7b2c\u4e00\u4e2a\u5b9d\u8d1d\u662f\u6309\u7167\u6210\u4ea4\u7ed3\u675f\u65f6\u95f4\uff0c\u5176\u4f59\u5356\u5bb6\u7684\u5b9d\u8d1d\u6309\u7167\u4fe1\u7528\uff0c\u5f53\u7136\u60a8\u4e5f\u53ef\u4ee5\u5207\u6362\u5230\u6309\u4ef7\u683c\u6392\u5e8f\u3002\r\n \r\n\r\n \r\n\u5341\u4e09\u3001\u770b\u56fe\u8d2d\u91cc\u9762\u7684\u8863\u670d\u56fe\u7247\u591a\u4e45\u66f4\u65b0\u4e00\u6b21\uff1f\r\n\u4e00\u5929\u4e00\u6b21\uff0c\u5c55\u73b0\u6700\u65b0\u7684\u5973\u88c5\uff0c\u8d70\u5728\u65f6\u5c1a\u524d\u6cbf\r\n \r\n\u5341\u56db\u3001\u4ec0\u4e48\u6837\u7684\u5546\u54c1\u80fd\u88ab\u770b\u56fe\u8d2d\u641c\u7d22\u51fa\u6765\r\n1.       \u5e97\u94fa\u4e2d\u51fa\u552e \r\n2.       \u975e\u62cd\u5356\u5b9d\u8d1d\r\n3.       \u6709\u6548\u56fe\u7247\r\n  \uff081\uff09\u8be6\u60c5\u9875\u5b9d\u8d1d\u63cf\u8ff0\u4e2d\u5305\u542b\u56fe\u7247\r\n   \uff082\uff09\u5c3a\u5bf8\u5408\u9002\uff08\u5bf9\u4e8e\u56fe\u7247\u957f\u8fb9\u8d85\u8fc71500\u50cf\u7d20\u7684\u8d85\u957f\u56fe\uff0c\u770b\u56fe\u8d2d\u65e0\u6cd5\u5c55\u793a\uff09\r\n   \uff083\uff09\u6bd4\u4f8b\u5408\u9002\r\n   \uff084\uff09\u975e\u52a8\u753b\u56fe\r\n4.       \u6709\u6548\u5b9d\u8d1d\r\n\uff081\uff09\u5b9d\u8d1d\u8be6\u60c5\u9875\u4e2d\u7684\u6709\u6548\u56fe\u7247\u8981\u8fbe\u5230\u4e00\u5b9a\u6570\u76ee\uff1a\u5efa\u8bae4-6\u5f20\r\n\uff082\uff09\u975e\u91cd\u590d\u94fa\u8d27\uff08\u540c\u4e00\u5356\u5bb6\u5728\u5176\u591a\u4e2a\u5b9d\u8d1d\u4f7f\u7528\u4e86\u76f8\u540c\u7684\u56fe\uff0c\u5219\u53ea\u4fdd\u7559\u4e00\u4e2a\u5b9d\u8d1d\uff09\r\n \r\n \r\n\u5341\u4e94\u3001\u4e3a\u4ec0\u4e48\u6211\u5728\u770b\u56fe\u8d2d\u4e2d\u627e\u4e0d\u5230\u53d1\u5e03\u7684\u5b9d\u8d1d\uff1f\r\n\u53ef\u80fd\u7684\u539f\u56e0\uff1a \r\n1.       \u5b9d\u8d1d\u6210\u4ea4\u5373\u5c06\u7ed3\u675f\r\n2.       \u65b0\u53d1\u5e03\u5b9d\u8d1d\r\n3.       \u8bf7\u68c0\u67e5\u662f\u5426\u91cd\u590d\u94fa\u8d27\r\n4.       \u7cfb\u7edf\u9650\u5236\uff1a\u6bcf\u4e2a\u4ea7\u54c1\u6700\u591a\u663e\u793a100\u4e2a\u5356\u5bb6\r\n5.       \u770b\u56fe\u8d2d\u7cfb\u7edf\u672a\u4e0e\u6dd8\u5b9d\u4e3b\u641c\u7d22\u7cfb\u7edf\u8fbe\u5230\u5b8c\u5168\u540c\u6b65\uff0c\u8bf7\u8010\u5fc3\u7b49\u5f85\uff0c\u6211\u4eec\u4f1a\u9010\u6b65\u5b8c\u5584\u770b\u56fe\u8d2d\u7cfb\u7edf\u7684\r\n \r\n\u5982\u679c\u53d1\u73b0\u6b64\u7c7b\u60c5\u51b5\uff0c\u5efa\u8bae\u60a8\u5c06\u5b9d\u8d1d\u8be6\u60c5\u9875\u7684\u94fe\u63a5\u5730\u5740\u63d0\u4f9b\u7ed9\u6dd8\u5b9d\u5ba2\u670d\uff0c\u6211\u4eec\u4f1a\u505a\u540e\u7eed\u7684\u8ddf\u8fdb\u548c\u5904\u7406\u3002\u8054\u7cfb\u4eba\uff1ayunsun#taobao.com(\u8bf7\u5c06#\u53f7\u66ff\u6362\u6210@)\r\n \r\n\u5341\u516d\u3001\u770b\u56fe\u8d2d\u5bf9\u5356\u5bb6\u662f\u514d\u8d39\u7684\u5417\uff1f \r\n \r\n\u76ee\u524d\u6240\u6709\u7684\u670d\u52a1\u90fd\u662f\u514d\u8d39\u7684\uff0c\u4e0d\u8fc7\u6211\u4eec\u4ee5\u540e\u4f1a\u63a8\u51fa\u66f4\u591a\u7684\u521b\u65b0\u670d\u52a1\r\n \r\n\u5341\u4e03\u3001\u53d1\u73b0\u6709\u4eba\u76d7\u7528\u6211\u7684\u56fe\u7247\u600e\u4e48\u529e\uff1f\r\n\u9047\u5230\u76d7\u56fe\u7684\u60c5\u51b5\u8bf7\u5411\u6dd8\u5b9d\u5ba2\u670d\u90e8\u95e8\u53cd\u5e94\uff0c\u4ed6\u4eec\u4f1a\u53d7\u7406\u5e76\u4f9d\u60c5\u51b5\u8fdb\u884c\u76f8\u5e94\u5904\u7f5a\u3002\r\n\u8054\u7cfb\u65b9\u5f0f\uff1a0571-88157858\r\n\u6211\u4eec\u4e5f\u5728\u79ef\u6781\u4ece\u6280\u672f\u89d2\u5ea6\u8003\u8651\uff0c\u5e2e\u60a8\u51cf\u5c11\u635f\u5931\u3002\r\n \r\n\u6211\u4eec\u5021\u5bfc\u5356\u5bb6\u53d1\u5e03\u7684\u5973\u88c5\u56fe\u7247\u5747\u4e3