6f4\u6307\u70ed\u70b9\u95ee\u9898\uff0c\u6df1\u5f97\u6f2b\u753b\u771f\u8c1b\u3002", "imagename": "2892.jpg", "infoid": 2892, "category": "technology_internet", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u975e\u5e38\u771f\u4eba", "\u6f2b\u753b", "\u7ecf\u5178", "\u56fe\u7247", "\u6709\u8da3", "\u641e\u7b11"]}, {"url": "http://my.donews.com/dujunday/2006/06/02/\u5341\u5927\u6700\u4ee4\u4eba\u8ba8\u538c\u7684\u95f9\u949f\uff01", "title": "\u5341\u5927\u6700\u4ee4\u4eba\u8ba8\u538c\u7684\u95f9\u949f\uff01", "tags": "clock \u5341\u5927 \u641e\u602a ", "name": "dujunday", "posttime": "2006-06-02 21:34:26", "ip": "60.176.94.213", "mark": 5, "note": "\u5341\u5927\u6700\u4ee4\u4eba\u8ba8\u538c\u7684\u95f9\u949f\uff01\u4f60\u7edd\u5bf9\u60f3\u8c61\u4e0d\u5230~\r\n\r\n\u7b2c10\u540d: Climbing clock\r\n\u5efa\u8bae\u548c\u68af\u5b50\u642d\u914d\u4f7f\u7528,\u5f53\u95f9\u949f\u54cd\u7684\u65f6\u5019\uff0c\u5c31\u5f00\u59cb\u81ea\u5df1\u5f80\u4e0a\u5347\u3002\u5982\u679c\u4f60\u4e0d\u8d76\u5feb\u8d77\u5e8a\u7684\u8bdd\uff0c\u90a3\u4f60\u5c31\u53ea\u6709\u722c\u68af\u5b50\u624d\u80fd\u5173\u6389\u5b83~\r\n\r\n\u7b2c9\u540d: Wake Up Puzzle\r\n\u4f60\u5fc5\u987b\u5b8c\u6210\u62fc\u56fe\u624d\u80fd\u8ba9\u5b83\u505c\u6b62,\u8010\u6027\u4e0d\u597d\u8005\u5fcc\u7528.\r\n\r\n\u7b2c8\u540d: Wake or Curse\r\n\u542b\u8bed\u97f3\u8bc6\u522b,\u4f60\u53ef\u4ee5\u968f\u65f6\u95ee\u5b83\u73b0\u5728\u4ec0\u4e48\u65f6\u95f4,\u4f1a\u81ea\u52a8\u5e94\u7b54.\u5f53\u7136\u4f60\u4e0d\u53ca\u65f6\u8d77\u5e8a\u7684\u8bdd,\u5b83\u5c31\u4f1a\u4e00\u523b\u4e0d\u505c\u7684\u8bc5\u5492\u4f60,\u76f4\u9053\u4f60\u53d7\u4e0d\u4e86\u4e3a\u6b62!(\u6390\u4f4f\u5b83\u8116\u5b50\u5c31\u53ef\u4ee5\u5173\u6389\u5566)\r\n\r\n\u7b2c7\u540d: High Tech\r\n\u8fd9\u4e2a\u95f9\u949f\u81ea\u5e26\u7684\u9707\u52a8\u566895\u5206\u8d1d!\u540c\u65f6\u4f1a\u53d1\u51fa\u7ea2\u8272\u65cb\u8f6c\u95ea\u5149(\u50cf\u8b66\u8f66\u4e00\u6837).95\u5206\u8d1d\u662f\u4ec0\u4e48\u6982\u5ff5?\u4e13\u5bb6\u8ba4\u4e3a\u566a\u97f3\u8d85\u8fc790\u5206\u8d1d\u4ee5\u4e0a\uff0c\u5c31\u6709\u53ef\u80fd\u4f1a\u81f4\u804b.\r\n\r\n\r\n\u7b2c6\u540d: Find The Pin \r\n\u8fd9\u4e2a\u957f\u6ee1\u6309\u94ae\u7684\u7403\u4e0a\u4f60\u9700\u8981\u627e\u5230\u6b63\u786e\u7684\u90a3\u4e2a\u624d\u53ef\u4ee5\u5173\u6389\u5b83.\r\n\r\n\u7b2c5\u540d: Chicken and Egg Problem \r\n\u4f60\u53ea\u6709\u628a\u6240\u6709\u7684\u9e21\u86cb\u653e\u56de\u7bee\u5b50\u91cc\u624d\u53ef\u4ee5\u5173\u6389\u5b83!\u6240\u4ee5\u6700\u597d\u7761\u89c9\u524d\u786e\u8ba4\u4e0b\u4f60\u7236\u6bcd\u6709\u6ca1\u6709\u628a\u86cb\u85cf\u8d77\u6765.\r\n\r\n\u7b2c4\u540d: GI Joe\r\n\u8457\u540d\u7684\u7279\u79cd\u90e8\u961f\u957f\u5b98,\u5230\u8d77\u5e8a\u65f6\u95f4,\u4ed6\u4f1a\u6253\u7535\u8bdd\u8bad\u65a5\u4f60\u8d77\u5e8a,\u76f4\u5230\u4f60\u7cbe\u795e\u5d29\u6e83.\r\n\r\n\u7b2c3\u540d: Floating Around \r\n\u4e0d\u5149\u6837\u5b50\u5947\u602a,\u95f9\u949f\u54cd\u7684\u65f6\u5019\u8fd8\u4f1a\u5728\u623f\u95f4\u91cc\u4e71\u98de,\u76f4\u5230\u4f60\u6293\u4f4f\u5b83!\r\n\r\n\u7b2c2\u540d: Kaboom\r\n\u8bf7\u76f8\u4fe1\u8fd9\u4e2a\u58f0\u97f3\u70b8\u5f39\u7684\u9707\u64bc\u6548\u679c,\u552f\u4e00\u7f3a\u70b9\u662f\u4f1a\u628a\u4f60\u90bb\u5c45\u5435\u9192.\r\n\r\n\u7b2c1\u540d: Hide and Seek \r\n\u7b2c\u4e00\u540d\u95ea\u4eae\u767b\u573a...\u4e24\u4e2a\u5927\u8f6e\u5b50? \u56e0\u4e3a\u4e00\u5230\u95f9\u94c3\u65f6\u95f4,\u5b83\u5c31\u8fc5\u901f\u5f00\u52a8\u81ea\u5df1,\u4e00\u8fb9\u53eb\u56a3\u4e00\u8fb9\u6eda\u5230\u5730\u4e0a\u627e\u89d2\u843d\u8eb2\u8d77\u6765!\u5982\u679c\u4f60\u4e0d\u60f3\u642c\u6c99\u53d1\u642c\u5e8a\u642c\u8863\u67dc\u7684\u8bdd,\u8bf7\u9a6c\u4e0a\u8d77\u5e8a\u8ffd\u8d76\u5b83!", "imagename": "2890.jpg", "infoid": 2890, "category": "technology_internet", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["clock", "\u5341\u5927", "\u641e\u602a"]}, {"url": "http://www.econsultant.com/i-want-firefox-extension/index.html