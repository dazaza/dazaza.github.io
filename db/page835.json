[{"url": "http://www.juyit.cn", "title": "\u5341\u5927\u7a7f\u8d8a\u5c0f\u8bf4", "tags": "\u56de\u5230\u660e\u671d\u5f53\u738b \u6df7\u5728\u4e09\u56fd\u5f53\u519b\u9600 \u65b0\u5b8b", "name": "yqwei", "posttime": "2008-08-22 23:27:14", "ip": "219.134.153.144", "mark": 3, "note": "\u7a7f\u8d8a\u5c0f\u8bf4\u662f\u6307\u5f53\u4e0b\u7f51\u7edc\u5c0f\u8bf4\u6700\u70ed\u95e8\u9898\u6750\u7684\u4e00\u79cd\u3002\u5176\u57fa\u672c\u8981\u70b9\u662f\uff0c\u4e3b\u4eba\u516c\u7531\u4e8e\u67d0\u79cd\u539f\u56e0\u4ece\u5176\u539f\u672c\u751f\u6d3b\u7684\u5e74\u4ee3\u79bb\u5f00\u3001\u7a7f\u8d8a\u65f6\u7a7a\uff0c\u5230\u4e86\u53e6\u4e00\u4e2a\u65f6\u4ee3\uff0c\u5728\u8fd9\u4e2a\u65f6\u7a7a\u5c55\u5f00\u4e86\u4e00\u7cfb\u5217\u7684\u6d3b\u52a8\u3002\u4e00\u822c\u6839\u636e\u7a7f\u8d8a\u5230\u7684\u671d\u4ee3\u53ef\u5206\u4e3a\u660e\u672b\u515a\uff0c\u4e09\u56fd\u515a\uff0c\u7687\u6c49\u515a\uff0c\u53cd\u6e05\u515a\uff0c\u7f57\u9a6c\u515a\uff0c\u897f\u5316\u515a\uff0c\u6c11\u4e3b\u515a\u3002\r\n\u7a7f\u8d8a\u7684\u65f6\u7a7a\u5206\u522b\uff1a1.\u4e2d\u56fd\u53e4\u4ee3 2.\u5916\u56fd\u53e4\u4ee33.\u672a\u6765\u65f6\u7a7a4.\u67b6\u7a7a\u65f6\u7a7a\u7b49\r\n\u4ece\u9ec4\u6613\u7684\u201c\u5bfb\u79e6\u8bb0\u201d\u5f00\u59cb\uff0c\u5404\u79cd\u7a7f\u8d8a\u5c11\u8bf4\u5c42\u51fa\u4e0d\u7a77\u3002\u5728\u8fd9\u4e48\u591a\u7a7f\u8d8a\u5c0f\u8bf4\u4e2d\u4f5c\u8005\u7684\u6587\u5316\u6c34\u5e73,\u6587\u7b14\u529f\u5e95\u5404\u6709\u4e0d\u540c. \u805a\u4e49\u5802\u73b0\u4e3a\u60a8\u63a8\u8350\u503c\u505a\u4e00\u770b\u5341\u5927\u7a7f\u8d8a\u5c0f\u8bf4\u3002\r\n\r\n\u7b2c\u5341\u4f4d\uff1a\u660e\u540f \r\n\u4e00\u4f4d\u73b0\u5728\u7684\u7f16\u8f91\u5728\u4e00\u6b21\u89c1\u4e49\u52c7\u4e3a\u4e2d\u56de\u5230\u4e86\u9756\u96be\u4e4b\u540e\u660e\u671d\uff0c\u53d8\u6210\u4e86\u4e00\u4e2a\u4f4d\u660e\u671d\u7684\u5c0f\u540f\u3002\r\n\r\n\u660e\u540f\u5934\u4e0a\u7684\u5929\u7a7a\uff0c\u770b\u4f3c\u5e73\u9759\u7684\u5e1d\u56fd\u5374\u9690\u85cf\u60ca\u5929\u5927\u9634\u8c0b\uff01\u4e00\u4e2a\u6027\u60c5\u7537\u4eba\uff0c\u5982\u4f55\u7528\u4eba\u6027\u9b45\u529b\u4fd8\u83b7\u4f0a\u4eba\u82b3\u5fc3\uff1f \u770b\u4e3b\u89d2\u662f\u600e\u4e48\u5728\u660e\u671d\u9ed1\u6697\u7684\u5929\u5730\u95f4\u751f\u5b58\u3002\u63a8\u8350\u7406\u7531\uff1a\u4ece\u4e00\u540d\u5c0f\u540f\u91cd\u73b0\u4e86\u660e\u671d\u7684\u9ed1\u6697\uff0c\u6587\u7b14\u529f\u5e95\u4e00\u822c\u3002\r\n\r\n\u660e\u53f2\u5728\u7ebf\u9605\u8bfb\uff1ahttp://www.juyit.cn/modules/article/articleinfo.php?id=220\r\n\r\n\u7b2c\u4e5d\u540d\uff1a\u6b66\u5510\u653b\u7565\r\n\u4f5c\u8005\uff1a\u5e9c\u5929 \u4e00\u540d\u65b0\u7684\u5c0f\u8bf4\u65b0\u624b\uff0c\u4e3b\u89d2\u83ab\u540d\u56de\u5230\u4e86\u5510\u671d\u4f46\u4ed6\u7684\u7406\u60f3\u662f\u4e0d\u60f3\u6539\u53d8\u4e16\u754c\uff0c\u4e0d\u60f3\u540d\u5782\u9752\u53f2\uff0c\u66f4\u4e0d\u60f3\u5f53\u52b3\u4ec0\u5b50\u7684\u7687\u5e1d\uff0c\u6211\u53ea\u60f3\u75db\u75db\u5feb\u5feb\u5f53\u4e00\u56de\u7ea8\u7ed4\u5b50\u5f1f\uff01\u4f46\u5929\u4e0d\u4ece\u4eba\u613f\u6ca1\u60f3\u5230\u6210\u4e86\u4e00\u4ee3\u5973\u7687\u7684\u513f\u5b50\uff0c\u6ca1\u56de\u5934\u8def\u4e86\uff0c\u90a3\u53ea\u597d\u6b66\u5510\u653b\u7565\uff01\u63a8\u8350\u7406\u7531\uff1a\u4e0e\u666e\u901a\u7684\u7a7f\u8d8a\u5c0f\u8bf4\u6bd4\uff0c\u66f4\u5927\u7684\u6ee1\u8db3\u4e86\u6211\u4eec\u7684\u7a7f\u8d8a\u6b32\u671b\u3002\r\n\r\n\u6b66\u5510\u653b\u7565\u5728\u7ebf\u9605\u8bfb\uff1ahttp://www.juyit.cn/modules/article/articleinfo.php?id=1707\r\n\r\n\u7b2c\u516b\u540d\uff1a\u9189\u56de\u4e03\u4e5d\u5f53\u519c\u6c11\r\n\u4e00\u4e2a\u5e74\u8fd1\u56db\u5341\u7684\u4e2d\u5e74\u4eba\uff0c\u9189\u68a6\u4e2d\u65e0\u610f\u7a7f\u8d8a\u56de\u5230\u4e00\u4e5d\u4e03\u4e5d\u5e74\uff0c\u8be5\u4f5c\u54c1\u6ca1\u6709\u5f02\u80fd\uff0c\u6ca1\u6709\u5947\u5e7b\uff0c\u6709\u5c11\u8bb8YY,\u8fd8\u6709\u806a\u660e\u624d\u667a\u548c\u5bf9\u8fd9\u7247\u70ed\u571f\u7684\u6df1\u60c5\uff0c\u4e00\u4e2a\u4f20\u5947\u5f0f\u7684\u73b0\u4ee3\u9648\u6c38\u8d35\u5373\u5c06\u8bde\u751f\u3002\u4f5c\u54c1\u6709\u519c\u6751\u3001\u57ce\u5e02\u3001\u571f\u5730\u3001\u4f01\u4e1a\u548c\u519c\u6c11\u4eec\u7684\u8f89\u714c......   \u63a8\u8350\u7406\u7531\uff1a\u4ece\u6765\u8fd8\u6ca1\u6709\u5199\u8fc7\u4e2d\u56fd70\u5e74\u4ee3\u90a3\u6bb5\u82e6\u96be\u7684\u65e5\u5b50\uff0c\u6587\u7b14\u975e\u5e38\u597d.\u4f5c\u8005\u5bf9\u8fd1\u4ee3\u5386\u53f2\u7cbe\u901a\u3002\u8ba9\u4eba\u4e0d\u7531\u81ea\u4e3b\u7684\u53bb\u4f53\u9a8c\u3002\r\n\r\n\u9189\u56de\u4e03\u4e5d\u5f53\u519c\u6c11\u5728\u7ebf\u9605\u8bfb\uff1ahttp://www.juyit.cn/modules/article/articleinfo.php?id=1575\r\n\r\n\u7b2c\u4e03\u540d\uff1a\u6211\u662f\u963f\u6597\uff0c\u6211\u4e0d\u7528\u4eba\u6276\r\n\u201c\u4e00\u4e2a\u4eba\u53ef\u4ee5\u50bb\uff0c\u53ef\u4ee5\u7b28\uff0c\u4f46\u4ed6\u4e0d\u53ef\u4ee5\u5931\u53bb\u81ea\u5df1\u7684\u76ee\u6807\u548c\u6267\u7740\u7684\u52aa\u529b\u3002\u201d\uff0d\uff0d\u963f\u6597\u4e09\u56fd\uff0c\u4e00\u4e2a\u7fa4\u661f\u6c47\u8403\u7684\u65f6\u4ee3\u3002\u4e09\u56fd\uff0c\u4e00\u4e2a\u5149\u534e\u593a\u76ee\u7684\u65f6\u4ee3\u3002\u4e09\u56fd\uff0c\u4e00\u4e2a\u4ee4\u65e0\u6570\u7537\u513f\u70ed\u8840\u5954\u6d8c\u7684\u65f6\u4ee3\u3002\u4e09\u56fd\uff0c\u4e00\u4e2a\u8ba9\u82b8\u82b8\u4f17\u751f\u5fc3\u9189\u795e\u8ff7\u7684\u65f6\u4ee3\u3002\u4e09\u4e07\u91cc\u5c71\u6cb3\uff0c\u4e94\u5343\u5e74\u534e\u590f\uff0c\u53c8\u6709\u54ea\u4e00\u6bb5\u5149\u9634\u80fd\u6709\u5b83\u8fd9\u6837\u4e30\u5bcc\u591a\u5f69\uff1f\u5386\u53f2\u7684\u957f\u6cb3\uff0c\u6d41\u5230\u8fd9\u91cc\uff0c\u5ffd\u2026\u2026\r\n\u63a8\u8350\u7406\u7531\uff1a\u628a\u4e00\u4e2a\u4e09\u56fd\u7684\u540d\u661f\u201c\u963f\u6597\u201d\u4ece\u6276\u4e0d\u8d77\u7684\u963f\u6597\u5230\u4e09\u56fd\u7edf\u4e00\u5c0f\u8bf4\u5199\u7684\u9ad8\u6f6e\u8d77\u6d6e\u3002\r\n\r\n\u6211\u662f\u963f\u6597\uff0c\u6211\u4e0d\u7528\u4eba\u6276 \u5728\u7ebf\u9605\u8bfb\uff1ahttp://www.juyit.cn/modules/article/articleinfo.php?id=1718\r\n\r\n\u7b2c\u516d\u540d\uff1a\u5927\u5b8b\u4e4b\u5929\u5b50\u95e8\u751f\r\n\u201c\u7334\u5b50\u4e0d\u548c\u9a74\u6bd4\u8111\u5b50\uff0c\u975e\u8981\u6bd4\u8c01\u7684\u5c4c\u957f\uff0c\u90a3\u4e0d\u662f\u626f\u86cb\u5417\uff1f\u201d\u2014\u2014\u6c5f\u9010\u6d41\r\n\r\n\u3000\u3000\u7b97\u672f\u5929\u624d\u6c5f\u9010\u6d41\u56de\u5230\u4e86\u5317\u5b8b\uff0c\u56e0\u7f18\u9645\u4f1a\u4e4b\u4e0b\u5377\u5165\u4e86\u540e\u515a\u3001\u5e1d\u515a\u4e4b\u4e89\uff0c\u4e14\u770b\u4ed6\u5982\u4f55\u5728\u8be1\u5f02\u9669\u6076\u7684\u671d\u5802\u4e0a\u7b97\u51fa\u4e00\u6761XX\u4e4b\u8def\u2026\u2026\r\n\u63a8\u8350\u7406\u7531\uff1a\u671d\u5ef7\u5185\u90e8\u6597\u4e89\uff0c\u52fe\u5fc3\u6597\u89d2\u3002\u60c5\u666f\u5165\u6728\u4e09\u5206\u3002\r\n\r\n\u5927\u5b8b\u4e4b\u5929\u5b50\u95e8\u751f\u5728\u7ebf\u9605\u8bfb\uff1ahttp://www.juyit.cn/modules/article/articleinfo.php?id=1442\r\n\r\n\u7b2c\u4e94\u540d\uff1a\u4e94\u80e1\u70fd\u706b\u5f55\r\n\u4e2d\u56fd\u7684\u5386\u53f2\uff0c\u8d70\u5230\u4e1c\u6c49\u7684\u672b\u5e74\uff0c\u8d70\u8fc7\u52a8\u8361\u7684\u4e09\u56fd\uff0c\u8d70\u8fc7\u77ed\u547d\u7684\u897f\u664b\uff0c\u5f00\u59cb\u662f\u6084\u6084\u7684\uff0c\u7136\u540e\u662f\u60ca\u4eba\u7684\uff0c\u5ffd\u7136\u6ed1\u5165\u8fd1\u4e4e\u6bc1\u706d\u7684\u6df1\u6e0a\u3002\r\n\r\n\u3000\u3000\u5f02\u65cf\u5165\u4fb5\uff0c\u664b\u5ba4\u5357\u8fc1\uff0c\u6c11\u65cf\u4ec7\u6740\u6d41\u51fa\u7684\u9c9c\u8840\u704c\u6ee1\u4e86\u5386\u53f2\u7684\u957f\u6cb3\u3002\r\n\r\n\u3000\u3000\u540e\u8d75\u5f00\u56fd\u7687\u5e1d\u77f3\u52d2\uff08\u7faf\u65cf\uff09\u516c\u7136\u660e\u5b9a\u80e1\u4eba\u52ab\u63a0\u6c49\u65cf\u58eb\u4eba\u514d\u7f5a\uff0c\u80e1\u4eba\u6709\u6240\u9700\uff0c\u53ef\u4ee5\u4efb\u610f\u7d22\u53d6\u4e00\u822c\u6c49\u4eba\u7684\u4e1c\u897f\u3002\u53ef\u4ee5\u60f3\u50cf\u4e00\u822c\u6c49\u4eba\u5f53\u65f6\u7684\u5904\u5883\u3002\r\n\r\n\u3000\u3000\u8700\u5730\u7684\u6210\u56fd\u4f7f\u8005\u51fa\u4f7f\u540e\u8d75\uff0c\u8bb0\u5f55\u4e86\u6cbf\u9014\u7684\u60e8\u8c61\uff1a\u4ece\u957f\u5b89\u5230\u6d1b\u9633\u518d\u5230\u90ba\u57ce\uff0c\u6811\u4e0a\u6302\u6ee1\u4e0a\u540a\u81ea\u6740\u7684\u6c49\u4eba\uff0c\u57ce\u5899\u4e0a\u6302\u6ee1\u6c49\u4eba\u4eba\u5934\uff0c\u5c38\u9aa8\u5219\u88ab\u505a\u6210\u5c38\u89c2\u6050\u5413\u4e16\u4eba\uff0c\u6570\u4e07\u53cd\u6297\u5c06\u58eb\u7684\u5c38\u4f53\u88ab\u5f03\u4e4b\u8352\u91ce\u5582\u517d\u2026\u2026\r\n\r\n\u3000\u3000\u8840\u8165\u5c60\u6740\u548c\u6b8b\u9177\u7684\u6c11\u65cf\u538b\u8feb\uff0c\u4f7f\u5317\u65b9\u6c49\u4eba\u9510\u51cf\u81f3\u516d\u4e03\u767e\u4e07\uff0c\u9020\u6210\u8d64\u5730\u5343\u91cc\u7684\u666f\u8c61\uff0c\u6c49\u6c11\u65cf\u7b2c\u4e00\u6b21\u6fd2\u4e34\u706d\u7edd\u7684\u8fb9\u7f18\u3002\r\n\r\n\u3000\u3000\u5386\u53f2\u4e0d\u5fcd\u770b\u4e0b\u6c49\u6c11\u65cf\u6c89\u6ca6\u4e0b\u53bb\uff0c\u5ffd\u7136\u6253\u4e86\u778c\u7761\uff0c\u4e8e\u662f\u2026\u2026\r\n\r\n\u63a8\u8350\u7406\u7531\uff1a\u4e09\u56fd\u7cbe\u54c1\uff0c\u6587\u7b14\u529f\u592b\u975e\u5e38\u597d\uff0c\u4ece\u540d\u5b57\u5c31\u77e5\u9053\u4f5c\u8005\u7231\u56fd\u5fc3\u86ee\u5f3a\u3002\u9b4f\u664b\u80e1\u81bb\u6ee1\u5929\u4e0b \uff0c\u5f53\u4e16\u6000\u53e4\u53f9\u8e49\u8dce \uff0c\u4e0d\u559c\u5ce8\u51a0\u5e7f\u535a\u5e26 \uff0c\u4e50\u6548\u6c49\u519b\u5317\u5e9c\u53f0   \u503c\u5f97\u5927\u5bb6\u4e00\u9605\r\n\r\n\u4e94\u80e1\u70fd\u706b\u5f55\u5728\u7ebf\u9605\u8bfb\uff1ahttp://www.juyit.cn/modules/article/articleinfo.php?id=1153\r\n\r\n\u7b2c\u56db\u540d\uff1a\u65b0\u5b8b\r\n\u5386\u53f2\u5e7b\u60f3\u5c0f\u8bf4\uff0c\u53d1\u751f\u5728\u5317\u5b8b\u7199\u5b81\u5e74\u95f4\uff08\u5b54\u53861620\u5e74\u3001\u8036\u53861069\u5e74\u4ee5\u540e\uff09\u7684\u6545\u4e8b\u3002\u4f5c\u8005\u56e0\u4e00\u6b21\u8003\u8bd5\u6709\u4e00\u9053\u9898\u4e0d\u4f1a\u505a\uff0c\u7136\u540e\u731b\u770b\u5386\u53f2\u4e66\u7a81\u53d1\u7075\u611f\u6240\u5199\u3002\u767e\u5ea6\u5c0f\u8bf4\u699c\u524d50\r\n\r\n\u63a8\u8350\u7406\u7531\uff1a\u300a\u65b0\u5b8b\u300b\u8005\uff0c\u963f\u8d8a\u6240\u8457\uff0c\u786e\u5b9e\u4e0d\u51e1\u3002 \r\n\u975e\u53ea\u4e00\u90e8\u73b0\u4ee3\u6124\u9752\u7684\u7a7f\u8d8a\u53f2\uff0c \r\n\u975e\u53ea\u4e00\u90e8\u4eba\u751f\u5730\u4e0d\u719f\u7684\u594b\u6597\u53f2\uff0c \r\n\u975e\u53ea\u4e00\u90e8\u7ee7\u5f80\u5f00\u6765\u7684\u6539\u9769\u53f2\uff0c \r\n\u975e\u53ea\u4e00\u90e8\u582a\u79f0\u6559\u5b66\u8bfe\u672c\u7684\u5b8b\u53f2\uff0c \r\n\u7b80\u76f4\u5c31\u662f\u4e00\u526f\u300a\u9752\u660e\u4e0a\u6cb3\u56fe\u300b\uff0c \r\n\u52fe\u52d2\u51fa11\u4e16\u7eaa\u4e2d\u56fd\u4eba\u6c11\u751f\u6d3b\u7684\u65b9\u65b9\u9762\u9762\uff0c \r\n\u5f62\u5f62\u8272\u8272\uff0c\u753b\u91cc\u68a6\u4e2d\uff0c\u6829\u6829\u5982\u751f\u3002 \r\n\r\n\u867d\u7136\u66f4\u65b0\u5f88\u6162\uff0c\u4f9d\u7136\u671f\u5f85\u753b\u5377\u7684\u7f13\u7f13\u5c55\u5f00......\r\n\r\n\u65b0\u5b8b\u5728\u7ebf\u9605\u8bfb\uff1ahttp://www.juyit.cn/modules/article/articleinfo.php?id=888\r\n\r\n\u7b2c\u4e09\u540d\uff1a\u6df7\u5728\u4e09\u56fd\u5f53\u519b\u9600\r\n\u6b8b\u9633\u5982\u8840\uff0c\u6714\u98ce\u4f3c\u5200\uff0c\u5927\u5730\u4e00\u7247\u82cd\u51c9\u3002\r\n\r\n\u3000\u3000\u8a3e\u6c34\u6cb3\u7554\uff0c\u9a6c\u8dc3\u8fce\u98ce\u50b2\u7acb\uff0c\u4e00\u53cc\u9ed1\u7738\u5bd2\u6c89\u4f3c\u6c34\uff0c\u624b\u4e2d\u94a2\u5200\u9ad8\u4e3e\u5411\u524d\u3001\u76f4\u523a\u957f\u7a7a\u2026\u2026\r\n\r\n\u3000\u3000\u9a6c\u8dc3\u8eab\u540e\uff0c\u4e24\u5343\u7cbe\u9a91\u7f13\u7f13\u5c55\u5f00\uff0c\u94c1\u7532\u8be4\u8be4\uff0c\u6c47\u805a\u6210\u4e00\u9053\u94a2\u94c1\u6d2a\u6d41\uff0c\u77db\u5203\u68ee\u68ee\uff0c\u95ea\u70c1\u7740\u6b7b\u4ea1\u7684\u51b7\u7130\u3002\r\n...............\r\n\r\n\u63a8\u8350\u7406\u7531\uff1a\u6211\u89c9\u5f97\u5251\u5ba2\u7684\u4e09\u56fd\u6709\u4e00\u79cd\u8840\u6027\uff0c\u4eba\u7269\u7684\u8840\u6027\u91ce\u5fc3\uff0c\u5f88\u591a\u4eba\u7269\u90fd\u6709\u4e00\u9897\u70d8\u70d8\u71c3\u70e7\u7684\u70c8\u706b\u4e4b\u5fc3\uff0c\u4e3a\u4e86\u56fe\u8c0b\u5929\u4e0b\u4e4b\u4e1a\u727a\u7272\u4e86\u4e00\u5207\u3002\r\n\u8fd8\u63cf\u5199\u4e86\u5f88\u591a\u5c11\u6570\u6c11\u65cf\u6bd4\u5982\u9c9c\u5351\u3001\u5308\u5974\u3001\u5927\u6708\u6c0f\u3001\u7f8c\u4eba\u3001\u9ad8\u4e3d\u3001\u897f\u57df\u5404\u56fd\u90fd\u6d89\u53ca\u5230\u4e86\u3002\r\n\u4e3b\u4eba\u516c\u9a6c\u8dc3\u7531\u4e00\u4e2a\u9ec4\u5dfe\u519b\u58eb\u5175\u4e00\u8dc3\u6210\u4e3a\u4ee4\u5927\u5c06\u6731\u643a\u4ee5\u53ca\u66f9\u64cd\u7b49\u4eba\u4fa7\u76ee\u7684\u9996\u9886\u7ea7\u4eba\u7269\uff0c\u53c8\u4ece\u5e26\u7740\u516b\u767e\u6d41\u5bc7\u5e2d\u5377\u4e2d\u539f\u5230\u6210\u5c31\u4e00\u652f\u6b63\u89c4\u519b\uff0c\u867d\u7136\u8bf4\u7ecf\u5386\u4e86\u5f88\u591a\u8270\u8f9b\u56f0\u82e6\uff0c\u4f46\u51e0\u4e4e\u6ca1\u6709\u8d25\u8ff9\uff0c\u90fd\u633a\u8fc7\u53bb\u4e86\u3002\u5f88\u591a\u65f6\u5019\u4ee4\u4eba\u76f8\u5f53\u4f69\u670d\uff0c\u53c8\u5927\u6c14\u56de\u80a0\u3002\r\n\u73b0\u5728\u5df2\u7ecf\u5199\u5230\u597d\u51e0\u767e\u7ae0\u4e86\uff0c\u4e3b\u4eba\u516c\u5012\u4e5f\u5f53\u6210\u4e86\u519b\u9600\uff0c\u52bf\u529b\u8fd8\u6709\u70b9\u96c4\u539a\uff0c\u4ed6\u65e5\u4e89\u9738\u5929\u4e0b\uff0c\u6050\u6015\u4e5f\u662f\u76f8\u5f53\u6050\u6016\u7684\u5427\uff0c\u671f\u5f85\u671f\u5f85\u518d\u671f\u5f85\uff0c\u613f\u5251\u5ba2\u5144\u5feb\u5feb\u66f4\u65b0\u3002\r\n\r\n\u6df7\u5728\u4e09\u56fd\u5f53\u519b\u9600\u5728\u7ebf\u9605\u8bfb\uff1ahttp://www.juyit.cn/modules/article/articleinfo.php?id=1412\r\n\r\n\u7b2c\u4e8c\u540d\uff1a\u5546\u4e1a\u4e09\u56fd\r\n\u4e00\u4e2a\u66fe\u7ecf\u5f53\u8fc7\u6559\u5e08\u7684\u5546\u4eba\u548c\u4ed6\u76843\u4e2a\u6559\u5e08\u670b\u53cb\uff0c\u5728\u4e00\u6b21\u53bb\u795e\u519c\u67b6\u63a2\u9669\u7684\u8fc7\u7a0b\u4e2d\uff0c\u7a7f\u8d8a\u65f6\u7a7a\u6765\u5230\u4e09\u56fd\u65f6\u4ee3\uff08\u8001\u5957\u4e86\uff0c\u6ca1\u529e\u6cd5\uff0c\u5404\u4f4d\u4e0d\u6ee1\u610f\uff0c\u5c31\u7528\u7968\u7838\u6211\uff0c-_-\uff09\u3002\u4ed6\u4eec\u4e0d\u6ee1\u610f\u5f53\u65f6\u7684\u4e2d\u56fd\u73b0\u72b6\uff0c\u5bf9\u4e8e\u5373\u5c06\u6765\u4e34\u7684\u4e94\u80e1\u4e71\u534e\u65f6\u4ee3\u6709\u7740\u6df1\u6df1\u7684\u5fe7\u8651\u3002\u4e3a\u4e86\u907f\u514d\u6c49\u6c11\u65cf\u957f\u8fbe300\u5e74\u7684\u82e6\u96be\uff0c\u4ed6\u4eec\u5728\u8fd9\u4e71\u4e16\u5d1b\u8d77\uff0c\u4ee5\u5546\u7acb\u56fd\u3002\u5229\u7528\u53d1\u8fbe\u7684\u7ecf\u6d4e\u548c\u5148\u8fdb\u7684\u4ea7\u54c1\uff0c\u521b\u5efa\u66f4\u9002\u5b9c\u53d1\u5c55\u7ecf\u6d4e\u7684\u793e\u4f1a\u5236\u5ea6\uff0c\u5efa\u7acb\u66f4\u5f3a\u5927\u7684\u519b\u961f\uff0c\u63a8\u884c\u4ed6\u4eec\u7684\u7edf\u4e00\u5927\u4e1a\u548c\u6b96\u6c11\u8ba1\u5212\u3002\u4ed6\u4eec\u7684\u773c\u5149\u5df2\u7ecf\u8d85\u8d8a\u4e86\u4e2d\u539f\u7684\u4e89\u6597\uff0c\u671b\u5411\u9065\u8fdc\u7684\u7f57\u9a6c\uff0c\u57c3\u53ca\u3002\u81f3\u4e8e\u65e5\u672c\uff0c\u53ea\u4e0d\u8fc7\u662f\u4ed6\u4eec\u6b96\u6c11\u8ba1\u5212\u7684\u4e00\u5c0f\u6b65\u3002\u4e66\u4e2d\u63a2\u7d22\u4e86\u4e00\u4e0b\u793e\u4f1a\u7ed3\u6784\u3001\u6cd5\u5f8b\u4f53\u7cfb\u3001\u5b98\u5458\u5236\u5ea6\u3001\u5b97\u6559\u89c2\u5ff5\uff0c\u7eaf\u5c5eYY\uff0c\u671b\u5404\u4f4d\u8bfb\u8005\u4e0d\u8981\u7c7b\u6bd4\uff0c\u4e0d\u8981\u5f53\u771f\u3002\u5149\u8363\u5c5e\u4e8e\u5927\u6c49\u6c11\u65cf\uff0c\u677f\u7816\u5c5e\u4e8e\u6211\u3002\u53ea\u4f9b\u8bfb\u8005\u4e00\u7b11\u3002\u5546\u4e1a\u8c61\u5f81\u7ade\u4e89\uff0c\u594b\u6597\uff0c\u5192\u9669\uff0c\u8ffd\u6c42\uff0c\u521b\u9020\uff0c\u6218\u7565\uff0c\u5927\u5c40\uff0c\u53d1\u5c55\uff0c\u624b\u6bb5\uff0c\u89c4\u5219\uff0c\u6807\u51c6\uff0c\u5b9e\u529b\uff0c\u8d22\u5bcc\uff0c\u5229\u76ca\uff0c\u4ef7\u503c\uff0c\u6210\u8d25\uff0c\u7ba1\u7406\uff0c\u4eba\u624d\uff0c\u4ea4\u6613\uff0c\u8d23\u4efb\uff0c\u534f\u4f5c\uff0c\u6c11\u4e3b\uff0c\u81ea\u7531\uff0c\u6743\u5229\uff0c\u89c2\u5ff5\uff0c\u521b\u65b0\uff0c\u6289\u62e9\uff0c\u6548\u7387\uff0c\u77e5\u8bc6\uff0c\u6280\u672f\uff0c\u4fe1\u606f\uff0c\u8d44\u6e90\uff0c\u4ea7\u54c1\uff0c\u6d41\u901a\u2026\u2026..\r\n\r\n\u63a8\u8350\u7406\u7531\uff1a\u4ece\u4e2a\u4eba\u89d2\u5ea6\uff0c\u300a\u5546\u4e1a\u4e09\u56fd\u300b\u662f\u4e00\u90e8\u975e\u5e38\u51fa\u8272\u7684\u56de\u5230\u8fc7\u53bb\u7c7b\u7684\u5c0f\u8bf4\uff0c\u4e0d\u4f46\u5728\u8fd9\u4e2a\u5df2\u7ecf\u6cdb\u6ee5\u7684\u9898\u6750\u4e2d\u5199\u51fa\u4e86\u65b0\u610f\uff0c\u800c\u4e14\u5bf9\u56fd\u5bb6\u3001\u6c11\u4e3b\u7684\u79cd\u79cd\u601d\u8003\u548c\u53d8\u9769\u7684\u6df1\u5ea6\uff0c\u76ee\u524d\u53ea\u6709\u300a\u65b0\u5b8b\u300b\u53ef\u6bd4\u3002\u800c\u6218\u4e89\u63cf\u5199\u7684\u5927\u6c14\u78c5\u7934\uff0c\u5404\u79cd\u4eba\u7269\u6027\u683c\u7684\u63cf\u5199\u5bf9\u8bdd\uff0c\u65e0\u4e00\u4e0d\u900f\u9732\u51fa\u4f5c\u8005\u7684\u529f\u5e95\uff0c\u770b\u5f97\u51fa\u8d64\u864e\u5144\u5bf9\u4e09\u56fd\u5386\u53f2\u662f\u4e0b\u4e86\u5f88\u6df1\u7684\u529f\u592b\u7684\u3002\u800c\u6700\u8ba9\u6211\u60ca\u8bb6\u7684\u662f\u662f\u5173\u4e8e\u65b0\u5b97\u6559\u521b\u7acb\u7684\u63cf\u5199\uff0c\u4e0e\u6211\u5fc3\u6709\u621a\u621a\uff0d\uff0d\u4e2d\u56fd\u4eba\u7f3a\u5c11\u4fe1\u4ef0\u4e00\u76f4\u662f\u4e00\u4e2a\u5f0a\u75c5\u3002\r\n\r\n\u5546\u4e1a\u4e09\u56fd\u5728\u7ebf\u9605\u8bfb\uff1ahttp://www.juyit.cn/modules/article/articleinfo.php?id=729\r\n\r\n\u7b2c\u4e00\u540d\uff1a\u56de\u5230\u660e\u671d\u5f53\u738b\u7237\r\n\r\n\r\n\r\n\u4e00\u4e2a\u901f\u6210\u7684\u4e5d\u4e16\u5584\u4eba\uff0c\u88ab\u9634\u53f8\u5224\u5b98\u9001\u5230\u4e86\u5927\u660e\u6b63\u5fb7\u5e74\u95f4\u3002\u3000\u3000\u81ea\u8ba4\u6ca1\u6709\u4e00\u6280\u4e4b\u957f\u3001\u53c8\u5bf9\u5386\u53f2\u4e00\u77e5\u534a\u89e3\u7684\u53f2\u4e0a\u6700\u65e0\u80fd\u7684\u7a7f\u8d8a\u8005\u90d1\u5927\u5584\u4eba\uff0c\u5e78\u597d\u9047\u4e0a\u4e86\u4e00\u4e2a\u6700\u4e0d\u8c61\u7687\u5e1d\u7684\u7687\u5e1d\uff0c\u4e00\u4e2a\u4e0d\u60f3\u5f53\u7687\u5e1d\u5374\u4e0d\u5f97\u4e0d\u5f53\u7687\u5e1d\u7684\u6731\u539a\u7167\u3002\u3000\u3000\u56fd\u5bb6\u548c\u4e2a\u4eba\u7684\u547d\u8fd0\uff0c\u5c31\u8c61\u5386\u53f2\u6d2a\u6d41\u4e2d\u7684\u4e00\u6761\u5c0f\u8239\u513f\uff0c\u4e14\u770b\u4ed6\u5982\u4f55\u628a\u8fd9\u8258\u8239\u7684\u8235\u638c\u63e1\u5728\u81ea\u5df2\u624b\u4e2d\u3002\r\n\r\n\u63a8\u8350\u7406\u7531\uff1a\u660e\u671d\u201c\u9e7f\u9f0e\u8bb0\u201d==\u8bc4\u6708\u5173\u5927\u4f5c\u201c\u56de\u5230\u6