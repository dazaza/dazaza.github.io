formation.gif\" align=absMiddle><FONT color=#1e5c99 size=2>\u5173\u952e\u8bcd\uff1a</FONT></SPAN> <SPAN><A class=red href=\"http://www.cnetnews.com.cn/list-0-0-187383-0-1.htm\" target=_blank><FONT color=#990000 size=2>\u5218\u7fbd\u7426</FONT></A> <A class=red href=\"http://www.cnetnews.com.cn/list-0-0-187498-0-1.htm\" target=_blank><FONT color=#990000 size=2>\u8fdd\u7ea6</FONT></A> <A class=red href=\"http://www.cnetnews.com.cn/list-0-0-45478-0-1.htm\" target=_blank><FONT color=#990000 size=2>\u7f8e\u5973</FONT></A> <A class=red href=\"http://www.cnetnews.com.cn/list-0-0-187499-0-1.htm\" target=_blank><FONT color=#990000 size=2>\u701b\u51ef</FONT></A> <A class=red href=\"http://www.cnetnews.com.cn/list-0-0-42356-0-1.htm\" target=_blank><FONT color=#990000 size=2>\u6cd5\u9662</FONT></A> </SPAN></STRONG><BR>\r\n<DIV></DIV>\r\n<P class=text01>\r\n<P><IMG alt=\u88ab\u79f0\u4e3a\u201c\u7f51\u7edc\u7b2c\u4e00\u7f8e\u5973\u201d\u7684\u5218\u7fbd\u7426 src=\"http://msn.ynet.com/img.db?41706039+s(400)\" border=0></P>\r\n<P>\u3000\u3000\u5317\u4eac\u6668\u62a57\u670821\u65e5\u62a5\u9053 \u56e0\u672a\u7ecf\u7b7e\u7ea6\u516c\u53f8\u5141\u8bb8\u800c\u79c1\u62cd\u5e7f\u544a\uff0c\u88ab\u79f0\u4e3a\u201c\u7f51\u7edc\u7b2c\u4e00\u7f8e\u5973\u201d\u7684\u5218\u7fbd\u7426\u88ab\u5176\u7b7e\u7ea6\u516c\u53f8\u701b\u51ef\u6587\u5316\u4f20\u5a92\uff08\u5317\u4eac\uff09\u6709\u9650\u516c\u53f8\u544a\u4e0a\u6cd5\u5ead\uff0c\u8fd1\u65e5\uff0c\u5927\u5174\u533a\u6cd5\u9662\u4f5c\u51fa\u4e00\u5ba1\u5224\u51b3\uff0c\u5218\u7fbd\u7426\u88ab\u5224\u8d54\u507f\u7b7e\u7ea6\u516c\u53f8400\u4e07\u5143\u3002\u636e\u6089\uff0c\u8be5\u6848\u4e5f\u662f\u672c\u5e02\u6cd5\u9662\u5ba1\u7406\u7684\u827a\u4eba\u8fdd\u7ea6\u6848\u4e2d\u8d54\u507f\u91d1\u989d\u6700\u9ad8\u7684\u4e00\u8d77\u3002</P>\r\n<P>\u3000\u3000\u636e\u701b\u51ef\u6587\u5316\u4f20\u5a92\uff08\u5317\u4eac\uff09\u6709\u9650\u516c\u53f8\u8bc9\u79f0\uff0c2006\u5e747\u670813\u65e5\uff0c\u516c\u53f8\u4e0e\u5218\u7fbd\u7426\u7b7e\u8ba2\u4e86\u4e00\u4efd\u300a\u4e13\u5c5e\u7ecf\u7eaa\u5408\u7ea6\u4e66\u300b\uff0c\u7ea6\u5b9a\u5218\u7fbd\u7426\u59d4\u6258\u516c\u53f8\u62c5\u4efb\u5176\u5168\u4e16\u754c\u72ec\u5bb6\u4e13\u5c5e\u7ecf\u7eaa\u4eba\u3002\u5218\u7fbd\u7426\u4fdd\u8bc1\u4e0d\u81ea\u884c\u63a5\u53d7\u4efb\u4f55\u5f62\u5f0f\u7684\u6f14\u51fa\uff0c\u4e0d\u4e0e\u4efb\u4f55\u7b2c\u4e09\u4eba\u7b7e\u8ba2\u4e0e\u672c\u7ea6\u6027\u8d28\u76f8\u540c\u6216\u7c7b\u4f3c\u7684\u5408\u7ea6\u3002\u5982\u679c\u8fdd\u7ea6\uff0c\u5218\u7fbd\u7426\u9700\u8d54\u507f\u701b\u51ef\u516c\u53f8\uff15\uff10\uff10\u4e07\u5143\u3002</P>\r\n<P>\u3000\u3000\u701b\u51ef\u516c\u53f8\u65b9\u9762\u8868\u793a\uff0c\u516c\u53f8\u4e3a\u5218\u7fbd\u7426\u6295\u5165\u4e86\u76f8\u5e94\u7684\u4eba\u529b\u3001\u8d22\u529b\u548c\u7269\u529b\uff0c\u5bf9\u5176\u8fdb\u884c\u5f62\u8c61\u5ba3\u4f20\u3001\u8d2d\u4e70\u6b4c\u66f2\u3001\u5f55\u97f3\u3001\u5236\u4f5c\u3001\u53d1\u5e03\u53ca\u5ba3\u4f20\u63a8\u5e7f\u3002\u4f46\u5218\u7fbd\u7426\u5374\u7792\u7740\u516c\u53f8\u4e3a\u4e00\u5bb6\u6742\u5fd7\u505a\u4e13\u5c5e\u6a21\u7279\uff0c\u5e76\u62cd\u6444\u5e7f\u544a\uff0c\u800c\u4e14\u4e0d\u542c\u516c\u53f8\u529d\u963b\u3002\u56e0\u6b64\uff0c\u516c\u53f8\u5c06\u5176\u8bc9\u81f3\u6cd5\u9662\uff0c\u8981\u6c42\u5218\u7fbd\u7426\u8d54\u507f\u516c\u53f8\uff14\uff10\uff10\u4e07\u5143\u3002</P>\r\n<P>\u3000\u3000\u636e\u6089\uff0c\u8be5\u6848\u5728\u5927\u5174\u533a\u6cd5\u9662\u7acb\u6848\u540e\uff0c\u5218\u7fbd\u7426\u5728\u6ca1\u6709\u6b63\u5f53\u7406\u7531\u7684\u60c5\u51b5\u4e0b\u62d2\u4e0d\u51fa\u5ead\u5e94\u8bc9\uff0c\u56e0\u6b64\uff0c\u6cd5\u9662\u89c6\u5176\u653e\u5f03\u4e86\u7b54\u8fa9\u4ee5\u53ca\u8d28\u8bc1\u6743\u5229\u3002\u6700\u7ec8\uff0c\u5927\u5174\u533a\u6cd5\u9662\u8ba4\u5b9a\u701b\u51ef\u516c\u53f8\u63d0\u4f9b\u7684\u5408\u540c\u4e3a\u6709\u6548\u5408\u540c\uff0c\u5bf9\u53cc\u65b9\u5177\u6709\u7ea6\u675f\u529b\uff0c\u5e76\u8ba4\u5b9a\u5218\u7fbd\u7426\u8fdd\u7ea6\uff0c\u4e00\u5ba1\u5224\u51b3\u5218\u7fbd\u7426\u8981\u5728\u5224\u51b3\u751f\u6548\u540e\uff11\uff10\u65e5\u5185\u7ed9\u4ed8\u701b\u51ef\u516c\u53f8\uff14\uff10\uff10\u4e07\u5143\u3002</P>\r\n<P>\u3000\u3000\u4e2a\u4eba\u8d44\u6599</P>\r\n<P>\u3000\u3000\u5218\u7fbd\u7426 \u66fe\u83b7\u201c2006\u56fd\u9645\u5c0f\u59d0\u4e2d\u56fd\u533a\u603b\u51b3\u8d5b\u6700\u4f73\u4e0a\u955c\u5956\u201d\u3001\u201c2006\u4e9a\u59d0\u7f51\u7edc\u8d5b\u533a\u5341\u4f73\u201d\uff0c\u88ab\u79f0\u4e3a\u7f51\u7edc\u7b2c\u4e00\u7f8e\u5973\u3002 (\u672c\u6587\u6765\u6e90\uff1a\u5317\u4eac\u6668\u62a5 \u4f5c\u8005\uff1a\u59dc\u6676\u6676)</P><!--\u5206\u9875-->\r\n<P>\u3000\u3000\u5317\u4eac\u6668\u62a57\u670821\u65e5\u62a5\u9053 \u56e0\u672a\u7ecf\u7b7e\u7ea6\u516c\u53f8\u5141\u8bb8\u800c\u79c1\u62cd\u5e7f\u544a\uff0c\u88ab\u79f0\u4e3a\u201c\u7f51\u7edc\u7b2c\u4e00\u7f8e\u5973\u201d\u7684\u5218\u7fbd\u7426\u88ab\u5176\u7b7e\u7ea6\u516c\u53f8\u701b\u51ef\u6587\u5316\u4f20\u5a92\uff08\u5317\u4eac\uff09\u6709\u9650\u516c\u53f8\u544a\u4e0a\u6cd5\u5ead\uff0c\u8fd1\u65e5\uff0c\u5927\u5174\u533a\u6cd5\u9662\u4f5c\u51fa\u4e00\u5ba1\u5224\u51b3\uff0c\u5218\u7fbd\u7426\u88ab\u5224\u8d54\u507f\u7b7e\u7ea6\u516c\u53f8400\u4e07\u5143\u3002\u636e\u6089\uff0c\u8be5\u6848\u4e5f\u662f\u672c\u5e02\u6cd5\u9662\u5ba1\u7406\u7684\u827a\u4eba\u8fdd\u7ea6\u6848\u4e2d\u8d54\u507f\u91d1\u989d\u6700\u9ad8\u7684\u4e00\u8d77\u3002</P>\r\n<P>\u3000\u3000\u636e\u701b\u51ef\u6587\u5316\u4f20\u5a92\uff08\u5317\u4eac\uff09\u6709\u9650\u516c\u53f8\u8bc9\u79f0\uff0c2006\u5e747\u670813\u65e5\uff0c\u516c\u53f8\u4e0e\u5218\u7fbd\u7426\u7b7e\u8ba2\u4e86\u4e00\u4efd\u300a\u4e13\u5c5e\u7ecf\u7eaa\u5408\u7ea6\u4e66\u300b\uff0c\u7ea6\u5b9a\u5218\u7fbd\u7426\u59d4\u6258\u516c\u53f8\u62c5\u4efb\u5176\u5168\u4e16\u754c\u72ec\u5bb6\u4e13\u5c5e\u7ecf\u7eaa\u4eba\u3002\u5218\u7fbd\u7426\u4fdd\u8bc1\u4e0d\u81ea\u884c\u63a5\u53d7\u4efb\u4f55\u5f62\u5f0f\u7684\u6f14\u51fa\uff0c\u4e0d\u4e0e\u4efb\u4f55\u7b2c\u4e09\u4eba\u7b7e\u8ba2\u4e0e\u672c\u7ea6\u6027\u8d28\u76f8\u540c\u6216\u7c7b\u4f3c\u7684\u5408\u7ea6\u3002\u5982\u679c\u8fdd\u7ea6\uff0c\u5218\u7fbd\u7426\u9700\u8d54\u507f\u701b\u51ef\u516c\u53f8\uff15\uff10\uff10\u4e07\u5143\u3002</P>\r\n<P>\u3000\u3000\u701b\u51ef\u516c\u53f8\u65b9\u9762\u8868\u793a\uff0c\u516c\u53f8\u4e3a\u5218\u7fbd\u7426\u6295\u5165\u4e86\u76f8\u5e94\u7684\u4eba\u529b\u3001\u8d22\u529b\u548c\u7269\u529b\uff0c\u5bf9\u5176\u8fdb\u884c\u5f62\u8c61\u5ba3\u4f20\u3001\u8d2d\u4e70\u6b4c\u66f2\u3001\u5f55\u97f3\u3001\u5236\u4f5c\u3001\u53d1\u5e03\u53ca\u5ba3\u4f20\u63a8\u5e7f\u3002\u4f46\u5218\u7fbd\u7426\u5374\u7792\u7740\u516c\u53f8\u4e3a\u4e00\u5bb6\u6742\u5fd7\u505a\u4e13\u5c5e\u6a21\u7279\uff0c\u5e76\u62cd\u6444\u5e7f\u544a\uff0c\u800c\u4e14\u4e0d\u542c\u516c\u53f8\u529d\u963b\u3002\u56e0\u6b64\uff0c\u516c\u53f8\u5c06\u5176\u8bc9\u81f3\u6cd5\u9662\uff0c\u8981\u6c42\u5218\u7fbd\u7426\u8d54\u507f\u516c\u53f8\uff14\uff10\uff10\u4e07\u5143\u3002</P>\r\n<P>\u3000\u3000\u636e\u6089\uff0c\u8be5\u6848\u5728\u5927\u5174\u533a\u6cd5\u9662\u7acb\u6848\u540e\uff0c\u5218\u7fbd\u7426\u5728\u6ca1\u6709\u6b63\u5f53\u7406\u7531\u7684\u60c5\u51b5\u4e0b\u62d2\u4e0d\u51fa\u5ead\u5e94\u8bc9\uff0c\u56e0\u6b64\uff0c\u6cd5\u9662\u89c6\u5176\u653e\u5f03\u4e86\u7b54\u8fa9\u4ee5\u53ca\u8d28\u8bc1\u6743\u5229\u3002\u6700\u7ec8\uff0c\u5927\u5174\u533a\u6cd5\u9662\u8ba4\u5b9a\u701b\u51ef\u516c\u53f8\u63d0\u4f9b\u7684\u5408\u540c\u4e3a\u6709\u6548\u5408\u540c\uff0c\u5bf9\u53cc\u65b9\u5177\u6709\u7ea6\u675f\u529b\uff0c\u5e76\u8ba4\u5b9a\u5218\u7fbd\u7426\u8fdd\u7ea6\uff0c\u4e00\u5ba1\u5224\u51b3\u5218\u7fbd\u7426\u8981\u5728\u5224\u51b3\u751f\u6548\u540e\uff11\uff10\u65e5\u5185\u7ed9\u4ed8\u701b\u51ef\u516c\u53f8\uff14\uff10\uff10\u4e07\u5143\u3002</P>\r\n<P>\u3000\u3000\u4e2a\u4eba\u8d44\u6599</P>\r\n<P>\u3000\u3000\u5218\u7fbd\u7426 \u66fe\u83b7\u201c2006\u56fd\u9645\u5c0f\u59d0\u4e2d\u56fd\u533a\u603b\u51b3\u8d5b\u6700\u4f73\u4e0a\u955c\u5956\u201d\u3001\u201c2006\u4e9a\u59d0\u7f51\u7edc\u8d5b\u533a\u5341\u4f73\u201d\uff0c\u88ab\u79f0\u4e3a\u7f51\u7edc\u7b2c\u4e00\u7f8e\u5973\u3002 (\u672c\u6587\u6765\u6e90\uff1a\u5317\u4eac\u6668\u62a5 \u4f5c\u8005\uff1a\u59dc\u6676\u6676)</P>\r\n<P>\u6765\u81ea\uff1a<A href=\"http://www.cnetnews.com.cn/2008/0721/998189.shtml\">http://www.cnetnews.com.cn/2008/0721/998189.shtml</A></P>", "imagename": null, "infoid": 79209, "category": "technology_internet", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u5218\u7fbd\u7426", "\u8fdd\u7ea6", "\u7f8e\u5973", "\u701b\u51ef", "\u6cd5\u9662"]}, {"url": null, "title": "\u82f9\u679c\u5728\u534e\u9996\u5bb6\u96f6\u552e\u5e97\u5f00\u5f20 \u4e2d\u56fd\u5e02\u573a\u8fd8\u6709\u5f88\u957f\u8def\u8981\u8d70", "tags": "iPod iTunes iPhone MacBook Mac \u82f9\u679c Apple Store \u82f9\u679c\u96f6\u552e\u5e97 ", "name": "maker", "posttime": "2008-07-24 00:13:23", "ip": "219.153.131.101", "mark": 3, "note": "<FONT size=2><STRONG><FONT color=#990000><SPAN class=red>\u4f5c\u8005\uff1a CNET\u79d1\u6280\u8d44\u8baf\u7f51 </SPAN><BR></FONT></STRONG><SPAN class=blanktext>CNETNews.com.cn</SPAN></FONT> <BR><SPAN class=gray2><FONT color=#999999 size=2>2008-07-23 09:54:46</FONT></SPAN> <BR><STRONG><SPAN class=blue><IMG src=\"http://icon.zdnet.com.cn/cnetnews/pic/information.gif\" align=absMiddle><FONT color=#1e5c99 size=2>\u5173\u952e\u8bcd\uff1a</FONT></SPAN> <SPAN><A class=red href=\"http://www.cnetnews.com.cn/list-0-0-120494-0-1.htm\" target=_blank><FONT color=#990000 size=2>iPod</FONT></A> <A class=red href=\"http://www.cnetnews.com.cn/list-0-0-185691-0-1.htm\" target=_blank><FONT color=#990000 size=2>iTunes</FONT></A> <A class=red href=\"http://www.cnetnews.com.cn/list-0-0-178983-0-1.htm\" target=_blank><FONT color=#990000 size=2>iPhone</FONT></A> <A class=red href=\"http://www.cnetnews.com.cn/list-0-0-45584-0-1.htm\" target=_blank><FONT color=#990000 size=2>MacBook</FONT></A> <A class=red href=\"http://www.cnetnews.com.cn/list-0-0-127013-0-1.htm\" target=_blank><FONT color=#990000 size=2>Mac</FONT></A> <A class=red href=\"http://www.cnetnews.com.cn/list-0-0-163590-0-1.htm\" target=_blank><FONT color=#990000 size=2>\u82f9\u679c</FONT></A> <A class=red href=\"http://www.cnetnews.com.cn/list-0-0-1016-0-1.htm\" target=_blank><FONT color=#990000 size=2>Apple Store</FONT></A> <A class=red href=\"http://www.cnetnews.com.cn/list-0-0-142467-0-1.htm\" target=_blank><FONT color=#990000 size=2>\u82f9\u679c\u96f6\u552e\u5e97</FONT></A> </SPAN></STRONG><BR>\r\n<DIV></DIV>\r\n<P class=text01>\r\n<P><FONT color=#0000ff>CNET\u79d1\u6280\u8d44\u8baf\u7f517\u670823\u65e5\u56fd\u9645\u62a5\u9053 </FONT>20\u5c81\u7684\u5317\u4eac\u5927\u5b66\u751fYang Weiguo\u662f\u540d\u5fe0\u5b9e\u7684\u82f9\u679c\u8ff7\u3002\u7531\u4e8e\u82f9\u679c\u5e76\u672a\u5927\u89c4\u6a21\u8fdb\u5165\u4e2d\u56fd\uff0c\u8fd9\u7b97\u5f97\u4e0a\u662f\u4e00\u4e2a\u4e0d\u5c0f\u7684\u6210\u5c31\u30024\u6708\uff0cYang\u901a\u8fc7MacX.cn\u7f51\u7ad9\u8d2d\u4e70\u4e86\u65b0Macbook\uff0c\u8fd9\u662f\u4e00\u4e2a\u82f9\u679c\u673a\u8ff7\u7f51\u7edc\u5546\u5e97\uff0c\u4e0e\u82f9\u679c\u5e76\u65e0\u5173\u8054\u3002\u8fd9\u4e2a\u7f51\u7ad9\u5728\u4e2d\u56fd\u9999\u6e2f\u4e3aYang\u91c7\u8d2d\u4e86Macbook\uff0c\u7136\u540e\u8fd0\u56de\u5317\u4eac\uff0c\u8fd9\u79cd\u8d2d\u7269\u6a21\u5f0f\u4e3a\u4ed6\u8282\u7701\u4e86239\u7f8e\u5143\u3002</P>\r\n<P>Yang\u901a\u8fc7\u82f9\u679c\u7231\u597d\u8005\u793e\u533a\u5f97\u77e5\uff0c7\u670819\u65e5\u82f9\u679c\u5728\u4e2d\u56fd\u5f00\u8bbe\u4e86\u7b2c\u4e00\u5bb6Apple Store\u96f6\u552e\u5e97\uff0c\u4ed6\u51b3\u5b9a\u524d\u53bb\u6367\u573a\u3002Yang\u63d0\u524d\u4e8622\u5c0f\u65f6\u8d76\u5230\u82f9\u679c\u9996\u4e2a\u4e2d\u56fd\u96f6\u552e\u5e97\u7684\u6240\u5728\u5730\uff0c\u5317\u4eac\u4e09\u91cc\u5c6f\uff0c\u6709100\u591a\u540d\u82f9\u679c\u8ff7\u5728\u90a3\u91cc\u624e\u8425\u8fc7\u591c\uff0c\u7b49\u5f85\u7b2c\u4e8c\u5929\u7684\u5546\u5e97\u5f00\u5f20\u3002</P>\r\n<P>\u82f9\u679c\u5e0c\u671b\u62e5\u6709\u66f4\u591a\u50cfYang\u8fd9\u6837\u7684\u82f9\u679c\u8ff7\u3002\u82f9\u679c\u8ba1\u52122009\u5e74\u5728\u5317\u4eac\u5f00\u8bbe\u7b2c\u4e8c\u5bb6\u5546\u5e97\uff0c\u968f\u540e\u5728\u4e0a\u6d77\u5f00\u8bbe\u53e6\u5916\u4e00\u5bb6\u5e97\u3002\u82f9\u679c\u96f6\u552e\u90e8\u95e8\u526f\u603b\u88c1Ron Johnson\u8bf4\uff1a\u201c\u6211\u4eec\u5e0c\u671b\u5728\u4e2d\u56fd\u53d6\u5f97\u6210\u529f\uff0c\u4e2d\u56fd\u7684\u6574\u4f53\u7ecf\u6d4e\u6b63\u5728\u589e\u957f\u3002\u201d</P>\r\n<P>\u82f9\u679c\u5728\u4e2d\u56fd\u8fd8\u6709\u5f88\u957f\u7684\u8def\u8981\u8d70\u3002\u5c3d\u7ba1\u82f9\u679c\u662f\u7f8e\u56fd\u6570\u5b57\u97f3\u4e50\u64ad\u653e\u5668\u5e02\u573a\u7684\u9738\u4e3b\uff0c\u4f46\u5728\u4e2d\u56fd\uff0c\u82f9\u679c\u53bb\u5e74\u4ec5\u552e\u51fa70\u4e07\u53f0iPod\uff0c\u4ec5\u5360\u4e2d\u56fd\u5e02\u573a\u4efd\u989d\u76847.5%\u3002\uff08IDC\u6570\u636e\u663e\u793a\uff0c\u4e2d\u56fd\u5e02\u573aiPod\u6c34\u8d27\u6570\u91cf\u4e3a30\u4e07\u3002\uff09</P>\r\n<P>\u82f9\u679cMac\u5728\u4e2d\u56fd\u5e02\u573a\u5360\u6709\u7387\u66f4\u7cdf\u7cd5\uff0c\u53bb\u5e74\uff0cMac\u5728\u4e2d\u56fd\u9500\u91cf\u4e3a6.5\u4e07\uff0c\u5e02\u573a\u4efd\u989d\u4e0d\u52300.18%\u3002iPhone\u624b\u673a\u5e76\u672a\u5728\u4e2d\u56fd\u6b63\u5f0f\u9500\u552e\uff0c\u4e0d\u8fc7In-Stat\u4f30\u8ba1\uff0c\u622a\u6b62\u52302007\u5e74\u5e95\uff0c\u670940\u4e07\u90e8iPhone\u6d41\u5411\u4e86\u4e2d\u56fd\u5e02\u573a\uff0c\u4ec5\u5360\u8fd9\u4e2a\u5168\u7403\u6700\u5927\u624b\u673a\u5e02\u573a\u4efd\u989d\u76840.07%\u3002</P>\r\n<P>IDC\u5206\u6790\u5e08Bryan Yuan\u8868\u793a\uff0c\u5728\u82f9\u679c\u4e09\u5927\u6838\u5fc3\u4ea7\u54c1\u4e2d\uff08iPod\u64ad\u653e\u5668\uff0ciPhone\u624b\u673a\u548cMac\u7535\u8111\uff09\uff0ciPod\u662f\u82f9\u679c\u5728\u4e2d\u56fd\u7684\u4e3b\u8981\u6536\u5165\u6765\u6e90\uff0c\u4e3a\u4e94\u5206\u4e4b\u56db\u3002\u82f9\u679c\u5df2\u7ecf\u5728\u6084\u6084\u505aiPhone\u624b\u673a\u4e2d\u56fd\u9500\u552e\u7684\u51c6\u5907\u5de5\u4f5c\uff0ciPhone\u6700\u7ec8\u53ef\u80fd\u8d85\u8d8aiPod\u7684\u9500\u91cf\uff0c\u56e0\u4e3a\u4e2d\u56fd\u7684\u624b\u673a\u5e02\u573a\u975e\u5e38\u5e9e\u5927\u3002\u82f9\u679c\u548c\u4e2d\u56fd\u79fb\u52a8\u6700\u8fd1\u91cd\u65b0\u5f00\u59cb\u4e86iPhone\u7684\u5f15\u8fdb\u8c08\u5224\u3002</P>\r\n<P>\u963b\u788d\u82f9\u679c\u5728\u4e2d\u56fd\u53d1\u5c55\u7684\u4e00\u4e2a\u56e0\u7d20\u662f\u5176\u96f6\u552e\u6a21\u5f0f\u3002\u591a\u5e74\u4ee5\u6765\uff0c\u82f9\u679c\u901a\u8fc7\u6388\u6743\u7684IT\u5356\u573a\u6e20\u9053\u9500\u552eiPod\u548cMac\u3002\u53bb\u5e74\u5f00\u59cb\uff0c\u82f9\u679c\u5f00\u59cb\u4fee\u6539\u5728\u4e2d\u56fd\u7684\u9500\u552e\u6a21\u5f0f\uff0c\u82f9\u679c\u4e0e\u82cf\u5b81\u7535\u5668\u548c\u56fd\u7f8e\u7535\u5668\u7b7e\u7f72\u5408\u4f5c\u534f\u8bae\uff0c\u5728\u8fd9\u4e9b\u5bb6\u7535\u5356\u573a\u5f00\u59cb\u9500\u552e\u82f9\u679c\u4ea7\u54c1\u3002\u82f9\u679c\u5f00\u59cb\u8fd8\u8058\u8bf7\u4e86\u6765\u81ea\u6469\u6258\u7f57\u62c9\u524d\u9ad8\u7ba1\u8d1f\u8d23\u9500\u552e\u3002</P>\r\n<P>\u4e0d\u662f\u6240\u6709\u4eba\u90fd\u770b\u597d\u82f9\u679c\u6700\u65b0\u7684\u96f6\u552e\u6218\u7565\u3002IDC\u4e2d\u56fd\u7814\u7a76\u7ecf\u7406Antonio Wang\u8bf4\uff1a\u201c\u82f9\u679c\u5f00\u8bbe\u81ea\u5df1\u7684\u5546\u5e97\u5c06\u6709\u52a9\u4e8e\u63d0\u9ad8\u54c1\u724c\u77e5\u540d\u5ea6\uff0c\u4f46\u5f88\u96be\u8bf4\u8fd9\u4f1a\u63d0\u9ad8\u5176\u4ea7\u54c1\u9500\u91cf\u3002\u201d</P>\r\n<P>\u6700\u5927\u7684\u95ee\u9898\u5728\u4e8e\u4ef7\u683c\u3002\u4e00\u4e9b\u4e2d\u56fd\u7528\u6237\u559c\u6b22Mac\u5e72\u51c0\u7684\u8bbe\u8ba1\u4ee5\u53ca\u9632\u8303\u75c5\u6bd2\u7684\u80fd\u529b\uff0c\u4e0d\u8fc7\uff0c\u7531\u4e8e\u4ef7\u683c\u9ad8\u9ad8\u5728\u4e0a\uff0c\u771f\u6b63\u91c7\u8d2d\u82f9\u679c\u4ea7\u54c1\u7684\u7528\u6237\u6bd4\u8f83\u5c11\u3002</P>\r\n<P>\u82f9\u679c\u5728\u4e2d\u56fd\u9500\u552e\u7684\u4ea7\u54c1\u4e00\u822c\u6bd4\u5728\u7f8e\u56fd\u5e02\u573a\u4ef7\u683c\u8981\u8d35\u3002\u4ee52.4 GHz\u82f1\u7279\u5c14Core Duo MacBook\u4e3a\u4f8b\uff0c\u5728\u5317\u4eac\u82f9\u679c\u96f6\u552e\u5e97\uff0c\u4ef7\u683c\u4e3a2000\u7f8e\u5143\uff0c\u8fd9\u79cd\u4ef7\u683c\u51e0\u4e4e\u662f2007\u5e74\u4e2d\u56fd\u57ce\u5e02\u5de5\u4eba\u4e00\u5e74\u7684\u5e73\u5747\u6536\u5165\u6240\u5f97\u3002</P>\r\n<P>\u800c\u5728\u7f8e\u56fd\u82f9\u679c\u7f51\u4e0a\u5546\u5e97\uff0c\u8be5\u6b3e\u4ea7\u54c1\u53ea\u89811300\u7f8e\u5143\u3002\u82f9\u679c\u65b9\u9762\u8ba4\u4e3a\u8fd9\u5e76\u6ca1\u6709\u95ee\u9898\uff0cJohnson\u8bf4\uff0c\u82f9\u679c\u662f\u6839\u636e\u5e02\u573a\u7684\u60c5\u51b5\u5236\u5b9a\u7684\u4ef7\u683c\u3002\u4ed6\u8bf4\uff1a\u201c\u6211\u542c\u8bf4\uff0c\u5317\u4eac\u6709330\u4e07\u4eba\u62e5\u6709\u6c7d\u8f66\u3002\u5982\u679c\u4f60\u80fd\u591f\u8d1f\u62c5\u5f97\u8d77\u4e00\u8f86\u6c7d\u8f66\uff0c\u6211\u60f3\u4f60\u80fd\u591f\u8d1f\u62c5\u5f97\u8d77\u4e00\u90e8iPod\u6216Mac\u3002\u201d</P>\r\n<P>\u5728\u5f88\u591a\u65b9\u9762\uff0c\u4e2d\u56fd\u4e0d\u540c\u4e8e\u82f9\u679c\u8fdb\u8fc7\u7684\u5176\u5b83\u5916\u56fd\u5e02\u573a\u3002\u4e2d\u56fd\u662f\u82f9\u679c\u552f\u4e00\u4e00\u4e2a\u5f00\u8bbe\u4e86\u96f6\u552e\u5546\u5e97\u7684\u53d1\u5c55\u4e2d\u56fd\u5bb6\uff1b\u82f9\u679c\u5728\u7f8e\u56fd\u4ee5\u5916\uff0c\u4ec5\u5728\u6fb3\u6d32\u3001\u82f1\u56fd\u3001\u52a0\u62ff\u5927\u3001\u65e5\u672c\u5f00\u8bbe\u6709\u82f9\u679c\u96f6\u552e\u5e97\u3002</P>\r\n<P>\u4e2d\u56fd\u8fd8\u662f\u82f9\u679c\u9996\u4e2a\u5f00\u8bbe\u4e86\u5b9e\u4f53\u5546\u5e97\u3001\u4f46\u6ca1\u6709\u63a8\u51fa\u4e2d\u6587iTunes\u97f3\u4e50\u5546\u5e97\u7248\u672c\u7684\u56fd\u5bb6\u3002\u82f9\u679cJohnson\u62d2\u7edd\u900f\u9732\u4e2a\u4e2d\u539f\u56e0\u3002\u5206\u6790\u5e08\u8868\u793a\uff0c\u82f9\u679c\u6700\u5927\u7684\u62c5\u5fc3\u662f\u76d7\u7248\u95ee\u9898\u3002</P>\r\n<P>\u56fd\u9645\u5531\u7247\u4e1a\u534f\u4f1a\u4f30\u8ba1\uff0c\u4e2d\u56fd99%\u6d41\u901a\u7684\u97f3\u4e50\u6587\u4ef6\u4e3a\u76d7\u7248\u3002\u5317\u4eacR2G\u5531\u7247\u53d1\u884c\u516c\u53f8\u526f\u603b\u88c1Matthew Daniel\u8bf4\uff1a\u201c\u82f9\u679c\u6216\u8bb8\u5e94\u8be5\u66f4\u591a\u7684\u53c2\u4e0e\u5230\u8fd9\u4e00\u95ee\u9898\u7684\u89e3\u51b3\u5f53\u4e2d\u6765\uff0c\u901a\u8fc7iTunes\u7b49\u65b9\u5f0f\uff0c\u6bd5\u7adf\uff0c\u4e2d\u56fd\u8fd8\u6709\u76f8\u5f53\u591a\u7684\u4eba\u5728\u4f7f\u7528iPod\u3002\u201d</P>\r\n<P>\u5176\u4ed6\u5382\u5546\u5df2\u7ecf\u6709\u6240\u52a8\u4f5c\u30022005\u5e74\uff0c\u7231\u56fd\u8005\u6210\u4e3a\u4e2d\u56fd\u9996\u4e2a\u5f00\u8bbe\u7f51\u7edc\u97f3\u4e50\u5546\u5e97\u7684\u4f01\u4e1a\u3002\u7231\u56fd\u8005\u521b\u59cb\u4eba\u517c\u603b\u88c1\u51af\u519b\u627f\u8ba4\uff0c\u7231\u56fd\u8005\u7f51\u4e0a\u97f3\u4e50\u5546\u5e97\u4ecd\u5904\u4e8e\u4e8f\u635f\u5f53\u4e2d\uff0c\u4f46\u4ed6\u76f8\u4fe1\uff0c\u968f\u7740\u4e2d\u56fd\u7ee7\u7eed\u6253\u51fb\u76d7\u7248\uff0c\u6b63\u7248\u97f3\u4e50\u4e0b\u8f7d\u5c06\u6709\u7ffb\u8eab\u7684\u4e00\u5929\u3002</P>\r\n<P>\u4ed6\u8bf4\uff1a\u201c\u6211\u4eec\u662f\u4e00\u5bb6\u521d\u521b\u516c\u53f8\uff0c\u4f46\u6211\u4eec\u4e5f\u6295\u8d44\u4e86\u4e00\u5bb6\u7f51\u7edc\u97f3\u4e50\u5546\u5e97\uff0c\u82f9\u679c\u5e94\u8be5\u53ef\u4ee5\u8d1f\u62c5\u5f97\u8d77\u76f8\u5173\u7684\u8d39\u7528\u3002\u63a8\u51fa\u4e2d\u6587\u7248\u7684iTunes\u5bf9\u82f9\u679c\u6765\u8bf4\u4e0d\u662f\u4e00\u7b14\u5927\u7684\u6295\u8d44\u3002\u201d</P>\r\n<P>\r\n<P></P>\r\n<P>\u6765\u81ea\uff1a<A href=\"http://www.cnetnews.com.cn/2008/0723/1005416.shtml\">http://www.cnetnews.com.cn/2008/0723/1005416.shtml</A></P>", "imagename": null, "infoid": 79208, "category": "technology_apple", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["ipod", "itunes", "iphone", "macbook", "mac", "\u82f9\u679c", "apple", "store", "\u82f9\u679c\u96f6\u552e\u5e97"]}, {"url": "http://www.codyy.com/", "title": "\u9614\u5730(Codyy):\u4e2a\u6027\u5316\u4e3b\u9875", "tags": "\u9614\u5730 Codyy ", "name": "spmobile", "posttime": "2008-07-23 20:38:15", "ip": "58.217.222.62", "mark": 7, "note": "\u9614\u5730\u7f51\u7edc\uff08Coddy\uff09\u662f\u56fd\u5185\u4e00\u5bb6\u63d0\u4f9b\u53ef\u9ad8\u5ea6\u4e2a\u6027\u5316\u7684\u4e2a\u4eba\u95e8\u6237\u5e73\u53f0\u3002