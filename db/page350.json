8c\u80a5\u5927\uff0c\u6613\u60a3\u5fc3\u8111\u8840\u7ba1\u3001\u9ad8\u8840\u538b\u3001\u4e2d\u98ce\u7b49\u75be\u75c5\u3002\r\n\r\n\u4e13\u5bb6\u8868\u793a\uff0c\u6708\u7259\u8d8a\u5c11\uff0c\u8868\u793a\u7cbe\u529b\u8d8a\u5dee\uff0c\u4f53\u8d28\u8d8a\u5dee\uff0c\u514d\u75ab\u529b\u8d8a\u5f31\uff0c\u4e5f\u610f\u5473\u7740\u4eba\u8d8a\u5bb9\u6613\u75b2\u52b3\u3002\u6ca1\u6709\u6708\u7259\u7684\uff0c\u867d\u7136\u4e0d\u4e00\u5b9a\u5c31\u8868\u793a\u6709\u75c5\uff0c\u4f46\u8981\u6ce8\u610f\u7684\u662f\uff1a\u65e0\u6708\u7259\u7684\u4eba\uff0c\u5f80\u5f80\u4e0d\u75c5\u5219\u5df2\uff0c\u4e00\u75c5\u5c31\u5f80\u5f80\u6bd4\u8f83\u4e25\u91cd\u3002\u6b64\u5916\uff0c\u53ea\u5269\u4e0b\u5927\u62c7\u6307\u8fd8\u6709\u70b9\u6708\u7259\u7684\u670b\u53cb\u6ce8\u610f\u4e86\uff0c\u8fd9\u610f\u5473\u7740\u4f60\u7684\u8eab\u4f53\u80fd\u91cf\u6216\u8bb8\u5df2\u5f00\u59cb\u4e0d\u8db3\u4e86\uff0c\u75be\u75c5\u4e5f\u4f1a\u79bb\u4f60\u4e0d\u8fdc\u4e86\u3002\u5982\u53d1\u73b0\u6708\u7259\u51cf\u5c11\uff0c\u53ef\u4ee5\u8865\u5145\u86cb\u767d\u8d28\u548c\u9ed1\u8272\u98df\u54c1\uff0c\u5982\u9ed1\u7c73\uff0c\u9ed1\u6728\u8033\u7b49\u3002\u5c3d\u91cf\u4fdd\u6301\u4f53\u529b\u65fa\u76db\uff0c\u6b64\u5916\u8981\u9002\u5f53\u953b\u70bc\u3002\u5224\u65ad\u4e00\u4e2a\u4eba\u662f\u5426\u60a3\u67d0\u79cd\u75be\u75c5\uff0c\u8fd8\u5e94\u8be5\u7efc\u5408\u5176\u4ed6\u65b9\u9762\u7684\u56e0\u7d20\uff0c\u901a\u8fc7\u5404\u65b9\u68c0\u67e5\u8bba\u8bc1\u624d\u80fd\u786e\u5b9a\uff0c\u4e0d\u5fc5\u56e0\u6708\u7259\u4e00\u53d1\u751f\u53d8\u5316\u5c31\u5fc3\u614c\u3002\r\n\r\n\u4e2d\u533b\u5b66\u8ba4\u4e3a\uff0c\u722a\u4e3a\u7b4b\u4e4b\u4f59\uff0c\u4e3a\u809d\u80c6\u4e4b\u5916\u5019\u3002\u7b80\u5355\u5730\u8bb2\uff0c\u770b\u6307\u7532\u53ef\u6d4b\u77e5\u4f53\u5185\u810f\u8151\u6c14\u8840\u7684\u76db\u8870\uff0c\u53ef\u4ee5\u77e5\u9053\u4e00\u4e2a\u4eba\u8eab\u4f53\u5065\u5eb7\u4e0e\u5426\uff0c\u6307\u7532\u7684\u6708\u7259\u53ef\u4ee5\u8bf4\u662f\u4eba\u4f53\u5065\u5eb7\u7684\u201c\u6674\u96e8\u8868\u201d\u3002\r