\u535a\u5ba2\u91cc\uff0c\u8ba9\u4f60\u7684\u539f\u521b\u95ea\u70c1\u5728\u6bcf\u4e00\u4e2a\u89d2\u843d\u3002 \r\n\r\n\u5f15\u7206\u70b9\r\n\r\nPlanbus!\u662f\u4e00\u4e2a\u793e\u4f1a\u5316\u7684\u805a\u5408\u5206\u4eab\u5e73\u53f0\uff0c\u805a\u5408\u5206\u4eab\u7684\u5bf9\u8c61\u662f\u670b\u53cb\u7684\u6700\u65b0\u5728\u7ebf\u6d3b\u52a8\u884c\u4e3a\u7684\u4fe1\u606f\uff08feed\uff09\u3002\u7f51\u7ad9\u7684\u529f\u80fd\u4e3b\u8981\u4e09\u5927\u5757\uff1a \r\n\r\n\u53d1\u73b0\uff1a\u5728Planbus!\u4e0a\u6dfb\u52a0\u4f60\u611f\u5174\u8da3\u7684\u670b\u53cb\uff0c\u5c31\u53ef\u4ee5\u5b9e\u65f6\u770b\u5230\u597d\u53cb\u613f\u610f\u5206\u4eab\u7684\u6700\u65b0\u5728\u7ebf\u6d3b\u52a8\u3002\u4f8b\u5982\uff0c\u597d\u53cb\u201c\u7d2b\u841d\u535c\u201d\u5728Q-zone\u4e0a\u4f20\u4e868\u5f20\u7167\u7247\uff0c\u5c31\u53ef\u4ee5\u5728Planbus!\u53ca\u65f6\u53d1\u73b0\u4ed6\u7684\u8e2a\u8ff9\u3002 \r\n\r\n\u8ba8\u8bba\uff1a\u5728Planbus!\u5e73\u53f0\u8fd8\u53ef\u4ee5\u5bf9\u597d\u53cb\u7684\u4fe1\u606f\u5185\u5bb9\u8fdb\u884c\u8bc4\u8bba\u3001\u6536\u85cf\u3002 \u5728\u6bcf\u6761\u4fe1\u606f\u7684\u5e95\u90e8\u90fd\u6709\u52a8\u6001\u7684\u201c\u7559\u8a00\u201d\u6846\uff0c\u8ba9\u4f60\u5728\u4f60\u7684\u597d\u53cb\u5708\u751a\u81f3Everyone\u91cc\u8fdb\u884c\u8ba8\u8bba\u3002\r\n\r\n\u5206\u4eab\uff1a\u5728Planbus!\u5e73\u53f0\u4e0a\uff0c\u53ef\u4ee5\u540c\u65f6\u805a\u5408\u6765\u81ea\u5176\u4ed6\u7f51\u7ad9\u7684\u5e73\u53f0\u4fe1\u606f\u8fdb\u884c\u5206\u4eab\u3002\u76ee\u524dPlanbus!\u5df2\u7ecf\u63d0\u4f9b\u65b0\u95fb\u3001RSS\u3001\u804a\u5929\u5de5\u5177\u3001\u89c6\u9891\u3001\u535a\u5ba2\u3001\u56fe\u7247\u3001\u97f3\u4e50\u7b49\u5404\u79cd\u7f51\u7edc\u5e73\u53f0\u7684\u652f\u6301\u3002\u5728Planbus!\u53ef\u4ee5\u540c\u65f6\u805a\u5408\u6765\u81ea\u5404\u5927\u793e\u4ea4\u7f51\u7ad9\uff08\u8b6c\u5982\uff1a \u6821\u5185\u7f51\u3001Facebook\u3001Chinaren\u7b49\u7b49\uff09\u3001\u535a\u5ba2\u7f51\u7ad9\uff08\u8b6c\u5982\uff1a\u65b0\u6d6a\u535a\u5ba2\u3001Q-zone\u3001\u996d\u5426\u3001\u53fd\u6b6a\u3001\u535a\u5ba2\u4e2d\u56fd\u7b49\u7b49\uff09\u4ee5\u53ca\u652f\u6301Media RSS\u683c\u5f0f\u7684\u5185\u5bb9\u7f51\u7ad9\uff08\u8b6c\u5982\uff1a\u4f18\u9177\u89c6\u9891\u3001YouTube\u3001\u571f\u8c46\u7f51\u7b49\u7b49\uff09\u7b49\u591a\u79cd\u5e73\u53f0\u7684\u4fe1\u606f\uff0c\u53ea\u8981\u8c61RSS\u9605\u8bfb\u5668\u90a3\u6837\u6dfb\u52a0\u7f51\u5740\u6216\u8005\u7528\u6237\u540d\u5c31\u884c\u3002 \r\n\r\n\u76ee\u524dPlanbus!\u5df2\u7ecf\u5185\u7f6e\u4e8610\u591a\u79cd\u5e38\u89c1\u7684\u670d\u52a1\u65b9\u4fbf\u7528\u6237\u8fdb\u884c\u6dfb\u52a0\u5185\u5bb9\u3002\u62d2\u5b98\u65b9\u535a\u5ba2\u8bf4\u4eca\u540e\u652f\u6301\u7684\u670d\u52a1\u5c06\u4f1a\u66f4\u591a\u3002Planbus!\u901a\u8fc7\u5bf9\u7528\u6237\u8bc4\u8bba\u3001\u6536\u85cf\u7684\u6570\u636e\u8fdb\u884c\u5206\u6790\uff0c\u8fd8\u63d0\u4f9b\u4e86\u4e00\u4e9b\u6709\u8da3\u7684\u529f\u80fd\u3002Planbus!\u7684\u7edf\u8ba1\u529f\u80fd\u53ef\u4ee5\u5e2e\u7528\u6237\u627e\u51fa\u54ea\u4e9b\u597d\u53cb\u5bf9\u81ea\u5df1\u7684\u5185\u5bb9\u611f\u5174\u8da3\uff0c\u800c\u81ea\u5df1\u53c8\u5bf9\u54ea\u4e9b\u597d\u53cb\u7684\u5185\u5bb9\u611f\u5174\u8da3\uff1b\u4e5f\u53ef\u4ee5\u770b\u51fa\u7528\u6237\u53ca\u597d\u53cb\u4f7f\u7528\u54ea\u4e9b\u670d\u52a1\u66f4\u4e3a\u9891\u7e41\u3002Planbus!\u5e76\u4ee5\u6b64\u4e3a\u7528\u6237\u201c\u753b\u201d\u51fa\u4e00\u5e45\u7528\u6237\u8d8b\u52bf\u56fe\uff0c\u5e76\u4e14\u80fd\u591f\u63a8\u8350\u201c\u7cbe\u786e\u6253\u51fb\u201d\u578b\u7684\u597d\u53cb\u548c\u7528\u6237\u611f\u5174\u8da3\u7684\u5185\u5bb9\u3002 \r\n\r\n\u540c\u6b65\u805a\u5408\u4e4b\u9053 \r\n\r\nPlanbus!\u7684\u7279\u5f81\u5f88\u660e\u663e\uff1a\u5373\u65f6\u6027\u3001\u7b2c\u4e09\u65b9\u3001\u793e\u4f1a\u5316\u3002 \r\n\r\n\u5728Planbus!\u5e73\u53f0\u7b2c\u4e00\u65f6\u95f4\u805a\u5408\u4e86\u7528\u6237\u5404\u79cd\u5404\u6837\u7684\u4fe1\u606f\uff0c\u8ddf\u8e2a\u53d1\u73b0\u7528\u6237\u548c\u597d\u53cb\u7684\u7f51\u7edc\u8e2a\u8ff9\u3002Planbus!\u8bbe\u7f6e\u4e86\u201c\u5927\u4e8b\u4ef6\u201d\u63d0\u793a\u529f\u80fd\uff0c\u8ba9\u7528\u6237\u767b\u9646\u4e4b\u540e\u53ef\u4ee5\u7acb\u5373\u67e5\u770b\u597d\u53cb\u4eec\u7684\u6700\u65b0\u52a8\u6001\u3002\u540c\u65f6\u8d77\u5230\u4e86\u201c\u5206\u6d41\u201d\u548c\u201c\u5bfc\u822a\u201d\u7684\u4f5c\u7528\u3002 \r\n\r\nPlanbus!\u76ee\u524d\u5df2\u7ecf\u591a\u79cd\u5e38\u89c1\u7684\u7f51\u7edc\u670d\u52a1\uff0c\u805a\u5408\u6765\u81ea\u5404\u4e2a\u7f51\u7ad9\u7684\u4fe1\u606f\uff0c\u5b8c\u5168\u662f\u7ad9\u5728\u7b2c\u4e09\u65b9\u7684\u89d2\u5ea6\u4e3a\u7528\u6237\u63d0\u4f9b\u670d\u52a1\u3002\u5728Planbus!\u5e73\u53f0\u4e0d\u9700\u8981\u767b\u9646\u5176\u4ed6\u7f51\u7ad9\uff0c\u5c31\u53ef\u4ee5\u83b7\u5f97\u76f8\u5e94\u7684\u4fe1\u606f\u3002 \r\n\r\nPlanbus!\u540c\u6837\u5728\u6784\u5efa\u4e00\u4e2a\u793e\u4f1a\u5316\u7684\u597d\u53cb\u7f51\u7edc\u3002\u4e0eFacebook\u3001Myspace\u7684\u533a\u522b\u5728\u4e8e\u662f\u4e00\u79cd\u7b2c\u4e09\u65b9\u7acb\u573a\u7684\u7f51\u7edc\u3002 \r\n\r\nPlanbus! VS Facebook \r\n\r\n\u628aPlanbus!\u4e0e\u53e6\u4e00\u4e2a\u660e\u661fFacebook\u5bf9\u6bd4\u53ef\u4ee5\u53d1\u73b0\uff0cPlanbus!\u628aFacebook\u7684NewsFeed\u7684\u529f\u80fd\u5265\u79bb\u51fa\u53bb\uff0c\u5e76\u6269\u5927\u548c\u7b2c\u4e09\u65b9\u5316\u3002 \r\n\r\nFacebook\u7684Newsfeed\u4e3a\u7528\u6237\u63d0\u4f9b\u4e86\u597d\u53cb\u6700\u65b0\u7684\u7ad9\u5185\u6d3b\u52a8\u4fe1\u606f\uff0c\u5305\u62ec\u65e5\u5fd7\u3002\u800c\u8fd9\u6b63\u662f\u597d\u591a\u7528\u6237\u613f\u610f\u548c\u60f3\u8981\u83b7\u5f97\u7684\u6765\u81ea\u597d\u53cb\u7684\u4fe1\u606f\uff0c\u597d\u53cb\u4e0d\u4ec5\u4ec5\u662f\u804a\u5929\u3002Planbus!\u4f5c\u4e3a\u5206\u4eab\u597d\u53cb\u6700\u65b0\u5728\u7ebf\u6d3b\u52a8\u7684\u5e73\u53f0\uff0c\u663e\u7136\u4e8c\u8005\u5177\u6709\u5171\u6027\uff0c\u5e76\u4e14\u5728\u67d0\u79cd\u7a0b\u5ea6\u4e0a\u540c\u6837\u6ee1\u8db3\u4e86\u90e8\u5206\u201c\u7aa5\u63a2\u8005\u201d\u7684\u5fc3\u7406\u3002", "imagename": "9116d2abba9340ed8aa3c71359a15042.jpg", "infoid": 55064, "category": "technology_inter