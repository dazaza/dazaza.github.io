f\u8bbe\u7f6e\u81ea\u52a8\u653e\u884c\u5df2\u77e5\u5b89\u5168\u7684\u5e94\u7528\u8f6f\u4ef6\uff0c\u6539\u5584\u7535\u8111\u521d\u5b66\u8005\u4f7f\u7528\u9632\u706b\u5899\u4f53\u9a8c </P>\r\n<P>\u3000\u3000\u5f15\u64ce\u8131\u58f3\u529f\u80fd\u589e\u5f3a </P>\r\n<P>\u3000\u3000\u652f\u6301\u8131\u8d85\u8fc7110 \u79cd\uff0c\u8d85\u8fc7400 \u4e2a\u4e0d\u540c\u7248\u672c\u52a0\u58f3 </P>\r\n<P>\u3000\u3000\u5168\u65b0\u7684\u8131\u58f3\u865a\u62df\u673a\uff0c\u8131\u58f3\u6548\u7387\u6210\u500d\u63d0\u5347 </P>\r\n<P>\u3000\u3000\u65b0\u6f0f\u6d1e\u4fee\u590d\uff08\u8fd9\u4e2a\u4f53\u9a8c\u8fc7\u6e05\u7406\u4e13\u5bb62.5\u7684\u670b\u53cb\u4eec\u4f1a\u6df1\u6709\u4f53\u4f1a\u4e86\uff09 </P>\r\n<P>\u3000\u3000\u57fa\u4e8eP2SP \u7684\u6025\u901f\u8865\u4e01\u4e0b\u8f7d\u6280\u672f\uff1b </P>\r\n<P>\u3000\u3000\u7b2c\u4e09\u65b9\u6f0f\u6d1e\u7684\u652f\u6301\uff1b </P>\r\n<P>\u3000\u3000\u57fa\u4e8e\u81ea\u52a8\u722c\u866b\u6280\u672f\u7684\u6f0f\u6d1e\u6570\u636e\u81ea\u52a8\u6536\u96c6\u6280\u672f\uff1b </P>\r\n<P>\u3000\u3000\u5728\u7ebf\u5ba2\u670d\u529f\u80fd\uff1a\u4e13\u5bb6\u5728\u7ebf\uff0c\u53ca\u65f6\u89e3\u51b3\u7528\u6237\u95ee\u9898\uff0c\u53ef\u901a\u8fc7\u5ba2\u6237\u7aef\u76f4\u63a5\u547c\u53eb\u5728\u7ebf\u5ba2\u670d </P>\r\n<P>\u3000\u3000\u5347\u7ea7\u670d\u52a1\u4f18\u5316 </P>\r\n<P>\u3000\u3000\u4f18\u5316\u5347\u7ea7\u6d41\u7a0b\u3001\u91d1\u5c71\u6bd2\u97382009\u4e3b\u8981\u7684\u6539\u8fdb\u662f\u5728\u670d\u52a1\u5668\u7aef\uff0c\u800c\u5ba2\u6237\u7aef\u7684\u6539\u8fdb\u662f\u5b9e\u5b9e\u5728\u5728\u5730\u8868\u73b0\u5728\u5f15\u64ce\u548c\u9a71\u52a8\u4e2d\uff0c\u6211\u4eec\u5e76\u6ca1\u6709\u523b\u610f\u53bb\u4fee\u6539\u5ba2\u6237\u7aef\u7684\u529f\u80fd\u754c\u9762\uff0c\u4ee5\u6c42\u6700\u5927\u7a0b\u5ea6\u4e0a\u964d\u4f4e\u7528\u6237\u7684\u5b66\u4e60\u6210\u672c\uff0c\u4e5f\u8ba9\u8001\u7528\u6237\u7528\u8d77\u6765\u66f4\u52a0\u5f97\u5fc3\u5e94\u624b\u3002 </P>\r\n<P>\u3000</P>\r\n<P>\u3000\u3000\u529f\u80fd\u6539\u8fdb\u5217\u8868\uff1a </P>\r\n<P>\u30001.\u4e92\u8054\u7f51\u53ef\u4fe1\u8ba4\u8bc1\u670d\u52a1\u7aef\u7684\u589e\u5f3a \u2014\u2014 </P>\r\n<P>\u3000\u3000\u6837\u672c\u6536\u96c6\u80fd\u529b\u7684\u63d0\u9ad8\uff1a\u767d\u540d\u5355\u5e93\u8d85\u8fc71\u4ebf\u4e2a\uff0c\u5e76\u4e14\u8fd9\u4e00\u6570\u91cf\u8fd8\u5728\u4e0e\u65e5\u4ff1\u589e\u3002 </P>\r\n<P>\u3000\u3000\u65e5\u75c5\u6bd2\u5904\u7406\u80fd\u529b\u589e\u5f3a\uff1a\u65e5\u6700\u5927\u75c5\u6bd2\u6837\u672c\u5904\u7406\u80fd\u529b\u63d0\u9ad81500\u500d \u65e5\u5e73\u5747\u5904\u7406\u6837\u672c\u91cf\u53ef\u8fbe\u767e\u4e07\u4e4b\u591a </P>\r\n<P>\u3000\u3000\u5e94\u6025\u80fd\u529b\u63d0\u9ad8\uff1a\u7d27\u6025\u75c5\u6bd2\u54cd\u5e94\u65f6\u95f4\u7f29\u77ed\u5230\u4ee5\u5c0f\u65f6\u8ba1\uff0c\u8fd9\u91cc\u7684\u54cd\u5e94\u65f6\u95f4\u6307\u83b7\u5f97\u6837\u672c\u5230\u5b8c\u6210\u5168\u90e8\u6d4b\u8bd5\uff0c\u66f4\u65b0\u670d\u52a1\u7aef\u548c\u5ba2\u6237\u7aef\u5347\u7ea7\u6570\u636e\u7684\u65f6\u95f4\u3002 </P>\r\n<P>\u3000\u3000\u75c5\u6bd2\u68c0\u51fa\u6570\u91cf\u63d0\u5347\u8fd110\u500d </P>\r\n<P>\u30002.\u5ba2\u6237\u7aef\u7684\u589e\u5f3a </P>\r\n<P>\u3000\u3000\u7f51\u9556\u52a0\u5165\u53ef\u4fe1\u8ba4\u8bc1\u652f\u6301\uff0c\u53ef\u8bbe\u7f6e\u81ea\u52a8\u653e\u884c\u5df2\u77e5\u5b89\u5168\u7684\u5e94\u7528\u8f6f\u4ef6\uff0c\u6539\u5584\u7535\u8111\u521d\u5b66\u8005\u4f7f\u7528\u9632\u706b\u5899\u4f53\u9a8c </P>\r\n<P>\u3000\u3000\u5f15\u64ce\u8131\u58f3\u529f\u80fd\u589e\u5f3a </P>\r\n<P>\u3000\u3000\u652f\u6301\u8131\u8d85\u8fc7110 \u79cd\uff0c\u8d85\u8fc7400 \u4e2a\u4e0d\u540c\u7248\u672c\u52a0\u58f3 </P>\r\n<P>\u3000\u3000\u5168\u65b0\u7684\u8131\u58f3\u865a\u62df\u673a\uff0c\u8131\u58f3\u6548\u7387\u6210\u500d\u63d0\u5347 </P>\r\n<P>\u3000\u3000\u65b0\u6f0f\u6d1e\u4fee\u590d\uff08\u8fd9\u4e2a\u4f53\u9a8c\u8fc7\u6e05\u7406\u4e13\u5bb62.5\u7684\u670b\u53cb\u4eec\u4f1a\u6df1\u6709\u4f53\u4f1a\u4e86\uff09 </P>\r\n<P>\u3000\u3000\u57fa\u4e8eP2SP \u7684\u6025\u901f\u8865\u4e01\u4e0b\u8f7d\u6280\u672f\uff1b </P>\r\n<P>\u3000\u3000\u7b2c\u4e09\u65b9\u6f0f\u6d1e\u7684\u652f\u6301\uff1b </P>\r\n<P>\u3000\u3000\u57fa\u4e8e\u81ea\u52a8\u722c\u866b\u6280\u672f\u7684\u6f0f\u6d1e\u6570\u636e\u81ea\u52a8\u6536\u96c6\u6280\u672f\uff1b </P>\r\n<P>\u3000\u3000\u5728\u7ebf\u5ba2\u670d\u529f\u80fd\uff1a\u4e13\u5bb6\u5728\u7ebf\uff0c\u53ca\u65f6\u89e3\u51b3\u7528\u6237\u95ee\u9898\uff0c\u53ef\u901a\u8fc7\u5ba2\u6237\u7aef\u76f4\u63a5\u547c\u53eb\u5728\u7ebf\u5ba2\u670d </P>\r\n<P>\u3000\u3000\u5347\u7ea7\u670d\u52a1\u4f18\u5316 </P>\r\n<P>\u3000\u3000\u4f18\u5316\u5347\u7ea7\u6d41\u7a0b\u3001\u63d0\u5347\u5347\u7ea7\u901f\u5ea6 </P>\r\n<P>\u3000\u3000\u4f18\u5316\u5347\u7ea7\u7684\u4ea4\u4e92\u4f53\u9a8c\uff0c\u51cf\u5c11\u5347\u7ea7\u91cd\u542f\u5bf9\u7528\u6237\u5e26\u6765\u7684\u56f0\u6270 </P>\r\n<P>\u3000\u3000\u8d44\u6e90\u5360\u7528\u4f18\u5316 </P>\r\n<P>\u3000\u3000\u5f15\u64ce\u5185\u5b58\u5360\u7528\u4f18\u5316 </P>\r\n<P>\u3000\u3000\u7f51\u9556\u9632\u706b\u5899\u7684CPU\u5360\u7528\uff1b </P>\r\n<P>\u3000\u3000\u76d1\u63a7\u63d0\u901f\uff1b </P>\r\n<P>\u3000\u3000\u81ea\u4fdd\u62a4\u589e\u5f3a\uff1a\u63d0\u5347\u81ea\u8eab\u6297\u6253\u51fb\u7684\u80fd\u529b </P>\r\n<P>\u3000\u3000\u5168\u9762\u652f\u6301Vista\u3001XP SP3\uff08\u4e3b\u8981\u662f\u9a71\u52a8\u7a0b\u5e8f\u7684\u6539\u8fdb\uff09 <BR>\u63d0\u5347\u5347\u7ea7\u901f\u5ea6 </P>\r\n<P>\u3000\u3000\u4f18\u5316\u5347\u7ea7\u7684\u4ea4\u4e92\u4f53\u9a8c\uff0c\u51cf\u5c11\u5347\u7ea7\u91cd\u542f\u5bf9\u7528\u6237\u5e26\u6765\u7684\u56f0\u6270 </P>\r\n<P>\u3000\u3000\u8d44\u6e90\u5360\u7528\u4f18\u5316 </P>\r\n<P>\u3000\u3000\u5f15\u64ce\u5185\u5b58\u5360\u7528\u4f18\u5316 </P>\r\n<P>\u3000\u3000\u7f51\u9556\u9632\u706b\u5899\u7684CPU\u5360\u7528\uff1b </P>\r\n<P>\u3000\u3000\u76d1\u63a7\u63d0\u901f\uff1b </P>\r\n<P>\u3000\u3000\u81ea\u4fdd\u62a4\u589e\u5f3a\uff1a\u63d0\u5347\u81ea\u8eab\u6297\u6253\u51fb\u7684\u80fd\u529b </P>\r\n<P>\u3000\u3000\u5168\u9762\u652f\u6301Vista\u3001XP SP3\uff08\u4e3b\u8981\u662f\u9a71\u52a8\u7a0b\u5e8f\u7684\u6539\u8fdb\uff09 <BR></P>", "imagename": null, "infoid": 101627, "category": "technology_software", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u91d1\u5c71\u6bd2\u9738"]}, {"url": "http://en.cnci.gov.cn/", "title": "\u4e2d\u56fd\u6587\u5316\u4ea7\u4e1a\u7f51\u82f1\u6587\u7248\u5168\u65b0\u4e0a\u7ebf", "tags": "\u4e2d\u56fd \u6587\u5316 \u4ea7\u4e1a \u7f51\u7ad9 ", "name": "yinyin", "posttime": "2008-11-07 15:51:30", "ip": "222.128.48.207", "mark": 1, "note": "2008\u5e7411\u67087\u65e5\uff0c\u5168\u9762\u5347\u7ea7\u540e\u7684\u4e2d\u56fd\u6587\u5316\u4ea7\u4e1a\u7f51\u82f1\u6587\u7248\uff08en.cnci.gov.cn\uff09\u6b63\u5f0f\u4e0a\u7ebf\u4e86\u3002\u8fd9\u662f\u7ee72008\u5e748\u6708\u4e2d\u56fd\u6587\u5316\u4ea7\u4e1a\u7f51\u4e2d\u6587\u7248\u4e4b\u540e\uff0c\u7f51\u7ad9\u6240\u505a\u7684\u7b2c\u4e8c\u6b21\u91cd\u5927\u5347\u7ea7\u3002\u6b64\u6b21\u82f1\u6587\u7248\u7684\u5347\u7ea7\u4e0a\u7ebf\uff0c\u4e0d\u4f46\u5168\u9762\u63d0\u5347\u4e86\u4e2d\u56fd\u6587\u5316\u4ea7\u4e1a\u7f51\u72ec\u5bb6\u6027\u3001\u4e13\u4e1a\u6027\u548c\u6743\u5a01\u6027\uff0c\u66f4\u4e3a\u4e2d\u56fd\u4f18\u79c0\u6587\u5316\u4ea7\u4e1a\u9879\u76ee\u4e0e\u4ea7\u54c1\u8d70\u5411\u56fd\u9645\u5e02\u573a\u6253\u5f00\u4e86\u4e00\u6247\u5e7f\u9614\u7684\u7a97\u53e3\uff0c\u4e3a\u4e2d\u56fd\u4f18\u79c0\u6587\u5316\u4ea7\u4e1a\u9879\u76ee\u4e0e\u4ea7\u54c1\u53c2\u4e0e\u56fd\u9645\u7ade\u4e89\u63d0\u4f9b\u4e13\u4e1a\u4e92\u8054\u7f51\u670d\u52a1\u5e73\u53f0\u3002 \r\n\r\n\r\n\u4e2d\u56fd\u6587\u5316\u4ea7\u4e1a\u7f51\u662f\u7531\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6587\u5316\u90e8\u4e3b\u7ba1\uff0c\u6587\u5316\u90e8\u6587\u5316\u4ea7\u4e1a\u53f8\u4e3b\u529e\uff0c\u6df1\u5733\u62a5\u4e1a\u96c6\u56e2\u3001\u6df1\u5733\u56fd\u9645\u6587\u5316\u4ea7\u4e1a\u535a\u89c8\u4ea4\u6613\u4f1a\u6709\u9650\u516c\u53f8\u8054\u5408\u6253\u9020\u8fd0\u8425\u7684\u56fd\u5bb6\u7ea7\u6743\u5a01\u6587\u5316\u4ea7\u4e1a\u95e8\u6237\u7f51\u7ad9\u3002\u76ee\u524d\u5171\u6709\u7b80\u4f53\u4e2d\u6587\u3001\u7e41\u4f53\u4e2d\u6587\u3001\u82f1\u6587\u4e09\u79cd\u7248\u672c\u3002 \r\n\r\n\r\n\u968f\u7740\u5168\u7403\u5e02\u573a\u7684\u8fc5\u901f\u878d\u5408\uff0c\u4e2d\u56fd\u6587\u5316\u4ea7\u4e1a\u9879\u76ee\u4e0e\u4ea7\u54c1\u5bf9\u4e8e\u56fd\u9645\u5316\u5c55\u793a\u5e73\u53f0\u7684\u9700\u6c42\u6108\u52a0\u8feb\u5207\u3002\u5728\u8fd9\u6837\u7684\u5f62\u52bf\u4e0b\uff0c\u4e2d\u56fd\u6587\u5316\u4ea7\u4e1a\u7f51\u82f1\u6587\u7248\u987a\u65f6\u800c\u52a8\uff0c\u529b\u6c42\u4ee5\u4e00\u79cd\u5d2d\u65b0\u7684\u9762\u8c8c\u548c\u4f53\u7cfb\uff0c\u4e3a\u4e2d\u56fd\u6587\u5316\u4ea7\u54c1\u9762\u5411\u4e16\u754c\u3001\u8d70\u5411\u4e16\u754c\u505a\u51fa\u5e94\u6709\u7684\u52aa\u529b\u3002\u5168\u9762\u5347\u7ea7\u540e\u7684\u82f1\u6587\u7248\uff0c\u5171\u8bbe\u6709\u8d44\u8baf\u4e2d\u5fc3\u3001\u4ea7\u54c1\u4ea4\u6613\u4e2d\u5fc3\u3001\u5168\u56fd\u6587\u5316\u4ea7\u4e1a\u9879\u76ee\u670d\u52a1\u5de5\u7a0b\u3001\u7f51\u4e0a\u6587\u535a\u4f1a\u56db\u5927\u677f\u5757\u3002 \r\n\r\n\r\n\u4e3a\u4e86\u4fbf\u4e8e\u6d77\u5916\u53d7\u4f17\u5373\u65f6\u4e86\u89e3\u56fd\u5185\u4ea7\u4e1a\u52a8\u6001\uff0c\u8d44\u8baf\u4e2d\u5fc3\u8bbe\u6709\u65b0\u95fb\u8d44\u8baf\u9891\u9053\u3001\u6cd5\u5f8b\u6cd5\u89c4\u9891\u9053\u4ee5\u53ca\u6587\u5316\u5927\u89c2\u56ed\u7b49\u4e09\u5927\u5185\u5bb9\u3002\u65b0\u95fb\u8d44\u8baf\u5c06\u4e0e\u4e2d\u6587\u7248\u5b9e\u73b0\u540c\u6b65\u66f4\u65b0\uff0c\u4f7f\u6d77\u5916\u53d7\u4f17\u80fd\u7b2c\u4e00\u65f6\u95f4\u4ece\u4e2d\u56fd\u6587\u5316\u4ea7\u4e1a\u7f51\u4e86\u89e3\u4e2d\u56fd\u6587\u5316\u4ea7\u4e1a\u7684\u6700\u65b0\u524d\u6cbf\u52a8\u6001\uff1b\u6cd5\u5f8b\u6cd5\u89c4\u9891\u9053\u5219\u662f\u4e13\u4e3a\u6d77\u5916\u4e13\u4e1a\u4eba\u58eb\u5f00\u8f9f\u7684\u65b0\u680f\u76ee\uff0c\u6db5\u76d6\u4e86\u4e2d\u56fd\u6587\u5316\u6cd5\u5f8b\u6cd5\u89c4\u3001\u4e2d\u56fd\u7ecf\u8d38\u6cd5\u5f8b\u6cd5\u89c4\u7b49\u653f\u7b56\u5185\u5bb9\u3002\u6cd5\u5f8b\u9891\u9053\u7684\u5f00\u8bbe\uff0c\u5145\u5206\u4f53\u73b0\u4e86\u56fd\u5bb6\u7ea7\u6743\u5a01\u95e8\u6237\u7f51\u7ad9\u7684\u7279\u70b9\u3002\u6587\u5316\u5927\u89c2\u56ed\u9891\u9053\uff0c\u5305\u62ec\u6587\u5b66\u3001\u97f3\u4e50\u3001\u66f2\u827a\u3001\u98ce\u4fd7\u7b499\u4e2a\u680f\u76ee\uff0c\u6c47\u96c6\u4e86\u5927\u91cf\u6781\u5177\u8da3\u5473\u6027\u3001\u77e5\u8bc6\u6027\u7684\u6587\u5316\u8d44\u8baf\uff0c\u4ee5\u6ee1\u8db3\u6d77\u5916\u89c2\u4f17\u5bf9\u4e2d\u56fd\u5386\u53f2\u6587\u5316\u591a\u5c42\u9762\u3001\u591a\u89d2\u5ea6\u7684\u4e86\u89e3\u9700\u6c42\u3002 \r\n\r\n\r\n\u5168\u65b0\u5347\u7ea7\u7684\u4ea7\u54c1\u4ea4\u6613\u4e2d\u5fc3\uff0c\u4f18\u5316\u4e86\u4f1a\u5458\u914d\u5957\u670d\u52a1\u529f\u80fd\u4f53\u7cfb\uff0c\u4e3a\u5728\u7ebf\u4ea4\u6613\u63d0\u4f9b\u4e86\u7cfb\u5217\u4fbf\u6377\u670d\u52a1\uff0c\u4e3a\u6d77\u5916\u4f1a\u5458\u7684\u5438\u7eb3\u63d0\u4f9b\u4e86\u57fa\u7840\u3002\u800c\u9879\u76ee\u4ea4\u6613\u4e2d\u5fc3\uff0c\u662f\u4e2d\u56fd\u6587\u5316\u4ea7\u4e1a\u9879\u76ee\u670d\u52a1\u5de5\u7a0b\u7684\u552f\u4e00\u53d1\u5e03\u5e73\u53f0\uff0c\u76ee\u524d\u96c6\u4e2d\u4e86\u534e\u5317\u3001\u4e2d\u5357\u3001\u6e2f\u6fb3\u53f0\u7b49\u5168\u56fd\u4e03\u5927\u7247\u533a\u7684\u6587\u5316\u4ea7\u4e1a\u91cd\u70b9\u9879\u76ee\u6743\u5a01\u6570\u636e\uff0c\u4e3a\u6d77\u5916\u4eba\u58eb\u68c0\u7d22\u4e0e\u4e86\u89e3\u56fd\u5185\u6587\u5316\u5e02\u573a\u63d0\u4f9b\u4e86\u56fd\u5bb6\u7ea7\u7684\u6743\u5a01\u6d88\u606f\u6765\u6e90\u3002\u82f1\u6587\u7248\u7684\u6587\u535a\u4f1a\u7f51\u4e0a\u5c55\u9986\uff0c\u5c06\u4e8e\u4eca\u540e\u4e0e\u6587\u535a\u4f1a\u7684\u6d77\u5916\u62db\u5546\u76f8\u7ed3\u5408\uff0c\u72ec\u5bb6\u5c55\u73b0\u6587\u535a\u4f1a\u6d77\u5916\u5206\u4f1a\u573a\u7684\u6700\u65b0\u52a8\u6001\uff0c\u7acb\u4f53\u5c55\u793a\u53c2\u5c55\u4ea7\u54c1\uff0c\u6253\u9020\u72ec\u7279\u7684\u7f51\u4e0a\u5c55\u5385\u3002 \r\n\r\n\r\n\u4e2d\u56fd\u6587\u5316\u4ea7\u4e1a\u7f51\u82f1\u6587\u7248\u7684\u5347\u7ea7\uff0c\u5728\u5185\u5bb9\u548c\u8d28\u91cf\u4