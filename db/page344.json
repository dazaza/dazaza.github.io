[{"url": null, "title": "\u5173\u6ce8\u4f4e\u78b3:\u5bb6\u7535\u5173\u673a\u4e4b\u540e\u4ecd\u7136\u8017\u7535?", "tags": "\u5bb6\u7535 \u8017\u7535 \u4f4e\u78b3 ", "name": "geekzhang", "posttime": "2010-09-02 09:36:49", "ip": "117.40.196.173", "mark": 1, "note": "\u9999\u6e2f\u5927\u5b66\u673a\u68b0\u5de5\u7a0b\u5b66\u7cfb\u6559\u6388\u6881\u8000\u5f70\u5411\u672c\u62a5\u63d0\u4f9b\u4e86\u4ed6\u6700\u8fd1\u7684\u4e00\u9879\u7814\u7a76\u6570\u636e\uff0c\u8bc1\u5b9e\u90e8\u5206\u7535\u5668\u5728\u5173\u673a\u540e\u4e0d\u62d4 \u63d2\u5934\u4ecd\u5728\u8017\u7535\u3002\u6309\u7167\u5176\u7814\u7a76\u6570\u636e\uff0c\u8fd9\u4e9b\u5173\u673a\u540e\u4ecd\u8017\u7535\u7684\u5bb6\u7528\u7535\u5668\u6bcf\u5c0f\u65f6\u8017\u75352\u81f324\u74e6\u4e0d\u7b49\uff0c\u8fd9\u610f\u5473\u7740\u6bcf\u4e2a\u9999\u6e2f\u5bb6\u5ead\u5982\u679c\u62d4\u6389\u7535\u6e90\uff0c\u4e00\u6708\u80fd\u8282\u7701\u8fd130\u5ea6\u7535\u3002\r\n\r\n\u6839\u636e\u4ed6\u4eec\u7684\u6d4b\u8bd5\uff0c\u53f0\u5f0f\u7535\u8111\u5f85\u673a\u65f6\u5e73\u5747\u6bcf\u5c0f\u65f6\u8017\u753543.06\u74e6\uff0c\u5173\u673a\u540e\u5982\u679c\u4e0d\u62d4\u7535\u6e90\u6bcf\u5c0f\u65f6\u4ecd\u7136\u8017\u753512.34\u74e6\uff1b\u97f3\u54cd\u5668\u6750\u3001\u7535\u98ce\u6247 \u53ca\u7535\u89c6\u89e3\u7801\u5668\uff08\u673a\u9876\u76d2\uff09\u7b49\u5173\u673a\u540e\u4e0d\u62d4\u7535\u6e90\u7684\u8017\u7535\u60c5\u51b5\u5206\u522b\u4e3a3.91\u74e6\u30013.38\u74e6\u53ca1.56\u74e6\u3002\u5f71\u5370\u673a\u5728\u5f85\u673a\u72b6\u6001\u65f6\uff0c\u5e73\u5747\u6bcf\u5c0f\u65f6\u8017\u7535116.7\u74e6\uff0c\u5173\u673a\u540e \u6bcf\u5c0f\u65f6\u8017\u7535\u4ecd\u670924.8\u74e6\u3002\r\n\r\n\u4e3a\u4ec0\u4e48\u90e8\u5206\u7535\u5668\u5728\u5173\u673a\u540e\u4e0d\u62d4\u6389\u7535\u6e90\u4ecd\u7136\u4f1a\u8017\u7535\u5462\uff1f\u6881\u8000\u5f70\u89e3\u91ca\u8bf4\uff0c\u4e00\u822c\u7535\u5668\u5185\u90fd\u6709\u53d8\u538b\u5668\uff0c\u7528\u4f5c\u7535\u8def\u4f20\u9001\uff0c\u4e14\u8fde\u63a5\u7535\u7ebf\u53ca\u63d2\u5934\uff0c\u9664