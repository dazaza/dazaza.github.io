\u6709\u4e89\u8bae\u7684\uff0c\u6216\u8005\u4e0d\u4e3a\u4eba\u6240\u77e5\u7684\uff0c\u6216\u8005\u5c1a\u5904\u4e8e\u8fb9\u5b9e\u8df5\u8fb9\u6539\u8fdb\uff1b\r\n3\uff0c\u5f15\u5165\u65f6\uff0c\u7528\u5927\u91cf\u8bcd\u6c47\u5806\u780c\uff0c\u628a\u7406\u8bba\u4ee5\u53ca\u5546\u54c1\u5305\u88c5\u4e3a\u4e00\u4e2a\u65e0\u6240\u4e0d\u80fd\u6240\u89c1\u5373\u6240\u5f97\u53ea\u8981\u4f60\u6562\u60f3\u4f60\u5c31\u4f1a\u5f97\u5230\u6548\u679c\u91d1\u5149\u95ea\u95ea\u524d\u65e0\u53e4\u4eba\u540e\u65e0\u6765\u8005\u4f1f\u5927\u7684\u4ea7\u54c1\u3002\r\n\r\n\r\n\u5b9e\u8df5\u8bc1\u660e\uff0c\u8fd9\u91cc\u4eba\u50bb\u94b1\u591a\u901f\u6765\u3002\u522b\u8bef\u4f1a\uff0c\u6211\u4eec\u8fd9\u91cc\u4e0d\u8c08\u674e\u4e00\u80e1\u4e07\u6797\u5f20\u609f\u672c\uff0c\u56e0\u4e3a\u4e2d\u56fd\u4eba\u592a\u719f\u6089\u4ed6\u4eec\u7684\u5957\u8def\uff0c\u6240\u4ee5\u63ed\u7a7f\u4ed6\u4eec\u5f88\u5bb9\u6613\u3002\u6211\u4eec\u8c08\u7684\u4f8b\u5b50\u662f\uff1a\u675c\u66fc\u95ea\u5361\u3002\r\n\r\n\r\n\u675c\u66fc\u5927\u5e08\r\n\u675c\u66fc\uff0c\u4e00\u4e2a\u770b\u4e0a\u53bb\u548c\u853c\u7684\u767d\u4eba\u8001\u5934\uff1a\r\n\r\n<img src=http://www.chinaduman.com/uploadfile/2009102710115609.jpg>\r\n\r\n\r\n\u4e2d\u56fd\u5546\u4eba\u4e00\u5b9a\u4f1a\u7231\u6b7b\u4ed6\uff0c\u957f\u5f97\u592a\u5bf9\u4e2d\u56fd\u4eba\u7684\u80c3\u53e3\u4e86\u3002\r\n\r\n\u675c\u66fc\u5927\u5e0860\u5e74\u4ee3\u5f00\u59cb\u4ece\u4e8b\u65e9\u671f\u8111\u635f\u4f24\u513f\u7ae5\u7684\u6cbb\u7597\u7814\u7a76\uff0c\u6240\u53d1\u660e\u7684\u201cDOMAN\u6559\u5b66\u6cd5\u201d\u65e9\u671f\u4e3b\u8981\u7528\u4e8e\u8111\u635f\u4f24\u513f\u7ae5\u7684\u6cbb\u7597\u3002\r\n\r\n\u5927\u8111\u635f\u4f24\u513f\u7ae5\u624d\u6709\u591a\u5c11\u554a\uff0c\u4e8e\u662f\u5f88\u5feb\u8fd9\u79cd\u6559\u5b66\u6cd5\u5ef6\u4f38\u5230\u4e86\u5065\u5eb7\u513f\u7ae5\u4e0a\u3002\u5230\u4e8621\u4e16\u7eaa\uff0c\u4e2d\u56fd\u5927\u9646\u5bb6\u957f\u5bf9\u6b64\u8d8b\u4e4b\u82e5\u9e5c\u3002\r\n\r\n \r\n\r\n\u7ef4\u57fa\u767e\u79d1\u548c\u767e\u5ea6\u767e\u79d1\u7684\u533a\u522b\r\n\u770b\u770b\u7ef4\u57fa\u767e\u79d1\u4e3a\u4ee3\u8868\u7684\u82f1\u6587Wiki\u548c\u767e\u5ea6\u767e\u79d1\u4e3a\u4ee3\u8868\u7684\u4e2d\u6587Wiki\uff0c\u4f60\u5c31\u4f1a\u77e5\u9053\u5546\u4e1a\u7684\u529b\u91cf\u5728\u4e2d\u6587\u4e16\u754c\u53ef\u4ee5\u64cd\u7eb5\u66f4\u591a\u3002\r\n\r\n\u7ef4\u57fa\u82f1\u6587\u6761\u76ee\u63cf\u8ff0\u675c\u66fc\u5927\u5e08\u521b\u5efa\u7684\u201c\u4eba\u7c7b\u6f5c\u80fd\u5f00\u53d1\u7814\u7a76\u6240\uff08IAHP\uff09\u201d(http://en.wikipedia.org/wiki/The_Institutes_for_the_Achievement_of_Human_Potential) \uff08\u4e00\u4e2a\u975e\u76c8\u5229\u6027\u6559\u80b2\u7ec4\u7ec7\uff09\uff0c\u6050\u6015\u80fd\u8bfb\u61c2\u7684\u4e2d\u56fd\u5bb6\u957f\u4e0d\u591a\uff0c\u8981\u77e5\u9053\u7ef4\u57fa\u767e\u79d1\u4ee5\u5ba2\u89c2\u516c\u6b63\u3001\u5c55\u793a\u591a\u65b9\u4e0d\u540c\u89c2\u70b9\u4e3a\u8981\u65e8\uff0c\u6240\u4ee5\u8be5\u6761\u76ee\u4e0a\u6765\u5c31\u8bf4\u660e\u675c\u66fc\u5927\u5e08\u7684IAHP\u4e3b\u8981\u9762\u5411\u5927\u8111\u635f\u4f24\u7684\u513f\u7ae5\u63d0\u4f9b\u670d\u52a1\u3002\r\n\r\n\u800c\u767e\u5ea6\u767e\u79d1\u7684\u6761\u76ee\u201c\u675c\u66fc\u95ea\u5361\u201d(http://baike.baidu.com/view/2770536.htm)\u5219\u5b8c\u5168\u56de\u907f\u8fd9\u4e2a\u4e8b\u5b9e\uff0c\u770b\u5b8c\u6574\u4e2a\u6761\u76ee\uff0c\u4f60\u4f1a\u4ee5\u4e3a\u8fd9\u4e2a\u5f00\u53d1\u65b9\u6cd5\u5b8c\u5168\u662f\u9488\u5bf9\u5065\u5eb7\u513f\u7ae5\u7684\uff0c\u8fde\u5bf9\u675c\u66fc\u5927\u5e08\u7684\u80cc\u666f\u4ecb\u7ecd\u90fd\u53ea\u4e00\u7b14\u5e26\u8fc7\u8111\u635f\u4f24\uff0c\u529b\u56fe\u8bf4\u670d\u4f60\u201c\u675c\u66fc\u535a\u58eb\u7684\u65b9\u6cd5\uff0c\u5b8c\u5168\u662f\u4f9d\u636e\u4eba\u7c7b\u5927\u8111\u795e\u7ecf\u7cfb\u7edf\u6700\u81ea\u7136\u7684\u751f\u7406\u73b0\u8c61\u800c\u8bbe\u8ba1\u7684\u3002\u201d\r\n\r\n\u8fd9\u5c31\u662f\u8d28\u7684\u533a\u522b\u3002\r\n\r\n\u518d\u56de\u5934\u770b\u7ef4\u57fa\u767e\u79d1\u63a5\u4e0b\u6765\u662f\u600e\u4e48\u4ecb\u7ecd\u79d1\u5b66\u754c\u5bf9\u675c\u66fc\u65b9\u6cd5\u7684\u4e89\u8bae\u7684\uff0c\uff08\u4f5c\u4e3a\u4e00\u4e2aWiki\uff0c\u5982\u679c\u4e0d\uff08\u6562/\u613f\uff09\u4ecb\u7ecd\u4e89\u8bae\u4e0d\u5c55\u793a\u4e0d\u9f13\u52b1\u4e89\u8bae\uff0c\u4f60\u8fd8\u53eb\u4ec0\u4e48\u201c\u767e\u79d1\u201d\uff09\uff0c\u675c\u66fc\u65b9\u6cd5\u4e3b\u8981\u6709\u4ee5\u4e0b\u6f0f\u6d1e\uff1a\r\n\r\n1\u3001\u5b83\u7684\u7406\u8bba\u57fa\u7840\u201crecapitulation theory\u201d\u5df2\u7ecf\u88ab\u81ea\u7136\u79d1\u5b66\u6240\u629b\u5f03\u3002\r\n\r\n2\u3001\u6ca1\u6709\u8bc1\u636e\u8bc1\u660e\uff0c\u5e7c\u513f\u7684\u88ab\u52a8\u5f0f\u8fd0\u52a8\uff0c\u5982\u5f3a\u8feb\u8fdb\u884c\u722c\u884c\u8fd0\u52a8\uff0c\u80fd\u591f\u5f71\u54cd\u5230\u795e\u7ecf\u7ec4\u7ec7\u3002\r\n\r\n3\u3001\u5f53\u5e7c\u513f\u7684\u81ea\u89c9\u81ea\u613f\u884c\u52a8\uff0c\u88abIAHP\uff08\u6839\u636e\u5176\u7406\u8bba\uff09\u963b\u6b62\u8fd9\u4e48\u505a\uff0c\u53ef\u80fd\u4f1a\u4f24\u5bb3\u5e7c\u513f\u3002\r\n\r\n4\u3001\u675c\u66fc\u5927\u5e08\u552f\u4e00\u53d1\u8868\u8fc7\u7684\u79d1\u6280\u8bba\u6587\u4e2d\uff0c\u5305\u542b\u4e86\u5f88\u591a\u5f88\u591a\u65b9\u6cd5\u9519\u8bef\uff08methodological errors\uff09\u548c\u5938\u5927\u63cf\u8ff0\u3002\u4ed6\u7684\u7814\u7a76\u6ca1\u6709\u5bf9\u7167\u7ec4\u5b9e\u9a8c\u8bbe\u8ba1\uff08control group\uff09\uff0c\u6240\u4ee5\u65e0\u6cd5\u505a\u51fa\u5bf9\u6bd4\u3002\u5f53\u5176\u4ed6\u72ec\u7acb\u7684\u7b2c\u4e09\u65b9\u79d1\u5b66\u5bb6\u8bd5\u56fe\u7528\u6ca1\u6709\u63a5\u53d7\u8fc7IAHP\u65b9\u6cd5\u6cbb\u7597\u7684\u513f\u7ae5\u6765\u6bd4\u8f83\u8fd9\u4e9b\u7ed3\u679c\u65f6\uff0c\u7ed3\u679c\u6781\u5176\u7684\u5e73\u5eb8\uff08singularly unimpressive\uff09\u3002\u7b80\u800c\u8a00\u4e4b\uff0c\u505a\u5bf9\u6bd4\u8bd5\u9a8c\uff0c\u8bc1\u660e\u675c\u66fc\u5927\u5e08\u7684\u4e34\u5e8a\u8bd5\u9a8c\u7ed3\u679c\u6ca1\u6709\u6548\u679c\u3002\r\n\r\n5\u3001\u5c06\u5e0c\u671b\u5bc4\u6258\u4e8e\u4e00\u4e2a\u5b8c\u5168\u4e0d\u53ef\u80fd\u627f\u8f7d\u8fd9\u4e2a\u5e0c\u671b\u7684\u6559\u7a0b\u4e0a\uff0c\u5bf9\u4e8e\u53c2\u4e0e\u8005\u6765\u8bf4\u662f\u975e\u5e38\u6b8b\u5fcd\u7684\u3002\r\n\r\n\u8036\u9c81\u5927\u5b66\u7684\u4e00\u4f4d\u52a9\u7406\u6559\u6388\u603b\u7ed3\u675c\u66fc\u65b9\u6cd5\u4e3a\uff1a\u201c\u675c\u66fc\u6a21\u5f0f\u6280\u672f\u662f\u4ee5\u4e00\u79cd\u7834\u4ea7\u7684\u3001\u5b8c\u5168\u88ab\u629b\u5f03\u7684\u7406\u8bba\u4e3a\u57fa\u7840\uff0c\u540c\u65f6\u4e5f\u5728\u53d7\u63a7\u6761\u4ef6\u4e0b\u6d4b\u8bd5\u5931\u8d25\u2026\u8fd9\u4e2a\u8fc7\u7a0b\u6d6a\u8d39\u5bb6\u957f\u4eec\u7684\u65f6\u95f4\u3001\u7cbe\u529b\u3001\u611f\u60c5\u548c\u91d1\u94b1\u3002\u201d\r\n\r\n\u7f8e\u56fd\u513f\u79d1\u533b\u5b66\u4f1a\u65e9\u57281968\u5e74\u5c31\u5411IAHP\u5bf9\u8111\u635f\u4f24\u513f\u7ae5\u7684\u6cbb\u7597\u7a0b\u5e8f\u63d0\u51fa\u4e86\u8d28\u7591\uff0c\u4e4b\u540e\u57281999\u5e74\u30012002\u5e74\u4ee5\u53ca2005\u5e74\u53c8\u91cd\u7533\u4e86\u5bf9\u4e8e\u6cbb\u7597\u7a0b\u5e8f\u7684\u8d28\u7591\uff1a\u201c...\u8fd9\u79cd\u6cbb\u7597\u7a0b\u5e8f\u662f\u5efa\u7acb\u5728\u7b80\u5316\u7684\u4ee5\u53ca\u8fc7\u65f6\u7684\u5927\u8111\u53d1\u80b2\u7406\u8bba\u4e4b\u4e0a\u7684\uff0c\u76ee\u524d\u6240\u6709\u7684\u4fe1\u606f\u4e0d\u80fd\u8bc1\u660e\u8fd9\u79cd\u6cbb\u7597\u7684\u6709\u6548\u6027\uff0c\u4f7f\u7528\u8fd9\u79cd\u65b9\u6cd5\u6ca1\u6709\u4efb\u4f55\u4fdd\u969c...\u8fd9\u79cd\u65b9\u6cd5\u5bf9\u5bb6\u5ead\u63d0\u51fa\u7684\u9700\u6c42\u4ee5\u53ca\u671f\u671b\u592a\u9ad8\uff0c\u67d0\u79cd\u7a0b\u5ea6\u4e0a\u6d88\u8017\u4e86\u5bb6\u5ead\u7684\u8d22\u529b\u7269\u529b\u540c\u65f6\u4f1a\u9020\u6210\u7236\u6bcd\u4e0e\u5b69\u5b50\u4e4b\u95f4\u7684\u5173\u7cfb\u4ee5\u53ca\u5144\u5f1f\u59ca\u59b9\u4e4b\u95f4\u7684\u5173\u7cfb\u7d27\u5f20\u3002\u201d\r\n\r\n \r\n\u201c\u95ea\u201d\r\n\r\n\u5c31\u662f\u8fd9\u6837\u4e00\u79cd\u5efa\u7acb\u5728\u8fc7\u65f6\u548c\u88ab\u629b\u5f03\u7684\u7406\u8bba\u57fa\u7840\u4e0a\u7684\u675c\u66fc\u65b9\u6cd5\uff0c\u5230\u4e86\u4e2d\u56fd\uff0c\u5230\u4e8621\u4e16\u7eaa\uff0c\u4e2d\u56fd\u5546\u4eba\u5c06\u5176\u53d1\u626c\u5149\u5927\uff0c\u53d8\u6210\u4e00\u95e8\u5229\u6da6\u6781\u5176\u4e30\u539a\u7684\u751f\u610f\uff1a\r\n\r\n\u4e00\u5957\u675c\u66fc\u95ea\u5361\uff08\u5c31\u662f\u4e00\u6253\u5361\u7247\uff0c\u4e0a\u9762\u5370\u4e86\u5404\u79cd\u70b9\u70b9\uff0c\u6bcf\u5929\u5728\u5a74\u513f\u773c\u524d\u6643\u52a8\uff08\u4e5f\u5c31\u662f\u201c\u95ea\u201d\uff0c\u8bf7\u6ce8\u610f\u662f\u4f60\u624b\u52a8\u6643\uff0c\u4e0d\u6d89\u53ca\u4efb\u4f55\u9ad8\u79d1\u6280\uff09\uff0c\u53f7\u79f0\u95ea\u4e00\u6bb5\u65f6\u95f4\u540e\u5a74\u513f\u5c31\u5982\u4f55\u5982\u4f55\u725b\u903c\uff09\u5356900\u5143\u4eba\u6c11\u5e01\uff0c\u582a\u79f0\u5bf8\u5361\u5bf8\u91d1\uff1b\r\n\r\n\u4e00\u5957\u767d\u7eb8\uff0c\u4e00\u6839MARK\u7b14\uff0c\uff08\u610f\u601d\u662f\u4f60\u81ea\u5df1\u53ef\u4ee5\u5728\u5361\u7247\u4e0a\u753b\u675c\u66fc\u95ea\u5361\uff09\uff0c\u53f7\u79f0\u201c\u675c\u66fcDIY\u201d\uff0c\u535628\u5143\u4eba\u6c11\u5e01\u3002\r\n\r\n\u4efb\u4f55\u4e00\u4e2a\u7406\u5de5\u79d1\u751f\u90fd\u80fd\u770b\u51fa\u6765\u4e0d\u9760\u8c31\u7684\u4e1c\u897f\uff0c\u5c31\u662f\u8fd9\u6837\u4e00\u73a9\u610f\u513f\uff0c\u5728\u6dd8\u5b9d\u4e0a\u5356\u5f97\u8fd8\u633a\u706b\uff0c\u65e0\u6570\u4eba\u5728\u7ebf\u4e0a\u5404\u79cd\u8bba\u575b\u8ba8\u8bba\u5176\u7597\u6548\u3002\u5176\u79bb\u5947\u8352\u8c2c\u76f4\u8ffd\u6253\u9e21\u8840\u7529\u624b\u7597\u6cd5\u7eff\u8c46\u795e\u54c1\u3002\r\n\r\n \r\n\r\n\u6d41\u884c\u548cCCTV\r\n\r\n\u5546\u4eba\u4eec\u4e3a\u675c\u66fc\u5efa\u7acb\u4e86\u4e00\u4e2a\u4e2d\u56fd\u675c\u66fc\u7f51\uff0c\u5439\u5618\u675c\u66fc\u65b9\u6cd5\u662f\u56fd\u9645\u4e0a\u6700\u6d41\u884c\u7684\u65e9\u6559\u65b9\u6cd5\uff0c\u662fCCTV\u548c\u8be5\u7f51\u7ad9\u8054\u5408\u63a8\u5e7f\u7684\u65b9\u6cd5\u3002\r\n\r\n \r\n\r\n\u63a7\u5236\u4e66\u8bc4\r\n\r\n\u675c\u66fc\u5927\u5e08\u7684\u300aHow Smart is Your Baby\uff1f\u300b\u56fe\u4e66\u5728\u56fd\u5185\u5df2\u7ecf\u51fa\u7248\u53d1\u884c\u3002\u6709\u7f51\u53cb\u79f0\uff1a\u201c\u4f46\u662f\u5f53\u6211\u4ed4\u7ec6\u7ffb\u770b\u7f51\u4e0a\u4e66\u5e97\u7684\u51e0\u767e\u4e2a\u4e66\u8bc4\u540e\uff0c\u5b9e\u5728\u771f\u7684\u975e\u5e38\u6c14\u6124\uff01\u6211\u672c\u4eba\u662f\u51fa\u7248\u4e1a\u5185\u7684\u7f16\u8f91\uff0c\u5bf9\u4e66\u7684\u5ba3\u4f20\u8425\u9500\u624b\u6bb5\u4e5f\u6bd4\u8f83\u4e86\u89e3\uff0c\u5f53\u5f53\u7f51\u4e0a\u7684\u5927\u51e0\u767e\u4e2a\u4e66\u8bc4\u4e2d\u768490\uff05\u4ee5\u4e0a\uff08\u751a\u81f3\u66f4\u591a\uff09\u51e0\u4e4e\u53ef\u4ee5\u80af\u5b9a\u5730\u8bf4\u662f\u51fa\u7248\u793e\u7f51\u7edc\u8425\u9500\u7b56\u7565\u7684\u4ea7\u7269\uff0c\u4efb\u4f55\u6709\u81ea\u5df1\u72ec\u7acb\u89c1\u89e3\u548c\u5224\u65ad\u80fd\u529b\u7684\u4eba\u90fd\u53ef\u4ee5\u770b\u51fa\u6765\u2014\u2014\u6ca1\u6709\u4efb\u4f55\u4e00\u672c\u4e66\uff0c\u53ea\u6709\u8d5e\u7f8e\uff0c\u6ca1\u6709\u7f3a\u61be\uff08\u54ea\u6015\u662f\u4e00\u70b9\u70b9\u7684\u5ba2\u89c2\u8bc4\u4ef7\uff09\uff01\u800c\u4e14\u5728\u5e02\u573a\u5229\u76ca\u7684\u9a71\u52a8\u4e0b\uff0c\u5bf9\u8fd9\u672c\u4e66\u7684\u7f51\u7edc\u8425\u9500\u624b\u6bb5\uff08\u7531\u4e13\u95e8\u7684\u56e2\u961f\u5728\u5404\u5927\u7f51\u7ad9\u3001\u8bba\u575b\u4e0a\u53d1\u5e03\u6d88\u606f\uff0c\u5f15\u8d77\u76ee\u6807\u8bfb\u8005\u7684\u6ce8\u610f\uff09\u662f\u505a\u5f97\u5f88\u5f7b\u5e95\uff0c\u751a\u81f3\u89e6\u89d2\u5230\u8fbe\u5404\u7701\u5e02\u7684\u5c0f\u7684\u80b2\u513f\u8bba\u575b\u3002\u201d\r\n\r\n \r\n\r\n\u76d6\u697c\u56de\u590d\r\n\r\n\u53ea\u8981\u4e2d\u56fd\u5988\u5988\u5728\u5404\u4e2a\u8bba\u575b\u5bf9\u675c\u66fc\u95ea\u5361\u6216\u675c\u66fc\u65b9\u6cd5\u63d0\u51fa\u8d28\u7591\uff0c\u7acb\u523b\u5c31\u6709\u9a6c\u7532\uff08\u6ca1\u6709\u5934\u50cf\u7684id\uff09\u76d6\u697c\u56de\u590d\uff0c\u9f13\u52b1\u5988\u5988\u4eec\u575a\u6301\u4e0b\u53bb\uff0c\u575a\u6301\u5c31\u662f\u80dc\u5229\uff0c\u65e2\u7136\u4e70\u4e86\u5c31\u8981\u575a\u6301\u5230\u5e95\u3002\r\n\r\n \r\n\r\n\u5546\u4eba\u628a\u793e\u4f1a\u5316\u8425\u9500\u505a\u5f97\u5f88\u8e0f\u5b9e\uff0c\u53ef\u60dc\uff0c\u4ed6\u4eec\u63a8\u9500\u7684\u7406\u8bba\u548c\u5546\u54c1\uff0c\u4e0d\u4f46\u6ca1\u4ec0\u4e48\u7528\uff0c\u8fd8\u803d\u8bef\u5b69\u5b50\u7684\u6210\u957f\u3002\r\n\r\n\u5c31\u8fd9\u6837\uff0c\u4e00\u4e2a\u8fc7\u65f6\u7684\u3001\u88ab\u65e0\u6570\u4e13\u5bb6\u548c\u5b66\u4f1a\u62a8\u51fb\u65e0\u7528\u65e0\u6548\u65e0\u804a\u7684\u7406\u8bba\u548c\u65b9\u6cd5\uff0c\u7531\u4e8e\u7b26\u5408\u4ee5\u4e0b\u56db\u8981\u7d20\uff1a\r\n\r\n\u5356\u76f8\u5f88\u597d\u7684\u767d\u4eba\u8001\u5934\u521b\u7acb\u7684\u7406\u8bba\uff1b\r\n\u7531\u4e8e\u65e9\u5df2\u8fc7\u65f6\u548c\u88ab\u629b\u5f03\uff0c\u6240\u4ee5\u4e2d\u6587\u8d44\u6599\u8ba8\u8bba\u7684\u4e0d\u591a\uff0c\u5f88\u5bb9\u6613\u88ab\u5546\u5bb6\u5ba3\u4f20\u548c\u8f6f\u6587\u5360\u636e\uff1b\r\n\u89c1\u6548\u9700\u8981\u65f6\u95f4\u6765\u9a8c\u8bc1\uff0c\u6240\u4ee5\u7ed9\u5546\u5bb6\u4eec\u7559\u51fa\u4e86\u5145\u88d5\u7684\u9500\u552e\u65f6\u95f4\uff1b\r\n\u6d89\u53ca\u4e2d\u56fd\u6700\u91d1\u8d35\u7684\u5b69\u5b50\uff0c\u6240\u4ee5\u53ea\u8981\u627f\u8bfa\u4e00\u4e2a\u613f\u666f\uff0c\u5c31\u7b97\u5f00\u51fa\u5929\u4ef7\u4e5f\u6709\u5927\u91cf\u5bb6\u957f\u613f\u610f\u4e70\u5355\u3002\r\n\u6210\u4e3a\u4e00\u95e8\u597d\u751f\u610f\u3002\r\n\r\n\u53ea\u662f\u53ef\u601c\u4e2d\u56fd\u5927\u9646\u7684\u6c11\u4f17\uff0c\u4ed6\u4eec\u6210\u4e86\u80e1\u4e07\u6797\u674e\u4e00\u5f20\u609f\u672c\u675c\u66fc\u4eec\u7684\u8dd1\u9a6c\u573a\u3002\r\n\r\n\uff08\u6587\uff1a\u90d1\u6600\uff09", "imagename": "106142a833af4857964abe70106e377f.jpg", "infoid": 363610, "category": "technology_other", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u675c\u66fc\u95ea\u5361", "\u513f\u7ae5\u6559\u80b2"]}, {"url": null, "title": "\u592a\u9633\u80fd\u76f8\u673a\u80cc\u5e26", "tags": "\u76f8\u673a \u8bbe\u8ba1 ", "name": "geekzhang", "posttime": "2010-09-01 10:31:08", "ip": "219.138.39.171", "mark": 1, "note": "\u6b64\u6b3e\u76f8\u673a\u7684\u80cc\u5e26\u4e3a\u592a\u9633\u80fd\u88c5\u7f6e\uff0c\u53ef\u4e3a\u76f8\u673a\u63d0\u4f9b\u7535\u5