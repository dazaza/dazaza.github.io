c5f\u8054\u901a\u65d7\u4e0b\u6570\u636e\u4e2d\u5fc3\u9f99\u6c5fIDC\uff0c\u542f\u7528QQ.cn\u57df\u540d\u4f5c\u4e3a\u9996\u9875\u7684\u65b0\u7f51\u5740\u3002QQ.cn\u7684\u57df\u540d\u6ce8\u518c\u4fe1\u606f\u663e\u793a\uff0c\u6ce8\u518c\u673a\u6784\u4e3a\u8054\u901a\u9ed1\u9f99\u6c5f\u5206\u516c\u53f8\u3002\u6b64\u524d\uff0c\u9f99\u6c5fIDC\u4f7f\u7528\u7684\u9ed1\u9f99\u6c5f\u4fe1\u606f\u6e2f\u4e8c\u7ea7\u57df\u540d(idc.hlj.net)\u4ecd\u80fd\u6b63\u5e38\u8bbf\u95ee\u3002\r\n\r\n2003\u5e743\u670817\u65e5\uff0c\u4e2d\u56fd\u56fd\u5bb6\u9876\u7ea7\u57df\u540d.cn\u4e0b\u7684\u4e8c\u7ea7\u57df\u540d\u5168\u7403\u5f00\u653e\u6ce8\u518c\u3002\u5c31\u5728.CN\u5f00\u901a\u6ce8\u518c\u4e0d\u523020\u5206\u949f\u7684\u65f6\u95f4\u5185\uff0cQQ.cn\u88ab\u786e\u8ba4\u4e3a\u53a6\u95e8\u6ce8\u518c\u5546\u5546\u52a1\u4e2d\u56fd\u5347\u7ea7\u6210\u529f\uff0c\u6ce8\u518c\u65b9\u662f\u539f\u5148\u4e09\u7ea7\u57df\u540dQQ.hl.cn\u7684\u6301\u6709\u8005\u9ed1\u9f99\u6c5f\u6570\u636e\u901a\u4fe1\u5c40\u3002\r\n\r\n\u5b9e\u9645\u4e0a\u9664QQ.cn\u4e4b\u5916\uff0cQQ\u76f8\u5173\u57df\u540d\u7684\u5f52\u5c5e\u95ee\u9898\uff0c\u4e00\u76f4\u4e0e\u817e\u8baf\u6709\u7740\u5343\u4e1d\u4e07\u7f15\u7684\u8054\u7cfb\u3002\r\n\r\n\u4e3a\u4e86\u80fd\u6709\u4e00\u4e2a\u597d\u7684\u7f51\u7ad9\u5165\u53e3\uff0c\u817e\u8baf\u5206\u522b\u57281998\u5e7411\u67087\u65e5\u548c1999\u5e741\u670826\u65e5\u6ce8\u518c\u4e86\u4e0eOICQ\u5bf9\u5e94\u7684oicq.com\u3001oicq.net\u57df\u540d\u3002\u4f46\u57281999\u5e748\u6708\u5e95\u81f39\u6708\u4e2d\uff0c\u77ed\u77ed10\u5929\u65f6\u95f4\u5185\uff0cAOL\u5148\u540e\u4e24\u6b21\u5411\u817e\u8baf\u53d1\u9001\u63aa\u8f9e\u4e25\u5389\u7684\u6295\u8bc9\u4fe1\uff0c\u6307\u8d23\u817e\u8baf\u4fb5\u72af\u77e5\u8bc6\u4ea7\u6743\uff0c\u8981\u6c42\u817e\u8baf\u5c06\u57df\u540d\u514d\u8d39\u8f6c\u8ba9\u3002\r\n\r\n2000\u5e743\u670821\u65e5\uff0c\u7f8e\u56fd\u4ef2\u88c1\u5458\u8a79\u59c6\u58eb-\u5361\u83ab\u8fea\u7b7e\u7f72\u4e86\u4ef2\u88c1\u5224\u51b3\u4e66\uff0c\u5224\u5b9a\u817e\u8baf\u5c06