b\u771f\u662f\u53ef\u7231\u53c8\u7a9d\u5fc3\u554a\u3002\u65e7\u624b\u63d0\u7bb1\u8fd8\u80fd\u6539\u9020\u6210\u534e\u4e3d\u4e3d\u7684\u6905\u5b50\u548c\u97f3\u7bb1\u54e6\u3002", "imagename": "ef553457d65e4f749a0dce8069146441.jpg", "infoid": 492547, "category": "life_fashion", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "life", "via": null, "real_tags": []}, {"url": "http://thisiscolossal.com/2011/09/yesno-by-markus-raetz/?utm_source=feedburner&utm_medium=feed&utm_campaign=Feed%3A+colossal+%28Colossal%29", "title": "Yes and No", "tags": "\u8bbe\u8ba1 ", "name": "geekzhang", "posttime": "2011-09-21 11:03:13", "ip": "123.158.48.136", "mark": 0, "note": "\u5728\u67d0\u4e2a\u89d2\u5ea6\u770b\u662fYES\uff0c\u800c\u5728\u53e6\u5916\u4e00\u4e2a\u89d2\u5ea6\u5c31\u53d8\u6210\u4e86NO\uff0c\u6765\u81eaMarkus Raetz\u7684\u8bbe\u8ba1\u3002", "imagename": "414796f4fbc844e497a213c1e8f09891.jpg", "infoid": 492482, "category": "technology_design", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u8bbe\u8ba1"]}, {"url": "http://www.nphoto.net/news/2011-09/20/07f6b19642554286.shtml", "title": "\u4fc4\u7f57\u65af\u7537\u5b69\u7f6e\u8eab\u5efa\u7b51\u7269\u9876\u7aef\u62cd\u9ad8\u7a7a\u60ca\u53f9\u7f8e\u666f", "tags": "\u6444\u5f71 \u5efa\u7b51 \u5192\u9669 ", "name": "geekzhang", "posttime": "2011-09-21 10:48:36", "ip": "123.158.48.136", "mark": 0, "note": "\u4fc4\u7f57\u65af19\u5c81\u5b66\u751f\u9a6c\u62c9\u7279-\u675c\u6bd4\u7acb\u722c\u4e0a\u83ab\u65af\u79d1\u6700\u9ad8\u5efa\u7b51\u7269\uff0c\u62cd\u6444\u4e00\u4e9b\u4ee4\u4eba\u77a0\u76ee\u7ed3\u820c\u7684\u7cbe\u7f8e\u7167\u7247\u300218\u4e2a\u6708\u524d\u4ed6\u4e70\u4e86\u4e00\u90e8\u4f73\u80fd\u76f8\u673a\uff0c\u5e76\u7acb\u523b\u51b3\u5b9a\u5f00\u59cb\u62cd\u6444\u4e00\u4e9b\u4e0e\u4f17\u4e0d\u540c\u7684\u7f8e\u4e3d\u7167\u7247\u3002\r\n \r\n\u6700\u521d\u4ed6\u722c\u4e0a\u81ea\u5bb6\u623f\u9876\uff0c\u4ece\u9ad8\u7a7a\u6355\u6349\u4ee4\u4eba\u60ca\u53f9\u7684\u7f8e\u666f\uff0c\u4f46\u662f\u5f88\u5feb\u4ed6\u5c31\u89c9\u5f97\u9ad8\u5ea6\u8fd8\u4e0d\u591f\uff0c\u51b3\u5b9a\u722c\u5230\u66f4\u9ad8\u7684\u5730\u65b9\u3002\u4ed6\u4e0e\u52c7\u6562\u7684\u670b\u53cb\u548c\u6a21\u7279\u4e00\u8d77\u8d81\u8b66\u536b\u4e0d\u5907\uff0c\u5077\u5077\u722c\u4e0a\u4e00\u4e9b\u83ab\u65af\u79d1\u6700\u9ad8\u7684\u5efa\u7b51\u7269\uff0c\u4ea7\u751f\u8fd9\u4e9b\u4ee4\u4eba\u53f9\u4e3a\u89c2\u6b62\u7684\u56fe\u7247\u3002\u8fd9\u4e9b\u4ee4\u4eba\u96be\u4ee5\u7f6e\u4fe1\u7684\u7167\u7247\u663e\u793a\uff0c\u5927\u80c6\u7684\u5e74\u8f7b\u4eba\u7f6e\u8eab\u5728\u9ad8\u8fbe\u6570\u767e\u82f1\u5c3a\u7684\u94c1\u5854\u4e0a\uff0c\u6b63\u5728\u534a\u7a7a\u4e2d\u884c\u8d70\uff0c\u6216\u8005\u5728\u6ca1\u6709\u4f69\u6234\u5b89\u5168\u5e26\u7b49\u5b89\u5168\u63aa\u65bd\u7684\u60c5\u51b5\u4e0b\uff0c\u6b63\u5728\u4e00\u5ea7\u6469\u5929\u5927\u697c\u7684\u8fb9\u7f18\u201c\u95f2\u5ead\u4fe1\u6b65\u201d\u3002\r\n \r\n\u9a6c\u62c9\u7279\u8bf4\uff1a\u201c\u6211\u7f6e\u8eab\u5728\u5efa\u7b51\u7269\u9876\u7aef\u65f6\uff0c\u4f1a\u611f\u89c9\u6574\u4e2a\u4e16\u754c\u5c31\u5728\u6211\u7684\u811a\u4e0b\u3002\u6211\u9762\u4e34\u7684\u6240\u6709\u95ee\u9898\u548c\u9ebb\u70e6\u662f\u62c5\u5fc3\u4f1a\u5931\u8db3\u6389\u4e0b\u53bb\u3002\u7ad9\u5728\u9ad8\u5904\u4ee4\u6211\u5174\u594b\u4e0d\u5df2\u3002\u6211\u6b63\u5728\u6b23\u8d4f\u5bb6\u4e61\u7684\u57ce\u9547\u98ce\u666f\u3002\u5b83\u8ba9\u6211\u5145\u6ee1\u80fd\u91cf\u548c\u70ed\u60c5\uff0c\u5e0c\u671b\u62cd\u6444\u66f4\u591a\u65b0\u7167\u7247\u3002\u6211\u4e00\u76f4\u5bf9\u6444\u5f71\u975e\u5e38\u611f\u5174\u8da3\uff0c\u51e0\u5e74\u524d\u6211\u4e70\u4e86\u7b2c\u4e00\u90e8\u76f8\u673a\u3002\u6211\u60f3\u7528\u5b83\u62cd\u6444\u6211\u80fd\u62cd\u5230\u7684\u6700\u4ee4\u4eba\u4e0d\u53ef\u601d\u8bae\u7684\u7167\u7247\u2014\u2014\u4e00\u4e9b\u4ee5\u524d\u4ece\u6ca1\u6709\u4eba\u62cd\u6444\u8fc7\u7684\u7167\u7247\u3002\u6700\u521d\u6211\u7ad9\u5728\u81ea\u5bb6\u5c4b\u9876\u4e0a\u62cd\u7167\uff0c\u4f46\u662f\u5f88\u5feb\u6211\u5c31\u611f\u5230\u538c\u5026\u4e86\uff0c\u5e0c\u671b\u80fd\u722c\u5230\u66f4\u9ad8\u5904\uff0c\u62cd\u6444\u66f4\u5927\u3001\u66f4\u597d\u7684\u7167\u7247\u3002\u201d\r\n \r\n\u201c\u4e8e\u662f\u6211\u4e0e\u670b\u53cb\u4e00\u8d77\u722c\u4e0a\u4e00\u5ea733\u5c42\u9ad8\u7684\u5efa\u7b51\u7269\u3002\u5b83\u7684\u9ad8\u5ea6\u5927\u7ea6\u662f120\u7c73\uff0c\u6211\u4eec\u8d70\u5230\u9ad8\u697c\u7684\u8fb9\u7f18\uff0c\u6211\u5f00\u59cb\u62cd\u6444\u7167\u7247\u3002\u90a3\u662f\u4e00\u6b21\u6fc0\u52a8\u4eba\u5fc3\u7684\u7ecf\u5386\uff0c\u6211\u4eec\u771f\u5e0c\u671b\u518d\u6765\u4e00\u6b21\u3002\u6211\u5de7\u5999\u8eb2\u8fc7\u4fdd\u536b\uff0c\u975e\u6cd5\u8fdb\u5165\u5efa\u7b51\uff0c\u5077\u5077\u722c\u4e0a\u5efa\u7b51\u7269\u9876\u7aef\uff0c\u62cd\u6444\u4e86\u5927\u91cf\u7167\u7247\u3002\u4f46\u662f\u6211\u8ba4\u4e3a\uff0c\u80fd\u83b7\u5f97\u8fd9\u4e9b\u4ee4\u4eba\u60ca\u53f9\u7684\u7167\u7247\uff0c\u5192\u70b9\u9669\u662f\u503c\u5f97\u7684\u3002\u201d\u9a6c\u62c9\u7279\u7684\u7167\u7247\u663e\u793a\uff0c\u4ed6\u7684\u670b\u53cb\u5728\u8ddd\u79bb\u5730\u9762\u6570\u767e\u82f1\u5c3a\u7684\u6a2a\u6881\u4e0a\u6447\u6447\u6643\u6643\u5730\u8d70\u7740\u3002\u4ed6\u4eec\u5e76\u672a\u4f7f\u7528\u5b89\u5168\u5e26\uff0c\u968f\u65f6\u90fd\u6709\u53ef\u80fd\u4f1a\u4ece\u9ad8\u5904\u5760\u843d\u8eab\u4ea1\u3002\u5176\u4e2d\u4e00\u5f20\u7167\u7247\u663e\u793a\uff0c\u8fd9\u4e9b\u9752\u5c11\u5e74\u722c\u4e0a\u4fc4\u7f57\u65af\u7684\u4e03\u5ea7\u524d\u82cf\u8054\u6469\u5929\u697c\u4e4b\u4e00\uff0c\u5229\u7528\u4e00\u628a\u68af\u5b50\u722c\u5230\u5efa\u7b51\u7269\u7684\u8fb9\u7f18\u5904\u3002\r\n \r\n\u53e6\u4e00\u5f20\u7167\u7247\u663e\u793a\uff0c\u4ed6\u7684\u4e00\u4f4d\u670b\u53cb\u7ad9\u5728\u5f7c\u5f97\u5927\u5e1d\u7684\u7eaa\u5ff5\u7891\u8fb9\u7f18\u5904\uff0c\u8fd9\u5ea7\u7eaa\u5ff5\u7891\u9ad8215\u7c73\u3002\u8fd9\u4e9b\u80c6\u5927\u5305\u5929\u7684\u5e74\u8f7b\u4eba\u751a\u81f3\u7ad9\u5728\u83ab\u65af\u79d1\u5854\u9876\u4e0a\u62cd\u7167\u3002\u9a6c\u62c9\u7279\u8