f\uff0c\u817e\u8baf\u4eca\u65e5\u5411\u5176\u7528\u6237\u53d1\u5e03\u6d88\u606f\u79f0\uff0c\u5c06\u5728\u88c5\u6709360\u8f6f\u4ef6\u7684\u7535\u8111\u4e0a\u505c\u6b62\u8fd0\u884cQQ\u8f6f\u4ef6\u3002\u4ee5\u4e0b\u662f\u817e\u8baf\u7684\u516c\u5f00\u4fe1\u5168\u6587\uff1a\u4eb2\u7231\u7684QQ\u7528\u6237\uff1a\u5f53\u60a8\u770b\u5230\u8fd9\u5c01\u4fe1\u7684\u65f6\u5019\uff0c\u6211\u4eec\u521a\u521a\u4f5c\u51fa\u4e86\u4e00\u4e2a\u975e\u5e38\u8270\u96be\u7684\u51b3\u5b9a\u3002<br/><br/>11\u67083\u65e5\u4e0b\u53486\u70b9\uff0c\u817e\u8baf\u516c\u53f8\u608d\u7136\u53d1\u5e03\u516c\u544a\uff0c\u5ba3\u5e03\u5c06\u5728\u88c5\u6709360\u8f6f\u4ef6\u7684\u6240\u6709\u7535\u8111\u4e0a\u505c\u6b62\u8fd0\u884cQQ\u8f6f\u4ef6\uff0c\u8fd9\u662f\u7f6e6\u4ebfQQ\u7528\u6237\u5b89\u5371\u548c\u5229\u76ca\u4e8e\u5168\u7136\u4e0d\u987e\u7684\u66b4\u884c\u3002<br/><br/>11\u67083\u65e5\uff0c\u4e2d\u56fd\u6700\u5927\u7684\u4e92\u8054\u7f51\u5b89\u5168\u670d\u52a1\u63d0\u4f9b\u5546360\u516c\u53f8\u5ba3\u5e03\u63a8\u51faWEBQQ\u5ba2\u6237\u7aef\uff0c\u8be5\u6b3e\u8f6f\u4ef6\u53ef\u4ee5\u4fdd\u8bc1\u7528\u6237\u65e2\u80fd\u987a\u7545\u7684\u804a\u5929\uff0c\u540c\u65f6\u4e5f\u80fd\u907f\u514d\u88abQQ\u8f6f\u4ef6\u5077\u5077\u626b\u63cf\u786c\u76d8\u3002\u8be5\u7248\u672c\u9002\u7528\u4e8e\u90a3\u4e9b\u4ec5\u4ec5\u9700\u8981QQ\u57fa\u672c\u7684\u804a\u5929\u529f\u80fd\uff0c\u4e14\u504f\u7231\u7b80\u6d01\u7684\u4eba\u58eb\u4f7f\u7528\u3002<br/><br/>\u817e\u8bafQQ\u7a7a\u95f4\u7684\u516c\u544a\u622a\u56fe 11\u67083\u65e5\u665a\u95f4\u6d88\u606f\uff0c\u7ee7\u817e\u8baf\u5ba3\u5e03\u5c06\u5728\u88c5\u6709360\u8f6f\u4ef6\u7684\u7535\u8111\u4e0a\u505c\u6b62\u8fd0\u884cQQ\u8f6f\u4ef6\u540e\uff0c\u817e\u8bafQQ\u7a7a\u95f4\u5ba3\u5e03\u4e0d\u652f\u6301360\u6d4f\u89c8\u5668\u8bbf\u95ee\u3002\u6839\u636e\u817e\u8bafQQ\u7a7a\u95f4\u7684\u516c\u544a\uff0c\u79f0\u201c\u5c0a\u656c\u7684QQ\u7a7a\u95f4\u7528\u6237\uff0cQQ\u7a7a\u95f4\u4e0d\u652f\u6301360\u6d4f\u89c8\u5668\u8bbf\u95ee\u201d\u3002<br/><br/>11\u67083\u65e5\u6d88\u606f\uff0c\u5c31\u5728360\u8463\u4e8b\u957f\u5468\u9e3f\u794e\u521a\u521a\u5ba3\u5e03\u63a8\u51faWEB QQ\u5ba2\u6237\u7aef\u4e4b\u540e\uff0c\u817e\u8baf\u516c\u53f8\u4fbf\u5173\u95ed\u4e86WEB QQ\u7f51\u7ad9\u5165\u53e3\u3002<br/><br/>11\u67083\u65e5\u665a\u95f4\u6d88\u606f\uff0c360\u6263\u6263\u4fdd\u9556\u5b98\u65b9\u7f51\u9875\u548c\u4e0b\u8f7d\u9875\u9762\u5747\u4e0d\u80fd\u6b63\u5e38\u8bbf\u95ee\uff0c\u76ee\u524d360\u65b9\u9762\u5c1a\u672a\u5bf9\u6b64\u505a\u51fa\u6b63\u5f0f\u56de\u5e94\u3002\u4e0e\u6b64\u540c\u65f6\uff0c360\u9996\u9875\u4e0a\u9664\u4e00\u6761\u65b0\u95fb\u4e4b\u5916\uff0c\u4e5f\u65e0\u6cd5\u627e\u5230\u4efb\u4f55\u4e0e360\u6263\u6263\u4fdd\u9556\u6709\u5173\u7684\u5165\u53e3\u3002<br/><br/>360\u5e94\u5bf9\u817e\u8baf\u5c01\u6740\u53d1\u5e03\u7684WebQQ\u5ba2\u6237\u7aef\u63a8\u51fa\u4e0d\u5230\u534a\u5c0f\u65f6\u5373\u88ab\u817e\u8baf\u5173\u95ed\u7aef\u53e3\u800c\u4e0d\u80fd\u8bbf\u95ee\uff0c360\u516c\u53f8\u900f\u9732\uff0c\u8fd8\u6709\u5176\u4ed6\u7684\u89e3\u51b3\u65b9\u6848\u8ba9\u7528\u6237\u53ef\u4ee5\u540c\u65f6\u4f7f\u7528360\u548cQQ\uff0c\u76ee\u524d\u6b63\u5728\u51c6\u5907\u4e2d\u3002<br/><br/>360\u5728\u63a5\u53d7\u65b0\u6d6a\u79d1\u6280\u8fde\u7ebf\u65f6\u8bc1\u5b9e\uff0c\u7531\u6263\u6263\u4fdd\u9556\u548c\u817e\u8bafQQ\u4e4b\u95f4\u5b58\u5728\u6280\u672f\u51b2\u7a81\u4e8e\uff0c\u5df2\u7ecf\u5bf9\u8fd9\u6b3e\u4ea7\u54c1\u505a\u4e0b\u7ebf\u5904\u7406\u3002\u76ee\u524d\uff0c360\u6263\u6263\u4fdd\u9556\u5b98\u65b9\u7f51\u9875\u548c\u4e0b\u8f7d\u9875\u9762\u5747\u5df2\u4e0d\u80fd\u6b63\u5e38\u8bbf\u95ee\uff0c\u800c\u5176\u9996\u9875\u4e5f\u65e0\u6cd5\u627e\u5230\u8fd9\u6b3e\u4ea7\u54c1\u7684\u4efb\u4f55\u5165\u53e3\u3002<br/><br/>\u5728360\u6b63\u5f0f\u4e0b\u7ebf\u6263\u6263\u4fdd\u9556\u4ea7\u54c1\u540e\uff0c\u5176\u5bf9\u5916\u53d1\u5e03\u201c<a target=\"_blank\" rel=\"nofollow\" href=\"http://tech.sina.com.cn/i/2010-11-03/21364824509.shtml\">360\u81f4\u7f51\u6c11\u7684\u7d27\u6025\u6c42\u52a9\u4fe1</a>\u201d\uff0c\u79f0\