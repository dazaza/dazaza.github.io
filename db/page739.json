[{"url": "http://www.xtit.net/post/Chatroll/", "title": "Chatroll\uff1a\u521b\u5efa\u4f60\u7684\u7f51\u7edc\u751f\u6d3b\u793e\u533a", "tags": "SNS \u793e\u4f1a\u5316 web2.0 \u793e\u533a", "name": "xjyzhenai", "posttime": "2008-11-24 13:07:58", "ip": "222.243.160.37", "mark": 2, "note": "\u7f51\u7edc\u8fd9\u73a9\u610f\uff0c\u5c31\u662f\u4e00\u4e2a\u865a\u62df\u7684\u73b0\u5b9e\uff01\u8d8a\u6765\u8d8a\u591a\u7684\u865a\u62df\u73b0\u5b9e\u670d\u52a1\u5728\u4e92\u8054\u7f51\u4e0a\u5c55\u5f00\u3002\u4f34\u968f\u7740\u865a\u62df\u4eba\u751f\u7b49\u4e00\u6279\u73b0\u5b9e\u6a21\u62df\u6e38\u620f\u7684\u6210\u529f\uff0c\u4eba\u4eec\u5bf9\u4e92\u8054\u7f51\u865a\u62df\u73b0\u5b9e\u5df2\u7ecf\u6709\u4e86\u5f88\u6df1\u5165\u7684\u4e86\u89e3\u3002\u5728web2.0\u65f6\u4ee3\uff0cSNS\u4e5f\u5df2\u7ecf\u88ab\u8d8a\u6765\u8d8a\u591a\u7684\u4eba\u4eec\u6240\u4f7f\u7528\u5e76\u719f\u6089\uff0c\u4e00\u5927\u6279\u793e\u4f1a\u5316\u7f51\u7edc\u670d\u52a1\u4e5f\u5e94\u8fd0\u800c\u751f\u3002\r\n\r\nimage\u3000\u3000Chatroll\u6b63\u662f\u8fd9\u6837\u4e00\u4e2a\u5bf9\u73b0\u5b9e\u751f\u6d3b\u9ad8\u5ea6\u6a21\u62df\u7684\u7f51\u7edc\u751f\u6d3b\u793e\u533a\u3002\u5728Chatroll\uff0c\u4f60\u53ef\u4ee5\u521b\u5efa\u60a8\u4f60\u81ea\u5df1\u7684\u751f\u6d3b\u793e\u533a\u7f51\u7ad9\uff0c\u7535\u89c6\u8282\u76ee\u3001\u4f53\u80b2\u961f\u4f0d\u3001\u7ec4\u7ec7\u3001FANS\u4ff1\u4e50\u90e8\u3001\u73b0\u573a\u6d3b\u52a8\u3001\u7f51\u4e0a\u4f1a\u8bae\u573a\u6240\uff0c\u6216\u4efb\u4f55\u4f60\u559c\u6b22\u7684\u4e8b\u7269\uff01\r\n\r\n\u3000\u3000\u5728Chatroll\u7684\u7f51\u7edc\u751f\u6d3b\u793e\u533a\u4e2d\uff0c\u4f60\u80fd\u548c\u670b\u53cb\u5206\u4eab\u4e0e\u751f\u6d3b\u76f8\u5173\u7684\u5f71\u7247\uff0c\u56fe\u7247\u53ca\u7f51\u7ad9\u3002\u5e76\u5728\u540c\u4e00\u65f6\u95f4\u53c2\u4e0e\u591a\u4e2a\u751f\u6d3b\u793e\u533a\uff0c\u57fa\u4e8eChatroll\u7684\u9769\u547d\u6027SNS\u754c\u9762\u3002 \u4e0eChatroll\u76f8\u7ed3\u5408\u7684\u793e\u4f1a\u529b\u91cf\u4e0e\u793e\u4f1a\u7f51\u7edc\u7684\u4ea4\u4e92\u