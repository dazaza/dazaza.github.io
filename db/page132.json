09\u8272"]}, {"url": "http://www.vinuu.com/post-607.html", "title": "\u6700\u5177\u521b\u610f\u73af\u4fdd\u516c\u76ca\u5e7f\u544a", "tags": "", "name": "vinuu", "posttime": "2011-05-22 17:39:31", "ip": "123.146.221.67", "mark": 0, "note": "\u521b\u610f\u4ee4\u73af\u4fdd\u610f\u8bc6\u66f4\u52a0\u6df1\u5165\u4eba\u5fc3\uff0c\u5728\u6211\u4eec\u6367\u8179\u4e4b\u4f59\u66f4\u8981\u591a\u4e00\u70b9\u601d\u8003\uff1a\u5730\u7403\u662f\u6211\u4eec\u4eba\u7c7b\u7684\u5bb6\u56ed\uff0c\u6c34\u548c\u7a7a\u6c14\u662f\u6211\u4eec\u8d56\u4ee5\u751f\u5b58\u7684\u6839\u672c\uff0c\u52a8\u7269\u662f\u6211\u4eec\u7684\u670b\u53cb\uff0c\u4eba\u7c7b\u662f\u65f6\u5019\u53cd\u7701\u4e86\u3002SAFE\u7ec4\u7ec7\u5728\u8fc7\u53bb70\u5e74\u91cc\u4e00\u76f4\u5728\u4e3a\u4fdd\u62a4\u52a8\u7269\u800c\u52aa\u529b\uff0c\u4ed6\u4eec\u63ed\u9732\u8650\u5f85\u52a8\u7269\u7684\u4e8b\u4ef6\uff0c\u5e76\u4e14\u5728\u5168\u7403\u53d1\u52a8\u53cd\u5bf9\u7528\u52a8\u7269\u8fdb\u884c\u5b9e\u9a8c\u7684\u8fd0\u52a8\u3002SAFE\u7ec4\u7ec7\u4e3b\u8981\u4f7f\u7528\u516c\u5171\u5ba3\u4f20\u3001\u5e7f\u544a\u3001\u653f\u6cbb\u6e38\u8bf4\u7b49\u624b\u6bb5\u53bb\u63ed\u9732\u548c\u8d28\u7591\u52a8\u7269\u5b9e\u9a8c\u548c\u5546\u4e1a\u5f00\u53d1\u4e2d\u5bf9\u52a8\u7269\u7684\u8650\u5f85\u3002\u4e0a\u9762\u7684\u4e24\u4e2a\u5e7f\u544a\u4e3b\u8981\u662f\u9488\u5bf9\u5546\u4e1a\u5f00\u53d1\u4e2d\u7684\u8650\u5f85\u52a8\u7269\u7684\u4e8b\u4ef6\uff0c\u5bf9\u90a3\u4e9b\u628a\u52a8\u7269\u76ae\u6bdb\u505a\u684c\u5e03\u3001\u957f\u9774\u548c\u5176\u4ed6\u76ae\u6bdb\u5546\u54c1\u7684\u884c\u4e3a\u63d0\u51fa\u8d28\u7591\u3002\u5728\u7f8e\u6d32\u8c79\u7684\u8eab\u4e0a\u6807\u6ce8\u4e0a\u8863\u670d\u7684\u6807\u7b7exL\u548cS\u3002\u8fd9\u5219\u7531\u5965\u7f8e\u5e7f\u544a\u516c\u53f8\u63a8\u51fa\u7684\u5e7f\u544a\u7528\u6765\u544a\u8bc9\u4eba\u4eec\uff1a\u8ffd\u6c42\u65f6\u9ae6\u5bf9\u5927\u81ea\u7136\u7684\u4f24\u5bb3\u6bd4\u4f60\u60f3\u8c61\u5f97\u8981\u591a\u3002\u8fd9\u4e2a\u516c\u5171\u5395\u6240\u91cc\u7684\u7eb8\u5dfe\u76d2\u5370\u7740\u4e00\u4e2a\u5357\u7f8e\u5927\u9646\u7684\u56fe\u5f62\u3002\u76d2\u5185\u7684\u7eff\u8272\u7eb8\u5dfe\u4ee3\u8868\u5357\u7f8e\u6d32\u7684\u70ed\u5e26\u96e8\u6797\u3002\u5f53\u76d2\u5185\u7684\u7eb8\u5dfe\u88ab\u6162\u6162\u7684\u62bd\u51fa\u65f6\uff0c\u6211\u4eec\u5c06\u770b\u5230\u7eff\u8272\u90e8\u5206\u5728\u5357\u7f8e\u5927\u9646\u7684\u56fe\u5f62\u4e0a\u6162\u6162\u51cf\u5c11\u3002\u8fd9\u4ee3\u8868\u7740\u4e00\u6b21\u6027\u7eb8\u5dfe\u5bf9\u5357\u7f8e\u5927\u9646\u70ed\u5e26\u96e8\u6797\u9020\u6210\u7684\u6076\u52a3\u5f71\u54cd\u3002\u636e\u56fd\u5916\u5a92\u4f53\u62a5\u9053\uff0c\u4eba\u4eec\u6bcf\u5929\u90fd\u8981\u63a5\u89e6\u5404\u79cd\u5e7f\u544a\uff0c\u5176\u4e2d\u4e00\u4e9b\u4f18\u79c0\u4f5c\u54c1\u80fd\u8ba9\u4eba\u5370\u8c61\u6df1\u523b\uff0c\u6709\u4e9b\u8fd8\u9700\u8981\u8054\u60f3\u624d\u80fd\u7406\u89e3\u5176\u4e2d\u7684\u610f\u5473\u3002\u4ee5\u4e0b\u5217\u4e3e\u4e8615\u4e2a\u975e\u5e38\u4f18\u79c0\u7684\u73af\u4fdd\u5e7f\u544a\uff0c\u4e00\u5b9a\u80fd\u8ba9\u4f60\u7406\u89e3\u8bbe\u8ba1\u5e08\u7684\u715e\u8d39\u82e6\u5fc3\u548c\u4e30\u5bcc\u60f3\u8c61\u529b\uff0c\u5e76\u4e14\u8ba9\u4f60\u76f8\u4fe1\u73af\u4fdd\u7edd\u5bf9\u4e0d\u662f\u4e00\u79cd\u7a7a\u8bdd\u3002\u8fd9\u79cd\u751f\u6001\u5e7f\u544a\u4f7f\u7528\u7684\u662f\u4e00\u4e2a\u6ce2\u6d6a\u578b\u7684\u8986\u76d6\u7269\uff0c\u5f53\u592a\u9633\u7684\u5347\u8d77\u65f6\uff0c\u5e7f\u544a\u724c\u4e0a\u6ce2\u6d6a\u5f0f\u7684\u9634\u5f71\u4e0a\u5347\uff0c\u4ee5\u6b64\u6765\u8be0\u91ca\u5168\u7403\u53d8\u6696\u9020\u6210\u7684\u6d77\u5e73\u9762\u4e0a\u5347\u3002\u4e00\u4e2a\u5de8\u578b\u9ed1\u4e91\u72b6\u7684\u5927\u6c14\u7403\u8fde\u63a5\u5728\u8f66\u7684\u6392\u6c14\u7ba1\u4e0a\uff0c\u5e76\u7528\u8f66\u5b50\u4e00\u5929\u6392\u51fa\u7684\u5c3e\u6c14\u6765\u5145\u6ee1\u6c14\u7403\u3002\u9ed1\u4e91\u72b6\u6c14\u7403\u4e0a\u5199\u7740\uff0c\u201c\u5982\u679c\u4f60\u4e00\u5929\u4e0d\u5f00\u8f66\u7684\u8bdd\uff0c\u770b\u770b\u6211\u4eec\u547c\u5438\u7684\u7a7a\u6c14\u4e2d\u80fd\u5c11\u6392\