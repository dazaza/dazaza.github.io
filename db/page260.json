u793a\u4e86Chrome OS\u64cd\u4f5c\u7cfb\u7edf\u7684\u6700\u65b0\u8fdb\u5c55\uff0c\u63a8\u51fa\u4e86\u914d\u5957\u7684\u5e94\u7528\u5546\u5e97\uff0c\u5e76\u4e14\u5f00\u5c55\u4e86\u4e00\u4e2a\u786c\u4ef6\u6d4b\u8bd5\u9879\u76ee(\u6b63\u5f0f\u4ea7\u54c1\u8981\u52302011\u5e74\u4e2d\u624d\u80fd\u63a8\u51fa)\u3002\u4f46\u8fd9\u4e00\u5207\u4f3c\u4e4e\u90fd\u65e0\u6d4e\u4e8e\u4e8b\u3002\u867d\u7136\u8c37\u6b4cCEO\u57c3\u91cc\u514b&#183\uff1b\u65bd\u5bc6\u7279(Eric Schmidt)\u5e0c\u671b\u5c06Chrome OS\u6253\u9020\u6210\u4e3a\u64cd\u4f5c\u7cfb\u7edf\u9886\u57df\u201c\u53ef\u884c\u7684\u7b2c\u4e09\u9009\u62e9\u201d\uff0c\u4f46\u8fd9\u4f3c\u4e4e\u96be\u4ee5\u5b9e\u73b0\u3002\r\n\r\n\u3000\u3000\u76ee\u524d\uff0c\u79d1\u6280\u9886\u57df\u7684\u70ed\u95e8\u8d8b\u52bf\u662f\u793e\u4ea4\u3001\u5b9e\u65f6\u4fe1\u606f\u3001\u79fb\u52a8\u548c\u4e91\u8ba1\u7b97\u3002Chrome OS\u53ea\u9488\u5bf9\u4e91\u8ba1\u7b97\u4e00\u9879\u8fdb\u884c\u4e86\u4f18\u5316\u3002Chrome OS\u53ca\u5176\u7528\u6237\u754c\u9762\u4e1d\u6beb\u6ca1\u6709\u878d\u5165\u793e\u4ea4\u5a92\u4f53\u6216\u5b9e\u65f6\u4fe1\u606f\u5143\u7d20\u3002\u65bd\u5bc6\u7279\u751a\u81f3\u63d0\u8d77\u4e86\u7f51\u7edc\u8ba1\u7b97\u673a(Network Computer)\u8fd9\u4e2a\u4e45\u8fdc\u7684\u6982\u5ff5\u3002Chrome OS\u7535\u8111\u5c06\u975e\u5e38\u4f9d\u8d56\u4e91\u6765\u8fd0\u884c\u5e94\u7528\uff0c\u4e00\u65e6\u65e0\u6cd5\u4e0a\u7f51\uff0c\u529f\u80fd\u5c06\u53d7\u5230\u6781\u5927\u7684\u9650\u5236\u3002\u5c3d\u7ba1\u8fd9\u4e9b\u4ea7\u54c1\u5c06\u53ef\u4ee5\u501f\u52a9\u8702\u7a9d\u7f51\u7edc\u968f\u65f6\u968f\u5730\u4e0a\u7f51\uff0c\u4f46\u5bf9\u4e8e\u4e00\u6b3e\u4ee5\u4e91\u8ba1\u7b97\u4e3a\u4e2d\u5fc3\u7684\u8bbe\u5907\u800c\u8a00\uff0c\u73b0\u6709\u7684\u7f51\u7edc\u80fd\u5426\u6ee1\u8db3\u5176\u6d41\u91cf\u9700\u6c42\u8fd8\u672a\u53ef\u77e5\u3002\r\n\r\n\u3000\u3000Chrome OS\u8fd8\u9762\u4e34\u7740\u5c34\u5c2c\u7684\u5b9a\u4f4d\uff1a\u5bf9\u5916\u9762\u5bf9\u7740\u5f00\u53d1\u8005\u548c\u6f5c\u5728\u7684\u7528\u6237\uff0c\u5bf9\u5185\u5219\