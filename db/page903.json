u4f5c\u8005\uff1a[\u97e9] \u5168\u6c11\u7199 <BR>151\u300a\u7b26\u6587\u4e4b\u5b50\uff0d4 \u9c9c\u8840\u6c38\u5b58\u300b\u4f5c\u8005\uff1a[\u97e9] \u5168\u6c11\u7199 <BR>152\u300a\u7b26\u6587\u4e4b\u5b50\uff0d5 \u67d3\u8840\u76db\u5bb4\u300b\u4f5c\u8005\uff1a[\u97e9] \u5168\u6c11\u7199 <BR>153\u300a\u7b26\u6587\u4e4b\u5b50\uff0d6 \u5c01\u5370\u547c\u5524\u300b\u4f5c\u8005\uff1a[\u97e9] \u5168\u6c11\u7199 <BR>154\u300a\u7b26\u6587\u4e4b\u5b50\uff0d7 \u9009\u62e9\u9ece\u660e\u300b\u4f5c\u8005\uff1a[\u97e9] \u5168\u6c11\u7199 <BR>155\u300a\u5149\u66553\uff1a\u521d\u6b21\u53cd\u51fb\u300b\u4f5c\u8005\uff1a[\u7f8e] \u57c3\u91cc\u514b\u00b7\u5c3c\u4f26\u5fb7 <BR>156\u300aK\u661f\u5f02\u5ba2\u300b\u4f5c\u8005\uff1a[\u7f8e] \u5409\u6069\u00b7\u5e03\u9c81\u5c14 <BR>157\u300a\u6fc0\u6d41\u8003\u5bdf\u961f\u300b\u4f5c\u8005\uff1a[\u7f8e] \u52a0\u52d2\u65af <BR>158\u300a\u514b\u9686\u5730\u7403\u4eba\u300b\u4f5c\u8005\uff1a[\u6cd5] \u96f7\u8ba9 <BR>159\u300a\u7d22\u62c9\u5229\u65af\u661f\u300b\u4f5c\u8005\uff1a[\u6ce2\u5170] \u65af\u5766\u5c3c\u65af\u62c9\u592b\u00b7\u83b1\u59c6 <BR>160\u300a\u94f6\u6cb3\u884c\u5546\u300b\u4f5c\u8005\uff1a[\u7f8e] \u7f57\u4f2f\u7279\u00b7\u6d77\u56e0\u83b1\u56e0 <BR>161\u300a\u602a\u80ce\u300b\u4f5c\u8005\uff1a[\u7f8e] \u5927\u536b\u00b7\u8096\u5bbe <BR>162\u300a\u9cb5\u9c7c\u4e4b\u4e71\u300b\u4f5c\u8005\uff1a[\u6377\u514b] \u5361\u00b7\u6070\u4f69\u514b <BR>163\u300a\u733f\u7334\u4e16\u754c\u300b\u4f5c\u8005\uff1a[\u6cd5] \u5f7c\u57c3\u5c14\u00b7\u5e03\u52d2 <BR>164\u300aE\uff1dMC2\u6216\u4e00\u4e2a\u601d\u60f3\u7684\u6545\u4e8b\u300b\u4f5c\u8005\uff1a[\u6cd5] \u5f7c\u57c3\u5c14\u00b7\u5e03\u52d2 <BR>165\u300a\u592a\u7a7a\u5821\u5792\uff0d\u9ea6\u514b\u7f57\u65af\u4f20\u5947\u00b7\u5377\u4e8c\u300b\u4f5c\u8005\uff1a[\u7f8e] \u6770\u514b\u00b7\u9ea6\u91d1\u5c3c <BR>166\u300a\u592a\u7a7a\u5821\u5792\uff0d\u9ea6\u514b\u7f57\u65af\u4f20\u5947\u00b7\u5377\u4e09\u300b\u4f5c\u8005\uff1a[\u7f8e] \u6770\u514b\u00b7\u9ea6\u91d1\u5c3c <BR>167\u300a\u6050\u9f99\u6587\u660e\u4e09\u90e8\u66f22\uff1a\u5316\u77f3\u730e\u4eba\u300b\u4f5c\u8005\uff1a[\u52a0] \u7f57\u4f2f\u7279\u00b7J\u00b7\u7d22\u8036 <BR>168\u300a\u6050\u9f99\u6587\u660e\u4e09\u90e8\u66f23\uff1a\u5f02\u65cf\u300b\u4f5c\u8005\uff1a[\u52a0] \u7f57\u4f2f\u7279\u00b7J\u00b7\u7d22\u8036 <BR>169\u300a\u5149\u660e\u738b\u300b\u4f5c\u8005\uff1a[\u7f8e] \u7f57\u6770\u00b7\u6cfd\u62c9\u5179\u5c3c <BR>170\u300a\u94f6\u6cb3\u94c1\u9053\uff19\uff19\uff19\u300b\u4f5c\u8005\uff1a[\u65e5] \u677e\u672c\u96f6\u58eb <BR>171\u300a\u963f\u7279\u7c73\u65af\u7cfb\u5217 \u7b2c\u4e00\u518c\uff1a\u7cbe\u7075\u7684\u8d4e\u91d1\u300b\u4f5c\u8005\uff1a[\u7231\u5c14\u5170] \u6b27\u56e0\u00b7\u79d1\u5f17 <BR>172\u300a\u94f6\u6cb3\u5723\u77f3\u4f20\u5947 \u2161 \u9b54\u6cd5\u7687\u540e\u300b\u4f5c\u8005\uff1a[\u7f8e] \u5927\u536b\u00b7\u827e\u4e01\u65af <BR>173\u300a\u771f\u7406\u4e4b\u52511 \u5deb\u5e08\u7b2c\u4e00\u5b88\u5219\u00b7\u4e0a\u300b\u4f5c\u8005\uff1a\u6cf0\u745e\u00b7\u53e4\u5fb7\u574e <BR>174\u300a\u5b89\u73c0\u5fd7\u00b7\u5b89\u73c0\u4e5d\u738b\u5b50\u300b\u4f5c\u8005\uff1a[\u7f8e] \u7f57\u6770\u00b7\u6cfd\u62c9\u5179\u5c3c <BR>175\u300a\u5723\u9aa8\u8ff7\u8e2a\u300b\u4f5c\u8005\uff1a[\u7f8e] \u8a79\u59c6\u65af\u00b7\u7f57\u6797\u65af <BR>176\u300a\u661f\u4e1b\u300b\u4f5c\u8005\uff1a[\u52a0] \u7f57\u4f2f\u7279\u00b7J\u00b7\u7d22\u8036 <BR>177\u300a\u732b\u7684\u6447\u7bee\u300b\u4f5c\u8005\uff1a[\u7f8e] \u5e93\u7279\u00b7\u51af\u5c3c\u53e4\u7279 <BR>178\u300a\u5929\u715e\uff1a\u72ec\u7acb\u65e5\u70fd\u706b\u300b\u4f5c\u8005\uff1a[\u7f8e] \u8fea\u5b89\u00b7\u5fb7\u5c14\u6587 \u7b49 <BR>179\u300a\u4e0d\u6b7b\u4e4b\u5175\u300b\u4f5c\u8005\uff1a[\u4fc4] \u5fb7\u6d85\u5e03\u7f57\u592b <BR>180\u300a\u6b7b\u4ea1\u4e4b\u5c4b\u00b7\u8fdc\u79bb\u5730\u4e0b\u5ba4\u300b\u4f5c\u8005\uff1a[\u7f8e] R\u00b7L\u00b7\u65af\u5766 <BR>181\u300a\u57fa\u5730\u524d\u4f201\u00b7\u57fa\u5730\u524d\u594f\u300b\u4f5c\u8005\uff1a[\u7f8e] \u827e\u8428\u514b\u00b7\u963f\u897f\u83ab\u592b <BR>182\u300a