[\u7f8e] \u91d1\u00b7\u65af\u5766\u5229\u00b7\u9c81\u5bbe\u900a <BR>07\u300a\u6d3b\u8df3\u5c38(\u5f17\u5170\u80af\u65af\u5766)\u300b\u4f5c\u8005\uff1a[\u82f1] \u739b\u4e3d\u00b7\u96ea\u83b1 <BR>08\u300a\u4e1b\u6797\u6e29\u5ba4\u300b\u4f5c\u8005\uff1a[\u7f8e] \u5e03\u8d56\u6069\u00b7\u5965\u5c14\u8fea\u65af <BR>09\u300a\u5927\u897f\u6d0b\u5e95\u6765\u7684\u4eba\u300b\u4f5c\u8005\uff1a[\u7f8e] \u4e0d\u8be6 <BR>10\u300a\u9690\u5f62\u4eba\u5165\u4fb5\u300b\u4f5c\u8005\uff1a[\u7f8e] \u7406\u67e5\u5fb7\u00b7\u96f7\u8499\u5fb7 <BR>11\u300a\u88ab\u6bc1\u706d\u7684\u4eba\u300b\u4f5c\u8005\uff1a[\u7f8e] \u963f\u5c14\u5f17\u96f7\u5fb7\u00b7\u8d1d\u65af\u7279 <BR>12\u300a\u7fa4\u661f\uff0c\u6211\u7684\u5f52\u5bbf\u300b\u4f5c\u8005\uff1a[\u7f8e] \u963f\u5c14\u5f17\u96f7\u5fb7\u00b7\u8d1d\u65af\u7279 <BR>13\u300a\u6fd2\u6b7b\u7684\u5730\u7403\u300b\u4f5c\u8005\uff1a[\u7f8e] \u6770\u514b\u00b7\u4e07\u65af <BR>14\u300a\u9ed1\u6697\u7684\u5de6\u624b\u300b\u4f5c\u8005\uff1a[\u7f8e] \u5384\u4f11\u62c9\u00b7\u52d2\u594e\u6069 <BR>15\u300a\u53cc\u5b50\u5ea7\u5386\u9669\u8bb0\u300b\u4f5c\u8005\uff1a[\u7f8e] \u8fc8\u514b\u5c14\u00b7\u65af\u79d1\u7279 <BR>16\u300a\u5730\u6d77\u5deb\u5e08\u300b\u4f5c\u8005\uff1a[\u7f8e] \u5384\u4f11\u62c9\u00b7\u52d2\u594e\u6069 <BR>17\u300a\u592a\u7a7a\u70fd\u706b\u300b\u4f5c\u8005\uff1a[\u7f8e] \u65af\u8482\u6587\u00b7\u83b1\u54c8\u5fb7 <BR>18\u300a\u5730\u5fc3\u4e16\u754c\u730e\u5947\u8bb0\u300b[\u82cf] B\u00b7A\u00b7\u5965\u52c3\u9c81\u5951\u592b <BR>19\u300a\u822a\u6d77\u5bb6\u53f7\u300b\u4f5c\u8005\uff1a\u4e0d\u8be6 <BR>20\u300a\u98a0\u8986\u4e4b\u795e\u300b\uff08\u300a\u672b\u4e16\u8ff7\u8e2a\u300b\u7b2c\u4e8c\u90e8\uff09\u4f5c\u8005\uff1a[\u7f8e] \u8482\u59c6\u00b7\u83b1\u5e0c \u6770\u91cc\u00b7\u8a79\u91d1\u65af <BR>21\u300a\u706b\u661f\u516c\u4e3b\u300b\u4f5c\u8005\uff1a[\u7f8e] \u57c3\u5fb7\u52a0\u00b7\u8d56\u65af\u00b7\u4f2f\u52d2\u65af <BR>22\u300a\u661f\u9645\u65c5\u884c\u7cfb\u5217\uff0d\uff0d\u9996\u6b21\u63a5\u89e6\u300b\u4f5c\u8005\uff1a\u5409\u6069\u00b7\u7f57\u767b\u8d1d\u91cc <BR>23\u300a\u84b8\u53d1\u5bc6\u4ee4\u300b\u4f5c\u8005\uff1a[\u7f8e] \u6258\u5c3c\u00b7\u666e\u745e\u57c3\u62c9 <BR>24\u300a\u94f6\u6cb3\u7cfb\u6f2b\u6e38\u6307\u5357\u300b\u4f5c\u8005\uff1a[\u82f1] \u9053\u683c\u62c9\u65af\u00b7\u4e9a\u5f53\u65af <BR>25\u300a\u5b87\u5b99\u5c3d\u5934\u7684\u9910\u9986\u300b\u4f5c\u8005\uff1a[\u82f1] \u9053\u683c\u62c9\u65af\u00b7\u4e9a\u5f53\u65af <BR>26\u300a\u5feb\u4e50\u5236\u9020\u8005\u300b\u4f5c\u8005\uff1a[\u7f8e] \u8a79\u59c6\u65af\u00b7\u5188\u6069 <BR>27\u300a\u5371\u673a\u300b\u4f5c\u8005\uff1a[\u7f8e] \u8a79\u59c6\u65af\u00b7\u5188\u6069 <BR>28\u300a\u661f\u9645\u6865\u6881\u300b\u4f5c\u8005\uff1a[\u7f8e] \u8a79\u59c6\u65af\u00b7\u5188\u6069 <BR>29\u300a\u9b54\u6bd4\u65af\u73af\u300b\u4f5c\u8005\uff1a[\u7f8e] \u8ba9\u00b7\u7eaa\u52b3 <BR>30\u300a\u4e16\u754c\u672a\u65e5\u9634\u8c0b\u300b\u4f5c\u8005\uff1a[\u7f8e] \u897f\u5fb7\u5c3c\u00b7\u8c22\u5c14\u987f <BR>31\u300a\u683c\u5217\u4f5b\u6e38\u8bb0\u300b\u4f5c\u8005\uff1a[\u82f1] \u4e54\u7eb3\u68ee\u00b7\u65af\u5a01\u592b\u7279 <BR>32\u300a\u86c7\u77f3\u2160\uff0d\u62c9\u6069\u7684\u79d8\u5bc6\u300b\u4f5c\u8005\uff1a[\u7f8e] \u59ae\u59ae\u00b7\u963f\u4ec0\u83b1 <BR>33\u300a\u86c7\u77f3\u2161\uff0d\u6700\u540e\u7684\u732e\u796d\u300b\u4f5c\u8005\uff1a[\u7f8e] \u59ae\u59ae\u00b7\u963f\u4ec0\u83b1 <BR>34\u300a\u6211\u4eec\u300b\u4f5c\u8005\uff1a[\u4fc4] \u5c24\u91d1\u00b7\u624e\u7c73\u4e9a\u4eac <BR>35\u300a\u8747\u738b\u300b\u4f5c\u8005\uff1a[\u82f1] \u5a01\u5ec9\u00b7\u6208\u5c14\u4e01 <BR>36\u300a\u514b\u82cf\u9c81\u795e\u8bdd\u2160\uff0d\u90aa\u795e\u590d\u82cf\u300b\u4f5c\u8005\uff1a[\u7f8e] H\u00b7P\u00b7\u6d1b\u592b\u514b\u62c9\u592b\u7279 <BR>37\u300a\u514b\u82cf\u9c81\u795e\u8bdd\u2161\uff0d\u6050\u6016\u4eba\u95f4\u300b\u4f5c\u8005\uff1a[\u7f8e] \u65af\u8482\u82ac\u00b7\u91d1 \u7b49 <BR>38\u300a\u732e\u7ed9\u963f\u5c14\u5409\u4fac\u7684\u82b1\u675f\u300b\u4f5c\u8005\uff1a[\u7f8e] \u51ef\u65af\u3010\u957f\u7bc7\u3011 <BR>39\u300a\u8d39\u5c14\u8499\u7279\u4e2d\u5b66\u7684\u6d41\u661f\u5c81\u6708\u300b\u4f5c\u8005\uff1a(\u7f8e) \u8d39\u8bfa\u00b7\u6587\u5947 <BR>40\u300a\u4f60\u4e00\u751f\u7684\u6545\u4e8b\u300b\u4f5c\u8005\uff1a[\u7f8e] \u7279\u5fb7\u00b7\u848b <BR>41\u300a\uff23\uff34\u8f90\u5c04\u300b\u4f5c\u8005\uff1a[\u7f8e] \u6770\u514b\u00b7\u5a01\u5ec9\u68ee <BR>42\u300a\u53cd\u7269\u8d28\u98de\u8239\u300b\u4f5c\u8005\uff1a[\u7f8e] \u6770\u514b\u00b7\u5a01\u5ec9\u68ee \u5b8c\u6574\u724812.5\u66f4\u65b0 <BR>43\u300a\u9ed1\u592a\u9633\u300b\u4f5c\u8005\uff1a[\u7f8e] \u6770\u514b\u00b7\u5a01\u5ec9\u68ee \u540c\u4e0a <BR>44\u300a\u6f5c\u5728\u7684\u5f02\u65cf\u300b\u4f5c\u8005\uff1a[\u7f8e] \u6770\u514b\u00b7\u5a01\u5ec9\u68ee <BR>45\u300a\u675f\u624b\u65e0\u7b56\u300b\u4f5c\u8005\uff1a[\u7f8e] \u6770\u514b\u00b7\u5a01\u5ec9\u68ee <BR>46\u300a\u5929\u7f51\u7684\u5760\u843d\u300b\u4f5c\u8005\uff1a[\u7f8e] \u6770\u514b\u00b7\u5a01\u5ec9\u68ee <BR>47\u300a\u6708\u4eae\u5b69\u5b50\u300b\u4f5c\u8005\uff1a[\u7f8e] \u6770\u514b\u00b7\u5a01\u5ec9\u68ee <BR>48\u300a\u98de\u9f99\u5931\u8e2a\u6848\u300b-[\u4fc4] \u57fa\u5c14\u00b7\u5e03\u96f7\u5207\u592b <BR>49\u300a\u9e21\u76ae\u4fa6\u63a2\u300b-[\u4fc4] \u57fa\u5c14\u00b7\u5e03\u96f7\u5207\u592b <BR>50\u300a\u5377\u5165\u706b\u661f\u8c0b\u6740\u6848\u300b-[\u4fc4] \u57fa\u5c14\u00b7\u5e03\u96f7\u5207\u592b <BR>51\u300a\u4e24\u4e2a\u5730\u7403\u7684\u89d2\u6597\u300b-[\u4fc4] \u57fa\u5c14\u00b7\u5e03\u96f7\u5207\u592b <BR>52\u300a\u65f6\u95f4\u6740\u4eba\u5668\u300b-[\u4fc4] \u57fa\u5c14\u00b7\u5e03\u96f7\u5207\u592b <BR>53\u300a\u7f8e\u4e3d\u65b0\u4e16\u754c\u300b[\u6cd5] \u963f\u9053\u65af\u00b7\u8d6b\u80e5\u9ece <BR>54\u300a\u4eba\u683c\u88c2\u53d8\u7684\u59d1\u5a18\u300b[\u7f8e] F\u00b7R\u00b7\u65bd\u8d56\u52c3 <BR>55\u300a\u795e\u7ecf\u6d6a\u6e38\u8005\u300b[\u52a0] \u5a01\u5ec9\u00b7\u5409\u5e03\u68ee <BR>56\u300a\u767d\u8272\u9b54\u529b\u300b\u4f5c\u8005\uff1a[\u7f8e] \u52b3\u8389\u00b7\u83f2\u5229\u4e9a\u00b7\u65af\u9053\u52d2\u5179 <BR>57\u300a\u84dd\u8272\u5669\u68a6\u300b\u4f5c\u8005\uff1a[\u7f8e] \u52b3\u8389\u00b7\u83f2\u5229\u4e9a\u00b7\u65af\u9053\u52d2\u5179 <BR>58\u300a\u7eff\u8272\u5929\u4f7f\u300b\u4f5c\u8005\uff1a[\u7f8e] \u7231\u4e3d\u4e1d\u00b7\u970d\u592b\u66fc <BR>59\u300a\u4e4c\u9e26\u7edd\u58c1\u300b\u4f5c\u8005\uff1a[\u7f8e] \u6770\u5f17\u91cc\u00b7\u4ea8\u5ef7\u987f <BR>60\u300a\u90aa\u9b54\u5973\u5deb\u300b\u4f5c\u8005\uff1a[\u7f8e] \u6770\u5f17\u91cc\u00b7\u4ea8\u5ef7\u987f <BR>61\u300a\u5730\u7403\u6740\u573a\u300b\u4f5c\u8005\uff1a[\u7f8e] \uff2c\u00b7\u7f57\u6069\u00b7\u54c8\u4f2f\u5fb7 <BR>62\u300a\u5730\u7403\u4f7f\u547d\uff1a\u5165\u4fb5\u8005\u8ba1\u5212\u300b\u4f5c\u8005\uff1a[\u7f8e] \uff2c\u00b7\u7f57\u6069\u00b7\u54c8\u4f2f\u5fb7 <BR>63\u300a\u7269\u7ade\u5929\u62e9\u300b[\u7f8e] \uff2c\u00b7\u7f57\u6069\u00b7\u54c8\u4f2f\u5fb7 <BR>64\u300a\u65e5\u672c\u6c89\u6ca1\u300b[\u65e5] \u5c0f\u677e\u5de6\u4eac <BR>65\u300a\u5b87\u5b99\u6f02\u6d41\u8bb0\u300b[\u65e5] \u5c0f\u677e\u5de6\u4eac <BR>66\u300a\u8ba1\u7b97\u4e2d\u7684\u4e0a\u5e1d\u300b\u4f5c\u8005\uff1a[\u52a0] \u7f57\u4f2f\u7279\u00b7J\u00b7\u7d22\u8036 <BR>67\u300a\u6c99\u4e18\u300b\u4f5c\u8005\uff1a[\u7f8e] \u5f17\u5170\u514b\u00b7\u8d6b\u4f2f\u7279\uff08\u7b2c\u4e00\u90e8\uff09 <BR>68\u300a\u661f\u8239\u4f1e\u5175\u300b\u4f5c\u8005\uff1a[\u7f8e] \u7f57\u4f2f\u7279\u00b7\u6d77\u56e0\u83b1\u56e0 <BR>69\u300a\u53cc\u661f\u300b\u4f5c\u8005\uff1a[\u7f8e] \u7f57\u4f2f\u7279\u00b7\u6d77\u56e0\u83b1\u56e0 <BR>70\u300a\u7f57\u4f2f\u7279\u00b7\u6d77\u56e0\u6765\u56e0\u77ed\u7bc7\u5c0f\u8bf4\u96c6\u300b <BR>71\u300a\u8fbe\u5c14\u6587\u7684\u9634\u8c0b\u300b(\u5168\u672c)\u4f5c\u8005\uff1a[\u7f8e] \u7ea6\u7ff0\u00b7\u4e39\u987f <BR>72\u300a\u53d1\u6761\u6a59\u300b\u4f5c\u8005\uff1a[\u82f1] \u5b89\u4e1c\u5c3c\u00b7\u4f2f\u5409\u65af <BR>73\u300a\u75af\u72c2\u7684\u5730\u7403\u300b\u4f5c\u8005\uff1a[\u7f8e] \u9ed8\u91cc\u00b7\u83b1\u56e0\u65af\u7279\u5c14 <BR>74\u300a\u602a\u5f02\u6b66\u5668\u300b\u4f5c\u8005\uff1a\u57c3\u9