[{"url": "http://www.google.cn/intl/zh-CN/landing/gaokao/gaokao.html", "title": "\u8c37\u6b4c\u9ad8\u80032009", "tags": "\u8c37\u6b4c \u9ad8\u8003 ", "name": "yinyin", "posttime": "2009-06-05 10:54:01", "ip": "211.138.9.90", "mark": 0, "note": "\u9488\u5bf9\u5373\u5c06\u5230\u6765\u7684\u9ad8\u8003,\u8c37\u6b4c\u4e2d\u56fd\u5ba3\u5e03\u57282009\u5e74\u5f00\u53d1\u8005\u65e5\u5927\u4f1a\u671f\u95f4\u63a8\u51fa\u201c\u9ad8\u80032009\u5730\u56fe\u201d.\r\n\u8c37\u6b4c\u201c\u9ad8\u8003\u5730\u56fe\u201d\u6240\u6709\u6570\u636e\u6765\u81ea\u4e8e\u4e2d\u56fd\u6559\u80b2\u5728\u7ebf,\u53ef\u4ee5\u63d0\u4f9b\u5168\u56fd31\u4e2a\u7701\u4e0a\u5343\u6240\u5927\u5b66\u7684\u4fe1\u606f.\u5177\u4f53\u800c\u8a00,\u8be5\u4ea7\u54c1\u4e3b\u8981\u63d0\u4f9b\u4ee5\u4e0b\u4e09\u65b9\u9762\u7684\u529f\u80fd:\r\n\r\n\u4e00\u662f\u8003\u5bdf\u5927\u5b66\u73af\u5883, \u7f51\u53cb\u901a\u8fc7\u8c37\u6b4c\u9ad8\u8003\u5730\u56fe\u53ef\u4ee5\u67e5\u770b\u5168\u56fd\u5927\u5b66\u7684\u5206\u5e03\u56fe,\u67e5\u8be2\u5177\u4f53\u5927\u5b66\u9644\u8fd1\u7684\u996d\u5e97\u3001\u94f6\u884c\u7b49\u751f\u6d3b\u8bbe\u65bd,\u5e76\u901a\u8fc7\u536b\u661f\u822a\u62cd\u5730\u56fe\u6e05\u6670\u770b\u5230\u5927\u5b66\u5468\u8fb9\u771f\u5b9e\u573a\u666f\uff1b\r\n\r\n\u4e8c\u662f\u67e5\u8be2\u5206\u6570\u7ebf,\u8c37\u6b4c\u201c\u9ad8\u8003\u5730\u56fe\u201d\u63d0\u4f9b\u4e86\u9ad8\u6821\u7684\u5206\u6570\u7ebf\u67e5\u8be2\u529f\u80fd\uff1b\r\n\r\n\u6700\u540e,\u8c37\u6b4c\u201c\u9ad8\u8003\u5730\u56fe\u201d\u8fd8\u53ef\u4ee5\u5e2e\u52a9\u7f51\u53cb\u5206\u6790\u548c\u6bd4\u5bf9\u4e0d\u540c\u7684\u5b66\u6821,\u7b5b\u9009\u9002\u5408\u7684\u5b66\u6821\u548c\u4e13\u4e1a,\u627e\u51fa\u6700\u4f73\u9009\u62e9.\r\n\r\n\u636e\u6089,\u8fd9\u4e5f\u662f\u8c37\u6b4c\u9488\u5bf9\u4e2d\u56fd\u5e02\u573a\u7684\u6700\u65b0\u5730\u56fe\u7c7b\u4ea7\u54c1.\u6b64\u524d,\u8c37\u6b4c\u8fd8\u63a8\u51fa\u8fc7\u6625\u8282\u4ea4\u901a\u5730\u56fe\u548c\u5730\u9707\u5f62\u52bf\u56fe\u7b49\u4ea7\u54c1.", "imagename": "5b461fe290e3435c9