2\u5f0f\uff0c\u4e0e\u670b\u53cb\u4eec\u5206\u4eab\u5f7c\u6b64\u7684\u5fc3\u60c5\u3001\u53d1\u73b0\u548c\u89c1\u95fb\uff1b\u76ee\u524d\uff0c\u7528\u6237\u53ef\u4ee5\u7528\u7535\u8111\u3001\u684c\u9762\u5ba2\u6237\u7aef\u3001\u624b\u673a\u3001\u77ed\u4fe1\u3001MSN\u673a\u5668\u4eba\u7b49\u591a\u79cd\u65b9\u5f0f\u6536\u53d1\u81ea\u5df1\u7684\u72b6\u6001\u4fe1\u606f\u3002 9911\u5c0f\u5b57\u62a5\u7b80\u76f4\u662f\u4e00\u4e2a\u5b9e\u4e60\u751f\u5728\u82b1\u4e86\u4e24\u4e2a\u4e0b\u5348\u8336\u7684\u529f\u592b\u505a\u51fa\u6765\u7684\u534a\u6210\u54c1\uff0c\u8001\u5b9e\u8bf4\uff0c\u6211\u5bf9\u6b64\u5b8c\u5168\u63d0\u4e0d\u8d77\u4efb\u4f55\u5174\u8da3\uff0c\u751a\u81f3\u662f\u805a\u53cb\u6240\u63d0\u4f9b\u7684\u7edd\u5927\u591a\u6570\u670d\u52a1\uff1b\u5728\u6211\u773c\u4e2d\uff0c\u7f57\u5ddd\u672c\u6765\u5c31\u4e0d\u9760\u8c31\uff0c\u4ed6\u79bb\u804c\u540e\u73b0\u4efbCEO\u6240\u5e26\u9886\u7684\u805a\u53cb\u56e2\u961f\u5c31\u66f4\u663e\u5f97\u50cf\u662f\u4e00\u53ea\u65e0\u5934\u7684\u82cd\u8747\u4e86\u3002\u4e0d\u8fc7\uff0c\u5728\u7ee7\u65b0\u6d6a\u9ad8\u8c03\u5ba3\u5e03\u5373\u5c06\u53d1\u5e03\u7c7bTwitter\u5fae\u535a\u5ba2\u670d\u52a1\u540e\uff0c\u4ee5\u53ca\uff0c\u8fd9\u91cc\u805a\u53cb9911\u5c0f\u5b57\u62a5\uff0c\u4e0d\u514d\u5f15\u53d1\u4e86\u6211\u4e2a\u4eba\u5bf9\u4e8e\u201c\u540e\u5fae\u535a\u5ba2\u65f6\u4ee3\u201d\u7684\u601d\u8003\u2014\u2014\u5176\u5b9e\uff0c\u6211\u60f3\u8bf4\u7684\u662f\uff0c\u6211\u53e3\u4e2d\u6240\u8c13\u7684\u201c\u540e\u5fae\u535a\u5ba2\u201d\u9664\u4e86\u4e4b\u524d\u5728 \u62fe\u4eba\u7259\u6167\uff0c\u6211\u4e5f\u6765\u770b Twitter\u3001\u996d\u5426\u548c\u5600\u5495 \u4e00\u6587\u4e2d\u6240\u63d0\u5230\u7684\u72ec\u7acb\u6258\u7ba1\u5fae\u535a\u5ba2\uff08Twitter\u3001\u996d\u5426 \u7b49\uff09 \u5728\u793e\u4f1a\u5316\u5a92\u4f53\u8425\u9500\u65b0\u6218\u573a\u4e2d\u7684\u9a70\u9a8b\u8868\u73b0\u4ee5\u5916\uff0c\u8fd8\u5305\u62ec\uff1a\u5f53\u8d8a\u6765\u8d8a\u591a\u7684\u4e92\u8054\u7f51\u5de8\u5934\u5f00\u59cb\u6d89\u8db3\u7c7bTwitter\