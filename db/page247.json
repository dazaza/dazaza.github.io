u89c6\u9891"]}, {"url": "", "title": "2010\u5e74\u6700\u4f73\u56fd\u5916\u514d\u8d39\u5728\u7ebf\u5b58\u50a8\u670d\u52a1", "tags": "\u5728\u7ebf\u5b58\u50a8 \u5b58\u50a8", "name": "geekzhang", "posttime": "2010-12-30 09:55:33", "ip": "116.53.96.147", "mark": 0, "note": "<p><span><span>\u8fd1\u5e74\u6765\uff0c\u6570\u5b57\u5316\u4ea7\u54c1\u7684\u6570\u91cf\u5448\u6307\u6570\u589e\u957f\u3002\u7535\u8111\u7684\u7a7a\u95f4\u4f3c\u4e4e\u8d8a\u6765\u8d8a\u4e0d\u591f\u7528\uff0c\u5373\u4f7f\u73b0\u5728\u7684\u786c\u76d8\u5b58\u50a8\u91cf\u6bd4\u4ee5\u524d\u5927\u5f97\u591a\u3002\u540c\u65f6\uff0c\u4e0e\u4ed6\u4eba\u5206\u4eab\u7684\u6587\u4ef6\u6570\u4e5f\u9010\u65e5\u500d\u6570\u589e\u957f\u3002\u6587\u4ef6\u7684\u4f53\u79ef\u53d8\u5f97\u8d8a\u6765\u8d8a\u5927\u4f7f\u5f97\u6211\u4eec\u518d\u4e5f\u65e0\u6cd5\u901a\u8fc7\u90ae\u4ef6\u6765\u76f4\u63a5\u8fdb\u884c\u5206\u4eab\u3002</span></span></p>\r\n<p><span><span><a href=\"http://www.x-berry.com/wordpress/wp-content/uploads/2010/12/free-online-file-hosting.jpg\"></a></span></span></p>\r\n<p>&nbsp;</p>\r\n<p><span><span>\u4e0d\u8fc7\u597d\u5728\uff0c\u73b0\u5728\u7684\u5728\u7ebf\u5b58\u50a8\u670d\u52a1\u548c\u5171\u4eab\u670d\u52a1\u8d8a\u6765\u8d8a\u591a\u3002\u5728\u7ebf\u5171\u4eab\u670d\u52a1\u6210\u4e3a\u89e3\u51b3\u7a7a\u95f4\u4e0d\u8db3\u548c\u5171\u4eab\u56f0\u96be\u6210\u4e3a\u6700\u4f73\u7684\u9009\u62e9\u3002</span></span> \u4e0b\u9762\u5217\u4e3e\u4e00\u4e9b\u76f8\u5bf9\u51fa\u8272\u7684\u5728\u7ebf\u5b58\u50a8\u670d\u52a1\uff08\u7f51\u7edc\u786c\u76d8\uff09\uff1a</p>\r\n<h3>1. Badongo</h3>\r\n<p>\u5728\u7ebf\u5b58\u50a8\u4f60\u7684\u6587\u4ef6\uff0c\u8fd8\u652f\u6301\u64ad\u653e\u97f3\u4e50\u6587\u4ef6\u548c\u4e0e\u4ed6\u4eba\u5206\u4eab\u6587\u4ef6\u3002</p>\r\n<p><a href=\"http://www.x-berry.com/wordpress/wp-content/uploads/2010/12/Badongo.jpg\"></a></p>\r\n<h4><span><span>Badongo\u63d0\u4f9b\u670d\u52a1\u5305\u62ec\uff1a</span></span></h4>\r\n<ul>\r\n<li><span><span>\u5206\u4e2a\u4eba\u548c\u5546\u4e1a\u5957\u9910\u3002</span></span></li>\r\n<li><span><span>\u684c\u9762\u5e94\u7528\u7a0b\u5e8f\u652f\u6301Windows\u548c\u82f9\u679c</span></span><span><span> \u3002</span></span></li>\r\n<li><span><span>Badongo\u8fd8\u652f\u6301Firefox\u5de5\u5177\u680f\u8fdb\u884c\u6587\u4ef6\u5171\u4eab\u3002</span></span></li>\r\n<li><span><span>\u652f\u6301\u5982Facebook\uff0cOrkut\u548cMySpace\u7b49\u793e\u4ea4\u7f51\u7edc\u7684Apps\u3002</span></span></li>\r\n<li><span><span>\u97f3\u4e50\u64ad\u653e\u5668</span></span><span><span> \u548c\u6587\u4ef6\u94fe\u63a5widget\u3002</span></span></li>\r\n<li><span><span>\u53ef\u4f9b\u641c\u7d22\u4e0b\u8f7d\u7684\u6587\u4ef6\u8d85\u8fc71000\u4e07\u3002</span></span></li>\r\n</ul>\r\n<p><span><span>Badongo</span></span><strong>\u670d\u52a1\u7279\u70b9\uff1a</strong></p>\r\n<h4><span><span>\u63d0\u4f9b</span></span>\u514d\u8d39\u5e10\u6237\u7684\u670d\u52a1 -</h4>\r\n<ul>\r\n<li><span><span>\u65e0\u9650\u5b58\u50a8\u7a7a\u95f4</span></span></li>\r\n<li><span><span>\u6863\u6848\u7ba1\u7406</span></span></li>\r\n<li><span><span>\u76f8\u518c</span></span></li>\r\n<li><span><span>\u97f3\u4e50\u64ad\u653e\u5217\u8868</span></span></li>\r\n<li><span><span>FTP\u4e0a\u4f20</span></span></li>\r\n</ul>\r\n<h4><span><span>\u9ad8\u7ea7\u7528\u6237\u7684\u670d\u52a1\u8303\u56f4 -</span></span></h4>\r\n<ul>\r\n<li><span><span>\u65e0\u9650\u4e0b\u8f7d</span></span></li>\r\n<li><span><span>\u65e0\u9700\u7b49\u5f85</span></span></li>\r\n<li><span><span>\u6ca1\u6709\u5e7f\u544a</span></span></li>\r\n<li><span><span>\u6587\u4ef6\u6c38\u8fdc\u4e0d\u4f1a\u88ab\u5220\u9664</span></span></li>\r\n<li><span><span>\u4f18\u5148\u652f\u6301</span></span></li>\r\n</ul>\r\n<blockquote>\r\n<p>\u7acb\u5373\u8bbf\u95ee<a title=\"Badongo\" rel=\"nofollow\" href=\"http://www.badongo.com/\" target=\"_blank\"><span style=\"color: #0099cc;\">Badongo</span></a></p>\r\n</blockquote>\r\n<h3>2. OpenDrive</h3>\r\n<p>OpenDrive\u662f\u4e00\u4e2a\u4e91\u670d\u52a1</p>\r\n<p><a href=\"http://www.x-berry.com/wordpress/wp-content/uploads/2010/12/OpenDrive.jpg\"></a></p>\r\n<p><strong>OpenDrive\u63d0\u4f9b\u7684\u670d\u52a1\u5305\u62ec\uff1a</strong></p>\r\n<p><span><span>\u901a\u8fc7OpenDrive\uff0c\u4f60\u67093\u79cd\u65b9\u5f0f\u8bbf\u95ee\u548c\u5171\u4eab\u4f60\u7684\u6587\u4ef6\u3002</span></span></p>\r\n<ul>\r\n<li>OpenDrive Web (Web Application) -\u901a\u8fc7\u7f51\u9875\u4f60\u53ef\u4ee5\u5728\u4efb\u4f55\u5730\u65b9\u8bbf\u95ee\u4f60\u7684\u6587\u4ef6\uff0c\u4e0a\u4f20\u65b0\u7684\u6587\u4ef6\u548c\u7ba1\u7406\u6587\u4ef6\uff0c\u4e5f\u53ef\u4ee5\u521b\u5efa\u65b0\u7684\u6587\u4ef6\u5939\u548c\u7ba1\u7406\u6587\u4ef6\u5939\u3002</li>\r\n<li>OpenDrive Drive (Online Drive) -\u901a\u8fc7\u5b89\u88c5\u5230\u4f60\u7684\u7535\u8111\u7684\u865a\u62df\u6587\u4ef6\u9a71\u52a8\u5668\u8fdb\u884c\u8fdc\u7a0b\u8bbf\u95eeOpenDrive\u3002</li>\r\n<li>OpenDrive Desktop (Virtual desktop) -\u865a\u62df\u7cfb\u7edf\u5141\u8bb8\u7528\u6237\u4f7f\u7528\u7b2c\u4e09\u65b9\u5e94\u7528\u7a0b\u5e8f\u534f\u4f5c\u3001\u7ba1\u7406\u6587\u4ef6\u548c\u8d44\u6599\u3002</li>\r\n</ul>\r\n<p><span><span><strong>OpenDrive\u670d\u52a1\u7279\u70b9\uff1a</strong></span></span></p>\r\n<h4><span><span>\u514d\u8d39\u7528\u6237\u53ef\u7528\u7684\u670d\u52a1\u5305\u62ec -</span></span></h4>\r\n<ul>\r\n<li><span><span>5 GB\u7684\u5b58\u50a8\u7a7a\u95f4</span></span></li>\r\n<li><span><span>\u652f\u6301\u6587\u4ef6\u7684\u6700\u5927\u4f53\u79ef\u4e3a100MB</span></span></li>\r\n<li><span><span>1G/\u5929\u6d41\u91cf</span></span></li>\r\n<li><span><span>\u4e0b\u8f7d\u901f\u5ea6\u6700\u5927\u652f\u6301200 kb / s</span></span></li>\r\n<li><span><span>\u6709\u9650\u7684\u76f4\u63a5\u94fe\u63a5</span></span></li>\r\n<li><span><span>\u53ea\u5141\u8bb8\u4e00\u53f0\u7535\u8111\u8bbf\u95ee</span></span></li>\r\n<li><span><span>\u53ea\u5141\u8bb8\u4e00\u7528\u6237\u8bbf\u95ee</span></span></li>\r\n<li><span><span>\u6709\u6c34\u5370</span></span></li>\r\n</ul>\r\n<p>\u4e13\u4e1a\u670d\u52a1\u63d0\u4f9b\u66f4\u9ad8\u7684\u5b58\u50a8\u7a7a\u95f4\uff0c\u5e26\u5bbd\uff0c\u4e0b\u8f7d\u901f\u5ea6\uff0c\u591a\u7528\u6237\u8bbf\u95ee\uff0cSSL\u5b89\u5168\uff0c\u81ea\u52a8\u540c\u6b65\uff0c\u5907\u4efd\u7b49\u7b49\u3002</p>\r\n<blockquote>\r\n<p>\u7acb\u5373\u8bbf\u95ee<a title=\"Vist Open Drive\" rel=\"nofollow\" href=\"http://www.opendrive.com/\" target=\"_blank\"><span style=\"color: #0099cc;\">OpenDrive</span></a></p>\r\n</blockquote>\r\n<h3>3. MediaFire</h3>\r\n<p>\u76f8\u4fe1\u5f88\u591a\u90fd\u8ba4\u8bc6MediaFire\uff0c\u4e4b\u524d\u5728\u5185\u5730\u88ab\u548c\u8c10\u4e86\uff0c\u5728\u4e0d\u4e45\u524d\u89e3\u5c01\uff08\u89c1<a class=\"broken_link\" href=\"http://www.x-berry.com/mediafire-comes-back\" target=\"_blank\"><span style=\"text-decoration: line-through;\"><span style=\"color: #0099cc;\">MediaFire\u89e3\u5c01\u4e86</span></span></a>\uff09\u3002MediaFire\u63d0\u4f9b\u7684\u5728\u7ebf\u5b58\u50a8\u670d\u52a1\u4e16\u754c\u9886\u5148\uff0c\u53d7\u5230\u8bb8\u591a\u7f51\u53cb\u7684\u6b22\u8fce\u3002</p>\r\n<p><a href=\"http://www.x-berry.com/wordpress/wp-content/uploads/2010/12/Mediafire.jpg\"></a></p>\r\n<h4><span><span>MediaFire\u63d0\u4f9b\u670d\u52a1\uff1a</span></span></h4>\r\n<p><strong><span><span>\u514d\u8d39\u7528\u6237\u53ef\u4eab\u53d7\u7684\u670d\u52a1\u7279\u70b9\uff08\u539a\u9053\u6781\u4e86\uff09\uff1a</span></span></strong></p>\r\n<ul>\r\n<li><span><span>\u65e0\u9650\u5236\u4e0a\u4f20</span></span></li>\r\n<li><span><span>\u65e0\u9650\u4e0b\u8f7d</span></span></li>\r\n<li><span><span>\u65e0\u9650\u5b58\u50a8</span></span></li>\r\n<li><span><span>\u6ca1\u6709\u6ce8\u518c\u8981\u6c42</span></span></li>\r\n<li><span><span>\u6ca1\u6709\u901f\u5ea6\u9650\u5236</span></span></li>\r\n<li>RSS File Feeds</li>\r\n</ul>\r\n<h4><span><span>Pro\u5e10\u6237\uff0c\u9664\u4e86\u57fa\u672c\u7684\u529f\u80fd\u8fd8\u5305\u62ec\u4ee5\u4e0b\u529f\u80fd\uff1a</span></span></h4>\r\n<ul>\r\n<li><span><span>\u4e0a\u4f20\u548c\u4e0b\u8f7d</span></span></li>\r\n<li><span><span>\u5355\u6587\u4ef6\u6700\u5927\u652f\u63012GB</span></span></li>\r\n<li><span><span>\u6ca1\u6709\u5e7f\u544a</span></span></li>\r\n<li><span><span>\u6279\u91cf\u4e0b\u8f7d</span></span></li>\r\n<li><span><span>\u5197\u4f59\u5907\u4efd</span></span></li>\r\n<li><span><span>\u9ad8\u7ea7\u7edf\u8ba1\u6570\u636e</span></span></li>\r\n<li><span><span>\u4ece\u7f51\u7ad9\u4e0a\u4f20</span></span></li>\r\n<li><span><span>\uff08SSL\uff09\u52a0\u5bc6\u4f20\u8f93</span></span></li>\r\n</ul>\r\n<blockquote>\r\n<p><span><span>\u8bbf\u95ee</span></span><a href=\"http://www.mediafire.com/\" target=\"_blank\"><span style=\"color: #0099cc;\">MediaFire</span></a></p>\r\n</blockquote>\r\n<h3>4. SendSpace</h3>\r\n<p>\u7b80\u5355\u5feb\u6377\u5730\u53d1\u9001\u5171\u4eab\u6587\u6863</p>\r\n<p><a href=\"http://www.x-berry.com/wordpress/wp-content/uploads/2010/12/SendSpace.jpg\"></a></p>\r\n<h4><span><span>Sendspace\u63d0\u4f9b\u7684\u670d\u52a1\u5305\u62ec\uff1a</span></span></h4>\r\n<h4><span><span>\u514d\u8d39\u5e10\u6237\u53ef\u4eab\u53d7\u670d\u52a1\uff1a</span></span></h4>\r\n<ul>\r\n<li><span><span>\u65e0\u9650\u5236\u4e0a\u4f20</span></span></li>\r\n<li><span><span>\u65e0\u9650\u4e0b\u8f7d\u6bcf\u4e2a\u6587\u4ef6</span></span></li>\r\n<li><span><span>\u5171\u4eab\u6587\u4ef6\u5b89\u5168\u3001\u9690\u79c1</span></span></li>\r\n<li><span><span>\u5355\u72ec\u8d2d\u4e70\u5355\u6587\u4ef6\u7684\u6d41\u91cf\uff0c\u7279\u5b9a\u94fe\u63a5\u6307\u5b9a\u6587\u4ef6\u3002</span></span></li>\r\n<li><span><span>\u5b8c\u5168\u514d\u8d39\u6587\u4ef6\u5b58\u50a8\u7a7a\u95f4</span></span></li>\r\n<li><span><span>\u968f\u65f6\u968f\u5730\u5206\u4eab\u6587\u4ef6\uff0c\u6700\u5927\u6587\u4ef6\u652f\u6301\u9ad8\u8fbe300MB\uff01</span></span></li>\r\n<li><span><span>\u63d0\u4f9b\u652f\u6301Windows</span></span><span><span> \uff0cMac OS X\u548cLinux\u64cd\u4f5c\u7cfb\u7edf\u7684\u684c\u9762\u5de5\u5177SendSpace Wizard\u3002</span></span></li>\r\n<li><span><span>\u63d0\u4f9bAndroid\u548ciPhone\u5e94\u7528\u670d\u52a1\u3002</span></span></li>\r\n<li><span><span>\u6bcf\u65e5\u9650\u52361G\u4e0b\u8f7d\u3002</span></span></li>\r\n</ul>\r\n<h4><span><span>\u9ad8\u7ea7\u7528\u6237\u53ef\u4eab\u53d7\u7684\u670d\u52a1\uff1a</span></span></h4>\r\n<ul>\r\n<li><span><span>\u6bcf\u65e5\u4e0b\u8f7d\u7684\u6587\u4ef6\u5927\u5c0f\u5347\u81f38GB</span></span></li>\r\n<li><span><span>\u4e0b\u8f7d\u591a\u4e2a\u6587\u4ef6</span></span></li>\r\n<li><span><span>\u65ad\u70b9\u7eed\u4f20</span></span></li>\r\n<li><span><span>\u53ef\u4f7f\u7528\u5185\u7f6e\u52a0\u901f\u5668\u8fdb\u884c\u4e0b\u8f7d\uff0c\u65e0\u4efb\u4f55\u901f\u5ea6\u9650\u5236</span></span></li>\r\n<li><span><span>\u6ca1\u6709\u5e7f\u544a</span></span></li>\r\n</ul>\r\n<blockquote>\r\n<p><span><span>\u7acb\u5373\u8bbf\u95ee </span></span><a title=\"Visit Sendspace\" rel=\"nofollow\" href=\"http://www.sendspace.com/\" target=\"_blank\"><span><span><span style=\"color: #0099cc;\">Sendspace</span></span></span></a><span><span> </span></span></p>\r\n</blockquote>\r\n<h3>5. FileDen</h3>\r\n<p><a href=\"http://www.x-berry.com/wordpress/wp-content/uploads/2010/12/FileDen.jpg\"></a></p>\r\n<p><span><span>FileDen\u7684\u670d\u52a1\u66f4\u503e\u5411\u4e8e\u76f4\u63a5\u7684\u6587\u4ef6\u5171\u4eab\u3002</span></span></p>\r\n<h4><span><span>FileDen\u63d0\u4f9b\u514d\u8d39\u6587\u4ef6\u5206\u4eab\u670d\u52a1\uff1a</span></span></h4>\r\n<h4><span><span>\u514d\u8d39\u5e10\u6237\uff1a</span></span></h4>\r\n<ul>\r\n<li><span><span>\u6240\u6709\u6587\u4ef6\u8fd0\u884c\u5916\u94fe\u3002</span></span></li>\r\n<li><span><span>1GB\u7684\u514d\u8d39</span></span><span><span>\u5b58\u50a8</span></span><span><span>\u7a7a\u95f4\u3002</span></span></li>\r\n<li><span><span>\u6700\u5927\u6587\u4ef6\u652f\u6301100MB\u3002</span></span></li>\r\n<li><span><span>5GB/\u6708\u6d41\u91cf</span></span></li>\r\n</ul>\r\n<p><strong><em><span><span>FileDen\u63d0\u4f9b\u8f83\u5c11\u514d\u8d39\u5b58\u50a8\u7a7a\u95f4\u7ed9\u514d\u8d39\u7528\u6237</span></span><span><span>\uff0c\u4f46\u63d0\u4f9b\u76f4\u63a5\u7684\u4e0b\u8f7d\u94fe\u63a5\u3002</span> <span>\u867d\u7136\u6d41\u91cf\u53ea\u67095GB/\u6708\uff0c\u4f46\u4f60\u672a\u5fc5\u80fd\u7528\u5b8c\u8fd9\u4e2a5GB\uff01</span></span></em></strong></p>\r\n<h4><span><span>\u9ad8\u7ea7\u7528\u6237\u53ef\u4eab\u53d7\u670d\u52a1\uff1a</span></span></h4>\r\n<ul>\r\n<li><span><span>\u9ad8\u8fbe15GB\u7684\u4e2a\u4eba\u5b58\u50a8\u7a7a\u95f4\u3002</span></span></li>\r\n<li><span><span>\u6700\u5927\u6587\u4ef6\u652f\u63011GB\u3002</span></span></li>\r\n<li>150G/\u6708\u6d41\u91cf</li>\r\n</ul>\r\n<blockquote>\r\n<p><span><span>\u7acb\u5373\u8bbf\u95ee </span></span><a title=\"Visit Fileden\" rel=\"nofollow\" href=\"http://fileden.com/\" target=\"_blank\"><span><span><span style=\"color: #0099cc;\">Fileden</span></span></span></a><span><span> \u3002</span></span></p>\r\n</blockquote>\r\n<h3>6. ADrive</h3>\r\n<p>ADrive\u63d0\u4f9b\u4e00\u7ad9\u5f0f\u7684\u5728\u7ebf\u5b58\u50a8\u670d\u52a1\u548c\u5907\u4efd\u670d\u52a1</p>\r\n<p><a href=\"http://www.x-berry.com/wordpress/wp-content/uploads/2010/12/ADrive.jpg\"></a></p>\r\n<h4><span><span>\u770b\u770bADrive\u63d0\u4f9b\u7684\u670d\u52a1\u53c8\u662f\u600e\u6837\u7684\uff1a</span></span></h4>\r\n<h4><span><span>\u514d\u8d39\u5e10\u6237\uff1a</span></span></h4>\r\n<ul>\r\n<li><span><span>50 GB\u5728\u7ebf\u5b58\u50a8\uff08\u8fd9\u4e2a\u6bd4\u8f83\u5927\uff09</span></span></li>\r\n<li><span><span>\u4e0a\u8f7d\uff0c\u5b58\u50a8\u548c\u4e0b\u8f7d\u6587\u4ef6</span></span></li>\r\n<li><span><span>\u968f\u65f6\u968f\u5730\u8bbf\u95ee\u7a7a\u95f4</span></span></li>\r\n<li><span><span>\u4e91\u5b58\u50a8</span></span></li>\r\n<li><span><span>\u5171\u4eab\u6587\u4ef6</span></span></li>\r\n<li><span><span>\u5728\u7ebf\u7f16\u8f91\u6587\u6863</span></span></li>\r\n<li><span><span>\u652f\u6301FTP\uff08I LOVE THIS\uff09</span></span></li>\r\n<li><span><span>\u4fbf\u6377\u7684\u641c\u7d22\u5de5\u5177</span></span></li>\r\n</ul>\r\n<h4><span><span>\u4ed8\u8d39\u5e10\u6237\uff1a</span></span></h4>\r\n<ul>\r\n<li><span><span>\u9ad8\u8fbe1 TB\u7684\u5b58\u50a8\uff08\u54c7\u54c7\uff09</span></span></li>\r\n<li><span><span>\u652f\u6301Windows\uff0cMac\u548cLinux\u7684\u684c\u9762\u5de5\u5177ADrive Desktop</span></span></li>\r\n<li><span><span>\u6587\u4ef6\u5386\u53f2</span></span></li>\r\n<li><span><span>SSL\u52a0\u5bc6</span></span></li>\r\n<li><span><span>\u6ca1\u6709\u5e7f\u544a</span></span></li>\r\n<li>\u591a\u4e2a\u540c\u6642\u8fde\u7ebf\u6570</li>\r\n</ul>\r\n<blockquote>\r\n<p><span><span>\u7acb\u5373\u8bbf\u95ee </span></span><a title=\"Visit ADrive\" rel=\"nofollow\" href=\"http://www.adrive.com/\" target=\"_blank\"><span><span><span style=\"color: #0099cc;\">ADrive</span></span></span></a></p>\r\n</blockquote>\r\n<h3>7. Wuala</h3>\r\n<p>Wuala\u81ea\u79f0\u5176\u7684\u5728\u7ebf\u5b58\u50a8\u670d\u52a1\u975e\u5e38\u5b89\u5168\uff0c\u5982\u679c\u4f60\u62c5\u5fc3\u5176\u4ed6\u5728\u7ebf\u5b58\u50a8\u670d\u52a1\u4e0d\u5230\u5bb6\uff0c\u53ef\u4ee5\u9009\u62e9\u76f8\u4fe1Wuala\u3002</p>\r\n<p><a href=\"http://www.x-berry.com/wordpress/wp-content/uploads/2010/12/Wuala.jpg\"></a></p>\r\n<h4><span><span>Wuala\u4e3a\u7528\u6237\u63d0\u4f9b\u7684\u5728\u7ebf\u5b58\u50a8\u670d\u52a1\u6709\uff1a</span></span></h4>\r\n<h4><span><span>\u514d\u8d39\u5e10\u6237\uff1a</span></span></h4>\r\n<ul>\r\n<li><span><span>\u5b89\u5168\u5730\u5728\u7ebf\u5b58\u50a8\u548c\u5907\u4efd\u60a8\u7684\u6587\u4ef6</span></span></li>\r\n<li><span><span>\u968f\u65f6\u968f\u5730\u8bbf\u95ee\u6587\u4ef6</span></span></li>\r\n<li><span><span>\u5728\u7ebf\u548c\u591a\u53f0\u8ba1\u7b97\u673a\u540c\u6b65\u4f60\u7684\u6587\u4ef6</span></span></li>\r\n<li><span><span>\u4e0e\u9009\u5b9a\u7684\u670b\u53cb\u5171\u4eab\u6587\u4ef6\u3002</span></span></li>\r\n</ul>\r\n<h4><span><span>Wuala\u5bf9\u6bd4\u8d77\u5176\u4ed6\u5728\u7ebf\u5b58\u50a8\u670d\u52a1\u6709\u5176\u72ec\u5f53\u7684\u4e00\u9762\uff0c\u56e0\u4e3a\uff1a</span></span></h4>\r\n<ul>\r\n<li><span><span>\u6240\u6709\u6587\u4ef6\u4e0a\u4f20\u4e4b\u524d\u90fd\u4f1a\u88ab\u52a0\u5bc6\u5e76\u5197\u4f59\u5907\u4efd\u3002</span> <span>\u4efb\u4f55\u4eba\u672a\u7ecf\u6388\u6743\u65e0\u6cd5\u8bbf\u95ee\u60a8\u7684\u6587\u4ef6\u3002</span></span></li>\r\n<li><span><span>\u4e3a\u4f60\u7684\u8bbe\u8ba1\u521b\u5efa\u4e00\u4e2aWuala\u7fa4\u548c\u5efa\u7acb\u793e\u4ea4\u7f51\u7edc\u3002</span></span></li>\r\n<li><span><span>\u521d\u59cb\u7a7a\u95f4\u53ea\u67091G\uff0c\u60a8\u4e5f\u53ef\u4ee5\u5355\u72ec\u8d2d\u4e70\u989d\u5916\u7684\u5728\u7ebf\u5b58\u50a8\u7a7a\u95f4\uff0c\u6216\u8005\u7528\u672c\u5730\u7684\u5b58\u50a8\u7a7a\u95f4\u4ea4\u6362\u3002</span></span></li>\r\n<li><strong><span><span>\u6ce8\u610f\uff1a</span></span></strong><span><span> \u4f7f\u7528\u672c\u5730\u7a7a\u95f4\u6765\u6362\u53d6\u66f4\u5927\u7684\u5728\u7ebf\u5b58\u50a8\u7a7a\u95f4\u9700\u8981\u6bcf\u65e5\u5728\u7ebf\u4e0d\u5c11\u4e8e4\u5c0f\u65f6\u3002</span></span></li>\r\n</ul>\r\n<blockquote>\r\n<p><span><span>\u7acb\u5373\u8bbf\u95ee </span></span><span><span><a title=\"Visit Waula\" rel=\"nofollow\" href=\"http://www.wuala.com/\" target=\"_blank\"><span style=\"color: #0099cc;\">Wuala</span></a>\u3002</span></span></p>\r\n</blockquote>\r\n<h3>8. DivShare</h3>\r\n<p>\u66f4\u52a0\u4fbf\u6377\u5b9e\u73b0\u4f60\u7684\u591a\u5a92\u4f53\u5171\u4eab</p>\r\n<p><a href=\"http://www.x-berry.com/wordpress/wp-content/uploads/2010/12/DivShare.jpg\"></a></p>\r\n<h4><span><span>Divshare\u63d0\u4f9b\u7528\u6237\u670d\u52a1\uff1a</span></span></h4>\r\n<h4><span><span>\u514d\u8d39\u5e10\u6237\uff1a</span></span></h4>\r\n<ul>\r\n<li><span><span>5 GB\u5b58\u50a8\u7a7a\u95f4\u548c10 GB/\u6708\u4e0b\u8f7d</span></span></li>\r\n<li><span><span>\u652f\u6301\u4e0a\u4f20\u7167\u7247\uff0c\u6587\u4ef6\uff0c\u5f71\u7247\u548c\u97f3\u4e50\u3002</span></span></li>\r\n<li><span><span>\u521b\u5efa\u5d4c\u5165\u7684\u5e7b\u706f\u7247\uff0c\u97f3\u9891\u64ad\u653e\uff0cFlash\u89c6\u9891\u548c\u6587\u4ef6\u6d4f\u89c8\u5668\u3002</span></span></li>\r\n<li><span><span>\u627f\u8bfa\u6587\u4ef6\u88ab\u6c38\u4e45\u4fdd\u5b58\u3002</span></span></li>\r\n<li><span><span>\u641c\u7d22\uff0c\u5206\u7c7b\u548c\u7ba1\u7406\u6587\u4ef6\u3002</span></span></li>\r\n<li><span><span>\u53ef\u4f7f\u7528\u5bc6\u7801\u4fdd\u62a4</span></span><span><span>\u60a8\u7684\u6587\u4ef6\u548c\u6587\u4ef6\u5939</span></span></li>\r\n<li><span><span>\u5171\u4eab\u4f60\u7684\u6587\u4ef6\u3002</span></span></li>\r\n</ul>\r\n<p><strong><span><span>\u53ef\u4ee5 \u4ece\u514d\u8d39\u8d26\u6237\u5347\u7ea7\u4e3a\u9ad8\u7ea7\u7528\u6237\uff0c\u62e5\u6709\u66f4\u5927\u7684\u5b58\u50a8\u7a7a\u95f4\u548c\u4e0b\u8f7d\u6d41\u91cf\u3002</span></span></strong></p>\r\n<blockquote>\r\n<p><span><span>\u7acb\u5373\u8bbf\u95ee </span></span><a title=\"DivShare Homepage\" rel=\"nofollow\" href=\"http://www.divshare.com/\" target=\"_blank\"><span><span><span style=\"color: #0099cc;\">DivShare</span></span></span></a><span><span> \u3002</span></span></p>\r\n<p><span><span><br /></span></span></p>\r\n</blockquote>\r\n<h3>9. FileDropper</h3>\r\n<p>\u7b80\u5355\u7684\u5728\u7ebf\u5b58\u50a8\u670d\u52a1\uff0cA simple file hosting service to satisfy your needs of online storage space.</p>\r\n<p><a href=\"http://www.x-berry.com/wordpress/wp-content/uploads/2010/12/FileDropper.jpg\"></a></p>\r\n<h4>Filedropper\u4e3a\u7528\u6237\u63d0\u4f9b\u7684\u670d\u52a1\u5305\u62ec:</h4>\r\n<h4>\u514d\u8d39\u7528\u6237:</h4>\r\n<ul>\r\n<li>\u65e0\u9700\u6ce8\u518c\u5373\u53ef\u4e0a\u4f20.</li>\r\n<li>\u6700\u5927\u53ef\u4e0a\u4f205GB\u7684\u5355\u6587\u4ef6.</li>\r\n<li>\u5206\u4eab\u4f60\u4e0a\u8f7d\u7684\u6587\u4ef6</li>\r\n<li>\u63d0\u4f9b7\u65e5\u514d\u8d39\u4f7f\u7528. \u4ed8\u8d39\u7528\u6237\u6700\u4f4e\u53ea\u97000.99\u7f8e\u5143/\u6708.</li>\r\n</ul>\r\n<h4>\u6210\u4e3aFile Dropper\u6ce8\u518c\u7528\u6237\u6216\u9ad8\u7ea7\u7528\u6237:</h4>\r\n<ul>\r\n<li>\u63d0\u4f9b\u6587\u4ef6\u7ba1\u7406\u5668.</li>\r\n<li>\u53ef\u8bbe\u7f6e\u52a0\u5bc6\u4e0b\u8f7d.</li>\r\n<li>\u8bbe\u7f6e\u4e0a\u8f7d\u6587\u4ef6\u4e3a\u4e2a\u4eba\u79c1\u5bc6\u6587\u4ef6.</li>\r\n<li>\u5220\u9664\u6587\u4ef6.</li>\r\n</ul>\r\n<blockquote>\r\n<p>\u7acb\u5373\u8bbf\u95ee&nbsp;<a title=\"Visit Filedropper\" rel=\"nofollow\" href=\"http://www.filedropper.com/\" target=\"_blank\"><span style=\"color: #0099cc;\">Filedropper</span></a></p>\r\n</blockquote>\r\n<h3>10. Ifile.it</h3>\r\n<p>\u975e\u5e38\u7b80\u7ea6\u7684\u514d\u8d39\u7f51\u76d8\uff0c\u4e0a\u4f20\u548c\u5206\u4eab\u6587\u4ef6\u66f4\u65b9\u4fbf\u5feb\u6377</p>\r\n<p><a href=\"http://www.x-berry.com/wordpress/wp-content/uploads/2010/12/Ifile.jpg\"></a></p>\r\n<h4>iFile.it\u63d0\u4f9b\u7684\u670d\u52a1\u5305\u62ec:</h4>\r\n<ul>\r\n<li>\u6240\u6709\u670d\u52a1\u961f\u662f\u514d\u8d39\u63d0\u4f9b\u7684\uff0c\u6ca1\u6709\u6240\u8c13\u7684\u9ad8\u7ea7\u7528\u6237!</li>\r\n<li>\u6ce8\u518c\u6216\u8005\u975e\u6ce8\u518c\u7528\u6237\u90fd\u53ef\u4ee5\u4f7f\u7528.</li>\r\n<li>300 MB\u6587\u4ef6\u5927\u5c0f\u9650\u5236.</li>\r\n<li>\u65e0\u9650\u91cf\u6587\u4ef6\u9650\u5236.</li>\r\n<li>\u6240\u6709\u7528\u6237\u90fd\u53ef\u4ee5\u8fdb\u884c\u65ad\u70b9\u4e0b\u8f7d</li>\r\n<li>HTTP\u6587\u4ef6\u83b7\u53d6\u5668</li>\r\n</ul>\r\n<blockquote>\r\n<p>\u7acb\u5373\u8bbf\u95ee&nbsp;<a title=\"Visit iFile.it\" rel=\"nofollow\" href=\"http://ifile.it/\" target=\"_blank\"><span style=\"color: #0099cc;\">iFile.it</span></a></p>\r\n</blockquote>\r\n<h3>11. File Savr</h3>\r\n<p>\u514d\u8d39\u7684\u5728\u7ebf\u5171\u4eab\u7a7a\u95f4\u548c\u6587\u4ef6\u5907\u4efd\u670d\u52a1</p>\r\n<p><a href=\"http://www.x-berry.com/wordpress/wp-content/uploads/2010/12/File-Savr.jpg\"></a></p>\r\n<h4>Flie Savr\u63d0\u4f9b\u7684\u670d\u52a1\u5305\u62ec:</h4>\r\n<ul>\r\n<li>\u514d\u8d39\u7528\u6237\u53ef\u4e0a\u4f20\u6587\u4ef6\u6700\u5927\u4e3a2GB.</li>\r\n<li>\u53ef\u8bd5\u752830\u5929\u4ed8\u8d39\u7528\u6237\u670d\u52a1\uff0c\u5982\u679c\u4f60\u60f3\u4f53\u9a8c\u4e0b\u4ed8\u8d39\u7528\u6237.</li>\r\n<li>\u6700\u4f4e\u7684\u4ed8\u8d39\u7528\u6237\u5957\u9910\u4e3a0.99$/\u6708.</li>\r\n<li>\u6ce8\u518c/\u4ed8\u8d39\u7528\u6237\u53ef\u4ee5\u4e0a\u4f20\u7684\u5355\u6587\u4ef6\u6700\u5927\u4e3a5GB</li>\r\n<li>\u4ed8\u8d39\u7528\u6237\u7684\u5b58\u50a8\u7a7a\u95f4\u5347\u7ea7100GB</li>\r\n</ul>\r\n<blockquote>\r\n<p>\u7acb\u5373\u8bbf\u95ee<a title=\"Visit FileSavr\" rel=\"nofollow\" href=\"http://www.filesavr.com/\" target=\"_blank\"><span style=\"color: #0099cc;\">FileSavr</span></a></p>\r\n</blockquote>\r\n<h3>12. Uploading.com</h3>\r\n<p>\u5728\u7ebf\u5171\u4eab\u66f4\u7b80\u5355\u548c\u5b89\u5168</p>\r\n<p><a href=\"http://www.x-berry.com/wordpress/wp-content/uploads/2010/12/Uploading.jpg\"></a></p>\r\n<h4>Uploading.com\u63d0\u4f9b\u7684\u514d\u8d39\u670d\u52a1\u5305\u62ec:</h4>\r\n<h4>\u514d\u8d39\u7528\u6237\u53ef\u4eab\u53d7:</h4>\r\n<ul>\r\n<li>\u6700\u59271GB\u7684\u5355\u6587\u4ef6\u4e0a\u4f20.</li>\r\n<li>\u65e0\u9650\u5b58\u50a8\u7a7a\u95f4. \u5982\u679c\u4e0a\u4f20\u7684\u6587\u4ef6\u8fc7\u4e8e\u957f\u4e45\u4e0d\u88ab\u4e0b\u8f7d\u53ef\u80fd\u4f1a\u88ab\u5220\u9664.</li>\r\n<li>\u63d0\u4f9b\u652f\u6301Windows\u7684\u684c\u9762\u4e0a\u4f20\u7a0b\u5e8f.</li>\r\n<li>\u9ad8\u7ea7\u7528\u6237\u7684\u6587\u4ef6\u4f1a\u6c38\u4e45\u4fdd\u7559.</li>\r\n<li>\u514d\u8d39\u7528\u6237\u7684\u6587\u4ef6\u53ea\u80fd\u4fdd\u7559\u4e24\u4e2a\u6708\uff0c\u672a\u6ce8\u518c\u7684\u7528\u6237\u7684\u6587\u4ef6\u53ea\u80fd\u4fdd\u7559\u4e00\u4e2a\u6708</li>\r\n<li>\u53ef\u8bbe\u8ba1\u4fdd\u62a4\u5bc6\u7801\u548c\u6dfb\u52a0\u6587\u4ef6\u63cf\u8ff0.</li>\r\n</ul>\r\n<h4>\u9ad8\u7ea7\u7528\u6237:</h4>\r\n<ul>\r\n<li>\u4f18\u5148\u4e0b\u8f7d\u548c\u66f4\u5927\u7684\u5e26\u5bbd</li>\r\n<li>\u53ef\u4f7f\u7528\u6587\u4ef6\u7ba1\u7406\u8fdb\u884c\u591a\u6587\u4ef6\u4e0b\u8f7d\u548c\u591a\u7ebf\u7a0b\u4e0b\u8f7d.</li>\r\n<li>\u53ef\u4ece\u5176\u4ed64\u4e2a\u6d41\u884c\u7684\u6587\u4ef6\u5b58\u50a8\u670d\u52a1\u7a7a\u95f4\u4e0a\u4f20\u6587\u4ef6.</li>\r\n<li>\u652f\u6301FTP\u4e0a\u4f20.</li>\r\n<li>No\u5e7f\u