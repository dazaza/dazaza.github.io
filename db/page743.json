 7\u53ef\u4ee5\u5efa\u7acb\u4efb\u4f55\u4f60\u60f3\u8981\u8bbe\u8ba1\u76843D\u6a21\u578b\uff0c\u4e0d\u8fc7\u5b83\u63d0\u4f9b\u4e86\u66f4\u7b80\u5355\u7684\u6a21\u677f\u6765\u63a7\u5236\u6a21\u578b\u7684\u5927\u5c0f\u5c3a\u5bf8\uff0c\u800c\u4e14\u8fd8\u5305\u62ec\u5efa\u7b51\u8bbe\u8ba1\u3001Google Earth\u548c\u4ea7\u54c1\u8bbe\u8ba1\u6a21\u677f\u3002</P>\r\n<P>\u5728\u9009\u62e9\u4e86\u4e00\u4e2a\u6a21\u677f\u540e\uff0cSkethUp\u5c06\u63d0\u4f9b\u4e00\u4e2a\u76f8\u5bf9\u7b80\u5355\u7684\u8bbe\u8ba1\u9875\u9762\uff0c\u4f60\u53ef\u4ee5\u5728\u6b64\u57fa\u7840\u4e0a\u521b\u5efa\u6b63\u65b9\u5f62\u3001\u957f\u65b9\u5f62\u3001\u5f13\u5f62\u3001\u5706\u5f62\u3001\u76f4\u7ebf\uff0c\u6216\u8005\u662f\u624b\u52a8\u7ed8\u5236\u6a21\u578b\uff0c\u6a21\u677f\u4e0a\u65b9\u7684\u56fe\u6807\u7b80\u6d01\u6613\u7528\uff0c\u53f3\u65b9\u7684\u6307\u5bfc\u7a97\u53e3\u53ef\u4ee5\u5e2e\u52a9\u65b0\u624b\u4e86\u89e3\u5404\u4e2a\u5de5\u5177\u7684\u7528\u6cd5\uff0c\u4f7f\u7528\u5b83\u4f60\u4f1a\u53d1\u73b0\u539f\u6765\u7ed8\u52363D\u56fe\u50cf\u662f\u8fd9\u4e48\u7b80\u5355\u3002</P>\r\n<P>\u9664\u4e86\u81ea\u5df1\u7ed8\u753b\u4e4b\u5916\uff0c\u4f60\u8fd8\u53ef\u4ee5\u4eceGoogle\u76843D\u6a21\u578b\u5e93\u4e2d\u8c03\u7528\u4efb\u4f553D\u6a21\u578b\u6765\u4e30\u5bcc\u81ea\u5df1\u7684\u4f5c\u54c1\uff0c\u90a3\u91cc\u7684\u6a21\u578b\u6570\u91cf\u5e9e\u5927\uff0c\u4ece\u4eba\u7269\u5230\u5efa\u7b51\u65e0\u6240\u4e0d\u5305\uff0c\u4f60\u53ef\u4ee5\u65b9\u4fbf\u5730\u627e\u5230\u51e0\u4e4e\u6240\u6709\u9700\u8981\u7684\u4e1c\u897f\u3002</P>\r\n<P>Google\u5728SketchUp 7\u4e2d\u6dfb\u52a0\u4e86SketchUp 7 Pro\u4e13\u4e1a\u7248\u4e2d\u7684\u8bb8\u591a\u529f\u80fd\uff0c\u6bd4\u5982\u8bf4LayOut 2.0\uff0c\u652f\u6301\u77e2\u91cf\u6e32\u67d3\u548c\u5f88\u591a\u4e13\u4e1a\u4f5c\u56fe\u529f\u80fd\u3002\u800c\u4e14\u65b0\u589e\u4e86\u52a8\u6001\u7ec4\u4ef6\uff0c\u8fd9\u662f\u4e00\u4e2a\u5f88\u5f3a\u5927\u7684\u65b0\u6027\u80fd\uff0c\u5b83\u53ef\u4ee5\u5728\u591a\u79cd\u9650\u5b9a\u7684\u6761\u4ef6\u4e0b\u8fdb\u884c\u914d\u7f6e\u548c\u91cd\u65b0\u5b9a\u4e49\u5c3a\u5bf8\uff0c\u7c7b\u4f3c\u4e8e\u53ef\u4ee5\u8fdb\u884c\u53c2\u6570\u8bbe\u5b9a\u7684\u7ec4\u4ef6\uff0c\u8d4b\u4e88\u4e86\u6a21\u578b\u81ea\u52a8\u8c03\u6574\u7684\u80fd\u529b\uff0c\u6bd4\u5982\u8bf4\uff0c\u8bbe\u8ba1\u4e00\u4e2a\u697c\u68af\u7684\u65f6\u5019\uff0c\u5f53\u4f60\u5c06\u5176\u5c3a\u5bf8\u8c03\u5927\u6216\u662f\u8c03\u5c0f\u65f6\uff0c\u5b83\u4f1a\u81ea\u52a8\u589e\u52a0\u6216\u662f\u51cf\u5c11\u53f0\u9636\u6570\u76ee\u3002</P>\r\n<P>\u9a71\u52a8\u4e4b\u5bb6</P>", "imagename": null, "infoid": 104621, "category": "technology_google", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["google", "sketchup"]}, {"url": null, "title": "\u5fae\u8f6f2010\u5e74\u63a8\u51fa Windows 7 \u5d4c\u5165\u5f0f\u64cd\u4f5c\u7cfb\u7edf", "tags": "\u5fae\u8f6f Windows \u64cd\u4f5c\u7cfb\u7edf ", "name": "yinyin", "posttime": "2008-11-19 13:06:24", "ip": "222.128.48.207", "mark": 2, "note": "<DD id=articlebody>\r\n<P>\u5fae\u8f6f\u6bcf\u53d1\u5e03\u4e00\u4e2aWindows\u4e3b\u6d41\u7248\u672c\uff0c\u5c31\u4f1a\u5728\u57fa\u4e8e\u8be5\u7248\u672c\u4ee3\u7801\u7684\u57fa\u7840\u4e0a\u63d0\u4f9b\u6700\u65b0\u7248\u672c\u7684\u5d4c\u5165\u5f0f\u64cd\u4f5c\u7cfb\u7edf\uff0c\u4ee5\u7ec4\u4ef6\u5316\u7684\u5f62\u5f0f\u63d0\u4f9bWindows\u64cd\u4f5c\u7cfb\u7edf\u7684\u529f\u80fd\uff0c\u6b64\u6b21\u4e5f\u4e0d\u4f8b\u5916\uff0c\u5fae\u8f6f\u8ba1\u5212\u5728\u63a8\u51faWindows 7\u65f6\u4e5f\u63d0\u4f9b\u4e0b\u4e00\u4ee3Windows Embedded Standard\uff0c\u4ee3\u53f7\u4e3a\"Quebec\"\u3002</P>\r\n<P>\u76f8\u6bd4\u4e4b\u524d\u7684Windows XP Embedded\u4ee5\u53ca\u521a\u521a\u63a8\u51fa\u7684Windows Embedded Standard 2009\uff0cWindows Embedded \"Quebec\"\u63d0\u4f9b\u4e86\u66f4\u591a\u529f\u80fd\u5f3a\u5927\u7684\u4e0b\u4e00\u4ee3\u76f8\u5173\u6280\u672f\uff0c\u5305\u62ecSilverlight 2\u3001Windows Presentation Foundation\u4ee5\u53ca\u4e0eVisual Studio 2010\u7684\u4e92\u64cd\u4f5c\u6027\u3002</P>\r\n<P>\u57fa\u4e8eWindows 7\u7684Windows Embedded\"Quebec\"\u5c06\u63d0\u4f9b\u66f4\u4e30\u5bcc\u7684\u7528\u6237\u4f53\u9a8c\u3001\u66f4\u5f3a\u5927\u7684\u5b89\u5168\u6027\u548c\u63a7\u5236\u80fd\u529b\uff0c\u5e76\u4e14\u652f\u630164\u4f4d\u5904\u7406\u5668\uff0c\u8fd8\u5c06\u4e3a\u5d4c\u5165\u5f0f\u8bbe\u5907\u63d0\u4f9b\u66f4\u5f3a\u5927\u7684Web\u529f\u80fd\uff08\u5305\u62ec\u79bb\u7ebf\u529f\u80fd\uff09\u3002</P>\r\n<P>\u5176\u4e2d\uff0cSilverlight 2\u548cWindows Presentation Foundation\u5c06\u4e3a\u8bbe\u5907\u63d0\u4f9b\u65b0\u4e00\u4ee3\u5a92\u4f53\u4f53\u9a8c\u548c\u4e30\u5bcc\u7684Web\u5e94\u7528\u3002Windows BitLocker\u9a71\u52a8\u52a0\u5bc6\u548c\u5bc6\u7801\u7ba1\u7406\u53ef\u4ee5\u4fdd\u62a4\u5d4c\u5165\u5f0f\u8bbe\u5907\u4e0a\u7684\u6570\u636e\uff0c\u540c\u65f6\u63d0\u4f9b\u66f4\u9ad8\u7684\u5b89\u5168\u6027\u3002IE 8\u7684\u4f7f\u7528\u5219\u53ef\u4ee5\u6709\u6548\u9632\u8303\u6076\u610f\u7f51\u7ad9\uff0c\u901a\u8fc7\u6539\u5584\u5b89\u5168\u6027\u548cInPrivate\u9690\u79c1\u6d4f\u89c8\u529f\u80fd\u4fdd\u62a4\u4e2a\u4eba\u6570\u636e\u7684\u9690\u79c1\u3002</P>\r\n<P>\u5fae\u8f6f\u516c\u53f8Windows Embedded\u90e8\u95e8\u603b\u7ecf\u7406Kevin Dallas\u8868\u793a\uff1a\"\u901a\u8fc7\u589e\u52a0\u591a\u70b9\u89e6\u63a7\u3001\u652f\u6301\u624b\u52bf\u548c\u589e\u5f3a\u7684\u7528\u6237\u754c\u9762\u7b49\u529f\u80fd\uff0cWindows Embedded \u2018Quebec\u2019\u4f7f\u5f97OEM\u5382\u5546\u4eec\u80fd\u591f\u8fdb\u4e00\u6b65\u5c55\u73b0\u81ea\u5df1\u7684\u8bbe\u5907\u7279\u8272\uff0c\u63d0\u4f9b\u5168\u65b0\u7684\u7528\u6237\u4f53\u9a8c\u3002\u5b83\u62e5\u6709\u4e30\u5bcc\u7684\u7ec4\u4ef6\u5316\u64cd\u4f5c\u7cfb\u7edf\u6280\u672f\u548c\u4e13\u7528\u529f\u80fd\uff0c\u5141\u8bb8\u5f00\u53d1\u8005\u53ea\u4fdd\u7559\u4ed6\u4eec\u9700\u8981\u7684\u9a71\u52a8\u7a0b\u5e8f\u3001\u670d\u52a1\u548c\u5e94\u7528\uff0c\u8fd9\u6837\u5c31\u80fd\u5927\u5927\u4f18\u5316\u4ed6\u4eec\u8bbe\u5907\u4e0a\u7684\u64cd\u4f5c\u7cfb\u7edf\u3002\" </P></DD>\r\n<DD>\r\n<P>\u9a71\u52a8\u4e4b\u5bb6</P></DD>", "imagename": null, "infoid": 104620, "category": "technology_internet", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u5fae\u8f6f", "windows", "\u64cd\u4f5c\u7cfb\u7edf"]}, {"url": "http://my.dongua.com/wewa/blog!entry/4365.entry", "title": "\u8f66\u6807\u8bbe\u8ba1\u7684\u8fdb\u5316 (13P)", "tags": "\u6c7d\u8f66 \u6807\u5fd7 \u8bbe\u8ba1 ", "name": "lomomo", "posttime": "2008-11-19 12:48:49", "ip": "58.252.66.239", "mark": 3, "note": "\u5bf9\u4e8e\u6c7d\u8f66\uff0c\u8f66\u6807\u662f\u6700\u91cd\u8981\u7684\u6807\u8bc6\uff0c\u4e5f\u662f\u54c1\u724c\u7684\u4f9d\u6258\u3002\u5728\u6c7d\u8f66\u5386\u53f2\u7684\u957f\u6cb3\u91cc\uff0c\u5404\u5f0f\u540d\u8f66\u7684\u8f66\u6807\u4e5f\u5728\u4e0d\u65ad\u7684\u53d8\u5316\u3001\u9769\u65b0\u3002\u8fd9\u6b21\u6211\u4eec\u5c31\u6765\u770b\u4e00\u4e9b\u56fd\u9645\u6c7d\u8f66\u54c1\u724c\u7684\u8f66\u6807\uff0c\u5728\u6570\u5341\u5e74\u95f4\u662f\u5982\u4f55\u8fdb\u5316\u7684\u3002", "imagename": "72b782cbe924477185ab6b84a30ce892.jpg", "infoid": 104616, "category": "technology_design", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u6c7d\u8f66", "\u6807\u5fd7", "\u8bbe\u8ba1"]}, {"url": null, "title": "\u5fae\u8f6f\u6b63\u5f0f\u53d1\u5e03 Exchange / SharePoint Online", "tags": "\u5fae\u8f6f Exchange SharePoint Online ", "name": "yinyin", "posttime": "2008-11-19 12:26:40", "ip": "222.128.48.207", "mark": 1, "note": "<P>\u5728\u65e7\u91d1\u5c71\u4e3e\u884c\u7684\u53d1\u5e03\u4f1a\u4e0a\uff0c\u5fae\u8f6f\u5546\u52a1\u90e8\u95e8\u603b\u88c1Stehpen Elop\u6b63\u5f0f\u5ba3\u5e03\u63a8\u51fa<STRONG>Exchange Online</STRONG>\u548c<STRONG>SharePoint Online</STRONG>\u4e24\u4e2a\u65b0\u7684\u5728\u7ebf\u4f01\u4e1a\u670d\u52a1\u3002</P>\r\n<P>\u8fd9\u4e24\u79cd\u8ba2\u9605\u5f0f\u670d\u52a1\u73b0\u5df2\u9762\u5411\u7f8e\u56fd\u5927\u4e2d\u5c0f\u578b\u4f01\u4e1a\u516c\u53f8\u5f00\u653e\uff0c\u610f\u5728\u4e3a\u7528\u6237\u63d0\u4f9b\u4e00\u79cd\u5168\u65b0\u7684\u65b9\u5f0f\u8d2d\u4e70\u3001\u90e8\u7f72\u548c\u7ba1\u7406\u65b9\u5f0f\uff0c\u5176\u4e2dExchange Online\u4e3b\u8981\u7528\u4e8e\u684c\u9762\u548c\u79fb\u52a8\u7535\u5b50\u90ae\u4ef6\u3001\u65e5\u5386\u7ba1\u7406\uff0c\u5e76\u80fd\u4e0eOutlook Web Access\u3001Office Outlook\u5b8c\u7f8e\u96c6\u6210\uff0c\u800cSharePoint Online\u4e3b\u8981\u7528\u4e8e\u4f01\u4e1a\u95e8\u6237\u7f51\u7ad9\u3001\u5458\u5de5\u534f\u4f5c\u4e0e\u4ea4\u6d41\u3001\u641c\u7d22\u7b49\u3002</P>\r\n<P>Exchange Online\u548cSharePoint\u90fd\u662f<STRONG>\u5fae\u8f6f\u5728\u7ebf\u670d\u52a1(Online Services)\u4ea7\u54c1\u7ebf</STRONG>\u7684\u4e00\u90e8\u5206\uff0c\u5355\u72ec\u8d2d\u4e70\u6bcf\u4f4d\u7528\u6237\u6bcf\u6708\u9700\u8981<STRONG>10\u7f8e\u5143\u548c7.25\u7f8e\u5143</STRONG>\u3002\u4e0e\u6b64\u540c\u65f6\u5fae\u8f6f\u8fd8\u63d0\u4f9b\u4e86\u5176\u4ed6\u4e00\u4e9b\u8f85\u52a9\u670d\u52a1\uff1a</P>\r\n<P><STRONG>Office Live Meeting</STRONG>\uff1a\u7f51\u7edc\u548c\u89c6\u9891\u4f1a\u8bae\u65b9\u6848\uff0c\u6bcf\u4f4d\u7528\u6237\u6bcf\u67084.5\u7f8e\u5143\u3002</P>\r\n<P><STRONG>Office Communications Online</STRONG>\uff1a\u529e\u516c\u5373\u65f6\u901a\u8baf\u65b9\u6848\uff0c\u6bcf\u4f4d\u7528\u6237\u6bcf\u67082.5\u7f8e\u5143\u3002</P>\r\n<P><STRONG>Exchange Hosted Services</STRONG>\uff1a\u90ae\u4ef6\u5b89\u5168\u9632\u62a4\u65b9\u6848\uff0c\u6bcf\u4f4d\u7528\u6237\u6bcf\u67081.75\u7f8e\u5143(\u8fc7\u6ee4)\u62168.6\u7f8e\u5143(\u5b58\u6863)\u3002</P>\r\n<P><STRONG>Dynamics CRM Online</STRONG>\uff1a\u52a8\u6001CRM\u7ba1\u7406\u65b9\u6848\uff0c\u6bcf\u4f4d\u7528\u6237\u6bcf\u670839\u7f8e\u5143\u3002</P>\r\n<P>\u4f01\u4e1a\u8fd8\u53ef\u4ee5\u8d2d\u4e70Exchange Online\u3001SharePoint Online\u3001Office Live Meeting\u3001Office Communications Online\u7b49\u7ec4\u6210\u7684<STRONG>\u6807\u51c6\u5957\u88c5</STRONG>\uff0c<STRONG>\u6bcf\u4f4d\u7528\u6237\u6bcf\u670815\u7f8e\u5143</STRONG>\uff0c\u6bd4\u5355\u72ec\u8d2d\u4e70\u8282\u77019.25\u7f8e\u5143\u3002</P>\r\n<P>&nbsp;</P>\r\n<P>\u5fae\u8f6f\u5728\u7ebf\u670d\u52a1\u5b98\u65b9\u7f51\u7ad9\uff1a<BR><A class=f14_link href=\"http://www.microsoft.com/online/default.mspx\" target=_blank>http://www.microsoft.com/online/default.mspx</A></P>", "imagename": null, "infoid": 104614, "category": "technology_internet", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u5fae\u8f6f", "exchange", "online"]}]