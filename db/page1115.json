[{"url": "http://hi.baidu.com/wuhanhua", "title": "&quot;Google \u97e9\u56fd&quot; \u6c49\u5316\u7248", "tags": "Google ", "name": "wlhch", "posttime": "2007-05-31 18:58:10", "ip": "125.33.250.139", "mark": 22, "note": "\u53ef\u80fd\u5df2\u7ecf\u5f88\u591a\u4eba\u5df2\u7ecf\u770b\u5230\u4e86\u3002\r\n\u4eca\u5929\u7f51\u7edc\u4e0a\u5f00\u59cb\u6d41\u4f20\u8fd9\u4e2a\u6781\u9177\u7684 &quot;Google\u97e9\u56fd&quot;\u4e0b\u73ed\u524d\u628a\u5979\u6c49\u5316\u4e86\u4e00\u4e0b\u3002\u559c\u6b22\u7684\u53ef\u4ee5\u6536\u85cf\u8d77\u6765\u3002\u4e2a\u4eba\u5f88\u559c\u6b22\u8fd9\u4e2a\u9875\u9762\uff0c\u6240\u4ee5\u5c3d\u91cf\u5c0a\u91cd\u539f\u7248\uff0c\u4ec5\u4ec5\u5728\u53f3\u4e0a\u89d2\u52a0\u4e86\u6211\u7684blog\u94fe\u63a5\uff0c\u522b\u7684\u6ca1\u6709\u6539\u53d8\u9875\u9762\u4e0a\u4efb\u4f55\u4e00\u4e2a\u5143\u7d20\u3002\r\nhttp://www.x2y2.com/google/", "imagename": "", "infoid": 20982, "category": "technology_google", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["google"]}, {"url": "http://hi.baidu.com/wuhanhua/blog/item/d09f564e478e1d08b2de05c7.html", "title": "\u4e2d\u56fd\u4eba,\u4e3a\u957f\u57ce\u6295\u4e0a\u4e00\u7968", "tags": "\u4e03\u5927\u5947\u8ff9 ", "name": "wlhch", "posttime": "2007-05-31 18:52:35", "ip": "125.33.250.139", "mark": 21, "note": "\u4e16\u754c\u65b0\u4e03\u5927\u5947\u8ff9\u8bc4\u9009\u7531\u8054\u5408\u56fd\u79d1\u6559\u6587\u7ec4\u7ec7\u4e0e\u745e\u58eb\u56fd\u9645\u6587\u5316\u4fdd\u62a4\u7ec4\u7ec7\u2014\u2014\u4e16\u754c\u65b0\u4e03\u5927\u5947\u8ff9\u57fa\u91d1\u4f1a\u8054\u5408\u542f\u53d1,\u5728\u5168\u4e16\u754c\u8303\u56f4\u5185\u8fdb\u884c,\u5171\u670977\u4e2a\u5019\u9009\u5efa\u7b51\uff0c\u6700\u540e\u7ed3\u679c\u5c06\u4e8e2007\u5e747\u67087\u65e5\u5728\u8461\u8404\u7259\u91cc\u65af\u672c\u63ed\u6653.\u5165\u9009\u524d\u5341\u540d\u7684\u666f\u70b9\u65e5\u524d\u63ed\u6653,\u5206\u522b\u662f\u5e0c\u814a\u96c5\u5178\u7684\u536b\u57ce\u3001\u58a8\u897f\u54e5\u5c24\u5361\u5766\u534a\u5c9b\u4e0a\u7684\u829d\u9648\u5c3c\u8428\u9057\u5740\u3001\u7f57\u9a6c\u5706\u5f62\u5927\u5267\u573a\u3001\u4e2d\u56fd\u7684\u4e07\u91cc\u957f\u57ce\u3001\u5df4\u9ece\u7684\u827e\u83f2\u5c14\u94c1\u5854\u3001\u79d8\u9c81\u7684\u5370\u52a0\u68ee\u6797\u57ce\u9a6c\u4e18\u6bd4\u4e18\u3001\u7ea6\u65e6\u4f69\u7279\u62c9\u53e4\u57ce\u3001\u82f1\u56fd\u53f2\u524d\u5de8\u77f3\u67f1\u3001\u667a\u5229\u7684\u590d\u6d3b\u8282\u5c9b\u96d5\u50cf\u4ee5\u53ca\u5370\u5ea6\u963f\u683c\u62c9\u7684\u6cf0\u59ec\u9675. \r\n           \u4f46\u76ee\u524d\u4ee5\u5317\u4eac\u516b\u8fbe\u5cad\u957f\u57ce\u4e3a\u4ee3\u8868\u7684\u4e2d\u56fd\u957f\u57ce\u53ef\u80fd\u518d\u6b21\u65e0\u7f18\u4e16\u754c\u201c\u65b0\u4e03\u5927\u5947\u8ff9\u201d\u79f0\u53f7.\u6628\u5929,\u4e2d\u56fd\u957f\u57ce\u5b66\u4f1a\u8feb\u4e0d\u5f97\u5df2\u5728\u516b\u8fbe\u5cad\u957f\u57ce\u5c55\u5f00\u62c9\u7968\u6d3b\u52a8,\u9f13\u52b1\u66f4\u591a\u5e02\u6c11\u548c\u6e38\u5ba2\u5728\u6295\u7968\u622a\u6b62\u65e5\u671f(2007\u5e747\u67087\u65e5\u96f6\u65f6)\u524d\u6295\u7968.\u636e\u900f\u9732,\u4e3b\u529e\u65b9\u79f0\u957f\u57ce\u76ee\u524d\u6295\u7968\u603b\u6570\u5728\u524d\u4e03\u540d\u4e4b\u5916,\u4f46\u5177\u4f53\u7968\u6570\u4e0d\u4e88\u516c\u5f00. \uff08\u6d88\u606f\u6765\u6e90\uff1a\u957f\u57ce\u53ef\u80fd\u843d\u9009\u65b0\u4e03\u5927\u5947\u8ff9 \u7968\u6570\u4e0d\u516c\u5f00\u906d\u8d28\u7591\uff09 \r\n      \u670b\u53cb\u4eec,\u8ba9\u6211\u4eec\u884c\u52a8\u8d77\u6765,\u90fd\u6765\u4e3a\u7956\u56fd\u4f1f\u5927\u7684\u4e07\u91cc\u957f\u57ce\u6295\u4e0a\u5b9d\u8d35\u7684\u4e00\u7968\u5427!\u8ba9\u6211\u4eec\u643a\u624b\u52aa\u529b,\u8981\u4e16\u754c\u77e5\u9053\u2014\u2014\u5728\u53e4\u8001\u7684\u4e1c\u65b9,\u9f99\u7684\u56fd\u5ea6,\u6709\u7740\u5947\u8ff9\u822c\u7684\u4e07\u91cc\u957f\u57ce,The Great Wall!\r\n\r\n      \u4e3a\u65b0\u4e03\u5927\u5947\u8ff9\u6295\u7968\u65b9\u5f0f \r\n\r\n         \u25cf\u7f51\u4e0a\u6295\u7968\r\n\u7b2c\u4e00\u6b65:\u6253\u5f00\u94fe\u63a5www.new7wonders.com/index.php?id=409&amp;L=2 \r\n1,\u8f93\u5165\u5e76\u786e\u8ba4\u60a8\u7684\u90ae\u7bb1\u5730\u5740 \r\n2,\u9009\u62e9\u51fa7\u4e2a\u60a8\u5fc3\u76ee\u4e2d\u7684\u4e03\u5927\u5947\u8ff9(\u5fc5\u987b\u9009\u4e2d\u4e03\u4e2a) \r\n3,\u63d0\u4ea4\u6ce8\u518c,\u6210\u4e3a\u4f1a\u5458 \r\n\u7b2c\u4e8c\u6b65:\u63a5\u6536\u786e\u8ba4\u90ae\u4ef6 \r\n1,\u6253\u5f00\u60a8\u521a\u624d\u6ce8\u518c\u7684\u7535\u5b50\u90ae\u7bb1,\u63a5\u6536\u6765\u81ea\u4e03\u5927\u5947\u8ff9\u7ec4\u59d4\u4f1a\u7684\u786e\u8ba4\u90ae\u4ef6 \r\n2,\u6253\u5f00\u90ae\u4ef6\u5185\u5bb9\u7684\u94fe\u63a5,\u518d\u6b21\u8fdb\u5165\u4e03\u5927\u5947\u8ff9\u7f51\u7ad9 \r\n3,\u6309\u8981\u6c42\u586b\u5199\u4e2a\u4eba\u8d44\u6599,\u786e\u8ba4\u9009\u7968 \r\n4,\u5b8c\u6210\u64cd\u4f5c\u540e,\u9009\u7968\u751f\u6548 \r\n\r\n         \u25cf\u77ed\u4fe1\u6295\u7968\r\n\r\n\u4e2d\u56fd\u79fb\u52a8\u7528\u6237:\u53d1\u9001&quot;CC09&quot;\u5230125617;\r\n\r\n\u4e2d\u56fd\u8054\u901a\u7528\u6237:\u53d1\u9001&quot;CC#09&quot;\u52309836,\u5373\u53ef\u4e3a\u957f\u57ce\u6295\u7968. \r\n\r\n\u4e00\u90e8\u624b\u673a\u53ef\u591a\u6b21\u6295\u7968.(\u4fe1\u606f\u8d39:1\u5143/\u7968;\u6295\u7968\u4e0d\u6210\u529f\u4e0d\u8ba1\u8d39) \r\n\r\n            (\u672c\u6295\u7968\u4ec5\u9650\u4e2d\u56fd\u5927\u9646\u5730\u533a\u4e2d\u56fd\u79fb\u52a8\u548c\u8054\u901a\u7528\u6237) \r\n\r\n         \u6ce8\u610f\u4e8b\u9879\uff1a\r\n\u7f51\u4e0a\u6295\u7968,\u9700\u8981\u9009\u4e2d\u60a8\u559c\u7231\u7684\u4e03\u5904\u4e16\u754c\u540d\u80dc,\u5982\u679c\u60a8\u53ea\u60f3\u4e3a\u4e2d\u56fd\u957f\u57ce\u6295\u7968,\u5efa\u8bae\u60a8\u9009\u7528\u77ed\u4fe1\u6295\u7968\u65b9\u5f0f\u652f\u6301\u957f\u57ce.\r\n\r\n\u5efa\u8bae:   \u5176\u4ed66\u4e2a\u6700\u597d\u9009\u4e0d\u600e\u4e48\u6709\u540d\u7684,\u56e0\u4e3a\u5927\u5bb6\u90fd\u9009\u6709\u540d\u7684,\u5b83\u5c31\u66f4\u6709\u540d\u4e86", "imagename": "", "infoid": 20981, "category": "videos_other", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "videos", "via": null, "real_tags": ["\u4e03\u5927\u5947\u8ff9"]}, {"url": null, "title": "\u4e2d\u56fd\u4eba,\u4e3a\u957f\u57ce\u6295\u4e0a\u4e00\u7968", "tags": "\u4e03\u5927\u5947\u8ff9 \u957f\u57ce ", "name": "wlhch", "posttime": "2007-05-31 18:50:17", "ip": "125.33.250.139", "mark": 21, "note": "<FONT size=1>\u4e16\u754c\u65b0\u4e03\u5927\u5947\u8ff9\u8bc4\u9009\u7531\u8054\u5408\u56fd\u79d1\u6559\u6587\u7ec4\u7ec7\u4e0e\u745e\u58eb\u56fd\u9645\u6587\u5316\u4fdd\u62a4\u7ec4\u7ec7\u2014\u2014\u4e16\u754c\u65b0\u4e03\u5927\u5947\u8ff9\u57fa\u91d1\u4f1a\u8054\u5408\u542f\u53d1,\u5728\u5168\u4e16\u754c\u8303\u56f4\u5185\u8fdb\u884c,\u5171\u670977\u4e2a\u5019\u9009\u5efa\u7b51\uff0c\u6700\u540e\u7ed3\u679c\u5c06\u4e8e2007\u5e747\u67087\u65e5\u5728\u8461\u8404\u7259\u91cc\u65af\u672c\u63ed\u6653.\u5165\u9009\u524d\u5341\u540d\u7684\u666f\u70b9\u65e5\u524d\u63ed\u6653,\u5206\u522b\u662f\u5e0c\u814a\u96c5\u5178\u7684\u536b\u57ce\u3001\u58a8\u897f\u54e5\u5c24\u5361\u5766\u534a\u5c9b\u4e0a\u7684\u829d\u9648\u5c3c\u8428\u9057\u5740\u3001\u7f57\u9a6c\u5706\u5f62\u5927\u5267\u573a\u3001</FONT><FONT style=\"PADDING-RIGHT: 1px; PADDING-LEFT: 1px; FILTER: glow(color=#FF0033,strength=3); PADDING-BOTTOM: 1px; COLOR: #ffffff; PADDING-TOP: 1px; HEIGHT: 10px\" size=1>\u4e2d\u56fd\u7684\u4e07\u91cc\u957f\u57ce</FONT><WBR></WBR><FONT size=1>\u3001\u5df4\u9ece\u7684\u827e\u83f2\u5c14\u94c1\u5854\u3001\u79d8\u9c81\u7684\u5370\u52a0\u68ee\u6797\u57ce\u9a6c\u4e18\u6bd4\u4e18\u3001\u7ea6\u65e6\u4f69\u7279\u62c9\u53e4\u57ce\u3001\u82f1\u56fd\u53f2\u524d\u5de8\u77f3\u67f1\u3001\u667a\u5229\u7684\u590d\u6d3b\u8282\u5c9b\u96d5\u50cf\u4ee5\u53ca\u5370\u5ea6\u963f\u683c\u62c9\u7684\u6cf0\u59ec\u9675. <BR>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; \u4f46\u76ee\u524d<STRONG><WBR></WBR><FONT style=\"LINE-HEIGHT: 1.3em\" color=#6b0c1f>\u4ee5\u5317\u4eac\u516b\u8fbe\u5cad\u957f\u57ce\u4e3a\u4ee3\u8868\u7684\u4e2d\u56fd\u957f\u57ce\u53ef\u80fd\u518d\u6b21\u65e0\u7f18\u4e16\u754c\u201c\u65b0\u4e03\u5927\u5947\u8ff9\u201d\u79f0\u53f7.</FONT></STRONG>\u6628\u5929,\u4e2d\u56fd\u957f\u57ce\u5b66\u4f1a\u8feb\u4e0d\u5f97\u5df2\u5728\u516b\u8fbe\u5cad\u957f\u57ce\u5c55\u5f00\u62c9\u7968\u6d3b\u52a8,\u9f13\u52b1\u66f4\u591a\u5e02\u6c11\u548c\u6e38\u5ba2\u5728\u6295\u7968\u622a\u6b62\u65e5\u671f(2007\u5e747\u67087\u65e5\u96f6\u65f6)\u524d\u6295\u7968.\u636e\u900f\u9732,\u4e3b\u529e\u65b9\u79f0\u957f\u57ce\u76ee\u524d\u6295\u7968\u603b\u6570\u5728\u524d\u4e03\u540d\u4e4b\u5916,\u4f46\u5177\u4f53\u7968\u6570\u4e0d\u4e88\u516c\u5f00. <FONT style=\"LINE-HEIGHT: 1.3em\">\uff08<FONT style=\"LINE-HEIGHT: 1.3em\" color=#9933ff>\u6d88\u606f\u6765\u6e90\uff1a</FONT><WBR></WBR><A href=\"http://news.qq.com/a/20070529/000757.htm\" target=_blank>\u957f\u57ce\u53ef\u80fd\u843d\u9009\u65b0\u4e03\u5927\u5947\u8ff9 \u7968\u6570\u4e0d\u516c\u5f00\u906d\u8d28\u7591</A><WBR></WBR></FONT><WBR></WBR><FONT style=\"LINE-HEIGHT: 1.3em\">\uff09</FONT><WBR></WBR> <BR><FONT style=\"LINE-HEIGHT: 1.3em\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</FONT><WBR></WBR><FONT style=\"LINE-HEIGHT: 1.3em\">\u670b\u53cb\u4eec,\u8ba9\u6211\u4eec\u884c\u52a8\u8d77\u6765,\u90fd\u6765\u4e3a</FONT><WBR></WBR></FONT><FONT style=\"PADDING-RIGHT: 1px; PADDING-LEFT: 1px; FILTER: glow(color=#FF0033,strength=3); PADDING-BOTTOM: 1px; COLOR: #ffffff; PADDING-TOP: 1px; HEIGHT: 10px\" size=1>\u7956\u56fd\u4f1f\u5927\u7684\u4e07\u91cc\u957f\u57ce</FONT><WBR></WBR><FONT size=1><FONT style=\"LINE-HEIGHT: 1.3em\">\u6295\u4e0a\u5b9d\u8d35\u7684\u4e00\u7968\u5427!\u8ba9\u6211\u4eec\u643a\u624b\u52aa\u529b,\u8981\u4e16\u754c\u77e5\u9053\u2014\u2014\u5728</FONT><WBR></WBR><FONT style=\"LINE-HEIGHT: 1.3em\">\u53e4\u8001\u7684\u4e1c\u65b9,\u9f99\u7684\u56fd\u5ea6,\u6709\u7740\u5947\u8ff9\u822c\u7684</FONT><WBR></WBR></FONT><FONT style=\"PADDING-RIGHT: 1px; PADDING-LEFT: 1px; FILTER: glow(color=#FF0033,strength=3); PADDING-BOTTOM: 1px; COLOR: #ffffff; PADDING-TOP: 1px; HEIGHT: 10px\" size=1>\u4e07\u91cc\u957f\u57ce</FONT><WBR></WBR><FONT style=\"LIN