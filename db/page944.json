u864e\u7684\u4ee3\u7406\u6743\u4e4b\u4e89\uff0c\u540c\u65f6\u5c06\u964d\u4f4e\u6536\u8d2d\u8fd9\u5bb6\u5883\u51b5\u6b20\u4f73\u7684\u4e92\u8054\u7f51\u95e8\u6237\u7f51\u7ad9\u7684\u62a5\u4ef7\u3002\r\n\r\n\u3000\u3000\u4eca\u5929\u5f00\u76d8\u540e\u4e0d\u4e45\u53cc\u65b9\u7684\u6597\u4e89\u8fdb\u4e00\u6b65\u5347\u7ea7\u3002\u4eca\u6668\u96c5\u864e\u6307\u51fa\uff0c\u5fae\u8f6f\u81ea\u8eab\u80a1\u4ef7\u7684\u4e0b\u6ed1\u4f7f\u5176\u62a5\u4ef7\u7684\u5438\u5f15\u529b\u8fd8\u4e0d\u5982\u5df2\u906d\u5230\u62d2\u7edd\u7684\u6700\u521d\u62a5\u4ef7\u3002\r\n\r\n\u3000\u3000\u96c5\u864e\u8fd8\u8868\u793a\uff0c\u5fae\u8f6fCEO\u6709\u5173\u96c5\u864e\u8fd8\u6709\u4e09\u5468\u65f6\u95f4\u8fdb\u884c\u8c08\u5224\u4ee5\u8fbe\u6210\u4ea4\u6613\uff0c\u5426\u5219\u5c06\u9762\u4e34\u5fae\u8f6f\u654c\u610f\u6536\u8d2d\u884c\u52a8\u7684\u58f0\u660e\u53ea\u4f1a\u201c\u9002\u5f97\u5176\u53cd\u201d\u3002\r\n\r\n\u3000\u3000\u4ea4\u6613\u8fdb\u7a0b\u8868\u660e\uff1a\u4ef7\u683c\u5df2\u6210\u4e3a\u53cc\u65b9\u5408\u5e76\u7684\u6700\u5927\u969c\u788d\u3002\u5fae\u8f6f\u5f3a\u8c03\uff0c\u516c\u53f8\u575a\u4fe1\u5176\u62a5\u4ef7 -- \u6700\u521d\u4ef7\u503c\u7ea6446\u4ebf\u7f8e\u5143 -- \u662f\u5145\u5206\u800c\u516c\u5e73\u7684\uff0c\u4f46\u96c5\u864e\u5728\u53cc\u65b9\u7684\u6700\u8fd1\u4e00\u6b21\u63a5\u89e6\u4e2d\u518d\u6b21\u4e88\u4ee5\u62d2\u7edd\u3002\r\n\r\n\u3000\u3000\u96c5\u864eCEO\u6768\u81f4\u8fdc\u548c\u4e3b\u5e2d\u7f57\u4f0a-\u6ce2\u65af\u6258\u514b(Roy Bostock)\u5728\u4e00\u5c01\u81f4\u5fae\u8f6fCEO\u53f2\u8482\u592b-\u9c8d\u5c14\u9ed8(Steve Ballmer)\u7684\u4fe1\u4e2d\u5199\u9053\uff1a\u201c\u6211\u4eec\u4ecd\u7136\u8ba4\u4e3a\u4f60\u65b9\u7684\u62a5\u4ef7\u4e0d\u7b26\u5408\u96c5\u864e\u548c\u6211\u4eec\u80a1\u4e1c\u7684\u6700\u9ad8\u5229\u76ca\u3002\u201d\r\n\r\n\u3000\u3000\u5468\u672b\u9c8d\u5c14\u9ed8\u8868\u793a\uff0c\u201c\u516c\u5f00\u7edf\u8ba1\u6307\u6807\u201d\u8868\u660e\u96c5\u864e\u7684\u641c\u7d22\u548c\u7f51\u9875\u6d4f\u89c8\u91cf\u4e0b\u964d\u3002", "imagename":