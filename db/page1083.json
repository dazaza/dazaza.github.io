e6\u7ec6.\r\n\u65b0\u7248\u7684\u4e3b\u9875\u4f1a\u548c\u5c06\u6765\u7684\u793e\u533a\u66f4\u7d27\u5bc6\u7684\u7ed3\u5408,\u4fc3\u8fdb\u8d44\u6e90\u6240\u5728\u7684\u5c0f\u7ec4,\u8d44\u6e90\u53d1\u5e03\u8005\u548c\u7f51\u53cb\u4e4b\u95f4\u7684\u4e92\u52a8.\u6d4b\u8bd5\u53ef\u80fd\u4f1a\u6301\u7eed2\u5468\u5de6\u53f3,\u4e3b\u8981\u5bf9\u670d\u52a1\u5668\u8d1f\u8f7d\u548c\u7a0b\u5e8fbug\u65b9\u9762\u8fdb\u884c\u6539\u8fdb.", "imagename": "d8e835c62f964789a03786b43dd15243.png", "infoid": 24251, "category": "technology_internet", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["verycd", "\u7535\u9a74"]}, {"url": "http://kyyhkynen.net/stuff/diggtris/", "title": "digg\u5f0f\u7684\u4fc4\u7f57\u65af\u65b9\u5757", "tags": "digg \u4fc4\u7f57\u65af\u65b9\u5757", "name": "stephenzhai", "posttime": "2007-07-07 16:38:37", "ip": "124.19.18.204", "mark": 10, "note": "\u8fd9\u662f\u4e00\u4e2aFlash\u505a\u7684\u4fc4\u7f57\u65af\u65b9\u5757\u6e38\u620f\uff0c\u4e0e\u4ee5\u5f80\u65b9\u5757\u6e38\u620f\u4e0d\u540c\u7684\u662f\uff0c\u964d\u843d\u7684\u65b9\u5757\u8868\u793a\u6bcf\u4e00\u4e2a\u88ab\u53d1\u73b0\u7684\u6545\u4e8b\uff0c\u65b9\u5757\u7684\u989c\u8272\u8868\u793a\u6545\u4e8b\u7684\u5206\u7c7b\uff0c\u65b9\u5757\u7684\u5927\u5c0f\u5219\u8868\u793a\u8be5\u6545\u4e8b\u88ab\u9876\u7684\u6570\u91cf\u3002", "imagename": "59f4a6f324424c919bc9dc5517d4681f.gif", "infoid": 24227, "category": "technology_games", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["digg", "\u4fc4\u7f57\u65af\u65b9\u5757"]}]