3e\u793a\u5927\u54c1\u724c\u6b63\u7a33\u6b65\u5411\u65e0\u6570\u5b57\u7248\u6743\u7ba1\u7406DRM\u97f3\u4e50\u7684\u9500\u552e\u53d1\u5c55\u3002\u5728\u6211\u770b\u6765\u8fd9\u79cd\u53d1\u5c55/\u8fdb\u5316\u662f\u4e0d\u53ef\u907f\u514d\u7684\uff0c\u5e76\u4e14\u968f\u540e\u4ef7\u683c\u5c06\u88ab\u964d\u4f4e\u5230\u8d8b\u4e8e\u96f6\u3002\u53ef\u4ee5\u6839\u636e\u670d\u52a1\u6c34\u5e73\u51fa\u552e\u670d\u52a1\uff08\u7f13\u89e3\u548c\u4e0b\u8f7d\u901f\u5ea6\uff0c\u5305\u62ec\u97f3\u4e50\u89c6\u9891\u5185\u5bb9\u548c\u827a\u672f\u753b\u518c\u7b49\uff09\uff0c\u4f46\u4e0d\u8981\u592a\u591a\u3002\u6211\u4f1a\u5728\u672c\u5468\u665a\u4e9b\u65f6\u5019\u7684\u4e00\u7bc7\u6587\u7ae0\u91cc\u6269\u5c55\u8fd9\u4e9b\u601d\u60f3\u3002</P>\r\n<P>\u4eca\u5929\u6211\u5076\u7136\u770b\u5230\u4e86\u4e00\u4e2a\u53eb<A href=\"http://www.onlyshare.net/blog/ct.ashx?id=97339b35-ddee-46c1-8af3-77a742a03e3d&amp;url=http%3a%2f%2fwww.amie.st%2f\" ?>\u827e\u7c73\u8857</A>\u7684\u65b0\u521b\u7acb\u7684\u7f51\u7ad9\uff0c\u53ef\u80fd\u627e\u5230\u4e86\u5e2e\u52a9\u4eba\u4eec\u53d1\u73b0\uff0c\u63a8\u9500\u5b9a\u4ef7\u65b0\u7684\u6216\u4e0d\u4e3a\u4eba\u77e5\u7684\u97f3\u4e50\u7684\u65b9\u6cd5\u3002<A href=\"http://www.onlyshare.net/blog/ct.ashx?id=97339b35-ddee-46c1-8af3-77a742a03e3d&amp;url=http%3a%2f%2fmembers.amie.st%2fmembers%2faboutUs.php\" ?>\u521b\u59cb\u4eba</A>\u6709\uff1aElliott Breece, Elias Roman and Joshua Boltuch, \u662f\u4e09\u4e2a\u7f8e\u56fd\u7f57\u5f97\u5c9b\u5dde\u666e\u6d1b\u7ef4\u987f\u65af\u5b66\u9662Providence, RI college\u7684\u5b66\u751f\u3002</P>\r\n<P>\u8fd9\u662f\u4e00\u4e2a\u975e\u5e38\u521d\u59cb\u7684\u7ad9\u70b9\uff0c\u6709\u90a3\u4e48\u51e0\u4e2a\u6f0f\u6d1e\uff08\u6211\u53ea\u80fd\u4f7fflash player\u5728PC\u673aFirefox\u4e0a\u8fd0\u884c\uff0c\u5f88\u4e0d\u5e78\u4e0d\u80fd\u7528IE\u6216\u8005\u5b89\u88c5\u4e86Firefox\u7684Mac\uff09\uff0c\u754c\u9762\u53ef\u4ee5\u4f7f\u7528\u4e00\u4e9b\u6d41\u52a8\u5e2e\u52a9\u3002\u4f46\u8fd9\u4e2a\u5546\u4e1a\u6a21\u5f0f\u662f\u6740\u624b\uff0c\u6211\u4ece\u672a\u89c1\u5230\u8fc7\u3002</P>\r\n<P>\u827a\u672f\u5bb6\u53ef\u4ee5\u4e0a\u4f20\u4ed6\u4eec\u7684\u97f3\u4e50\u5230\u827e\u7c73\u8857\u8fdb\u884c\u63a8\u5e7f\u548c\u9500\u552e\u3002\u7528\u6237\u4e0e\u670b\u53cb\u7ec4\u6210\u793e\u4f1a\u7f51\u7edc\u3001\u8046\u542c\u3001\u8d2d\u4e70\u97f3\u4e50\u3002\u6240\u6709\u6b4c\u66f2\u90fd\u91c7\u7528\u514d\u6570\u5b57\u7248\u6743\u7ba1\u7406DRM\u7684MP3\u683c\u5f0f\u3002\u6b4c\u66f2\u770b\u4e0a\u53bb\u5728192kpbs\u7684\u8d28\u91cf\u6c34\u5e73\uff0c\u5c3d\u7ba1\u53ef\u80fd\u53ea\u662f\u827a\u672f\u5bb6\u4e0a\u4f20\u7684\u4e0d\u77e5\u9053\u4ec0\u4e48\u7684\u4e1c\u4e1c\u3002 </P>\r\n<P>\u6240\u6709\u6b4c\u66f2\u90fd\u53ef\u514d\u8d39\u6536\u542c\u3002\u4ef7\u683c\u5728\u4e00\u6bb5\u65f6\u95f4\u5185\u6839\u636e\u5bf9\u8fd9\u9996\u6b4c\u7684\u9700\u6c42\u6ce2\u52a8\u3002\u76ee\u524d\u6700\u9ad8\u4ef7\u6b4c\u66f2<A href=\"http://www.onlyshare.net/blog/ct.ashx?id=97339b35-ddee-46c1-8af3-77a742a03e3d&amp;url=http%3a%2f%2fmembers.amie.st%2fmembers%2fviewArtist.php%3fartistId%3d60\" ?>Danny Ross</A>\u7684\u201c\u649e\u5230\u5899\u4e0a\u201dAgainst the Wall\u4e3a0.36\u7f8e\u5143\u3002\u8fc4\u4eca\u4e3a\u6b62\u5df2\u6709273\u9996\u6b4c\u66f2\u88ab\u4e0a\u4f20\u3002\u8fd9\u79cd\u6309\u9700\u5b9a\u4ef7\u6a21\u5f0f\u770b\u4e0a\u53bb\u662f\u4e00\u79cd\u9500\u552e\u97f3\u4e50\u7684\u597d\u65b9\u6cd5\u3002</P>\r\n<P>\u7528\u6237\u53ef\u4ee5\u641c\u7d22\u3001\u6d4f\u89c8\u3001\u514d\u8d39\u542c\u97f3\u4e50\uff08\u901a\u8fc7\u5206\u6d41\uff09\u3002\u6211\u4e0b\u8f7d\u6d4b\u8bd5\u6548\u679c\u5f88\u597d\uff0c\u8fd9\u9996\u6b4c\u7684\u4ef7\u683c\u5df2\u4ece\u6211\u5b58\u653e\u5230\u4fe1\u7528\u5361\u4e2d\u76843\u7f8e\u5143\u4fe1\u7528\u8d26\u6237\u4e2d\u6070\u5f53\u5730\u6263\u9664\u3002</P>\r\n<P>\u5df2\u8d2d\u4e70\u6b4c\u66f2\u7684\u7528\u6237\u53ef\u4ee5\u4f7f\u7528\u4ed6\u4eec\u6536\u5230\u7684\u6570\u91cf\u6709\u9650\u7684\u201c\u63a8\u8350\u4ef6rec\u2019s\u201d\uff08\u7528\u6237\u6bcf\u589e\u52a0\u4e00\u7f8e\u5143\u5230\u8d26\u6237\u4fbf\u53ef\u5f97\u5230\u4e00\u4e2arec\uff09\u63a8\u8350\u7ed9\u4ed6\u4eec\u7684\u670b\u53cb\u3002\u4e00\u65e6\u63a8\u8350\u540e\uff0c\u5982\u679c\u8fd9\u9996\u6b4c\u7684\u4ef7\u683c\u4e0a\u6da8\uff0c\u7528\u6237\u8d26\u6237\u4f1a\u88ab\u8bb0\u4e00\u6b21\u501fcredit\u3002\u7ed9\u4e88\u4ed6\u4eec\u4e00\u79cd\u6fc0\u52b1\u63a8\u8350\u597d\u7684\u4f5c\u54c1\u3002</P>\r\n<P>\u5982\u679c\u4f60\u4ee51\u7f8e\u5206\u6216\u4ee5\u4e0a\u7684\u4ef7\u683c\u63a8\u8350\u4e86\u4e00\u9996\u6b4c\uff0c\u827e\u7c73\u8857\u4f1a\u652f\u4ed8\u4f60\u4ef7\u683c\u5dee\u5f02\u7684\u4e00\u534a\u3002\u56e0\u6b64\uff0c\u5982\u679c\u4f60\u4ee510\u7f8e\u5206\u63a8\u8350\u4e86\u4e00\u9996\u6b4c\uff0c\u8fd9\u9996\u6b4c\u7684\u4ef7\u683c\u6700\u540e\u4ee590\u7f8e\u5206\u7ed3\u675f\uff0c\u6211\u4eec\u5c06\u652f\u4ed8\u4f6040\u7f8e\u5206\uff0880\u7f8e\u5206\u7684\u5dee\u4ef7\u7684\u4e00\u534a\uff09\u3002 </P>\r\n<P>\u5982\u679c\u4f60\u4ee5\u4ecd\u514d\u8d39\uff080\u7f8e\u5206\uff09\u7684\u4ef7\u683c\u63a8\u8350\u4e86\u4e00\u9996\u6b4c\uff0c\u8fd9\u9996\u6b4c\u7684\u4ef7\u683c\u6700\u540e\u4ee598\u7f8e\u5206\u7ed3\u675f\uff0c\u6211\u4eec\u5c06\u4f1a\u5b58\u653e98\u7f8e\u5206\u5230\u4f60\u7684\u827e\u7c73\u8d26\u6237\u3002\u5bf9\u4ee5\u4ecd\u514d\u8d39\u7684\u4ef7\u683c\u63a8\u8350\u6b4c\u66f2\u7684\u7528\u6237\uff0c\u827e\u7c73\u8857\u652f\u4ed8\u4f60\u66f4\u591a\uff0c\u56e0\u4e3a\u4f60\u627f\u62c5\u4e86\u66f4\u591a\u98ce\u9669\u5e76\u4e14\u56e0\u4e3a\u6211\u4eec\u60f3\u8981\u827e\u7c73\u8857\u6240\u6709\u7684\u4eba\u90fd\u63a8\u8350\u90a3\u4e9b\u4f1f\u5927\u7684\u5c1a\u672a\u88ab\u53d1\u73b0\u7684\u6b4c\u66f2\u3002</P>\r\n<P><IMG height=198 alt=amiestreet275.jpg hspace=8 src=\"/images_article/amiestreet275.jpg\" width=275 align=right border=0>\u827a\u672f\u5bb6\u4eec\u4fdd\u6301\u552e\u540e5\u7f8e\u5143\u4ee5\u5916\u768470%\u7684\u6536\u76ca\u3002\u4ed6\u4eec\u4e0d\u5fc5\u5b8c\u5168\u5728\u827e\u7c73\u8857\u51fa\u552e\u4ed6\u4eec\u7684\u97f3\u4e50\uff0c\u4ed6\u4eec\u53ef\u4ee5\u5728\u4efb\u4f55\u65f6\u95f4\u53d6\u6d88\u3002</P>\r\n<P>\u8fd9\u4e2a\u6a21\u5f0f\u8003\u8651\u5f97\u5341\u5206\u5468\u8be6\u3002\u56e0\u4e3a\u7edd\u5927\u591a\u6570\u4e50\u961f\u5e76\u4e0d\u5173\u5fc3\u4eba\u4eec\u5077\u4e86\u4ed6\u4eec\u7684\u97f3\u4e50\u2014\u2014\u4ed6\u4eec\u53ea\u60f3\u8981\u4eba\u4eec\u542c\u5230\u5b83\u2014\u2014\u827e\u7c73\u8857\u53ef\u4ee5\u662f\u4ed6\u4eec\u5ba3\u4f20\u4ed6\u4eec\u4e1c\u4e1c\u7684\u4e00\u79cd\u7edd\u597d\u65b9\u5f0f\u3002Myspace\u5df2\u7ecf\u8bc1\u660e\u4e86\u793e\u4f1a\u7f51\u7edc\u662f\u5ba3\u4f20\u97f3\u4e50\u7684\u5b8c\u7f8e\u673a\u5236\uff0c\u827e\u7c73\u8857\u5728\u8fd9\u4e2a\u6a21\u5f0f\u4e0a\u6240\u505a\u51fa\u7684\u8f7b\u5fae\u8c03\u6574\u53ef\u4ee5\u6210\u4e3a\u80dc\u5229\u8005\u3002\u8fd9\u662f\u4e00\u4e2a\u503c\u5f97\u7559\u610f\u7684\u4e1c\u4e1c\uff0c\u56e0\u4e3a\u5b83\u51c6\u5907\u5168\u9762\u516c\u5f00\u542f\u52a8\u3002</P>\r\n<P>\u539f\u6587\u5730\u5740\uff1a<A href=\"http://www.onlyshare.net/blog/ct.ashx?id=97339b35-ddee-46c1-8af3-77a742a03e3d&amp;url=http%3a%2f%2fwww.techcrunch.com%2f2006%2f07%2f23%2famie-street-awesome-new-music-model%2f\" ?>Amie Street: Awesome New Music Model</A><BR>\u539f\u6587\u4f5c\u8005\uff1aMichael Arrington<BR>\u611f\u8c22 <A href=\"http://www.onlyshare.net/blog/AmieStreet.aspx\">StephenZhai</A>&nbsp;\u6295\u9012\u4e86\u672c\u6587\u3002 </P></DIV>", "imagename": null, "infoid": 3632, "category": "technology_internet", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["mp3", "drm", "music"]}, {"url": "http://www.world-heritage-tour.org", "title": "\u4ece\u6ca1\u89c1\u8fc7\u7684\u5168\u89d2\u5ea6\u65e0\u7f1d\u62fc\u63a5\u56fe\u7247", "tags": "\u65e0\u7f1d\u62fc\u63a5 ", "name": "hexybaby", "posttime": "2006-07-24 16:01:32", "ip": "203.187.182.58", "mark": 10, "note": "\u7c7b\u4f3c\u4e8egoogle earth\uff0c\u6bd4google earth\u8fd8\u8981\u5389\u5bb3\u7684\uff0c\u5168\u89d2\u5ea6\u5b8c\u5168\u65e0\u7f1d\u62fc\u63a5\u4e16\u754c\u5404\u4