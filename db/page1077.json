u7f51\u7ad9", "tags": "\u5b8b\u7956\u5fb7 \u53cd\u5b8b\u7956\u5fb7 \u9ed1\u5ba2 \u597d\u57df\u540d ", "name": "magictim", "posttime": "2007-07-17 22:20:55", "ip": "222.16.55.146", "mark": 9, "note": "\u57df\u540d\u5f88\u4e0d\u9519\uff5e\uff5e\uff5e\r\n\r\n\u5176\u4ed6\u4e00\u6982\u4e0d\u77e5\u9053\uff5e\uff5e\uff5e", "imagename": "e65c1d968a1d49489ad76022ffdf847f.jpg", "infoid": 25026, "category": "technology_internet", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u5b8b\u7956\u5fb7", "\u53cd\u5b8b\u7956\u5fb7", "\u9ed1\u5ba2", "\u597d\u57df\u540d"]}, {"url": "http://itbbs.pconline.com.cn/topic.jsp?tid=7304076", "title": "\u56fd\u4ea7\u6700\u5f3a\u638c\u673a,\u79d2\u6740PSP", "tags": "PSP ", "name": "magictim", "posttime": "2007-07-17 17:56:54", "ip": "222.16.55.146", "mark": 10, "note": "1.\u753b\u9762\u8fd0\u7528\u771f\u5b9e\u5149\u6e90\u6a21\u62df,\u5f3a\u5927\u7684HDR\u6548\u679c.\u5728\u5f3a\u5927\u9ad8\u5149\u4e0b\u5c24\u5176\u660e\u663e. \r\n\r\n2.\u6a21\u62df\u6db2\u4f53\u52a8\u6001\u6d41\u7545,\u771f\u5b9e.\u5c4f\u5e55\u5206\u8fa8\u7387\u8fbe\u5230\u60ca\u4eba\u7684\u5b9e\u65f6\u8272\u5f69\u5373\u7edd\u5bf9\u8fd8\u539f\u73b0\u5b9e. \r\n\r\n3.\u6db2\u6676\u5c4f\u8fd0\u7528\u7684\u662f\u56fd\u5bb6\u53d1\u660e\u5c40\u6700\u65b0\u7814\u5236GTWC\u52a8\u6001\u5c4f\u5373--\u5149\u7167(Guangzhao)\u900f\u660e(Touming)\u65e0(Wu)\u8fdf\u7591(Ciyi).....\u753b\u9762\u51b3\u4e0d\u6258\u5f71,\u7edd\u4e0d\u4ea7\u751f\u4efb\u4f55\u6709\u5bb3\u8f90\u5c04... \r\n\r\n4.\u5f3a\u5927\u7684CPU CPU\u8fd0\u7b97\u80fd\u529b\u80fd\u5c06\u6c34\u5185\u4efb\u4f55\u5fae\u751f\u7269,\u6742\u8d28\u5b8c\u7f8e\u7684\u8868\u73b0\u51fa\u6765.\u66f4\u5229\u75281\u5146\u591a\u8fb9\u5f62\u5b8c\u7f8e\u5851\u9020\u6e38\u620f\u4e3b\u89d2--\u5708\u5708(\u6682\u5b9a\u540d)\u7684\u5b8c\u7f8e\u8f6e\u5ed3. \r\n\r\n5.\u6e38\u620f\u5185\u771f\u5b9e\u7684\u5149\u5f71\u6548\u679c\u8ba9\u4eba\u53f9\u4e3a\u89c2\u6b62,\u5f3a\u5927\u5230\u80fd\u8ddf\u968f\u6e38\u620f\u8005\u7684\u79fb\u52a8\u968f\u65f6\u53d8\u6362\u5149\u5f71\u6548\u679c. \r\n\r\n\r\n6.\u66f4\u9644\u52a0\u5c24\u53ea\u6709\u4e13\u4e1a\u7ea7\u6e38\u620fPC\u6240\u914d\u5907\u7684\u7269\u7406\u8fd0\u7b97\u5904\u7406\u5668 (PPU),\u5b8c\u7f8e\u4f53\u73b0\u5305\u62ec\u6c34\u5728\u5185\u7684\u4e00\u5207\u7269\u4f53\u7684\u771f\u5b9e\u7269\u7406\u73b0\u8c61. \r\n\r\n\r\n7.\u8be5\u4ea7\u54c1\u5728\u8003\u8651\u5728\u7f29\u6c34\u6447\u6746\u9644\u5e26\u5728\u638c\u673a\u4e0a\u5e26\u6765\u7684\u624b\u611f\u7cdf\u7cd5\u7684\u60c5\u51b5\u4e0b,\u501f\u9274\u4e86\u65e5\u672c\u4efb\u5929\u5802\u516c\u53f8\u7684\u638c\u4e0a\u5a31\u4e50\u7cfb\u7edfGBA\u7684&lt;\u56de\u65cb\u74e6\u91cc\u5965&gt;\u5e26\u6765\u7684\u524d\u6240\u672a\u6709\u7684\u4f53\u611f\u6e38\u620f\u65b9\u5f0f..\u5f00\u53d1\u51fa\u6b64\u638c\u673a\u7684\u771f\u5b9e\u7269\u7406\u4f53\u611f\u7cfb\u7edf--ZWT(\u5373\u771f\u5b9eZhenshi\u7269\u7406Wuli\u4f53\u611fTigan)...\u6e38\u620f\u5c06\u5f7b\u5e95\u628a\u6e38\u620f\u8005\u7684\u5de6\u53f3\u6446\u52a8,\u4e0a\u4e0b\u6643\u52a8\u8fd0\u7b97\u8ba4\u8bc1\u4e3a\u6e38\u620f\u8005\u7684\u6307\u4ee4\u64cd\u4f5c\u8f93\u5165\u6e38\u620f\u5185,\u5e76\u5b9e\u65f6\u53d1\u751f\u6e38\u620f\u53d8\u5316. \r\n\r\n8.\u4f7f\u7528\u4e86\u5168\u65b0\u7684\u7a7a\u6c14\u8d1f\u79bb\u5b50\u7535\u89e3\u5faa\u73af\u5229\u7528\u7cfb\u7edf.\u8fbe\u5230\u4e86\u60ca\u4eba\u7684\u65e0\u529f\u8017\u65e0\u6c61\u67d3..\u5f88\u597d\u7684\u89e3\u51b3\u4e86\u638c\u673a\u5728\u7eed\u822a\u80fd\u529b\u4e0a\u7684\u95ee\u9898,\u518d\u4e0d\u4f1a\u4e3a\u6bcf\u5929\u53ea\u80fd\u51e0\u5c0f\u65f6\u6e38\u620f\u65f6\u95f4\u800c\u70e6\u607c.\u7cbe \r\n\r\n9.\u4e14\u8be5\u638c\u673a\u8bbe\u8ba1\u5b8c\u7f8e\u4f20\u627f\u82f9\u679c\u516c\u53f8\u7684\u7b80\u7ea6\u98ce,\u892a\u53bb\u6d6e\u534e,\u8fd8\u6211\u672c\u8272.. \r\n\r\n10.\u8003\u8651\u5230\u8be5\u4ea7\u54c1\u5c06\u6253\u5165\u56fd\u9645\u5e02\u573a,\u672c\u638c\u673a\u5c06\u51b3\u4e0d\u9644\u5e26\u6e38\u620f\u4ee5\u5916\u7684\u5176\u4ed6\u529f\u80fd,\u505a\u5230\u4e13\u4e1a.\u4e3a\u4e8b\u4e13\u4e00.", "imagename": "b14e1068ae0e4fcf9c523eb078880e59.jpg", "infoid": 25009, "category": "technology_hardware", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["psp"]}, {"url": "http://it.sohu.com/20070716/n251077160.shtml", "title": "\u6797\u8d5b\u7f57\u7ff0\u7535\u8111\u906d\u9ed1 \u6050\u6614\u65e5\u88f8\u7167\u5c06\u88ab\u5f20\u8d34\u7f51\u7edc(\u56fe)", "tags": "\u88f8\u7167 ", "name": "yiwu", "posttime": "2007-07-17 08:17:04", "ip": "60.191.227.44", "mark": 9, "note": "\u636e\u82f1\u56fd\u300a\u4e16\u754c\u65b0\u95fb\u62a5\u300b\u62a5\u9053\uff0c\u9752\u6625\u5076\u50cf\u6797\u8d5b&#183;\u7f57\u7ff0(Lindsay Lohan)\u53c8\u4f20\u9ebb\u70e6\u4e8b\uff01\u5979\u7684\u4e2a\u4eba\u7535\u8111\u906d\u9ed1\u5ba2\u5165\u4fb5\uff0c\u56e0\u6b64\u548c\u7537\u4f34\u5361\u4f26\u8d1d\u65af\u7279(Calum Best)\u7684\u4eb2\u70ed\u7167\u7247\u5f88\u53ef\u80fd.....", "imagename": "21610875c6cb4c24aa22a4ef5cfe416b.jpg", "infoid": 24986, "category": "entertainment_celebrity", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "entertainment", "via": null, "real_tags": ["\u88f8\u7167"]}, {"url": "http://tech.163.com/special/000915RB/100game.html", "title": "\u7f51\u6613\u79d1\u6280\u4e13\u9898:100\u540d\u73a9\u5bb6\u8bf4\u7f51\u6e38\u5b9e\u540d\u5236", "tags": "\u7f51\u6e38\u5b9e\u540d\u5236 ", "name": "cacard", "posttime": "2007-07-17 03:23:06", "ip": "221.14.253.252", "mark": 3, "note": "2007\u5e747\u670816\u65e5\uff0c\u4ece\u8fd9\u5929\u8d77\u4e2d\u56fd\u5404\u5927\u7f51\u7edc\u6e38\u620f\u516c\u53f8\u7684\u7f51\u7edc\u6e38\u620f\u6b63\u5f0f\u542f\u52a8\u9632\u6c89\u8ff7\u7cfb\u7edf\uff0c\u672a\u6210\u5e74\u73a9\u5bb6\u8fde\u7eed\u4e0a\u7f51\u65f6\u95f4\u5c06\u53d7\u63a7\u5236\uff0c\u51e1\u662f\u672a\u8fdb\u884c\u5b9e\u540d\u5236\u7684\u7f51\u6e38\u5c06\u6309\u89c4\u5b9a\u4e0d\u80fd\u518d\u8fd0\u8425[\u70b9\u51fb\u67e5\u770b\u65b0\u95fb\u62a5\u9053]\u3002\u7f