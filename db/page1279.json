e0e\u6253\u5206\u548c\u4e3a\u6700\u79ef\u6781\u7528\u6237\u7684\u5956\u52b1\u3002\u975e\u5e38\u9177\u3002\r\n<DIV class=itemBodyStyle>\r\n<P>\u516c\u53f8\u521b\u529e\u4eba Amanuel Tewold \u544a\u8bc9\u6211\u516c\u53f8\u7684\u540d\u79f0 Otavo \u5305\u62ec\u4e24\u5c42\u542b\u4e49\u3002\u5b83\u662f\u7ec4\u7ec7 Organizing \u6587\u672cText\u3001\u97f3\u9891 Audio\u3001\u89c6\u9891\u5bf9\u8c61 Video Object \u7684\u9996\u5b57\u6bcd\u7701\u7565\u8bed\u3002\u5b83\u4e5f\u662f\u4e00\u4e2a\u4e16\u754c\u8bed\u8a00\uff08Esperanto \u4e16\u754c\u8bed\uff09\u5355\u8bcd\u8868\u793a\u6e25\u592a\u534e Ottawa\uff0c\u4e5f\u5c31\u662f\u516c\u53f8\u521b\u529e\u6240\u5728\u5730\u3002</P>\r\n<P>\u5728\u521b\u5efa\u4e2a\u4eba\u7b80\u4ecb\u540e\uff0c\u4f60\u5c31\u53ef\u4ee5\u4f7f\u7528\u4e00\u4e2a\u8bbe\u8ba1\u5f88\u597d\u7684 Java \u811a\u672c\u4e66\u7b7e\u6765\u521b\u5efa\u201c\u8bf7\u6c42\u201d\uff0c\u6216\u8005\u94fe\u63a5\u4e00\u4e2a\u4f60\u6240\u6709\u7684URL\u5730\u5740\u5230\u4f60\u5df2\u7ecf\u5b58\u5728\u7684\u8bf7\u6c42\u4e2d\u3002\u4f60\u4e5f\u53ef\u4ee5\u5728\u4e3b\u9875\u5f00\u59cb\u63d0\u51fa\u8bf7\u6c42\u548c\u95ee\u9898\u3002\u6240\u6709\u4eba\u90fd\u53ef\u4ee5\u5728\u4f60\u7684\u8bf7\u6c42\u4e0a\u53d1\u8868\u8bc4\u8bba\uff0c\u4ed6\u4eec\u4e5f\u53ef\u4ee5\u628a\u4f60\u7684\u8bf7\u6c42\u52a0\u5230\u4ed6\u4eec\u7684\u7b80\u4ecb\u4e2d\u3002\u4e2a\u4eba\u7b80\u4ecb\u9644\u5e26\u535a\u5ba2\uff0c\u5e76\u5305\u62ec\u793e\u4f1a\u7f51\u7edc\u529f\u80fd\uff0c\u6bd4\u5982\u53ef\u4ee5\u5411\u4f60\u7684\u670b\u53cb\u53d1\u4fe1\u606f\u3002</P>\r\n<P>\u201c\u6d6e\u8d34 floster\u201d\uff08\u201c\u6d6e\u52a8\u62a5\u8d34 float poster\u201d\u7684\u50bb\u91cc\u50bb\u6c14\u7684\u540d\u5b57\uff09\u662f\u4e00\u4e2a\u8f83\u597d\u7684\u5d4c\u5165\u4f60\u4e66\u7b7e\u9875\u9762\u7684\u52a8\u6001\u7f51\u9875\u7a0b\u5e8f\uff0c\u8868\u793a\u5f53\u4f60\u70b9\u51fb\u56de\u9000\u7684\u65f6\u5019\uff0c\u7a0b\u5e8f\u4f1a\u81ea\u52a8\u6293\u53d6\u6587\u672c\u800c\u4e0d\u4f1a\u4f7f\u4f60\u7684\u4e66\u7b7e\u5de5\u5177\u4e22\u5931\u5728\u6d4f\u89c8\u5668\u4e4b\u540e\u3002Otavo \u8ba4\u4e3a\u5f53\u628a\u8bbe\u7f6e\u7528\u6237\u8bf7\u6c42\u3001\u63d0\u95ee\u548c\u4e66\u7b7e\u4e00\u65c1\u7684\u65f6\u5019 AdSense \u5c06\u4f1a\u975e\u5e38\u4e0e\u4e0a\u4e0b\u6587\u76f8\u5173\u3002\u6211\u89c9\u5f97\u6709\u9053\u7406\u3002\u4ed6\u4eec\u4e5f\u6b63\u5728\u8003\u8651\u7ed9\u50cf\u56fe\u4e66\u9986\u548c\u5927\u5b66\u8fd9\u6837\u7684\u5408\u9002\u673a\u6784\u628a\u4ed6\u4eec\u7684\u6280\u672f\u4f5c\u4e3a\u4e00\u79cd\u767d\u8272\u6807\u7b7e\u65b9\u6848 white lable solution \u63d0\u4f9b\u3002Tewold \u544a\u8bc9\u6211\u4ece\u56db\u6708\u4efd\u5230\u73b0\u5728\u7684\u63a8\u8fdf\u7684\u539f\u56e0\u4e3b\u8981\u662f\u4e3a\u4e86\u53d1\u5c55\u7528\u6237\u754c\u9762\uff0c\u73b0\u5728\u770b\u6765\u5f88\u6210\u529f\u3002\u5c31\u662f\u8fd9\u6837\u7684\u4e00\u79cd\u7cfb\u7edf\uff0c\u975e\u6280\u672f\u6027\u7528\u6237\u4f7f\u7528\u793e\u4f1a\u4e66\u7b7e\u3001\u5206\u4eab\u76ee\u6807\u548c\u5176\u5b83\u9700\u8981\u7ec4\u7ec7\u7684\u4fe1\u606f\u65f6\u5c06\u611f\u89c9\u5341\u5206\u60ec\u610f\u3002<BR>&nbsp;<BR>\u7528\u6237\u53ef\u4ee5\u4ece\u5404\u79cd\u5404\u6837\u6d3b\u52a8\u4e2d\u5f97\u5230\u5956\u52b1\uff0c\u6700\u9ad8\u5956\u52b1\u6765\u81ea\u4ecb\u7ecd\u65b0\u4eba\u548c\u6dfb\u52a0\u65b0\u7684\u8bf7\u6c42\u3002\u6700\u6d3b\u8dc3\u7528\u6237\u5c06\u4f1a\u6536\u5230\u5956\u52b1\uff0c\u5176\u5b83\u7528\u6237\u4e5f\u4f1a\u4e3a\u5956\u52b1\u5438\u5f15\u8fdb\u6765\u3002\u975e\u5e38\u9177\uff0c\u5c31\u662f\u4ed6\u4eec\u5728\u521b\u529e\u7684\u65f6\u5019\u4e5f\u672a\u66fe\u60f3\u5230\u3002\u8fd9\u662f\u4e00\u79cd\u5438\u5f15\u4eba\u7684\u53ef\u66ff\u4ee3\u5e7f\u544a\u5206\u4eab\u6240\u5e26\u6765\u6536\u5165\u7684\u53e6\u4e00\u4e2a\u9009\u62e9\uff0c\u4f46\u516c\u53f8\u8ba4\u4e3a\u5e26\u52a8\u53c2\u4e0e\u7684\u4e3b\u8981\u65b9\u5f0f\u8fd8\u662f\u7f51\u7ad9\u7ed3\u6784\u3002</P>\r\n<P>\u867d\u7136\u522b\u5904\u4e5f\u53ef\u4ee5\u64cd\u4f5c\u8be5\u7ad9\u51e0\u4e4e\u6240\u6709\u7684\u529f\u80fd\uff0c\u4f46\u5728 Otavo \u6267\u884c\u5f97\u5f88\u5f97\u5f53\u3002\u4e5f\u5f53\u7136\u6709\u6765\u81ea\u7f51\u4e0a\u5f88\u591a\u7684\u793e\u4f1a\u4e66\u7b7e\u3001\u63d0\u95ee\u6a21\u5f0f\u548c\u5b9a\u76ee\u6807\u4e4b\u7c7b\u7684\u7ad9\u70b9\u7b49\u6dfb\u6ee1\u6574\u4e2a\u535a\u5ba2\uff08\u563f\uff01\uff09\uff0c\u4f46\u628a\u6240\u6709\u7684\u670d\u52a1\u90fd\u6574\u5408\u5728\u4e00\u8d77\u5e76\u4e14\u505a\u597d\u8fd8\u662f\u4ee4\u4eba\u5370\u8c61\u6df1\u523b\u3002Yahoo! \u53ef\u4ee5\u4e5f\u53ef\u80fd\u628a Yahoo!Answers\u3001del.icio.us \u548c Yahoo!360 \u6574\u5408\u5728\u4e00\u8d77\uff0c\u4f46\u4ed6\u4eec\u5e76\u6ca1\u6709\u8fd9\u6837\u505a\u3002\u7f51\u4e0a\u6709\u5f88\u591a\u5373\u5c06\u5230\u6765\u7684\u65b0\u7684\u793e\u4f1a\u641c\u7d22\u5f15\u64ce\uff0c\u4f46\u628a Otavo \u53eb\u505a\u793e\u4f1a\u641c\u7d22\u8fd8\u662f\u4f4e\u4f30\u4e86\u5b83\u7684\u4ef7\u503c\u3002\u6709\u5f88\u591a\u4e0d\u80fd\u5c3d\u8a00\uff0c\u5bf9\u4e8e\u5b83\u600e\u4e48\u628a\u7528\u6237\u548c\u89c4\u6a21\u5efa\u8bbe\u5f97\u66f4\u597d\uff0c\u6211\u4eec\u5c06\u62ed\u76ee\u4ee5\u5f85\u3002</P>\r\n<P><IMG height=360 alt=otavoscreen.jpg src=\"/images_article/otavoscreen.jpg\" width=565 align=center border=0></P>\r\n<P>\u539f\u6587\u5730\u5740\uff1a<A href=\"http://www.onlyshare.net/blog/ct.ashx?id=91e47a1e-3fae-4db7-a919-bd67c0ddbbc3&amp;url=http%3a%2f%2fwww.techcrunch.com%2f2006%2f07%2f25%2fquestions-quests-and-bookmarks-otavo-does-it-all%2f\" ?><STRONG>Questions, Quests and Bookmarks: Otavo does it all</STRONG></A><BR>\u539f\u6587\u4f5c\u8005\uff1aMarshall Kirkpatrick </P></DIV>", "imagename": null, "infoid": 3752, "category": "technology_web2", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["web2.0", "bookmarks"]}, {"url": "http://www.wangtam.com/50226711/ae_diglog_cec_35437.php", "title": "\u5bf9\u4e8e diglog \u7684\u8d28\u7591", "tags": " digg diglog hung \u89c2\u70b9 Hung Talk ", "name": "Wangtam", "posttime": "2006-07-25 03:11:28", "ip": "127.