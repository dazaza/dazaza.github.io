[{"url": "http://google.com", "title": "\u4eca\u5929\u662f\u4f60\u7684\u751f\u65e5\uff0c\u6211\u7684google", "tags": "google", "name": "yinyin", "posttime": "2007-09-15 13:29:41", "ip": "121.229.11.145", "mark": 6, "note": "1997\u5e749\u670815\u65e5,\u65af\u5766\u798f\u5927\u5b66\u4e24\u540d24\u5c81\u7684\u5b66\u751f\u62c9\u91cc&amp;#183;\u4f69\u742a\u548c\u8d5b\u5409&amp;#183;\u5e03\u6797\u6ce8\u518c\u4e86\u201cgoogle.com\u201d\u57df\u540d.1998\u5e749\u67087\u65e5,Google\u516c\u53f8\u5728\u52a0\u5dde\u5317\u90e8\u7684\u4e00\u4e2a\u79c1\u5bb6\u8f66\u5e93\u5185\u8bde\u751f.\r\n\r\nGoogle\u4e4b\u6240\u4ee5\u80fd\u591f\u8fc5\u901f\u6210\u540d,\u4e3b\u8981\u662f\u56e0\u4e3a\u5176\u641c\u7d22\u6cd5\u5219\u80fd\u591f\u6709\u6548\u5730\u63d0\u4f9b\u7528\u6237\u6240\u9700\u8981\u7684\u641c\u7d22\u7ed3\u679c.\r\n\r\n2000\u5e74,Google\u5f00\u59cb\u9500\u552e\u5173\u952e\u5b57\u5e7f\u544a.\u5c3d\u7ba1\u6b63\u503c\u4e92\u8054\u7f51\u6ce1\u6cab\u7834\u706d\u4e4b\u9645,Google\u4ecd\u7136\u5b9e\u73b0\u4e86\u8d62\u5229.\r\n\r\n2004\u5e74,Goolge\u9996\u6b21\u516c\u5f00\u52df\u80a1,\u5f53\u65f6\u7684\u53d1\u884c\u4ef7\u4e3a85\u7f8e\u5143.\u4eca\u5929,Google\u80a1\u7968\u4ef7\u683c\u5df2\u7ecf\u8fbe\u5230525\u7f8e\u5143,\u5e02\u503c\u8fbe\u5230\u4e861640\u4ebf\u7f8e\u5143.\r\n\r\n2006\u5e74,Google\u8425\u6536\u989d\u8fbe\u5230\u4e86134\u4ebf\u7f8e\u5143,\u5b9e\u73b0\u51c0\u5229\u6da637\u4ebf\u7f8e\u5143.\u540c\u5e74,Google\u5e76\u8d2dYouTube,\u4eca\u5e744\u6708\u53c8\u5ba3\u5e03\u4ee531\u4ebf\u7f8e\u5143\u6536\u8d2dDoubleClick.\r\n\r\n\u76ee\u524d,Google\u62e5\u6709\u96c7\u545813700\u4eba,\u800c\u4e24\u4f4d\u5e74\u4ec530\u591a\u5c81\u7684\u521b\u59cb\u4eba\u5404\u81ea\u7684\u8eab\u4ef7\u5df2\u7ecf\u8fbe\u5230160\u4ebf\u7f8e\u5143.", "imagename": "ef51c14a29c0490a8cf2103fe378034b.gif", "infoid": 29900, "category": "technology_google", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["google"]}, {"url": "http://www.enet.com.cn/ar