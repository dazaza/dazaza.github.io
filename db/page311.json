f\u5b9a\u4f4d\u9ad8\u7aef\uff0c\u5728\u5e02\u573a\u4e0a\u52bf\u5fc5\u53d7\u5230iOS\u3001Android\u7684\u6fc0\u70c8\u7ade\u4e89\uff0c\u4e0b\u9762\u7b14\u8005\u5c31\u4e3a\u5927\u5bb6\u76d8\u70b9\u51e0\u6b3eWP7\u4e0d\u5f97\u4e0d\u9762\u5bf9\u7684\u5f3a\u52b2\u5bf9\u624b\u5427\u3002\r\n\u624b\u673a\u578b\u53f7\uff1a\u4e09\u661fi9000(\u53c2\u6570\u62a5\u4ef7\u8bba\u575b\u8f6f\u4ef6)\r\n\u53c2\u8003\u62a5\u4ef7\uff1a3850\u5143\uff08\u6c34\u6539\u673a\uff09\r\n\u9002\u5408\u4eba\u7fa4\uff1a\u9ad8\u7aef\u667a\u80fd\u624b\u673a\u73a9\u5bb6\u548c\u5546\u52a1\u4eba\u58eb\r\n\u5fae\u8f6f\u7684WP7\u4e0a\u5e02\u4e4b\u540e\uff0c\u5fc5\u7136\u662f\u8981\u53d7\u5230\u76ee\u524d\u5927\u70ed\u7684Android\u7684\u6781\u5927\u51b2\u51fb\uff0c\u4f5c\u4e3a\u4e09\u661f\u7684\u5e74\u5ea6\u65d7\u8230\uff0ci9000\u7684\u5f3a\u608d\u914d\u7f6e\u548cAndroid\u7684\u4e30\u5bcc\u5e94\u7528\u90fd\u5c06\u6781\u5927\u7a0b\u5ea6\u5730\u5c55\u73b0\u51faWP7\u6682\u65f6\u8fd8\u6ca1\u6709\u7684\u9b45\u529b\u3002\r\n\u70b9\u51fb\u56fe\u7247\u67e5\u770b\u4e09\u661fi9000\u8be6\u7ec6\u8d44\u6599\r\n\u4f5c\u4e3a\u4e09\u661f\u4eca\u5e74\u53d1\u5e03\u7684\u65d7\u8230\u7ea7\u65b0\u673a\uff0c\u8fd9\u6b21\u6b63\u5f0f\u53d1\u5e03\u7684\u4e09\u661fGalaxyS\uff08GT-i9000\uff09\u6700\u5927\u7684\u7279\u8272\u4fbf\u662f\u5728\u4ec5\u67099.9\u6beb\u7c73\u7684\u7ea4\u8584\u673a\u8eab\u4e2d\u878d\u5408\u4e86\u5f53\u524d\u7684\u5404\u79cd\u6d41\u884c\u529f\u80fd\uff0c\u8ba9\u624b\u673a\u5728\u6574\u4f53\u4e0a\u8fbe\u5230\u4e86\u65d7\u8230\u7ea7\u7684\u6c34\u51c6\u3002\u6bd4\u5982\u5728\u5c4f\u5e55\u914d\u7f6e\u4e0a\uff0c\u8be5\u673a\u8fd9\u6b21\u914d\u5907\u7684\u662f\u4e0e\u7d22\u5c3c\u7231\u7acb\u4fe1XperiaX10\u76f8\u540c\u76844.0\u82f1\u5bf8WVGA\u5206\u8fa8\u7387\u7684\u89e6\u63a7\u5c4f\uff0c\u5e76\u518d\u6b21\u4f7f\u7528\u4e86\u4e09\u661f\u81ea\u5bb6\u5f00\u53d1\u7684\u65b0\u4e00\u4ee3SuperAMOLED\u5c4f\u5e55\uff0c\u5176\u7279\u8272\u662f\u76f8\u6bd4\u4ee5\u5f80AMOLED\u5c4f\u5e55\u5728\u6280\u672f\u4e0a\u66f4\u4e3a\u5148\u8fdb\u3002\u8b6c\u5982\u5728\u4eae\u5ea6\u4e0a\u76f8\u6bd4\u8fc7\u53bb\u589e\u5f3a\u4e8620%\uff0c\u800c\u4e14\u964d\u4f4e\u4e86\u5c4f\u5e55\u7684\u539a\u5ea6\uff0c\u5e76\u4e14\u66f4\u96be\u80fd\u53ef\u8d35\u7684\u662f\u4ecd\u4fdd\u6301\u4e86\u4e0e\u8fc7\u53bb\u76f8\u540c\u7684\u8017\u7535\u91cf\uff0c\u52a0\u4e0a\u91c7\u7528\u6700\u65b0\u6280\u672f\uff0c\u4f7f\u5f97SuperAMOLED\u5c4f\u5e55\u5373\u4fbf\u5728\u6237\u5916\u9633\u5149\u76f4\u5c04\u7684\u60c5\u51b5\u4e0b\u90fd\u5177\u5907\u975e\u5e38\u9ad8\u7684\u663e\u793a\u6548\u679c\u3002\r\n\u70b9\u51fb\u56fe\u7247\u67e5\u770b\u4e09\u661fi9000\u8be6\u7ec6\u8d44\u6599\r\n\u4e3a\u83b7\u5f97\u66f4\u6d41\u7545\u7684\u8fd0\u884c\u901f\u5ea6\uff0c\u4e09\u661fGalaxyS\uff08GT-i9000\uff09\u4e5f\u5185\u7f6e\u4e861GHz\u5904\u7406\u5668\uff0c\u540c\u65f6\u57fa\u4e8eARMCortex-A8\u5904\u7406\u5668\u5185\u6838\u4e0d\u4ec5\u8ba9\u8be5\u6b3e\u624b\u673a\u7684\u5904\u7406\u5668\u6c34\u51c6\u5df2\u7ecf\u8fbe\u5230\u4e86\u4e0e\u7d22\u5c3c\u7231\u7acb\u4fe1XperiaX10\u540c\u7b49\u7ea7\u522b\u3002\u5c3d\u7ba1\u5728\u5185\u7f6e\u6444\u50cf\u5934\u65b9\u9762\uff0c\u8be5\u673a\u88c5\u8f7d\u7684\u662f500\u4e07\u50cf\u7d20\u6444\u50cf\u5934\uff0c\u4f46\u8fd8\u63d0\u4f9b\u4e86\u76f8\u5f53\u4e30\u5bcc\u62cd\u6444\u529f\u80fd\uff0c\u5305\u62ec\u81ea\u52a8\u805a\u7126\u3001\u9762\u90e8\u8bc6\u522b\u548c720P\u9ad8\u6e05\u89c6\u9891\u5f55\u5236\u7b49\u529f\u80fd\u3002\u4e09\u661fGalaxyS\uff08GT-i9000\uff09\u8fd8\u642d\u8f7d\u4e86\u6700\u65b0\u7248\u672c\u7684Android2.1\u64cd\u4f5c\u7cfb\u7edf\uff0c\u62e5\u6709TouchWiz3.0\u65b0\u7248\u672c\u7528\u6237\u754c\u9762\uff0c\u63d0\u4f9b\u4e86\u591a\u9875\u7684\u5f85\u673a\u4e3b\u5c4f\uff0c\u5e76\u4e14\u90a3\u4e9b\u7ecf\u5e38\u9700\u8981\u8bbf\u95ee\u793e\u4ea4\u7f51\u7ad9\u7684\u7528\u6237\u53ef\u4ee5\u81ea\u884c\u66f4\u6539\u4e3b\u9875\u7684\u5e03\u5c40\uff0c\u4ece\u800c\u53ef\u4ee5\u66f4\u5feb\u901f\u7684\u8bbf\u95eeTwitter\u3001Facebook\u4ee5\u53ca\u5176\u4ed6\u5927\u91cf\u793e\u4ea4\u7f51\u7edc\u670d\u52a1\u3002\r\n\u70b9\u51fb\u56fe\u7247\u67e5\u770b\u4e09\u661fi9000\u8be6\u7ec6\u8d44\u6599\r\n\u7f16\u8f91\u70b9\u8bc4\uff1a\u4f5c\u4e3a\u4e00\u6b3e\u5e74\u5ea6\u5927\u4f5c\uff0c\u4e09\u661fi9000\u7684\u5916\u5f62\u5e76\u4e0d\u662f\u5f88\u51fa\u5f69\uff0c\u4f46\u662f\u786c\u4ef6\u914d\u7f6e\u7edd\u5bf9\u662f\u4e00\u70b9\u4e5f\u4e0d\u542b\u7cca\uff0c\u5404\u9879\u90fd\u8fbe\u5230\u4e86\u4e00\u6b3e\u667a\u80fd\u624b\u673a\u7684\u9876\u7ea7\u6c34\u51c6\uff0c\u6027\u80fd\u76f8\u5f53\u7a81\u51fa\uff0c\u662f\u8ffd\u6c42\u9ad8\u6027\u80fd\u670b\u53cb\u7684\u4e0d\u4e8c\u9009\u62e9\u3002\r\n\u624b\u673a\u578b\u53f7\uff1a\u6469\u6258\u7f57\u62c9Milestone2(\u53c2\u6570\u8bba\u575b\u8f6f\u4ef6)\r\n\u53c2\u8003\u62a5\u4ef7\uff1a\u65b0\u54c1\u672a\u4e0a\u5e02\r\n\u9002\u7528\u4eba\u7fa4\uff1a\u516c\u53f8\u767d\u9886\uff0c\u5546\u52a1\u7cbe\u82f1\uff0c\u9ad8\u7ea7\u73a9\u5bb6\r\n\u76f8\u4fe1\u5173\u6ce8\u624b\u673a\u7684\u670b\u53cb\u90fd\u4f1a\u77e5\u9053\u4eca\u5e74\u9500\u91cf\u76f8\u5f53\u4e0d\u9519\u7684\u673a\u578b\u2014\u2014\u6469\u6258\u7f57\u62c9milestone\uff08\u91cc\u7a0b\u7891\uff09\uff0c\u5176\u9500\u91cf\u751a\u81f3\u8d85\u8d8a\u4e86iPhone\uff0c\u800c\u4eca\u5e74\u6469\u6258\u7f57\u62c9\u53d1\u5e03\u4e86\u8fd9\u6b3e\u624b\u673a\u7684\u5347\u7ea7\u7248\u672cmilestone2\uff0c\u4e0d\u4ec5\u5904\u7406\u5668\u8fbe\u52301GHz\uff0c\u8fd0\u884c\u5185\u5b58\u4e5f\u8fbe\u5230512MB\uff0c\u6bd4\u8d77\u5fae\u8f6f\u7684WP7\u673a\u578b\u90fd\u8981\u5f3a\u52b2\u3002\r\n\u70b9\u51fb\u56fe\u7247\u67e5\u770b\u6469\u6258\u7f57\u62c9Milestone2\u8be6\u7ec6\u8d44\u6599\r\n\u4ece\u5b98\u65b9\u7ed9\u51fa\u7684\u4ea7\u54c1\u8d44\u6599\u4e0a\u770b\uff0c\u6469\u6258\u7f57\u62c9\u8fd9\u6b3eMilestone2\u5c06\u4f1a\u5b89\u88c5Android2.2\u7248\u7cfb\u7edf\u548c\u589e\u5f3a\u7248MOTOBlur\u7528\u6237\u754c\u9762\uff0c\u76f8\u6bd4\u4e00\u4ee3\u91cc\u7a0b\u7891\uff0c\u6700\u4e3b\u8981\u7684\u8fdb\u6b65\u662f\u5904\u7406\u5668\u63d0\u5347\u81f31GHz\uff0c\u5185\u5b58\u52a0\u5927\u81f3512MBRAM\u3002\u5e76\u4e14\u5e26\u6765\u4e86720p\u5f55\u50cf\u80fd\u529b\uff0cFlash10.1\u4e5f\u5c06\u5e26\u6765\u66f4\u591a\u7684\u7f51\u7edc\u5185\u5bb9\u6d4f\u89c8\u3002\r\n\u70b9\u51fb\u56fe\u7247\u67e5\u770b\u6469\u6258\u7f57\u62c9Milestone2\u8be6\u7ec6\u8d44\u6599\r\n\u91cc\u7a0b\u7891\u4e8c\u4ee3\u91c7\u7528\u6539\u826f\u7684QWERTY\u952e\u76d8\uff0c\u5e26\u6765\u4e86\u66f4\u5927\u7684\u6309\u952e\uff0c\u8fd9\u5c06\u6709\u6548\u6539\u5584\u7528\u6237\u7684\u8f93\u5165\u901f\u5ea6\u548c\u64cd\u4f5c\u4f53\u9a8c\u3002Milestone2\u8fd8\u53ef\u4ee5\u4f5c\u4e3a\u4e00\u4e2a3G\u70ed\u70b9\u4f7f\u7528\uff0c\u652f\u6301\u8fde\u63a5\u6700\u591a5\u4e2aWiFi\u8bbe\u5907\u5171\u4eab\u7f51\u7edc\u8fde\u63a5\u3002Milestone2\u5185\u7f6e\u67098GB\u5185\u90e8\u5b58\u50a8\uff0c\u5e76\u9644\u8d60\u67098GBMicroSD\u5b58\u50a8\u5361\uff0c\u6700\u5927\u652f\u630132GBMicroSD\u5b58\u50a8\u5361\u62d3\u5c55\uff0c\u52a0\u8d77\u6765\u4e00\u517140GB\u3002\r\n\u70b9\u51fb\u56fe\u7247\u67e5\u770b\u6469\u6258\u7f57\u62c9Milestone2\u8be6\u7ec6\u8d44\u6599\r\n\u7f16\u8f91\u70b9\u8bc4\uff1a\u76f8\u5bf9\u4e8e\u4e00\u4ee3\u7684\u521b\u65b0\uff0c\u4e8c\u4ee3\u91cc\u7a0b\u7891\u66f4\u591a\u7684\u662f\u6539\u826f\u548c\u5347\u7ea7\uff0c\u5f3a\u608d\u7684\u914d\u7f6e\u4e5f\u8fbe\u5230\u4e86\u76ee\u524dAndroid\u673a\u578b\u7684\u9876\u5cf0\uff0c\u8fd9\u6b3e\u624b\u673a\u76ee\u524d\u5728\u6469\u6258\u7f57\u62c9\u82f1\u56fd\u5b98\u7f51\u63a5\u53d7\u9884\u5b9a\uff0c\u672c\u6708\u5e94\u8be5\u5c31\u80fd\u4e0a\u5e02\u9500\u552e\u4e86\u3002\u624b\u673a\u578b\u53f7\uff1aHTCDesire(\u53c2\u6570\u62a5\u4ef7\u56fe\u7247\u8bba\u575b\u8f6f\u4ef6)\r\n\u53c2\u8003\u62a5\u4ef7\uff1a3250\u5143\uff08\u6c34\u6539\u673a\uff09\r\n\u9002\u5408\u4eba\u7fa4\uff1a\u559c\u6b22HTC\u7684\u7528\u6237\u3001\u667a\u80fd\u624b\u673a\u73a9\u5bb6\r\n\u4f5c\u4e3aAndroid\u7684\u4ee3\u8a00\u4eba\u4e4b\u4e00\uff0cHTC\u5728WP7\u4e00\u5171\u53d1\u5e03\u4e865\u6b3e\u673a\u578b\uff0c\u4f46\u4e0a\u5e02\u4e4b\u540e\u5c31\u5f97\u9762\u5bf9\u540c\u54c1\u724c\u5144\u5f1f\u7684\u7ade\u4e89\u4e86\uff0c\u8fd9\u6b3eHTCDesire\u662fHTC\u76ee\u524d\u6700\u9ad8\u7aef\u7684\u673a\u578b\uff0c1GHz\u5904\u7406\u5668+576MBRAM\u7684\u914d\u7f6e\u662fWP7\u673a\u578b\u7684\u4e3b\u6d41\u914d\u7f6e\uff0c\u4f46\u76f8\u4fe1WP7\u521a\u4e0a\u5e02\u7684\u65f6\u5019\u7edd\u5bf9\u6ca1\u6709Desire\u7684\u8fd9\u4e2a\u4ef7\u683c\u3002\r\n\u70b9\u51fb\u56fe\u7247\u67e5\u770bHTCDesire\u8be6\u7ec6\u8d44\u6599\r\n\u5916\u5f62\u4e0a\uff0cHTCDesire\u91c7\u7528\u5168\u89e6\u63a7\u8bbe\u8ba1\uff0c\u673a\u8eab\u4e09\u56f4\u4e3a\uff1a119x60x11.9mm\uff0c\u673a\u91cd135g\uff0c\u673a\u8eab\u5927\u5c0f\u91cd\u91cf\u90fd\u6bd4\u8f83\u9002\u4e2d\u3002\u914d\u5907\u76843.7\u5bf8AMOLED\u7535\u5bb9\u89e6\u6478\u5c4f\uff0c\u4e0d\u540c\u7684\u662fNexusOne\u91c7\u7528\u89e6\u6478\u6309\u952e+\u8f68\u8ff9\u7403\u7684\u7ec4\u5408\uff0c\u800cDesire\u91c7\u7528\u5b9e\u4f53\u6309\u952e+\u5149\u5b66\u89e6\u63a7\u9762\u677f\u7684\u7ec4\u5408\uff0c\u5b9e\u9645\u64cd\u4f5c\u7684\u8bdd\u89e6\u6478\u952e\u66f4\u7075\u654f\u800c\u5b9e\u4f53\u952e\u66f4\u5177\u624b\u611f\uff0c\u5b70\u4f18\u5b70\u52a3\u5c31\u8981\u4f9d\u4e2a\u4eba\u559c\u597d\u800c\u5b9a\u4e86\u3002\r\n\u70b9\u51fb\u56fe\u7247\u67e5\u770bHTCDesire\u8be6\u7ec6\u8d44\u6599\r\nHTCDesire\u642d\u8f7d\u7684\u662f\u4e0eNexusOne\u76f8\u540c\u7684\u6700\u65b0\u7248Android2.1\u64cd\u4f5c\u7cfb\u7edf\uff0c\u4e0d\u540c\u7684\u662fDesire\u8fd8\u81ea\u5e26\u4e86HTC\u7684\u770b\u5bb6\u5229\u5668Sense\u754c\u9762\uff0c\u63d0\u4f9b\u4e86\u66f4\u4e3a\u534e\u4e3d\u4e0e\u4eba\u6027\u5316\u7684\u4eba\u673a\u754c\u9762\u3002\u5e76\u4e14HTCDesire\u81ea\u5e26\u7684\u6d4f\u89c8\u5668\u652f\u6301FLASH\u64ad\u653e\uff0c\u80fd\u8ba9\u60a8\u7684\u7f51\u7edc\u4f53\u9a8c\u66f4\u52a0\u5b8c\u6574\u3002\u786c\u4ef6\u4e0aDesire\u91c7\u7528\u7684\u4e3b\u9891\u9ad8\u8fbe1GHz\u7684\u9ad8\u901aQSD8250\u5904\u7406\u5668\uff0c512MROM+572MRAM\u7684\u5185\u5b58\u7ec4\u5408\uff0c\u8fd9\u4e5f\u662f\u76ee\u524d\u5e02\u9762\u4e0a\u7684\u9876\u7ea7\u914d\u7f6e\u4e86\uff0c\u8fd0\u884c