[{"url": "http://enjoyweb20.cn/index.php/2008/06/capzles/", "title": "Capzles\uff1a\u4e2a\u6027\u5316\u591a\u5a92\u4f53\u5c55\u793a", "tags": "web2.0 ", "name": "ybcz0519", "posttime": "2008-06-12 02:46:34", "ip": "78.42.119.244", "mark": 3, "note": "Capzles \u662f\u4e00\u4e2a\u4e0d\u9519\u7684\u4e2a\u4eba\u591a\u5a92\u4f53\u5c55\u793a\u5e73\u53f0\uff0c\u4f60\u53ef\u4ee5\u5c06\u81ea\u5df1\u7684\u7167\u7247\u3001\u89c6\u9891\u3001\u97f3\u9891\u4ee5\u53ca\u5176\u4ed6\u7684\u591a\u5a92\u4f53\u6587\u4ef6\uff0c\u521b\u5efa\u81ea\u5df1\u7684\u5c55\u793a\uff08capzle\uff09\uff0c\u5e76\u4e14\uff0cCapzles \u63d0\u4f9b\u4e86\u65f6\u95f4\u7ebf\uff08timeline\uff09\u529f\u80fd\uff0c\u4f60\u53ef\u4ee5\u6309\u65f6\u95f4\u987a\u5e8f\u5c06\u81ea\u5df1\u7684\u591a\u5a92\u4f53\u6587\u4ef6\u6392\u5217\uff0c\u5efa\u7acb\u4e00\u4e2a\u4f60\u81ea\u5df1\u6210\u957f\u7ecf\u5386\u7684\u4e16\u754c\u3002", "imagename": "3c90f59c9fe9447d85aca53d69ae155c.jpg", "infoid": 73811, "category": "technology_web2", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["web2.0"]}, {"url": "http://www.sogou.com/gaokao/", "title": "\u641c\u72d7 - \u9ad8\u8003\u5168\u641c\u7d22", "tags": "\u9ad8\u8003 \u641c\u7d22 \u641c\u72d7 ", "name": "yinyin", "posttime": "2008-06-12 01:10:24", "ip": "122.194.168.145", "mark": 2, "note": "1.\u5728\u641c\u7d22\u6846\u8f93\u5165\u9ad8\u6821\u540d\u79f0\uff0c\u8fdb\u5165\u641c\u7d22\u7ed3\u679c\u9875\uff0c\u60a8\u53ef\u4ee5\u67e5\u8be2\u4ee5\u4e0b\u4fe1\u606f\uff1a \r\na) \u9ad8\u6821\u5404\u5730\u5386\u5e74\u6587\u7406\u79d1\u7684\u5f55\u53d6\u7ebf\u548c\u5b66\u6821\u7b80\u4ecb\u3002\u4f8b\u5982\uff1a\u6e05\u534e\u5927\u5b66 \r\nb) \u9ad8\u6821\u5728\u5404\u5730\u5386\u5e74\u7684\u62db\u751f\u4eba\u6570\u3002\u4f8b\u5982\uff1a\u5357\u5f00\u5927\u5b66 \r\nc) \u9ad8\u6821\u5404\u5730\u5404\u4e13\u4e1a\u5386\u5e74\u62db\u751f\u5206\u6570\u3002\u4f8b\u5982\uff1a\u6d59\u6c5f\u5927\u5b66 \r\nd) \u9ad8\u6821\u6bcf\u4e2a\u4e13\u4e1a\u672a\u6765\u7684\u5c31\u4e1a\u60c5\u51b5\u3002\u4f8b\u5982\uff1a\u53a6\u95e8\u5927\u5b66 \r\n\u3000 \r\n2.\u62a5\u8003\u6307\u5357 \r\n\u8f93\u5165\u60a8\u7684\u9884\u4f30\u5206\u6570\uff0c\u6211\u4eec\u4f1a\u6839\u636e\u5404\u9ad8\u6821\u5728\u672c\u5730\u5386\u5e74\u62db\u751f\u5206\u6570\uff0c\u63d0\u4f9b\u7ed9\u60a8\u62a5\u8003\u4e13\u4e1a\u7684\u53c2\u8003\u4fe1\u606f\u3002 \r\n\u3000 \r\n3.\u9ad8\u8003\u8bd5\u5377 \r\n\u6bcf\u79d1\u8003\u8bd5\u7ed3\u675f\u540e\uff0c\u53ef\u8f93\u5165\u201c\u8003\u8bd5\u79d1\u76ee\u540d\u79f0 + \u6240\u5728\u7701\u4efd\u201d\u67e5\u8be2\u8bd5\u9898\u548c\u7b54\u6848 \u4f8b\u5982\uff1a\u9ad8\u8003\u8bed\u6587\u8bd5\u5377 \u5317\u4eac", "imagename": "422e3573cffa4e1189fc955add446dd4.gif", "infoid": 73806, "category": "technology_internet", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u9ad8\u8003", "\u641c\u7d22", "\u641c\u72d7"]}, {"url": "http://www.jianbitou.com/post/16_sites_web_design_inspiratio.html#diglog-3d26b090b27c46c8a5263c4dd9028d68", "title": "16\u4e2a\u4f18\u79c0\u7f51\u7ad9\u6559\u4f60\u7f51\u7ad9\u8bbe\u8ba1", "tags": "\u7f51\u7ad9 \u8bbe\u8ba1 ", "name": "yinyin", "posttime": "2008-06-12 00:55:21", "ip": "122.194.168.145", "mark": 4, "note": "\u5927\u5bb6\u90fd\u5e0c\u671b\u81ea\u5df1\u7684\u7f51\u7ad9\u7279\u522b\u53c8\u597d\u770b\uff0c\u5176\u5b9e\u81ea\u5df1\u8bbe\u8ba1\u7684\u4e1c\u897f\u624d\u662f\u81ea\u5df1\u6700\u559c\u6b22\u7684\uff0c\u7f51\u7ad9\u4e5f\u662f\uff0c\u6211\u76f8\u4fe1\u5927\u5bb6\u5bf9\u57fa\u672c\u7684\u4ee3\u7801\u662f\u638c\u63e1\u7684\uff0c\u4f46\u79bb\u6210\u4e3a\u4e00\u4e2a\u4f18\u79c0\u7684\u7f51\u7ad9\u8bbe\u8ba1\u5e08\u8fd8\u6709\u4e00\u6bb5\u8ddd\u79bb\uff0c\u4e0d\u8981\u7d27\uff0c\u53ea\u8981\u6709\u4e86\u597d\u7684\u6307\u5f15\uff0c\u597d\u7f51\u7ad9\u54b1\u4eec\u81ea\u5df1\u4e5f\u53ef\u4ee5\u8bbe\u8ba1\u3002Jacob Gube\u5728\u81ea\u5df1\u7684\u535a\u5ba2\u5f81\u6c42\u8bfb\u8005\u7684\u610f\u89c1\uff0c\u603b\u7ed3\u4e8616\u4e2a\u4f18\u79c0\u7f51\u7ad9\u8bbe\u8ba1\u7f51\u7ad9\u3002\u53ef\u80fd\u5927\u5bb6\u5bf9\u4e8e\u5916\u56fd\u4eba\u7684\u4e1c\u897f\u4e0d\u662f\u5f88\u559c\u6b22\uff0c\u4f46\u65e0\u53ef\u5426\u8ba4\u7684\u662f\uff0c\u4ed6\u4eec\u6709\u4e9b\u4e1c\u897f\u786e\u5b9e\u503c\u5f97\u54b1\u4eec\u5b66\u4e60\u3002", "imagename": "547a87e2711d495a8c9bb76df67cecb9.jpg", "infoid": 73805, "category": "technology_design", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u7f51\u7ad9", "\u8bbe\u8ba1"]}, {"url": "http://www.apple.com/iphone/", "title": "3G iPhone", "tags": "3G iPhone", "name": "yinyin", "posttime": "2008-06-12 00:24:22", "ip": "122.194.168.145", "mark": 3, "note": "\u6839\u636e\u82f9\u679c\u5b98\u7f51\u4ee5\u53ca\u4e00\u4e9b\u53c2\u52a0\u4e86WWDC\u7684\u8bb0\u8005\u7684\u4ecb\u7ecd,\u65b0\u7248iPhone - 3G iPhone\u7684\u6700\u5927\u66f4\u65b0\u5c31\u662f\u652f\u63013G\u7f51\u7edc,\u901f\u5ea6\u6bd4\u4e0a\u4e00\u4ee3\u5feb2.8\u500d.\r\n\u800c\u5728\u5916\u89c2\u65b9\u9762\uff0c\u82f9\u679c\u5e76\u6ca1\u6709\u505a\u592a\u591a\u7684\u6539\u53d8\uff0c\u4ece\u6b63\u9762\u770b\u51e0\u4e4e\u548c\u4e0a\u4ee3\u4e00\u6a21\u4e00\u6837.\r\n\u7ec6\u8282\u4e0a\u7684\u6539\u53d8\u5305\u62ec\uff1a\u539a\u5ea6\u964d\u4f4e\u523012.3mm\uff0c\u80cc\u76d6\u91c7\u7528\u5f27\u5f62\u8bbe\u8ba1\uff0c\u5e76\u4ece\u91d1\u5c5e\u6750\u8d28\u6362\u7528\u5851\u6599\uff0c\u673a\u8eab\u4fa7\u9762\u7684\u6309\u952e\u5219\u6539\u7528\u91d1\u5c5e\u6750\u8d28\uff0c16GB\u7248\u8fd8\u4f1a\u63a8\u51fa\u767d\u8272\u80cc\u76d6.\u8033\u673a\u63a5\u53e3\u4f4d\u4e8e\u9876\u90e8\u8868\u9762\uff0c\u4e0d\u4f1a\u518d\u6709\u8033\u673a\u65e0\u6cd5\u63d2\u5165\u7684\u95ee\u9898.\r\n\u53e6\u5916\uff0c\u624b\u673a\u7684\u97f3\u8d28\u65b9\u9762\u8bbe\u8ba1\u4e5f\u8fdb\u884c\u4e86\u6539\u8fdb.\r\n\r\n\u8fd9\u6b21\u82f9\u679c\u5bf9iPhone 3G\u7684\u5ba3\u4f20\u53e3\u53f7\u5176\u4e2d\u6709\u4e00\u53e5\u5c31\u662f2\u500d\u7f51\u901f,\u4e00\u534a\u539a\u5ea6.\r\n\u800c\u636e\u4e00\u4e2a\u8bb0\u8005\u8bd5\u7528\u540e\u79f0,iPhone 3G\u7684\u7f51\u7edc\u901f\u5ea6\u8fbe\u5230216Kbps\uff0c\u800c\u65e7EDGE\u7248\u672c\u4e3a105Kbps\uff0c\u82f9\u679c\u5ba3\u79f0\u7684\u901f\u5ea6\u63d0\u5347\u4e00\u500d\u5e76\u6ca1\u6709\u5439\u725b.\r\n\r\n\u786c\u4ef6\u76f8\u5173:\r\n\u5728\u786c\u4ef6\u4e0a,\u82f9\u679c\u8fd9\u6b21\u7684\u66f4\u65b0\u4f3c\u4e4e\u6709\u70b9\u4e0d\u5c3d\u5982\u4eba\u610f.\r\n\u5c4f\u5e55\u3001\u6444\u50cf\u5934\u3001802.11 b/g\u65e0\u7ebf\u7f51\u7edc\u90fd\u6ca1\u6709\u8fdb\u884c\u5347\u7ea7\uff0c\u65e0\u524d\u7f6e\u6444\u50cf\u5934\uff0c\u82f9\u679c\u4e5f\u6ca1\u6709\u5728\u4efb\u4f55\u5730\u65b9\u63d0\u52303G\u89c6\u9891\u901a\u8bdd\u95ee\u9898.\r\nA-GPS\u53ef\u7efc\u5408\u5e94\u7528\u5185\u7f6eGPS\u4e0e\u624b\u673a\u7f51\u7edc\u57fa\u7ad9\u8fdb\u884c\u5b9a\u4f4d\uff0c\u652f\u6301\u4e3a\u624b\u673a\u62cd\u6444\u7167\u7247\u6dfb\u52a0\u5730\u7406\u4f4d\u7f6e\u6807\u7b7e.\r\n\u624b\u673a\u5b9e\u9645\u6301\u63e1\u611f\u89c9\u8f83\u539a\uff0c\u4f46\u7531\u4e8e\u5176\u80cc\u90e8\u7684\u5f27\u7ebf\u80fd\u591f\u8ba9\u4eba\u6709\u7ea4\u8584\u7684\u89c6\u89c9\u6548\u679c.\r\n\u5e78\u597d\u5851\u6599\u80cc\u76d6\u5e76\u6ca1\u6709\u5ec9\u4ef7\u4e4b\u611f.\r\n\u4f46\u7531\u4e8e\u91c7\u7528\u9ad8\u4eae\u6f06\u9762\uff0c\u73b0\u5728\u80cc\u9762\u548c\u5c4f\u5e55\u4e00\u6837\u5bb9\u6613\u6536\u96c6\u6307\u7eb9.iPhone 3G\u4e0d\u518d\u9644\u8d60\u5e95\u5ea7\uff0c\u800c\u662f\u4ec5\u63d0\u4f9bUSB\u7535\u6e90\u7ebf\u548c\u5e95\u5ea7\u9002\u914d\u5668\uff0c\u5c3d\u7ba1\u5b83\u9644\u8d60\u4e86\u4e00\u4e2a\u7528\u6765\u53d6\u51faSIM\u5361\u7684\u5c0f\u5de5\u5177.\r\n\u53e6\u5916\u89e3\u51b3\u4e86\u624b\u673a\u8f6f\u4ef6\u540e\u53f0\u8fd0\u884c\u65f6\u8017\u7535\u548c\u62d6\u6162\u7cfb\u7edf\u901f\u5ea6\u7684\u95ee\u9898.\r\niPhone\u64cd\u4f5c\u7cfb\u7edf\u4e0d\u5141\u8bb8\u7b2c\u4e09\u65b9\u7a0b\u5e8f\u5728\u540e\u53f0\u8fd0\u884c\uff0c\u4e3a\u6b64\u82f9\u679c\u63d0\u4f9b\u4e00\u9879\u540d\u4e3a\u63a8\u9001\u63d0\u9192\u670d\u52a1\u7684\u5f00\u53d1\u5de5\u5177\uff0c\u7531\u82f9\u679c\u670d\u52a1\u5668\u548c\u6240\u6709iPhone\u4fdd\u7559\u4e00\u4e2a\u6c38\u4e45\u6027\u7684IP\u8fde\u63a5.\u5f53\u7b2c\u4e09\u65b9\u8f6f\u4ef6\u9700\u8981\u5411iPhone\u53d1\u9001\u6d88\u606f\u65f6\uff0c\u9700\u8981\u82f9\u679c\u670d\u52a1\u5668\u53d1\u51fa\u8bf7\u6c42\uff0c\u7136\u540e\u7531\u8be5\u63d0\u9192\u670d\u52a1\u5668\u5411iPhone\u53d1\u9001\u4fe1\u606f.\r\n\u6bd4\u5982\uff0c\u8bf8\u5982Skype\u3001MSN\u7b49\u5373\u65f6\u804a\u5929\u8f6f\u4ef6\u65e0\u9700\u5728\u540e\u53f0\u8fd0\u884c\uff0c\u5f53\u6709\u65b0\u6d88\u606f\u53d1\u9001\u7ed9\u4f60\u65f6\uff0c\u8be5\u670d\u52a1\u5373\u901a\u8fc7\u670d\u52a1\u5668\u53d1\u9001\u63d0\u9192\uff0c\u5524\u9192\u7a0b\u5e8f\u8fdb\u884c\u63a5\u6536.\r\n\u53e6\u5916\uff0c\u7b2c\u4e09\u65b9\u8f6f\u4ef6\u4e5f\u53ef\u4ee5\u901a\u8fc7\u8be5\u529f\u80fd\u5b9e\u73b0\u81ea\u52a8\u5347\u7ea7,\u8be5\u670d\u52a19\u6708\u4efd\u624d\u4f1a\u6b63\u5f0f\u63a8\u51fa\uff0c\u4f46\u4e0b\u6708\u8d77\u5c31\u53ef\u4ee5\u5411\u7b2c\u4e09\u65b9\u8f6f\u4ef6\u5546\u63d0\u4f9b\u5f00\u53d1\u5de5\u5177\u4e86.\r\n\r\n3.\u8f6f\u4ef6\u76f8\u5173\r\n\u76f8\u6bd4\u786c\u4ef6\u4e0a\u7684\u5c0f\u5e45\u5347\u7ea7\uff0c\u82f9\u679c\u4e3aiPhone 3G\u51c6\u5907\u7684\u8f6f\u4ef6\u66f4\u65b0\u4f30\u8ba1\u4f1a\u66f4\u5177\u5438\u5f15\u529b.\r\n7\u6708\u521d\u5c06\u516c\u5e03\u7684iPhone 2.0\u7248\u56fa\u4ef6\u5c06\u652f\u6301App Store\u8f6f\u4ef6\u5546\u5e97\uff0c\u5168\u7403\u5f00\u53d1\u8005\u53ef\u901a\u8fc7\u8be5\u6e20\u9053\u9500\u552e\u6216\u514d\u8d39\u53d1\u653eiPhone\u7b2c\u4e09\u65b9\u8f6f\u4ef6!\r\n\u5176\u4ed6\u529f\u80fd\u8fd8\u5305\u62ec\uff1a\u82f9\u679ciWork\u548c\u5fae\u8f6fOffice\u6587\u4ef6\u683c\u5f0f\u652f\u6301\uff0c\u901a\u8baf\u5f55\u641c\u7d22\uff0c\u7535\u90ae\u9644\u4ef6\u53e6\u5b58\uff0c\u5bb6\u957f\u63a7\u5236\u7b49.\r\niPhone 3G\u539f\u751f\u652f\u6301Exchange\uff0c\u53ef\u63d0\u4f9b\u7535\u5b50\u90ae\u4ef6\u3001\u901a\u8baf\u5f55\u3001\u65e5\u7a0b\u8868\u63a8\u9001\u548c\u8fdc\u7a0b\u64e6\u9664\u7b49\u4f01\u4e1a\u529f\u80fd.\r\niPhone\u7b2c\u4e00\u4ee3\u7528\u6237\u53ef\u514d\u8d39\u5347\u7ea72.0\u7248\u56fa\u4ef6\uff0ciPod touch\u7528\u6237\u5219\u9700\u8981\u4ed8\u8d399.99\u7f8e\u5143.\r\n\r\niPhone 3G\u5c06\u5728\u672a\u6765\u51e0\u4e2a\u6708\u5185\u5728\u5168\u740370\u4e2a\u56fd\u5bb6\u548c\u5730\u533a\u4e0a\u5e02\uff0c\u5176\u4e2d7\u670811\u65e5\u9996\u6279\u4e0a\u5e02\u7684\u5730\u533a\u5305\u62ec\uff1a\u6fb3\u5927\u5229\u4e9a\u3001\u5965\u5730\u5229\u3001\u6bd4\u5229\u65f6\u3001\u52a0\u62ff\u5927\u3001\u4e39\u9ea6\u3001\u82ac\u5170\u3001\u6cd5\u56fd\u3001\u5fb7\u56fd\u3001\u9999\u6e2f\u3001\u7231\u5c14\u5170\u3001\u610f\u5927\u5229\u3001\u65e5\u672c\u3001\u58a8\u897f\u54e5\u3001\u8377\u5170\u3001\u65b0\u897f\u5170\u3001\u632a\u5a01\u3001\u8461\u8404\u7259\u3001\u897f\u73ed\u7259\u3001\u745e\u5178\u3001\u745e\u58eb\u3001\u82f1\u56fd\u548c\u7f8e\u56fd.\r\n\r\niPhone 3G\u8bdd\u8d39\u5957\u9910\u4ee5\u53ca\u7834\u89e3\u8be6\u60c5:\r\n\u8fd9\u4e2a\u4f30\u8ba1\u662f\u5e7f\u5927\u670b\u53cb\u6700\u5173\u6ce8\u7684~\u6709\u5173iPhone 3G\u552e\u4ef7\u95ee\u9898\uff0c\u76ee\u524d\u4ec5\u786e\u5b9a\u7f8e\u56fd\u5730\u533a\u4ecd\u7531AT&amp;amp\uff1bT\u72ec\u5bb6\u9500\u552e.\r\n8GB\u548c16GB\u7248\u672c\u5206\u522b\u4e3a199\u548c299\u7f8e\u5143\uff0c\u4f46\u9700\u8981\u540c\u65f6\u7b7e\u8ba2\u4e3a\u671f\u4e24\u5e74\u7684\u8bdd\u8d39\u5408\u540c.\r\n\u6bcf\u67083G\u6570\u636e\u4e0d\u9650\u6d41\u91cf\u5305\u6708\u8d39\u7528\u4e3a30\u7f8e\u5143,\u4f01\u4e1a\u7528\u623745\u7f8e\u5143\uff0c\u800c\u5305\u62ec450\u5206\u949f\u901a\u8bdd\uff0c5000\u5206\u949f\u5468\u672b\u3001\u591c\u95f4\u901a\u8bdd\u548c200\u6761\u77ed\u4fe1\u7684\u8bed\u97f3\u4e1a\u52a1\u6708\u79df\u4e3a 39.99\u7f8e\u5143\uff08\u53e6\u6709\u5305\u542b\u66f4\u591a\u514d\u8d39\u901a\u8bdd\u65f6\u95f4\u3001\u77ed\u4fe1\u7684\u8bed\u97f3\u5957\u9910\uff09\uff0c\u4e5f\u5c31\u610f\u5473\u7740\u6bcf\u4e2aiPhone\u7528\u6237\u6bcf\u6708\u6700\u4f4e\u8bdd\u8d39\u5f00\u9500\u7ea670\u7f8e\u5143