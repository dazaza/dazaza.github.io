u574e\u8d1d\u5c14\u5c9b\u3002\r\n\r\n\u4ed6\u4e8e\uff12\uff10\uff10\uff19\u5e74\uff13\u6708\uff11\u65e5\u51fa\u53d1\uff0c\u9014\u7ecf\u8377\u5170\u3001\u6cd5\u56fd\u3001\u5fb7\u56fd\u3001\u7f8e\u56fd\uff0c\u6700\u7ec8\u4e8e\u5f53\u6708\uff13\uff10\u65e5\u5230\u8fbe\u65b0\u897f\u5170\u3002\u4f46\u7531\u4e8e\u672a\u627e\u5230\u524d\u5f80\u574e\u8d1d\u5c14\u5c9b\u7684\u8239\uff0c\u53f2\u5bc6\u65af\u4e0d\u5f97\u5df2\u5728\u65b0\u897f\u5170\u65af\u56fe\u5c14\u7279\u5c9b\u63d0\u524d\u7ed3\u675f\u65c5\u7a0b\u3002\r\n\r\n\u4e00\u8def\u4e0a\uff0c\u53f2\u5bc6\u65af\u501f\u52a9\u5fae\u535a\u968f\u65f6\u66f4\u65b0\u81ea\u5df1\u7684\u52a8\u6001\uff0c\u628a\u4e0b\u4e00\u6b65\u7684\u51fa\u884c\u3001\u4f4f\u5bbf\u5168\u4ea4\u7531\u5fae\u535a\u7528\u6237\u5b89\u6392\uff0c\u8fd9\u4e9b\u7528\u6237\u91cc\u6709\u5546\u4eba\u3001\u516c\u53f8\u7ecf\u7406\u3001\u5355\u8eab\u6bcd\u4eb2\u3001\u653f\u5e9c\u5b98\u5458\u7b49\uff0c\u867d\u4e0e\u4ed6\u7d20\u6627\u5e73\u751f\u5374\u70ed\u60c5\u5e2e\u5fd9\uff0c\u6709\u7684\u63d0\u4f9b\u9152\u5e97\u7a7a\u5e8a\u3001\u6709\u7684\u63d0\u4f9b\u8239\u7968\u3001\u673a\u7968\u3002\r\n\r\n\u6ca1\u6709\u8d44\u52a9\u5b81\u53ef\u9732\u5bbf\u8857\u5934\r\n\r\n\u4e3a\u505a\u5230\u5b8c\u5168\u4f9d\u9760\u5fae\u535a\u8d44\u6e90\u65c5\u884c\uff0c\u53f2\u5bc6\u65af\u5728\u51fa\u53d1\u524d\u4fbf\u4e3a\u81ea\u5df1\u7acb\u4e0b\u51e0\u6761\u89c4\u77e9\u3002\r\n\r\n\u4f8b\u5982\uff0c\u4ed6\u5728\u65c5\u884c\u671f\u95f4\u4e0d\u4f1a\u4e3a\u81ea\u5df1\u7684\u51fa\u884c\u3001\u4f4f\u5bbf\u57cb\u5355\uff0c\u53ea\u4f1a\u628a\u94b1\u82b1\u5728\u5403\u996d\u548c\u8d2d\u7269\u4e0a\u3002\u5982\u679c\u6ca1\u6709\u4eba\u7ed9\u4ed6\u63d0\u4f9b\u5e2e\u52a9\uff0c\u4ed6\u5b81\u53ef\u9732\u5bbf\u8857\u5934\u3002\r\n\r\n\u4ed6\u53ea\u63a5\u53d7\u5fae\u535a\u7528\u6237\u7684\u5e2e\u52a9\uff0c\u5982\u679c\u63d0\u4f9b\u5e2e\u52a9\u7684\u4eba\u672c\u8eab\u4e0d\u4f7f\u7528\u5fae\u535a\uff0c\u90a3\u4e48\u5373\u4f7f\u5e2e\u52a9\u662f\u7ecf\u7531\u5fae\u535a\u63d0\u4f9b\u4ed6\u4e5f\u4e0d\u63a5\u5