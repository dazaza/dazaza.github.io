535\u89c6\u673a\u98de\u5230\u90a3\u4e2a\u9ad8\u5ea6\uff0c\u6211\u5df2\u7ecf\u72c2\u7b11\u4e0d\u6b62\u4e86\u3002\u3002\u3002", "imagename": "cc9ddf0352554c5ba1fbef4dd8e5b0b2.jpg", "infoid": 395576, "category": "videos_comedy", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "videos", "via": null, "real_tags": ["\u642c\u5bb6", "\u56fd\u5916", "\u5b66\u751f"]}, {"url": "http://jdxi.net/post/pai-zhao.html", "title": "\u62cd\u7167\u4e70\u5356\uff1a\u5927S\u6c6a\u5c0f\u83f2\u5a5a\u793c\u544a\u641c\u72d0CEO\u5f20\u671d\u9633\u62cd\u7167", "tags": "\u5927S \u5a5a\u793c \u5f20\u671d\u9633 \u641c\u72d0 \u6c6a\u5c0f\u83f2 \u7231\u60c5\u4e70\u5356 \u62cd\u7167 \u6076\u641e ", "name": "wangweimei", "posttime": "2011-03-28 18:07:53", "ip": "113.95.36.207", "mark": 0, "note": "\u8fd9\u6b4c\u8bcd\u5176\u5b9e\u5e76\u4e0d\u662f\u5f20CEO\u4f5c\u7684\uff0c\u800c\u662f\u817e\u8baf\u5fae\u535a\u4e00\u4e2a\u53eb\u5f20\u671d\u9633\u7684\u4eba\u6076\u641e\u7684\u800c\u5df2\u3002\u3002\u3002", "imagename": "845935c8b4504f7da43abbec70ed8429.jpg", "infoid": 395553, "category": "videos_tech-stuff", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "videos", "via": null, "real_tags": ["\u5927s", "\u5a5a\u793c", "\u5f20\u671d\u9633", "\u641c\u72d0", "\u6c6a\u5c0f\u83f2", "\u7231\u60c5\u4e70\u5356", "\u62cd\u7167", "\u6076\u641e"]}, {"url": "http://jdxi.net/post/san-ju-yi-shu.html", "title": "\u4e09\u53e5\u8bdd\u9057\u4e66\uff1a\u4e0d\u7ba12012\u662f\u4e0d\u662f\u626f\u6de1", "tags": "\u9057\u4e66 2012 \u4e09\u53e5\u8bdd", "name": "wangweimei", "posttime": "2011-03-28 17:31:04", "ip": "113.95.36.207", "mark": 0, "note": "\u7ee7\u65e5\u672c\u201c\u4e09\u53e5\u8bdd\u60c5\u4e66\u201d\u4e4b\u540e\uff0c\u4e2d\u56fd\u5174\u8d77\u201c\u4e09\u53e5\u8bdd\u9057\u4e66\u201d\u6d3b\u52a8\u3002\r\n\u6709\u5fae\u7b11\uff0c\u6709\u54c0\u4f24\uff0c\u53c8\u6709\u6e29\u60c5\uff0c\u7279\u6574\u7406\u5982\u4e0b\uff0c\u5411\u8fd9\u4e9b\u53ef\u7231\u7684\u6709\u624d\u7684\u4e2d\u56fd\u7f51\u53cb\u4eec\u81f4\u656c\uff01\r\n\r\n\u4ee5\u4e0b\u662f\u7f51\u53cb\u4eec\u56de\u590d\u7684\u9057\u4e66\uff1a\r\n\r\n1. \u7238\uff0c\u4f60\u653e\u5fc3\r\n\u7b49\u6211\u78b0\u4e0a\u9093\u4e3d\u541b\u963f\u59e8\r\n\u6211\u4e00\u5b9a\u7ed9\u60a8\u62ff\u7b7e\u540d\uff01\uff01\r\n\r\n\r\n2. \u5b9d\u8d1d\uff0c\u4fdd\u9669\u5355\u5728\u5e8a\u5934\u67dc\u7b2c\u4e09\u5c42\uff0c\u53d7\u76ca\u4eba\u90fd\u662f\u4f60\u7684\u540d\u5b57\r\n\u628a\u6211\u7684\u9aa8\u7070\u6492\u8fdb\u5927\u6d77\r\n\u6211\u8981\u4f60\u5fd8\u8bb0\u6211\uff0c\u627e\u4e2a\u66f4\u597d\u7684\u5973\u4eba\u5feb\u4e50\u5730\u5728\u4e00\u8d77\r\n\r\n3. \u571f\u5c11\u76d6\u70b9\r\n\u538b\u529b\u5f88\u5927\r\n\u6ca1\u4e86\r\n\r\n4. \u6e05\u660e\u65f6\u8282\r\n\u80fd\u4e0d\u80fd\u70e7\u7ed9\u6211\r\n\u540d\u4fa6\u63a2\u67ef\u5357\u5927\u7ed3\u5c40\u3002\u3002\r\n\r\n5. \u8fd9\u4e2a\u6708\r\n\u8fd8\u80fd\u62ff\u5230\u5168\u52e4\u5417\r\n\u8001\u677f\uff1f\r\n\r\n6. \u522b\u70e7HP\u7684\r\n\u8981\u82f9\u679c\u7684\r\n\u6211\u90a3\u513f\u6ca1\u6cd5\u552e\u670d\r\n\r\n7. \u5929\u610f\u5982\u6b64\uff0c\u5c31\u8ba9\u6211\u8fd9\u6837\u8d70\u4e86\u5427\r\n\u65e9\u77e5\u9053\u8fd9\u6837\r\n\u6211\u5c31\u65e9\u70b9\u53bb\u76f8\u4eb2\u4e86\r\n\r\n8. \u8001\u516c\uff0c\u4f60\u7684\u82cd\u4e95\u7a7a\u5168\u96c6\r\n\u6211\u6ca1\u6709\u5220\u6389\u3002\u3002\r\n\u5728C\uff1a\\\u5510\u8bd7\u4e09\u767e\u9996\\\u674e\u767d\u5168\u96c6\u91cc\r\n\r\n9. \u5988\u4f60\u8f9b\u82e6\u4e86\r\n\u5982\u679c\u6709\u6765\u4e16\r\n\u6211\u505a\u4f60\u5988\u5988\r\n\r\n10. \u4e8c\u72d7\uff0c\u4ee3\u6211\u5411\u5f20\u8273\u8bf4\uff0c\r\n\u4eca\u751f\uff0c\u6211\u53ea\u7231\u5979\u4e00\u4eba\uff01\r\n\u8fd8\u6709\uff0c\u5468\u4e3d\u548c\u83f2\u83f2\u3002\u3002\r\n\r\n11. \u90a3\u4e2a\r\n\u5982\u679c\u4e0d\u9ebb\u70e6\u7684\u8bdd\r\n\u628a\u5730\u7403\u4e0a\u53ef\u70e7\u7684\u90fd\u70e7\u7ed9\u6211\u5427\r\n\r\n12. \u7167\u987e\u597d\r\n\u6211\r\n\u4e03\u8205\u8001\u7237\r\n\r\n13. \u613f\u4ed6\u4eec\u6b8b\u9177\uff0c\u4f46\u662f\u6c38\u8fdc\u6b63\u4e49\r\n\u613f\u6050\u60e7\u6c38\u8fdc\u4e0d\u4f1a\u4e3b\u5bb0\u4ed6\u4eec\u7684\u884c\u52a8\u5e76\u613f\u6c11\u65cf\u7684\u8363\u8a89\u5728\u4ed6\u4eec\u5fc3\u4e2d\u9ad8\u4e8e\u4e00\u5207\r\n\u6700\u540e\uff0c\u613f\u4ed6\u4eec\u6700\u7ec8\u53ef\u4ee5\u7406\u89e3\uff0c\u4e3a\u5b8c\u6210\u6211\u4eec\u5efa\u7acb\u6c11\u65cf\u793e\u4f1a\u4e3b\u4e49\u56fd\u5bb6\u7684\u4efb\u52a1\uff0c\u9700\u8981\u6570\u767e\u5e74\u65f6\u95f4\u5e76\u9700\u8981\u6bcf\u4e00\u4e2a\u4eba\u6c38\u8fdc\u5c06\u5171\u540c\u7684\u5229\u76ca\u7f6e\u4e8e\u4e2a\u4eba\u5229\u76ca\u4e4b\u4e0a\u3002----\u5e0c\u7279\u52d2\u7edd\u7b14\r\n\r\n14. \u5b58\u6298\u5728\u5bc6\u7801\u7bb1\u91cc\r\n\u5bc6\u7801\u7bb1\u5728\u4fdd\u9669\u67dc\u91cc\r\n\u4fdd\u9669\u67dc\u94a5\u5319\u5939\u5728\u5b58\u6298\u91cc\r\n\r\n15. \u628a\u91d1\u57ce\u6b66\r\n\u7ed9\u8001\u5a18\r\n\u70e7\u8fc7\u6765\r\n\r\n16. \u6211\u5728\u524d\u65b9\u7b49\u7740\u4f60\r\n\u8bb0\u5f97\u6765\u65f6\u8def\u4e0a\r\n\u522b\u996e\u5b5f\u5a46\u6c64\r\n\r\n17. \u7238\u7238\u5988\u5988\r\n\u5bf9\u4e0d\u8d77\r\n\u7ed9\u4f60\u4eec\u6dfb\u9ebb\u70e6\u4e86\r\n\r\n18. \u8bf4\u6765\u6211\u8fd8\u662f\u5f88\u9057\u61be\r\n\u6b7b\u4e4b\u524d\r\n\u4e5f\u6ca1\u9047\u5230\u4f60\r\n\r\n19. \u5988\uff0c\u52a0\u628a\u52b2\uff0c\u4f60\u4eec\u8fd8\u80fd\u751f\u4e00\u4e2a\u3002\r\n\u5b9d\u8d1d\uff0c\u6211\u662f\u771f\u7684\u5f88\u7231\u4f60\uff0c\u4f46\u662f\u771f\u53ef\u60dc\uff0c\u7b49\u4e0d\u5230\u4f60\u7231\u4e0a\u6211\u4e86\u3002\r\n\u5c3d\u7ba1\u6d3b\u7740\u6709\u592a\u591a\u9057\u61be\u7684\u4e8b\uff0c\u4f46\u662f\u6b7b\u4e86\u8fd9\u4ef6\u4e8b\uff0c\u4e00\u70b9\u90fd\u4e0d\u9057\u61be\u3002\r\n\r\n20. \u597d\u5403\u597d\u770b\u597d\u73a9\u6211\u8d70\u4e86\r\n\u60b2\u4f24\u5feb\u4e50\u5e73\u6de1\u8fc7\u53bb\u4e86\r\n\u5b8c\u7f8e\u8c22\u5e55\u8c22\u8c22\u4e86\r\n\r\n21. \u522b\u96be\u8fc7\uff0c\u6211\u8d70\u4e86\uff0c\u4f60\u4eec\u8fd8\u5f97\u7ee7\u7eed\u6d3b\u7740\r\n\u7ed9\u6211\u70e7\u53f0\u7535\u8111\u8ddf\u7f51\u7ebf\uff0c\u6700\u597d\u518d\u7ed9\u4e2a\u8def\u7531\u5668\r\n\u6211\u6d3b\u7684\u4e0d\u60b2\u4f24\uff0c\u613f\u4f60\u4eec\u5706\u6ee1\u3002\r\n\r\n22. \u6211\u6b7b\u4e86\r\n\u8fd9\u4ef6\u4e8b\r\n\u9ebb\u70e6\u706b\u5316\u524d\u591a\u786e\u8ba4\u51e0\u6b21\r\n\r\n23. \u82e5\u67d0\u65e5\u6211\u79bb\u5f00\u8fd9\u4e16\u754c\r\n\u8bf7\u8bb0\u5f97\u5728\u6211\u575f\u524d\u653e\u675f\u9999\u6c34\u767e\u5408\r\n\u56e0\u8fd9\u4e00\u8f88\u5b50\u6211\u90fd\u671f\u5f85\u5982\u8fd9\u82b1\u822c\u7eaf\u6d01\uff0c\u4f46\u4e00\u76f4\u4e8b\u4e0e\u613f\u8fdd\u3002\r\n\r\n24. \u6211\u6ca1\u6709\u6028\u5ff5\u54e6\uff0c\u771f\u7684\r\n\u8bf6\uff0c\u4f60\u95ee\u6211\u4e3a\u4ec0\u4e48\u7a7f\u7684\u7ea2\u901a\u901a\u7684\r\n\u8fd9\u4e2a\u662f\u4e2a\u4eba\u7231\u597d\u5566\uff0c\u54c8\u3002\u3002\u3002\u54c8\u54c8\r\n\r\n25. \u6211\u5e0c\u671b\u6211\u7231\u7684\u90a3\u4f4d\u5728\u90a3\u65f6\u5df2\u5ac1\u4f5c\u4eba\u5987\uff0c\u4f46\u80fd\u7ed9\u4ffa\u5728\u6e05\u660e\u65f6\u9732\u4e00\u5c0f\u9762\r\n\u7238\u5988\uff0c\u5b69\u513f\u4e0d\u5b5d\r\n\u751f\u5f97\u7a9d\u56ca\uff0c\u6b7b\u4e5f\u6d6a\u8d39\u3002\r\n\r\n26. \u6211\u7231\u4f60\r\n\u81f3\u6b7b\u65b9\u4f11\r\n\u505a\u5230\u4e86\r\n\r\n27. \u996d\r\n\u5728\u5fae\u6ce2\u7089\u91cc\r\n\u5148\u70ed\u70ed\u518d\u5403\r\n\r\n28. \u6709\u4e9b\u8bdd\r\n\u5c31\u8ba9\u6211\r\n\u5e26\u8fdb\u575f\u5893\u5427\r\n\r\n29. \u9996\u5148\u6211\u8981\u611f\u8c22\u56fd\u5bb6\r\n\u5176\u6b21\u6211\u8981\u611f\u8c22\u515a\u548c\u653f\u5e9c\r\n\u6700\u540e\u5c24\u4e3a\u611f\u8c22\u7236\u6bcd\uff0c\u6ca1\u6709\u4f60\u4eec\u6211\u4e0d\u4f1a\u5728\u8fd9\u4e2a\u795e\u5947\u7684\u56fd\u5ea6\u91cc\u89c1\u8bc1\u5404\u79cd\u795e\u5947\u7684\u6b7b\u6cd5\uff0c\u543e\u751f\u8db3\u4ee5\u3002\r\n\r\n30. \u59dc\u8d85\r\n\u522b\u5bb3\u6015\uff0c\u6211\u505a\u4e86\u9b3c\u5c31\u4e0d\u53bb\u627e\u4f60\u4e86\r\n\u5176\u5b9e\u6211\u6ca1\u6709\u81ea\u5df1\u8ba4\u4e3a\u7684\u90a3\u4e48\u6068\u4f60\uff0c\u5e0c\u671b\u4f60\u597d\u3002\r\n\r\n31. \u672c\u4eba\u6b7b\u540e\r\n\u5c06\u5411\u751f\u524d\u7d2f\u8ba1\u5bf9\u6