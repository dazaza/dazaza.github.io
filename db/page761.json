[{"url": null, "title": "\u65b0\u8054\u901a\u6b63\u5f0f\u516c\u5e03\u5185\u90e8\u673a\u6784\u8bbe\u7f6e", "tags": "\u65b0\u8054\u901a ", "name": "yinyin", "posttime": "2008-11-05 10:07:38", "ip": "222.128.48.207", "mark": 1, "note": "<P>\u8ddd\u79bb\u6b63\u5f0f\u6302\u724c\u6210\u7acb\u4ec5\u534a\u4e2a\u6708\uff0c\u4e2d\u56fd\u8054\u5408\u7f51\u7edc\u901a\u4fe1\u6709\u9650\u516c\u53f8(\u4ee5\u4e0b\u7b80\u79f0\u201c\u65b0\u8054\u901a\u201d)\u5c31\u516c\u5e03\u4e86\u516c\u53f8\u5185\u90e8\u673a\u6784\u8bbe\u7f6e\u548c\u9ad8\u7ba1\u540d\u5355\u3002\u5185\u90e8\u673a\u6784\u53ca\u5176\u8d1f\u8d23\u4eba\u7684\u660e\u6717\u5316\uff0c\u8868\u660e\u65b0\u8054\u901a\u7684\u91cd\u7ec4\u5de5\u4f5c\u5df2\u8fdb\u5165\u6536\u5b98\u9636\u6bb5\u3002 </P>\r\n<P><BR>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; \u9664\u65b0\u8054\u901a\u7b79\u5907\u7ec4\u7ec4\u957f\u5e38\u5c0f\u5175\u4e4b\u5916\uff0c\u65b0\u8054\u901a\u96c6\u56e2\u9ad8\u7ba1\u6392\u5e8f\u5206\u522b\u4e3a\u9646\u76ca\u6c11\u3001\u5de6\u8fc5\u751f\u3001\u88f4\u7231\u534e\u3001\u4f5f\u5409\u7984\u3001\u674e\u5efa\u56fd\u3001\u8d75\u7ee7\u4e1c\u3001\u674e\u798f\u7533\u3001\u674e\u521a\u3001\u5f20\u94a7\u5b89\u3001\u59dc\u6b63\u65b0\u3002\u5176\u4e2d\uff0c\u4f5f\u5409\u7984\u3001\u674e\u521a\u3001\u5f20\u94a7\u5b89\u4e3a\u539f\u4e2d\u56fd\u8054\u901a\u526f\u603b\u88c1\uff0c\u5176\u4f597\u4f4d\u526f\u603b\u88c1\u6765\u81ea\u4e2d\u56fd\u7f51\u901a\uff0c\u52a0\u4e0a\u5e38\u5c0f\u5175\uff0c\u5728\u65b0\u9ad8\u7ba1\u56e2\u961f\u4e2d\u6765\u81ea\u539f\u4e2d\u56fd\u8054\u901a\u7684\u4e3a4\u4e2a\u3002\u7531\u4e8e\u4e2d\u56fd\u8054\u901a\u548c\u4e2d\u56fd\u7f51\u901a\u5408\u5e76\u4e4b\u540e\u9886\u5bfc\u4f17\u591a\uff0c\u65b0\u8054\u901a\u57fa\u672c\u91c7\u53d6\u96c6\u56e2\u548c\u4e0a\u5e02\u516c\u53f8\u4e24\u5957\u73ed\u5b50\u7684\u505a\u6cd5\uff0c\u9664\u90e8\u5206\u91cd\u8981\u9ad8\u7ba1\u4e4b\u5916\uff0c\u5176\u4ed6\u9ad8\u7ba1\u4e0d\u518d\u517c\u804c\u3002\u4e0e\u6b64\u540c\u65f6\uff0c\u65b0\u8054\u901a\u8fd8\u516c\u5e03\u4e86\u5404\u7701\u516c\u53f8\u7684\u603b\u7ecf\u7406\u4eba\u9009\uff0c\u76f8\u5173\u4eba\u5458\u914d\u7f6e\u79c9\u6301\u4e86\u5e73\u8861\u539f\u5219\uff0c\u539f\u7f51\u901a\u548c\u539f\u8054\u901a\u4eba\u5458\u7684\u6bd4\u4f8b\u57fa\u672c\u4e3a1\uff1a1\u3002 </P>\r\n<P><BR>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; \u4e3a\u7a81\u51fa\u5ba2\u6237\u670d\u52a1\u5b9a\u4f4d\u7684\u539f\u5219\uff0c\u65b0\u8054\u901a\u5185\u90e8\u5171\u8bbe\u7f6e\u5e02\u573a\u90e8\u3001\u4e2a\u4eba\u5ba2\u6237\u90e8\u3001\u5bb6\u5ead\u5ba2\u6237\u90e8\u3001\u96c6\u56e2\u5ba2\u6237\u90e8\u4ee5\u53ca\u56fd\u9645\u4e1a\u52a1\u90e8\u7b4928\u4e2a\u90e8\u95e8\uff0c\u53e6\u5916\u8fd8\u8bbe\u7acb\u4e8618\u4e2a\u76f4\u5c5e\u7684\u751f\u4ea7\u652f\u6491\u5355\u4f4d\u3002\u5e38\u5c0f\u5175\u5728\u89c6\u9891\u4f1a\u8bae\u4e0a\u8868\u793a\uff0c\u6b64\u6b21\u5185\u90e8\u673a\u6784\u8bbe\u7f6e\u548c\u8d1f\u8d23\u4eba\u5b89\u6392\u7684\u5de5\u4f5c\uff0c\u4e3b\u8981\u9075\u5faa\u9002\u5e94\u53d1\u5c55\u9700\u8981\u3001\u786e\u4fdd\u5e73\u7a33\u8fc7\u6e21\u3001\u517c\u987e\u5f53\u524d\u53ca\u4eca\u540e\u3001\u5408\u7406\u5747\u8861\u914d\u5907\u7b494\u9879\u539f\u5219\u3002\u4f5c\u4e3a\u4e00\u5bb6\u65b0\u6210\u7acb\u7684\u5168\u4e1a\u52a1\u8fd0\u8425\u5546\uff0c\u65b0\u8054\u901a\u8fd8\u5ba3\u5e03\u5355\u72ec\u8bbe\u7acb\u79fb\u52a8\u7f51\u7edc\u516c\u53f8\u4ee5\u53d1\u5c553G\u4e1a\u52a1\uff0c\u8be5\u516c\u53f8\u5c06\u4e3b\u8981\u8d1f\u8d233G\u79fb\u52a8\u7f51\u7edc\u7684\u5efa\u8bbe\u3001\u7ef4\u62a4\u7b49\u5de5\u4f5c\u3002 </P>\r\n<P><BR>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; 10\u670815\u65e5\uff0c\u65b0\u8054\u901a\u6b63\u5f0f\u6302\u724c\u6210\u7acb\u3002\u5e38\u5c0f\u5175\u5f53\u65f6\u8868\u793a\uff0c\u65b0\u8054\u901a\u7684\u5b9a\u4f4d\u662f\u201c\u5bbd\u5e26\u901a\u4fe1\u548c\u4fe1\u606f\u670d\u52a1\u63d0\u4f9b\u5546\u201d\uff0c\u4eca\u540e\u4e00\u6bb5\u65f6\u95f4\u5185\uff0c\u5c06\u5168\u9762\u6574\u5408\u65e0\u7ebf\u53ca\u56fa\u7f51\u4e1a\u52a1\u63a8\u8fdb\u5168\u4e1a\u52a1\u7ecf\u8425\uff0c\u5e76\u52a0\u5927\u56fa\u7f51\u5bbd\u5e26\u7684\u5efa\u8bbe\u529b\u5ea6\u4ee5\u63a8\u8fdb\u56fa\u5b9a\u548c\u79fb\u52a8\u7f51\u7edc\u7684\u5bbd\u5e26\u5316\u3002 </P>\r\n<P><BR>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; \u6309\u7167\u6700\u65b0\u53d1\u5e03\u7684\u8d22\u62a5\uff0c\u4eca\u5e74\u524d\u4e09\u5b63\u5ea6\uff0c\u4e2d\u56fd\u8054\u901a\u7684\u51c0\u5229\u6da6\u7ea6\u4e3a74.1\u4ebf\u5143\u3002\u5728\u6b64\u671f\u95f4\uff0c\u8be5\u516c\u53f8\u5b9e\u73b0\u8425\u4e1a\u6536\u5165536.7\u4ebf\u5143\uff0c\u6bd4\u4e0a\u5e74\u540c\u671f\u589e\u957f3.9%\u3002\u5176\u4e2dG\u7f51\u6536\u5165494.8\u4ebf\u5143\uff0c\u5e73\u5747\u6bcf\u6708\u6bcf\u6237\u6536\u5165\u4e3a42.8\u5143\u3002\u6b64\u5916\uff0c\u5df2\u7ecf\u51fa\u552e\u7ed9\u4e2d\u56fd\u7535\u4fe1\u7684C\u7f51\u4e1a\u52a1\uff0c\u524d\u4e09\u5b63\u5ea6\u7684\u51c0\u5229\u6da6\u4e5f\u8fbe\u5230\u4e8616\u4ebf\u5143\u3002 </P>\r\n<P><BR>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; \u9762\u5bf9\u542f\u7528\u65b0\u5b98\u65b9\u7f51\u7ad9\u7684\u4f20\u8a00\uff0c\u65b0\u8054\u901a\u4e5f\u5bf9\u5916\u505a\u51fa\u4e86\u6f84\u6e05\u3002\u65b0\u8054\u901a\u516c\u53f8\u8868\u793a\uff0c\u76ee\u524d\u5bf9\u5916\u63d0\u4f9b\u4fe1\u606f\u670d\u52a1\u7684\u7f51\u7ad9\u6709\u4e24\u4e2a\uff0c\u4e00\u662f<A href=\"http://www.chinaunicom.com\">www.chinaunicom.com</A>\uff0c\u53e6\u4e00\u4e2a\u662f<A href=\"http://www.cnc.cn\">www.cnc.cn</A>\uff0c\u5176\u4e2d\u540e\u8005\u5df2\u7ecf\u8fdb\u884c\u6539\u7248\u3002\u9274\u4e8e\u5408\u5e76\u7684\u76f8\u5173\u540e\u7eed\u5de5\u4f5c\u8fd8\u9700\u8981\u4e00\u6bb5\u65f6\u95f4\u5b8c\u6210\uff0c\u65b0\u8054\u901a\u5728\u8fc7\u6e21\u671f\u5185\u5c06\u5229\u7528\u4e0a\u8ff0\u4e24\u4e2a\u7f51\u7ad9\u4e3a\u516c\u4f17\u548c\u5ba2\u6237\u63d0\u4f9b\u4fe1\u606f\u670d\u52a1\uff0c\u5e76\u63a8\u4ecb\u76f8\u5173\u4e1a\u52a1\u3002\u7b49\u5230\u65f6\u673a\u6210\u719f\u540e\uff0c\u65b0\u8054\u901a\u5c06\u5408\u5e76\u4e0a\u8ff0\u4e24\u4e2a\u7f51\u7ad9\uff0c\u5176\u4e2d<A href=\"http://www.cnc.cn\">www.cnc.cn</A>\u57df\u540d\u5c4a\u65f6\u5c06\u505c\u6b62\u4f7f\u7528\uff0c\u5176\u76ee\u524d\u627f\u62c5\u7684\u670d\u52a1\u529f\u80fd\u5c06\u7531\u53e6\u5916\u4e00\u4e2a\u7f51\u7ad9\u7edf\u4e00\u63a5\u66ff\u3002 </P>\r\n<P><BR>\u5546\u62a5\u8bb0\u8005 \u6bdb\u6d9b\u6d9b</P>\r\n<P>&nbsp;</P>", "imagename": null, "infoid": 101225, "category": "technology_internet", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u65b0\u8054\u901a"]}, {"url": null, "title": "\u5e02\u6c11\u5e74\u5185\u6709\u671b\u73a9\u201c\u4e92\u8054\u7f51\u624b\u673a\u201d\u4e86", "tags": "\u4e92\u8054\u7f51 \u624b\u673a CDMA \u7535\u4fe1 ", "name": "yinyin", "posttime": "2008-11-05 10:03:30", "ip": "222.128.48.207", "mark": 1, "note": "<P>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; \u6295\u8d4410\u4ebf\u5143\uff0c\u6b66\u6c49\u7535\u4fe1\u6539\u9020\u3001\u5347\u7ea7C\u7f51\uff0c189\u53f7\u6bb5\u5e74\u5185\u63a8\u51fa\u3000</P>\r\n<P>\u3000\u3000\u201c\u2018\u5929\u7ffc\u2019189\u53f7\u6bb5\u6709\u671b\u5e74\u5e95\u4eae\u76f8\u6b66\u6c49\u3002\u201d\u5728\u7535\u4fe1\u63a5\u624bCDMA\u7f51\u7edc\u6b63\u597d\u4e00\u4e2a\u6708\u7684\u65f6\u95f4\u540e\uff0c\u6628\u65e5\uff0c\u6b66\u6c49\u7535\u4fe1\u900f\u9732\uff0c\u5c06\u6295\u516510\u4ebf\u5143\u6539\u9020\u3001\u5347\u7ea7CDMA\u7f51\u7edc\uff0c\u540c\u65f6\u63a8\u51fa\u6709\u201c\u4e92\u8054\u7f51\u624b\u673a\u201d\u4e4b\u79f0\u7684\u201c\u5929\u7ffc\u201d189\u53f7\u6bb5\u3002\u5c4a\u65f6\u5e02\u6c11\u5c06\u53ef\u4ee5\u7528\u624b\u673a\u8fc5\u901f\u4e0b\u8f7d\u7535\u5f71\u4e86\u3002\u3000</P>\r\n<P>\u3000\u3000C\u7f51\u7528\u6237\u6709\u671b10\u5206\u949f\u4e0b\u8f7d\u4e00\u90e8\u5f71\u7247\u3000</P>\r\n<P>\u3000\u3000\u201c\u6211\u4eec\u5c06\u629510\u4ebf\u5143\u6539\u9020\u6b66\u6c49\u7684CDMA\u7f51\u7edc\u3002\u201d\u6628\u65e5\uff0c\u6b66\u6c49\u7535\u4fe1\u65b9\u9762\u8868\u793a\uff0c\u6b66\u6c49\u4f5c\u4e3a\u4e2d\u56fd\u7535\u4fe1C\u7f51\u5347\u7ea7\u6539\u9020\u4e2d\u5168\u56fd\u9996\u627934\u4e2a\u8bd5\u70b9\u57ce\u5e02\u4e4b\u4e00\uff0c\u5728\u4e2d\u56fd\u7535\u4fe1\u6295\u5165800\u4ebf\u8fdb\u884cC\u7f51\u6539\u9020\u5347\u7ea7\u5916\uff0c\u6b66\u6c49\u7535\u4fe1\u5c06\u53e6\u629510\u4ebf\u5143\u5bf9CDMA\u7f51\u7edc\u8fdb\u884c\u4f18\u5316\u5347\u7ea7\u3002\u3000<BR>\u3000\u3000\u636e\u4ecb\u7ecd\uff0c\u76ee\u524dCDMA\u6269\u5bb9\u5347\u7ea7\u5de5\u7a0b\u5df2\u9010\u6b65\u5c55\u5f00\u3002\u968f\u7740\u65b0\u589e\u548c\u6269\u5bb9\u8bbe\u5907\u7684\u9010\u6b65\u5b89\u88c5\u5230\u4f4d\uff0c\u6b64\u524d\u90e8\u5206\u6237\u5916\u548c\u5ba4\u5185\u7684\u4fe1\u53f7\u76f2\u70b9\u5c06\u6269\u5927\u4fe1\u53f7\u7684\u6574\u4f53\u8986\u76d6\u7387\uff0c\u8fdb\u4e00\u6b65\u63d0\u9ad8\u63a5\u901a\u7387\uff0c\u964d\u4f4e\u6389\u8bdd\u7387\u3002\u3000<BR>\u3000\u3000\u636e\u900f\u9732\uff0c\u5347\u7ea7\u540e\u7684C\u7f51\u65e0\u7ebf\u79fb\u52a8\u5bbd\u5e26\u5c06\u6bd4\u539f\u6765\u63d0\u9ad8\u8fd120\u500d\u7684\u5e26\u5bbd\uff0c\u76f4\u63a5\u4ece100\u591aKB\u5347\u7ea7\u52303M\uff0c\u4e0e\u73b0\u5728\u6b66\u6c49\u7535\u4fe1\u63a8\u51fa\u7684ADSL\u6709\u5f97\u4e00\u6bd4\u3002\u3000<BR>\u3000\u3000\u5c06\u73b0\u6709CDMA2.5G\u7684\u7f51\u7edc\u76f4\u63a5\u5347\u7ea7\u4e3a3G\u54114G\u8fc7\u6e21\u7684\u7f51\u7edc\u540e\uff0cCDMA\u7528\u6237\u901a\u8fc7\u624b\u673a\u4e0b\u8f7d\u4e00\u90e8700\u5146\u5de6\u53f3\u7684DVD\u5f71\u7247\uff0c\u6216\u8bb8\u5c31\u4e0d\u7528\u518d\u82b1\u4e0a\u51e0\u4e2a\u5c0f\u65f6\uff0c\u800c\u53ea\u898110\u5206\u949f\u5c31\u53ef\u4ee5\u4e86\u3002\u3000<BR>\u3000\u3000\u201c\u6b66\u6c49\u7535\u4fe1\u5c06\u572811\u670820\u65e5\u5de6\u53f3\uff0c\u5b8c\u62101000\u591a\u4e2a\u57fa\u7ad9\u7684\u5efa\u8bbe\u548c\u8fd1400\u4e2a\u539fC\u7f51\u8bbe\u5907\u7684\u5347\u7ea7\u3002\u201d\u636e\u6b66\u6c49\u7535\u4fe1\u76f8\u5173\u8d1f\u8d23\u4eba\u900f\u9732\uff0c\u6b66\u6c49\u7535\u4fe1\u5bf9C\u7f51\u7684\u6539\u9020\u5347\u7ea7\u65e9\u5728\u4eca\u5e749\u6708\u4efd\u5c31\u5f00\u59cb\u4e86\uff0c\u9884\u8ba1\u5728\u5e74\u5e95\u524d\uff0c\u5b9e\u73b0C\u7f51\u7684\u5168\u9762\u5347\u7ea7\u6539\u9020\u5de5\u4f5c\u3002\u3000</P>\r\n<P>\u3000\u3000189\u53f7\u6bb5\u662f\u51c63G\u3000</P>\r\n<P>\u3000\u3000\u5b8c\u6210C\u7f51\u7684\u5168\u9762\u6539\u9020\u540e\uff0c\u6b66\u6c49\u7535\u4fe1\u5c06\u63a8\u51fa\u201c\u5929\u7ffc\u201d189\u53f7\u6bb5\uff0c\u6253\u9020\u65b0\u4e00\u4ee3\u4e92\u8054\u7f51\u79fb\u52a8\u901a\u4fe1\u7684\u201c\u4e92\u8054\u7f51\u624b\u673a\u201d\u3002\u65b0\u63a8\u51fa\u7684\u201c\u4e92\u8054\u7f51\u624b\u673a\u201d\u5177\u5907\u54ea\u4e9b\u529f\u80fd\uff1f\u4e0e\u6211\u4eec\u73b0\u5728\u4f7f\u7528\u7684\u624b\u673a\u53c8\u6709\u4f55\u4e0d\u540c\uff1f\u3000<BR>\u3000\u3000\u6628\u65e5\uff0c\u6b66\u6c49\u7535\u4fe1\u76f8\u5173\u4eba\u58eb\u900f\u9732\uff0c\u201c\u4e92\u8054\u7f51\u624b\u673a\u201d\u5c31\u662f\u5c06\u8bed\u97f3\u901a\u8bdd\u3001\u638c\u4e0a\u7535\u8111\u548c\u529e\u516c\u5de5\u5177\u4e09\u8005\u5408\u4e00\uff0c\u76f8\u5f53\u4e8e\u63a5\u5165\u9ad8\u901f\u79fb\u52a8\u5bbd\u5e26\u7684\u638c\u4e0a\u7535\u8111\uff0c\u53d1\u6325\u79fb\u52a8\u4e92\u8054\u7f51\u7684\u6574\u5408\u4f18\u52bf\uff0c\u4fdd\u6301\u968f\u65f6\u968f\u5730\u7684\u9ad8\u901f\u63a5\u5165\uff0c\u786e\u4fdd\u901a\u8fc7\u624b\u673a\uff0c\u968f\u65f6\u968f\u5730\u4eab\u53d7\u9ad8\u901f\u7684\u7f51\u4e0a\u51b2\u6d6a\u3002\u3000<BR>\u3000\u3000\u636e\u4ecb\u7ecd\uff0c\u201c\u5929\u7ffc\u201d\u5c06\u878d\u5408\u79fb\u52a8\u4e0e\u56fa\u7f51\u7684\u76f8\u5173\u529f\u80fd\uff0c\u4e3a\u7528\u6237\u63d0\u4f9b\u771f\u6b63\u610f\u4e49\u4e0a\u7684\u4e92\u8054\u7f51\u624b\u673a\u670d\u52a1\u3002\u3000<BR>\u3000\u3000\u636e\u4e86\u89e3\uff0c\u7535\u4fe1\u62df\u5728\u5e74\u5185\u63a8\u51fa\u7684189\u53f7\u6bb5\uff0c\u5df2\u7ecf\u83b7\u5f97\u6709\u5173\u65b9\u9762\u7684\u6279\u51c6\u3002\u77e5\u60c5\u4eba\u58eb\u900f\u9732\uff0c189\u53f7\u6bb5\u5728\u5e26\u5bbd\u548c\u6570\u636e\u4e1a\u52a1\u3001\u589e\u503c\u4e1a\u52a1\u4e0a\u7684\u529f\u80fd\u4f1a\u66f4\u52a0\u5f3a\u5927\uff0c\u66f4\u63a5\u8fd13G\u3002</P>\r\n<P>&nbsp;</P>", "imagename": null, "infoid": 101220, "category": "technology_internet", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u4e92\u8054\u7f51", "\u624b\u673a", "cdma", "\u7535\u4fe1"]}, {"url": null, "title": "\u5f53\u5f53\u7f51\u529b\u4e3e\u4f4e\u4ef7\u5927\u65d7\u542f\u52a8\u5168\u573a\u514d\u8fd0\u8d39\u98ce", "tags": "\u5f53\u5f53\u7f51 \u7f51\u4e0a\u5546\u57ce ", "name": "yinyin", "posttime": "2008-11-05 10:02:10", "ip": "222.128.48.207", "mark": 1, "note": "<P>10\u670822\u65e5\uff0c\u5728\u65b0\u6539\u7248\u7684\u9996\u9875\u4e0a\u7ebf\u4e00\u5468\u540e\uff0c\u5168\u7403\u6700\u5927\u7684\u4e2d\u6587\u7f51\u4e0a\u5546\u57ce\u5f53\u5f53\u7f51\u5ba3\u5e03\u63a8\u51fa\u5168\u573a\u514d\u8fd0\u8d39\u6d3b\u52a8\u3002\u5f53\u5f53\u7f51\u7528\u6237\u51e1\u9009\u62e9\u666e\u901a\u5feb\u9012\u9001\u8d27\u4e0a\u95e8\u53ca\u666e\u901a\u90ae\u9012\u7684\uff0c\u4e0d\u8bba\u91d1\u989d\u5927\u5c0f\uff0c\u5747\u53ef\u4eab\u6709\u8fd0\u8d39\u5168\u514d\u4f18\u60e0\u3002\u5de7\u5408\u7684\u662f\uff0c\u5c31\u5728\u5f53\u5f53\u7f51\u542f\u52a8\u5168\u573a\u514d\u8fd0\u8d39\u7b56\u7565\u7684\u5f53\u5929\uff0c\u56fd\u5185\u53e6\u4e00\u5bb6\u7535\u5b50\u5546\u52a1\u7f51\u7ad9\u5353\u8d8a\u4e9a\u9a6c\u900a\u5374\u4e0a\u8c03\u4e86\u8fd0\u8d39\u4ef7\u683c\uff0c\u5c06\u539f\u5148\u7684\u5168\u573a\u514d\u8fd0\u8d39\u6539\u4e3a\u6ee130\u5143\u514d\u8fd0\u8d39\u3002</P>\r\n<P>\u5f53\u5f53\u7f51\u8054\u5408\u603b\u88c1\u674e\u56fd\u5e86\u8868\u793a\uff0c\u6b63\u54c1\u4f4e\u4ef7\u7b56\u7565\u4e00\u5411\u662f\u5f53\u5f53\u7f51\u81f4\u80dc\u7684\u91cd\u8981\u6cd5\u5b9d\u4e4b\u4e00\uff0c\u6b64\u6b21\u63a8\u51fa\u5168\u573a\u514d\u8fd0\u8d39\u4e3e\u63aa\uff0c\u65e8\u5728\u8fdb\u4e00\u6b65\u964d\u4f4e\u7f51\u8d2d\u95e8\u69db\uff0c\u63d0\u5347\u7528\u6237\u8d2d\u7269\u4f53\u9a8c\uff0c\u7ee7\u7eed\u4ee5\u4f4e\u4ef7\u5438\u5f15\u66f4\u591a\u7f51\u6c11\u9009\u62e9\u6765\u5f53\u5f53\u7f51\u8d2d\u7269\uff0c\u4f53\u9a8c\u7f51\u7edc\u8d2d\u7269\u7684\u4fbf\u6377\u548c\u5b9e\u60e0\u3002</P>\r\n<P>\u8bb0\u8005\u4e86\u89e3\u5230\uff0c\u5305\u62ec\u7545\u9500\u4e66\u5728\u5185\u7684\u8bb8\u591a\u5546\u54c1\uff0c\u5f53\u5f53\u7f51\u4e0a\u7684\u552e\u4ef7\u5747\u6bd4\u5176\u4ed6\u6e20\u9053\u4f4e\u51fa\u5f88\u591a\u3002\u4ee5\u90ed\u656c\u660e\u7684\u65b0\u4f5c\u300a\u5c0f\u65f6\u4ee3\u300b\u4e3a\u4f8b\uff0c\u76ee\u524d\u5f53\u5f53\u7f51\u4ee555\u6298\u7684\u8d85\u4f4e\u4ef7\u8fdb\u884c\u9500\u552e\uff0c\u800c\u8be5\u4e66\u5728\u5176\u4ed6\u7f51\u8d2d\u5e73\u53f0\u7684\u96f6\u552e\u4ef7\u5747\u572875\u6298\u4ee5\u4e0a\u3002\u7531\u4e8e\u5f53\u5f53\u7f51\u6b64\u4e3e\u6253\u4e71\u4e86\u4f17\u591a\u96f6\u552e\u5546\u7684\u9635\u811a\uff0c\u5bfc\u81f4\u51fa\u7248\u793e\u4e0d\u60dc\u53d1\u52a8\u4f9b\u5e94\u5546\u4ee5\u65ad\u8d27\u76f8\u5a01\u80c1\u3002\u751a\u81f3\u6709\u4e2a\u522b\u96f6\u552e\u5546\u5728\u5f53\u5f53\u7f51\u4e0a\u62a2\u8d2d\u300a\u5c0f\u65f6\u4ee3\u300b\u5e76\u8f6c\u624b\u5230\u5176\u4ed6\u6e20\u9053\u9500\u552e\uff0c\u4ee5\u7ef4\u630175\u6298\u5e02\u573a\u4ef7\u3002\u8fd9\u8db3\u4ee5\u663e\u793a\u5f53\u5f53\u7f51\u4ef7\u683c\u5bf9\u5e02\u573a\u7684\u5f71\u54cd\u529b\u3002</P>\r\n<P>\u636e\u4e86\u89e3\uff0c\u63a8\u51fa\u5168\u573a\u514d\u8fd0\u8d39\u662f\u5728\u7ecf\u8fc7\u4e00\u7cfb\u5217\u7cbe\u5fc3\u51c6\u5907\u4e0b\u505a\u51fa\u7684\u91cd\u5927\u51b3\u7b56\uff0c\u514d\u8fd0\u8d39\u7684\u540c\u65f6\uff0c\u5f53\u5f53\u7f51\u8fd8\u8fdb\u4e00\u6b65\u63d0\u9ad8\u4e86\u9001\u8d27\u670d\u52a1\u3002\u5728\u6b64\u4e4b\u524d\uff0c\u5f53\u5f53\u7f51\u5df2\u7ecf\u5728\u5317\u4eac\u3001\u4e0a\u6d77\u3001\u5e7f\u5dde\u3001\u6df1\u5733\u56db\u4e2a\u91cd\u70b9\u57ce\u5e02\u542f\u52a8\u7269\u6d41\u63d0\u901f\u8ba1\u5212\uff0c\u540c\u65f6\u8fd8\u5c06\u7269\u6d41\u914d\u9001\u7f51\u7edc\u5411\u5168\u56fd\u4e8c\u3001\u4e09\u7ea7\u57ce\u5e02\u8986\u76d6\u3002\u800c\u6b64\u6b21\u63a8\u51fa\u5168\u573a\u514d\u8fd0\u8d39\u653f\u7b56\uff0c\u4e5f\u6b63\u662f\u5728\u5f53\u5f53\u7f51\u4e5d\u5468\u5e74\u5e97\u5e86\u4e4b\u524d\uff0c\u4e3a\u5f53\u5f53\u7f51\u63d0\u9ad8\u987e\u5ba2\u4f53\u9a8c\u589e\u52a0\u4e86\u53c8\u4e00\u4e2a\u91cd\u8981\u781d\u7801\u3002</P>\r\n<P>\u4e1a\u5185\u4eba\u58eb\u8ba4\u4e3a\uff0c\u5c3d\u7ba1\u53d7\u7f8e\u56fd\u91d1\u878d\u5371\u673a\u7684\u5f71\u54cd\uff0c\u5f53\u524d\u5168\u7403\u7ecf\u6d4e\u6b63\u9762\u4e34\u65b0\u4e00\u8f6e\u8870\u9000\u7684\u5371\u673a\uff0c\u5bfc\u81f4\u4ee5\u5916\u8d38\u4e3a\u5bfc\u5411\u7684\u4f01\u4e1a\u95f4\u7535\u5b50\u5546\u52a1\u9677\u5165\u4f4e\u8c37\uff0c\u4f46\u56fd\u5185\u6d88\u8d39\u5e02\u573a\u5219\u4f9d\u7136\u6709\u5de8\u5927\u4e0a\u5347\u7a7a\u95f4\uff0c\u4ee5\u5f53\u5f53\u7f51\u4e3a\u4ee3\u8868\u7684B2C\u7535\u5b50\u5546\u52a1\u7f51\u7ad9\u5c06\u7ee7\u7eed\u4fdd\u6301\u5f3a\u52b2\u589e\u957f\u52bf\u5934\u3002&nbsp;&nbsp;</P>\r\n<P>\u91d1\u7f8a\u7f51-\u65b0\u5feb\u62a5</P>", "imagename": null, "infoid": 101219, "category": "technology_internet", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u5f53\u5f53\u7f51", "\u7f51\u4e0a\u5546\u57ce"]}, {"url": null, "title": "\u5546\u4e1a\u5468\u520a\uff1a\u8c37\u6b4c\u96c5\u864e\u4ee5\u9000\u4e3a\u8fdb \u4fee\u6539\u641c\u7d22\u5e7f\u544a\u4ea4\u6613", "tags": "\u8c37\u6b4c \u96c5\u864e \u641c\u7d22 \u5e7f\u544a ", "name": "yinyin", "posttime": "2008-11-05 10:01:28", "ip": "222.128.48.207", "mark": 1, "note": "<P>\u636e\u534e\u5c14\u8857\u77e5\u60c5\u8005\u79f0\uff0c\u4e3a\u4e86\u83b7\u5f97\u7f8e\u56fd\u53f8\u6cd5\u90e8\u7684\u901a\u8fc7\uff0c\u8c37\u6b4c\u548c\u96c5\u864e\u5df2\u5728\u641c\u7d22\u5e7f\u544a\u534f\u8bae\u4e2d\u505a\u51fa\u4e86\u91cd\u5927\u8ba9\u6b65\u3002\u6d88\u606f\u79f0\uff0c\u53cc\u65b9\u5c06\u5408\u4f5c\u534f\u8bae\u7531\u539f\u6765\u768410\u5e74\u65f6\u95f4\u7f29\u77ed\u4e3a2\u5e74\u65f6\u95f4\uff0c\u8c37\u6b4c\u53ef\u83b7\u5f97\u96c5\u864e\u641c\u7d22\u5e7f\u544a\u6536\u5165\u768425%.\u540c\u65f6\uff0c\u8c37\u6b4c\u5e7f\u544a\u5546\u8fd8\u53ef\u4ee5\u505a\u51fa\u9009\u62e9\uff0c\u4e0d\u4e00\u5b9a\u8981\u5728\u96c5\u864e\u7f51\u7ad9\u6295\u653e\u5e7f\u544a\u3002</P>\r\n<P>\u3000\u3000\u76ee\u524d\uff0c\u5c1a\u4e0d\u6e05\u695a\u53cc\u65b9\u505a\u51fa\u8c03\u6574\u6709\u591a\u5927\u3002\u6709\u4e00\u70b9\uff0c\u96c5\u864e\u66fe\u7ecf\u8868\u793a\uff0c\u4e0e\u8c37\u6b4c\u8fbe\u6210\u534f\u8bae\u6709\u4e9b\u665a\uff0c\u5728\u505a\u51fa\u662f\u5426\u6295\u5165\u8c37\u6b4c\u5e7f\u544a\u7684\u51b3\u5b9a\u4e4b\u524d\u8981\u770b\u534f\u8bae\u5982\u4f55\u8fdb\u884c\u3002\u7b2c\u4e09\u5b63\u5ea6\uff0c\u96c5\u864e\u7684\u641c\u7d22\u5e7f\u544a\u641c\u7d22\u4e3a4.38\u4ebf\u7f8e\u5143\uff0c\u56e0\u6b64\uff0c\u6309\u5e74\u8ba1\u5212\uff0c25%\u7684\u6536\u5165\u4e0d\u662f\u4e00\u4e2a\u5c0f\u6570\u76ee\uff0c\u4e0d\u662f8\u4ebf\u7f8e\u5143\u7684\u6536\u5165\u6f02\u8d70\u4e86\uff0c\u800c\u662f\u7ea6\u4e00\u534a\u7684\u6536\u5165\u3002\u56e0\u6b64\uff0c\u8fd9\u662f\u4e00\u4e2a\u91cd\u5927\u7684\u8c03\u6574\uff0c\u4e5f\u662f\u4e00\u7b14\u91cd\u8981\u7684\u6536\u5165\u3002\u5728\u4e92\u8054\u7f51\u65f6\u4ee3\uff0c10\u5e74\u7684\u5408\u4f5c\u534f\u8bae\u610f\u5473\u7740\u6709\u53ef\u80fd\u53d1\u751f\u4efb\u4f55\u60c5\u51b5\u3002</P>\r\n<P>\u3000\u3000\u4f46\u662f\uff0c\u73b0\u5728\u6700\u5927\u7684\u95ee\u9898\u662f\uff0c\u53f8\u6cd5\u90e8\u53cd\u6258\u62c9\u65af\u90e8\u95e8\u662f\u5426\u4f1a\u611f\u5230\u6ee1\u610f\uff0c\u6216\u662f\u9274\u4e8e\u8c37\u6b4c\u65e5\u76ca\u589e\u5f3a\u7684\u5b9e\u529b\uff0c\u8981\u6c42\u505a\u51fa\u8fdb\u4e00\u6b65\u8ba9\u6b65\u6216\u662f\u5b8c\u5168\u963b\u6b62\u8fd9\u8d77\u4ea4\u6613\u3002\u76ee\u524d\u6765\u770b\uff0c\u53cc\u65b9\u6ca1\u6709\u8fbe\u6210\u4e00\u81f4\u7684\u8ff9\u8c61\u3002\u5f88\u663e\u7136\uff0c\u8c37\u6b4c\u548c\u96c5\u864e\u6025\u4e8e\u60f3\u8fbe\u6210\u534f\u8bae\u3002\u636e\u53cd\u6258\u62c9\u65af\u4e13\u5bb6\u79f0\uff0c\u53cd\u6258\u62c9\u65af\u6cd5\u6848\u5728\u591a\u5927\u7a0b\u5ea6\u4e0a\u9002\u7528\u4e8e\u8fd9\u8d77\u4ea4\u6613\u5c1a\u4e0d\u5f97\u800c\u77e5\uff0c\u56e0\u4e3a\u8fd9\u4e0d\u662f\u4e00\u8d77\u5408\u5e76\uff0c\u96c5\u864e\u4ecd\u7136\u63a7\u5236\u5728\u4f55\u65f6\u3001\u5728\u4f55\u5730\u4ee5\u4ec0\u4e48\u65b9\u5f0f\u6295\u653e\u8c37\u6b4c\u5e7f\u544a\u3002\u56e0\u6b64\uff0c\u8fd9\u4e9b\u4e13\u5bb6\u8ba4\u4e3a\uff0c\u53f8\u6cd5\u90e8\u8981\u8d62\u5f97\u8d77\u8bc9\u53ef\u80fd\u4f1a\u6709\u5f88\u5927\u7684\u56f0\u96be\u3002</P>\r\n<P>\u3000\u3000\u5982\u679c\u53f8\u6cd5\u90e8\u7ee7\u7eed\u5e72\u6d89\uff0c\u90a3\u4e48\u5bf9\u4e8e\u8c37\u6b4c\u6765\u8bf4\uff0c\u8fd9\u7b14\u4ea4\u6613\u5c31\u6ca1\u6709\u592a\u5927\u7684\u610f\u4e49\u4e86\uff0c\u56e0\u4e3a\u5b83\u4e0d\u60f3\u8ba9\u653f\u5e9c\u90e8\u95e8\u8fc7\u591a\u5e72\u6d89\u81ea\u5df1\u7684\u4e1a\u52a1\u3002\u5982\u679c\u96c5\u864e\u4ece\u8fd9\u8d77\u4ea4\u6613\u83b7\u5f97\u7684\u6536\u5165\u6709\u9650\uff0c\u96c5\u864e\u4e5f\u4f1a\u8ba4\u4e3a\u6ca1\u6709\u4ec0\u4e48\u5438\u5f15\u529b\uff0c\u5c3d\u7ba1\u4e8b\u5b9e\u662f\uff0c\u8fd9\u8d77\u4ea4\u6613\u5bf9\u4e8e\u96c5\u864e\u6765\u8bf4\uff0c\u6709\u6bd4\u6ca1\u6709\u8981\u597d\u3002</P>\r\n<P>\u3000\u3000\u8c37\u6b4c\u548c\u96c5\u864e\u4e5f\u6709\u53ef\u80fd\u7ee7\u7eed\u524d\u8fdb\uff0c\u4e0e\u53f8\u6cd5\u90e8\u8fdb\u884c\u66f4\u6df1\u5c42\u63a5\u89e6\u3002\u636e\u77e5\u60c5\u8005\u79f0\uff0c\u5982\u679c\u4e0e\u53f8\u6cd5\u90e8\u7684\u534f\u5546\u8fdb\u5c55\u987a\u5229\uff0c\u8c37\u6b4c\u6216\u662f\u96c5\u864e\u5c06\u900f\u9732\u6709\u5173\u4fe1\u606f\u3002\u663e\u7136\uff0c\u8fd9\u4e5f\u662f\u53f8\u6cd5\u90e8\u770b\u5230\u7684\u9009\u62e9\u3002\u77e5\u60c5\u8005\u79f0\uff0c\u53f8\u6cd5\u90e8\u8981\u6c42\u83b7\u5f97\u53ef\u80fd\u7684\u8bc1\u636e\uff0c\u8bc1\u660e\u4ed6\u4eec\u4f1a\u505a\u51fa\u4f55\u79cd\u8ba9\u6b65\u3002\u5e95\u7ebf\u662f\uff1a\u5982\u679c\u8c37\u6b4c\u96c5\u864e\u4e0e\u53f8\u6cd5\u90e8\u7684\u534f\u5546\u53d6\u5f97\u6210\u679c\uff0c\u5728\u53cc\u65b9\u5ba3\u4f20\u6d88\u606f\u524d\u4e0d\u4f1a\u542c\u5230\u592a\u591a\u7684\u65b0\u95fb\u3002</P>\r\n<P>\u3000\u3000\u8c37\u6b4c\u548c\u96c5\u864e\u663e\u793a\uff0c\u4ed6\u4eec\u6709\u610f\u505a\u51fa\u8ba9\u6b65\uff0c\u4ee5\u6b64\u6765\u5411\u53f8\u6cd5\u90e8\u65bd\u538b\u3002\u6216\u8005\u4ed6\u4eec\u5728\u5411\u62c5\u5fc3\u7684\u5e7f\u544a\u5546\u53d1\u51fa\u4fe1\u53f7\uff0c\u8868\u793a\u4ed6\u4eec\u5e0c\u671b\u8fbe\u6210\u534f\u8bae\u3002\u6216\u8005\u8c37\u6b4c\u5e0c\u671b\u5728\u7f8e\u56fd\u603b\u7edf\u5927\u9009\u4e4b\u524d\u6682\u505c\u534f\u5546\uff0c\u56e0\u4e3a\u5c4a\u65f6\u4f1a\u6709\u65b0\u7684\u5b98\u5458\u51fa\u4efb\u53f8\u6cd5\u90e8\u957f\u3002\u65bd\u5bc6\u7279\u662f\u5965\u5df4\u9a6c\u7684\u652f\u6301\u8005\uff0c\u5c3d\u7ba1\u76ee\u524d\u5c1a\u4e0d\u77e5\u5965\u5df4\u9a6c\u4e0a\u53f0\u540e\u662f\u5426\u4f1a\u6bd4\u5e03\u4ec0\u653f\u5e9c\u91c7\u53d6\u66f4\u4e3a\u4e25\u5389\u7684\u53cd\u6258\u62c9\u65af\u653f\u7b56\u3002</P>\r\n<P>\u3000\u3000\u968f\u7740\u65f6\u95f4\u7684\u63a8\u79fb\uff0c\u8fd9\u8d77\u4ea4\u6613\u83b7\u5f97\u901a\u8fc7\u6027\u7684\u53ef\u80fd\u6027\u4e5f\u5728\u51cf\u5c0f\u3002<BR></P>\r\n<P>\u827e\u745e\u7f51</P>", "imagename": null, "infoid": 101218, "category": "technology_google", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u8c37\u6b4c", "\u96c5\u864e", "\u641c\u7d22", "\u5e7f\u544a"]}, {"url": null, "title": "\u8c37\u6c76\u9534\uff1a\u4e92\u8054\u7f51\u5c06\u8fdb\u5165\u540e\u535a\u5ba2\u65f6\u4ee3", "tags": "\u4e92\u8054\u7f51 \u535a\u5ba2 ", "name": "yinyin", "posttime": "2008-11-05 09:50:26", "ip": "222.128.48.207", "mark": 1, "note": "<P>2006\u5e747\u6708\uff0c\u654f\u601d\u535a\u5ba2\u53d1\u51fa\u7684\u201c\u5173\u95e8\u516c\u544a\u201d\u6572\u54cd\u4e86BSP\u4eec\u751f\u5b58\u7684\u8b66\u949f\uff0c2007\u5e7408\u6708\u535a\u6613\u56e0\u67d0\u4e9b\u4e2a\u4eba\u535a\u5ba2\u6709\u8fdd\u89c4\u5185\u5bb9\uff0c\u88ab\u4e0a\u7ea7\u90e8\u95e8\u5173\u95ed\u3002\u4eca\u5e747\u6708\u9ea6\u7530\u5728\u5176\u535a\u5ba2\u4e0a\u79f0\u201c\u535a\u5ba2\u5df2\u7ecf\u8fc7\u65f6\u4e86\u3002\u201d\u5c31\u5728\u8fd1\u671f\uff0c\u8fde\u201c\u4e2d\u56fd\u535a\u5ba2\u4e4b\u7236\u201d\u7684\u65b9\u5174\u4e1c\uff0c\u4e5f\u4f20\u51fa\u4e86\u516c\u53f8\u7834\u4ea7\u7684\u6d88\u606f\u3002</P>\r\n<P>\u3000\u3000SNS\u7684\u51fa\u73b0\u6539\u53d8\u4e86\u5f88\u591a\u7f51\u6c11\u7684\u4e0a\u7f51\u4e60\u60ef\uff0c\u5982\u540c\u535a\u5ba2\u521a\u521a\u8bde\u751f\u4e4b\u9645\u4e00\u822c\uff0c\u4eba\u4eec\u603b\u662f\u4f1a\u5bf9\u65b0\u751f\u4e8b\u7269\u611f\u5230\u597d\u5947\u548c\u65b0\u9c9c\u3002\u5f53\u5927\u5bb6\u53d1\u73b0\u5728SNS\u53d1\u5e03\u4e00\u7bc7\u65e5\u5fd7\u4f1a\u6bd4\u66f4\u5bb9\u6613\u4f53\u73b0\u51fa\u4ef7\u503c\u4e0e\u4f20\u64ad\uff0c\u65e0\u7591\u5bf9\u4e8e\u7ecf\u8425\u51e0\u5e74\u7684BSP\u4eec\uff0c\u662f\u4e2a\u76f8\u5f53\u7684\u751f\u5b58\u538b\u529b\u3002\u7136\u800c\u5728\u4e92\u8054\u7f51\u7684\u5708\u5b50\u4e2d\uff0c\u5927\u5bb6\u7684\u8111\u888b\u91cc\u6c38\u8fdc\u88c5\u7684\u662f\u201c\u5546\u4e1a\u6a21\u5f0f\u201d\uff0c\u6bcf\u6bcf\u4e00\u4e2a\u65b0\u7684\u9886\u57df\u548c\u884c\u4e1a\u8fd8\u6ca1\u6709\u6210\u719f\uff0c\u5173\u4e8e\u5b83\u7684\u5546\u4e1a\u4ef7\u503c\u548c\u8fd0\u8425\u6a21\u5f0f\u90fd\u5df2\u7ecf\u5927\u8c08\u7279\u8c08\u4e86\u3002</P>\r\n<P>\u535a\u5ba2\u7684\u8870\u843d\u5f88\u5927\u7a0b\u5ea6\u4e0a\u662f\u7531\u4e8e\u5b83\u8fc7\u4e8e\u660e\u663e\u7684\u529f\u5229\u548c\u5546\u4e1a\u5316\uff0c\u8fdd\u80cc\u4e86\u6700\u65e9\u4e00\u6279\u535a\u5ba2\u4eba\u53ea\u662f\u541f\u7269\u8a00\u5fd7\u6292\u60c5\u7684\u539f\u751f\u6001\u6587\u5316\u3002BSP\u4eec\u8981\u8003\u8651\u76c8\u5229\uff0c\u540d\u4eba\u535a\u5ba2\u3001\u7cbe\u82f1\u535a\u5ba2\u5e94\u8fd0\u800c\u751f\uff0c\u901a\u8fc7\u773c\u7403\u3001\u540d\u4eba\u6548\u5e94\u8d5a\u8db3\u4e86\u6d41\u91cf\u548c\u94b1\u3002\u800c\u901a\u8fc7\u8fd9\u6837\u7684\u5e73\u53f0\uff0c\u8ba9\u66f4\u591a\u7684\u5199\u624b\u540d\u58f0\u5927\u566a\uff0c\u7136\u800c\u4ed6\u4eec\u5e76\u6ca1\u6709\u901a\u8fc7BSP\u62ff\u5230\u4ec0\u4e48\u5206\u6210\uff0c\u8fd9\u4e2a\u65f6\u5019\u7684\u535a\u5ba2\u5df2\u7ecf\u662f\u8fdb\u5165\u4e86\u8f6f\u6587\u67aa\u7a3f\u6a2a\u884c\u7684\u65f6\u4ee3\uff0c\u8349\u6839\u7684\u58f0\u97f3\u5f7b\u5e95\u88ab\u57cb\u6ca1\u3002\u5f53\u535a\u5ba2\u4eec\u90fd\u7ed9\u81ea\u5df1\u5e26\u4e0a\u201c\u81ea\u5a92\u4f53\u201d\u7684\u5e3d\u5b50\u65f6\uff0c\u8f6c\u773c\u95f4BSP\u4eec\u5c31\u6210\u4e3a\u4e86\u5927\u5bb6\u6253\u53e3\u6c34\u4ed7\u7684\u821e\u53f0\u3002</P>\r\n<P>\u3000\u3000\u88ab\u201c\u6f5c\u89c4\u5219\u201d\u5316\u7684\u5e73\u53f0\u5df2\u7ecf\u53ea\u662f\u5c11\u6570\u4eba\u7684\u5e73\u53f0\uff0c\u5f53\u65e0\u6cd5\u627f\u8f7d\u4f17\u591a\u7f51\u6c11\u7684\u9700\u6c42\u4e4b\u65f6\uff0c\u4e5f\u662f\u5176\u6ca1\u843d\u7684\u65f6\u5019\u3002\u4e2d\u56fd\u8fd13\u4ebf\u7684\u7f51\u6c11\u4e0d\u53ef\u80fd\u6bcf\u4e2a\u4eba\u90fd\u80fd\u50cf\u4e2a\u4eba\u7ad9\u957f\u4e00\u6837\u8d2d\u4e70\u4e00\u4e2a\u7a7a\u95f4\u57df\u540d\u53bb\u4e0a\u4f20\u4e00\u4e2awordpress\u6216\u8005oblog\uff0c\u9762\u4e34\u5df2\u7ecf\u8981\u5230\u6765\u7684\u540e\u535a\u5ba2\u65f6\u4ee3\uff0c\u5927\u5bb6\u66f4\u591a\u7684\u773c\u5149\u9009\u62e9\u4e86\u65f6\u4e0b\u70ed\u95e8\u7684SNS\u3002</P>\r\n<P>\u3000\u3000\u4eba\u4eec\u5e38\u8bf4\uff0c\u4e00\u4e2a\u65f6\u4ee3\u7684\u7ed3\u675f\uff0c\u5f80\u5f80\u662f\u53e6\u4e00\u4e2a\u65f6\u4ee3\u7684\u5f00\u59cb\u3002\u968f\u7740WEB\u5e94\u7528\u7684\u4e0d\u65ad\u53d1\u5c55\uff0c\u5728\u5c06\u6765\u7684\u67d0\u4e00\u5929\uff0c\u5927\u5bb6\u4f1a\u611f\u6168\u66fe\u7ecf\u8bb0\u5f55\u8fc7\u81ea\u5df1\u559c\u6012\u54c0\u4e50\u7684\u535a\u5ba2\u65f6\u4ee3\uff0c\u6b63\u5982\u540c\u73b0\u5728\u53bb\u56de\u60f3\u90a3\u88ab\u5f7b\u5e95\u9057\u5fd8\u7684\u201c\u6c5f\u6e56\u201d\u3002</P>\r\n<P><BR>\u672c\u6587\u6765\u6e90\u4e8e WEB\u5f00\u53d1\u7f51</P>", "imagename": null, "infoid": 101216, "category": "technology_internet", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u4e92\u8054\u7f51", "\u535a\u5ba2"]}, {"url": null, "title": "\u4f01\u4e1a\u5e94\u7528\u7275\u624b\u793e\u4ea4\u7f51\u7ad9 Salesforce\u7ed3\u76dfFacebook", "tags": "Facebook Salesforce \u793e\u4ea4 ", "name": "yinyin", "posttime": "2008-11-05 09:48:29", "ip": "222.128.48.207", "mark": 1, "note": "<P>\u636e\u7f8e\u56fd\u5a92\u4f53\u62a5\u9053\uff0c\u5468\u4e00\uff0c\u7f8e\u56fd\u5728\u7ebf\u8f6f\u4ef6\u670d\u52a1\u5546Salesforce.com\u5ba3\u5e03\uff0c\u548cFacebook\u548c\u4e9a\u9a6c\u900a\u7ed3\u6210\u8054\u76df\uff0c\u63a8\u5e7f\u5176\u5728\u7ebf\u8f6f\u4ef6\u5373\u4e91\u8ba1\u7b97\u670d\u52a1\u3002</P>\r\n<P>Google\u662f\u76ee\u524d\u5168\u7403\u6700\u5927\u7684\u4e2a\u4eba\u5728\u7ebf\u5e94\u7528\u670d\u52a1\u5546\uff0c\u800c\u5728\u4f01\u4e1a\u8f6f\u4ef6\u9886\u57df\uff0cSalesforce.com\u5c5e\u4e8e\u5148\u9a71\u4f01\u4e1a\u3002\u5468\u4e00\uff0c\u5728\u65e7\u91d1\u5c71\u4e3e\u884c\u7684\u5f00\u53d1\u5927\u4f1a\u4e0a\uff0cSalesforce.com\u5ba3\u5e03\u5c06\u8054\u5408Facebook\u548c\u4e9a\u9a6c\u900a\u7f51\u7ad9\u3002</P>\r\n<P>\u3000\u3000\u6309\u7167\u548cFacebook\u7684\u534f\u8bae\uff0cFacebook\u7684\u7528\u6237\u53ef\u4ee5\u5f00\u53d1Salesforce.com\u7f51\u7ad9\u4f7f\u7528\u7684\u7f51\u7edc\u5e94\u7528\uff0c\u8fd9\u4e9b\u5e94\u7528\u540c\u65f6\u53ef\u4ee5\u5728Facebook\u7f51\u7ad9\u4f7f\u7528\u3002Facebook\u9996\u5e2d\u8fd0\u8425\u5b98\u6851\u5fb7\u4f2f\u683c\u8868\u793a\uff0c\u5728\u4f01\u4e1a\u5e94\u7528\u65b9\u9762\uff0cFacebook\u8fd8\u6709\u5f88\u5927\u7684\u53d1\u5c55\u7a7a\u95f4\u3002</P>\r\n<P>\u3000\u3000\u76ee\u524d\uff0cSalesforce.com\u63d0\u4f9b\u4e86\u5927\u91cf\u7684\u4f01\u4e1a\u5728\u7ebf\u5e94\u7528\u670d\u52a1\uff0c\u7528\u6237\u9700\u8981\u7f34\u7eb3\u8ba2\u7528\u8d39\u3002\u800c\u7b2c\u4e09\u65b9\u5f00\u53d1\u4eba\u5458\u53ef\u4ee5\u5f00\u53d1\u5404\u79cd\u5728\u7ebf\u5e94\u7528\uff0c\u5411Salesforce.com\u7684\u4f01\u4e1a\u5ba2\u6237\u8fdb\u884c\u63a8\u5e7f\u3002</P>\r\n<P>\u3000\u3000Salesforce.com\u8fd8\u8868\u793a\uff0c\u5c06\u5141\u8bb8\u5ba2\u6237\u5229\u7528\u4e9a\u9a6c\u900a\u516c\u53f8\u7684\u7f51\u7edc\u670d\u52a1\u5f00\u53d1\u4f01\u4e1a\u5e94\u7528\u3002\u76ee\u524d\uff0c\u4e9a\u9a6c\u900a\u63d0\u4f9b\u4e86\u5728\u7ebf\u5b58\u50a8\u7b49\u4e91\u8ba1\u7b97\u57fa\u7840\u670d\u52a1