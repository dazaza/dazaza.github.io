93e\u533a\u7684\u7535\u5b50\u5546\u52a1\u89e3\u51b3\u65b9\u6848\u7684\u670d\u52a1\u6027\u7ad9\u70b9\uff0c\u6dd8\u91d1\u94fe\uff08LinkMiner\uff09\u662f\u5176\u53d1\u5e03\u7684\u7b2c\u4e00\u4e2a\u4ea7\u54c1\u3002\u5b83\u80fd\u591f\u5c06\u7528\u6237\u7f51\u7ad9\u4e0a\u7684\u666e\u901a\u7684\u7f51\u5e97\u94fe\u63a5\u548c\u5728\u7ebf\u5546\u54c1\u94fe\u63a5\uff08\u6bd4\u5982\u6dd8\u5b9d\u5546\u54c1\u94fe\u63a5\uff09\u8f6c\u6362\u4e3a\u652f\u6301\u4f63\u91d1\u7ed3\u7b97\u7684CPS\u94fe\u63a5\uff08\u6bd4\u5982\u6dd8\u5b9d\u5ba2\u94fe\u63a5\uff09\uff0c\u5728\u4e0d\u5f71\u54cd\u7528\u6237\u4f53\u9a8c\u548c\u4e0d\u5360\u7528\u5e7f\u544a\u4f4d\u7684\u60c5\u51b5\u4e0b\uff0c\u4e3a\u7ad9\u957f\u4eec\u5f00\u8f9f\u51fa\u4e86\u4e00\u5757\u5168\u65b0\u7684\u6536\u5165\u6765\u6e90\u3002 \r\n\u5173\u6ce8\u7a0b\u5ea6\uff1a\u2605\u2605\u2605\u2605\u2605 \u8da3\u5473\u6307\u6570\uff1a\u2605\u2605\u2605\u2606\u2606 \u5546\u4e1a\u60f3\u6cd5\uff1a\u2605\u2605\u2605\u2605\u2605 \u4ea7\u54c1\u5206\u7c7b\uff1a\u7535\u5b50\u5546\u52a1\u3001\u63d2\u4ef6 \r\n\u5feb\u8bc4\uff1a\u5377\u8c46\u7f51\u662f\u4eca\u5e74\u6211\u89c1\u8fc7\u4f17\u591a\u4ea7\u54c1\u4e2d\u6700\u4ee4\u6211\u5174\u594b\u7684\u4e00\u4e2a\u9879\u76ee\uff0c\u5b83\u9769\u547d\u6027\u7684\u540c\u65f6\u6574\u5408\u4e86\u521b\u610f\u3001\u6280\u672f\u4ee5\u53ca\u5546\u4e1a\u3002\u7ed9\u4e2d\u5c0f\u578b\u7ad9\u957f\u5e26\u53bb\u4e86\u65b0\u7684\u673a\u9047\uff0c\u91cd\u8981\u7684\u662f\u4ea7\u54c1\u5bcc\u6709\u60f3\u8c61\u529b\uff01 \r\n\r\nNo.2 \u65e0\u89c5\u7f51 \u662f\u4e00\u5bb6\u63d0\u4f9b\u793e\u4f1a\u5316\u65b0\u95fb\u63a8\u4ecb\u670d\u52a1\u7684\u7ad9\u70b9\uff0c\u4f9d\u6258\u4e8e\u51e0\u5927\u4e3b\u6d41\u8d44\u8baf\u95e8\u6237\u7f51\u7ad9\u7684\u6d77\u91cf\u65b0\u95fb\uff0c\u5229\u7528\u4eba\u5de5\u667a\u80fd\u6280\u672f\uff0c\u6839\u636e\u7528\u6237\u559c\u6b22\u7684\u7f51\u9875\uff0c\u5728\u4f17\u591a\u7684\u7f51\u9875\u4e2d\u4e3b\u52a8\u5411\u8bfb\u8005\u63a8\u9001\u90a3\u4e9b\u6f5c\u5728\u611f\u5174\u8da3\u7684\u65b0\u95fb\u5185\u5bb9\u3002\u53e6\u5916\uff0c\u5728\u6700\u8fd1\u53d1\u5e03\u7684\u7248\u672c\u4e2d\uff0c\u65e0\u89c5\u7f51\u63a8\u51fa\u7684\u76f8\u5173\u6587\u7ae0\u63d2\u4ef6\u80fd\u591f\u7acb\u8db3\u4e8e\u4e91\u7aef\u6280\u672f\uff0c\u5d4c\u4e8eWordpress \u7b49\u72ec\u7acb\u535a\u5ba2\u7cfb\u7edf\u4e3a\u7528\u6237\u63d0\u4f9b\u66f4\u5927\u7cbe\u51c6\u7684\u8bdd\u9898\u5339\u914d\u3002\r\n \u5173\u6ce8\u7a0b\u5ea6\uff1a\u2605\u2605\u2605\u2605\u2605 \u8da3\u5473\u6307\u6570\uff1a\u2605\u2605\u2605\u2606\u2606 \u5546\u4e1a\u60f3\u6cd5\uff1a\u2605\u2605\u2605\u2606\u2606 \u4ea7\u54c1\u5206\u7c7b\uff1a\u63d2\u4ef6\u3001\u793e\u4f1a\u5316\u63a8\u8350\u3001 \r\n\u5feb\u8bc4\uff1a\u65e0\u89c5\u6700\u8fd1\u4e24\u4e2a\u6708\u7684\u66f4\u65b0\u52a8\u4f5c\u6781\u4e3a\u9891\u7e41\uff0c\u7279\u522b\u662f\u5728\u201c\u65e0\u89c5\u7f51\u7edc\u201d\u8bde\u751f\u4ee5\u540e\uff0c\u5176\u4ea7\u54c1\u7684\u7ebf\u8def\u8d8a\u6765\u8d8a\u6e05\u6670\uff0c\u4f5c\u4e3a\u4e00\u4e2a\u6280\u672f\u9a71\u52a8\u7684\u56e2\u961f\uff0c\u65e0\u89c5\u7684\u4ea7\u54c1\u5df2\u7ecf\u80fd\u591f\u8ba9\u4eba\u5728\u95f2\u6687\u4e4b\u4f59\u52fe\u8d77\u65e0\u9650\u7684\u9050\u60f3\u3002\u5728\u6b64\u4e0d\u8d1f\u8d23\u4efb\u7684\u9884\u8a00\uff0c\u65e0\u89c5\u7f51\u4f1a\u5728\u672a\u67654-8\u4e2a\u6708\u65f6\u95f4\u91cc\u5448\u73b0\u4e95\u55b7\u7684\u589e\u957f\u52bf\u5934\uff0c\u4e00\u4e2a\u597d\u7684\u7b97\u6cd5\u80fd\u591f\u8ba9\u65e0\u89c5\u6210\u957f\u6210\u4e3a\u4e2d\u56fd\u7684StumbleUpon\uff0c\u751a\u81f3Google\u4e00\u6837\u66f4\u4f1f\u5927\u7684\u4e92\u8054\u7f51\u516c\u53f8\u3002 \r\n\r\nNo.3 Doit.im \u662f\u4e00\u6b3e\u7b80\u5355\u6613\u7528\u7684GTD\u4efb\u52a1\u7ba1\u7406\u8f6f\u4ef6\uff0c\u76ee\u524d\u4ea7\u54c1\u7ebf\u5f7b\u5e95\u6a2a\u8de8\u5305\u62ec Windows\u3001Web\u3001iPhone\u4ee5\u53caAndroid \u5728\u5185\u7684\u591a\u4e2a\u7cfb\u7edf\u5e73\u53f0\uff0c\u6027\u80fd\u548c\u4ea7\u54c1\u4f53\u9a8c\u5728\u5168\u7403\u8303\u56f4\u5185\u7684\u540c\u7c7b\u4ea7\u54c1\u4e2d\u90fd\u6781\u5177\u7ade\u4e89\u529b\u3002 \r\n\u5173\u6ce8\u7a0b\u5ea6\uff1a\u2605\u2605\u2605\u2605\u2606 \u8da3\u5473\u6307\u6570\uff1a\u2605\u2605\u2606\u2606\u2606 \u5546\u4e1a\u60f3\u6cd5\uff1a\u2605\u2605\u2606\u2606\u2606 \u4ea7\u54c1\u5206\u7c7b\uff1a\u6e38\u620f\u3001\u4e91\u8ba1\u7b97 \u5feb\u8bc4\uff1a\r\n\r\nDoit.im \u53bb\u5e74\u66fe\u7ecf\u4e0a\u699c\u8fc7\u5206\u4eab\u7f51\u7edc2.0 &amp\uff1bamp\uff1bamp\uff1b#8211\uff1b 2009 \u6700\u503c\u5f97\u5173\u6ce8\u768410\u6b3e\u4e2d\u6587\u5c0f\u4f17\u4e92\u8054\u7f51\u4ea7\u54c1\u3002\u4eca\u5e74\u8be5\u56e2\u961f\u5386\u7ecf\u78d0\u6d85\uff0c\u91cd\u7ec4\u540e\u7684\u56e2\u961f\u7ed9\u6211\u4eec\u5e26\u6765\u4e86\u5b8c\u5168\u98a0\u8986\u4ee5\u5f80\u7684\u521b\u65b0\u4f5c\u54c1\uff1b\u56e2\u961f\u4e0d\u5c48\u4e0d\u9976\u7684\u521b\u4e1a\u7cbe\u795e\u503c\u5f97\u53bb\u5609\u5956\u3002\r\n\r\n No.4 \u8857\u65c1 \u662f\u4e00\u4e2a\u57fa\u4e8e\u5730\u7406\u4f4d\u7f6e\u7684\u79fb\u52a8\u793e\u4ea4\u670d\u52a1\u3002\u5b83\u5728\u4f20\u7edf\u7684\u793e\u4ea4\u670d\u52a1\u6240\u62e5\u6709\u7684\u65f6\u95f4\u3001\u4eba\u7269\u3001\u4e8b\u4ef6\u4e4b\u5916\uff0c\u6210\u529f\u5f15\u5165\u4e86\u7b2c\u56db\u4e2a\u7ef4\u5ea6\uff1a\u5730\u70b9\uff0c\u8ba9\u7528\u6237\u7684\u7f51\u7edc\u751f\u6d3b\u548c\u771f\u5b9e\u751f\u6d3b\u66f4\u7d27\u5bc6\u7684\u7ed3\u5408\u3002\u7528\u6237\u53ef\u4ee5\u4f7f\u7528\u8857\u65c1\u7f51\u6765\u201c\u7b7e\u5230\u201d\u81ea\u5df1\u6240\u5904\u7684\u5730\u70b9\uff0c\u7528\u521b\u65b0\u6709\u8da3\u7684\u6570\u5b57\u5316\u65b9\u5f0f\u8bb0\u5f55\u8db3\u8ff9\uff0c\u548c\u670b\u53cb\u5206\u4eab\u5fc3\u60c5\u3002\r\n \u5173\u6ce8\u7a0b\u5ea6\uff1a\u2605\u2605\u2605\u2605\u2606 \u8da3\u5473\u6307\u6570\uff1a\u2605\u2605\u2605\u2605\u2606 \u5546\u4e1a\u60f3\u6cd5\uff1a\u2605\u2605\u2605\u2606\u2606 \u4ea7\u54c1\u5206\u7c7b\uff1aLBS \u5feb\u8bc4\uff1a\u57fa\u4e8e\u5730\u7406\u4f4d\u7f6e\u7684\u79fb\u52a8\u670d\u52a1\u5f53\u4e4b\u65e0\u6127\u662f2010\u5e74\u6700\u70ed\u95e8\u7684\u79d1\u6280\u8bdd\u9898\uff0c\u4ece\u56fd\u5916\u7684Foursquare\u4e00\u5f00\u59cb\u5f15\u9886\u201c\u7b7e\u5230\u201d\u6f6e\u6d41\u4ee5\u540e\uff0c\u56fd\u5185\u7684\u540c\u7c7b\u4ea7\u54c1\u4fbf\u5982\u540c\u96e8\u540e\u6625\u7b0b\u822c\u6d8c\u73b0\u51fa\u6765\uff0c\u4e3a\u4ec0\u4e48\u4f1a\u662f\u8857\u65c1\u4e0a\u699c\u8fd9\u91cc\u7684Top10\uff1f\u800c\u4e0d\u662f\u5f00\u5f00\u3001\u5207\u5ba2\u6216\u8005\u73a9\u8f6c\u56db\u65b9\u3002\u4ece\u6211\u4e2a\u4eba\u7684\u7406\u89e3\u662f\uff0c\u8fd0\u8425\u662f\u4ea7\u54c1\u91cd\u8981\u7684\u7ec4\u6210\u90e8\u5206\uff0c\u4e5f\u8bb8\u8857\u65c1\u4ea7\u54c1\u5e76\u4e0d\u662f\u6700\u4f18\u79c0\u7684\uff0c\u4f46\u4ed6\u4eec\u7684\u8fd0\u8425\u7edd\u5bf9\u662f\u6700\u5145\u6ee1\u70ed\u60c5\u7684\u3002 \r\n\r\nNo.5 \u5feb\u76d8 \u662f\u91d1\u5c71\u8f6f\u4ef6\u63a8\u51fa\u7684\u4e00\u6b3e\u7c7bDropbox\u7684\u4e91\u5b58\u50a8\u670d\u52a1\uff0c\u7528\u4e8e\u6587\u4ef6\u7ba1\u7406\u4ee5\u53ca\u5907\u4efd\uff1b\u5b83\u53ef\u4ee5\u5c06\u76f8\u540c\u6587\u4ef6\u5373\u65f6\u81ea\u52a8\u7684\u540c\u6b65\u81f3PC\u3001\u624b\u673a\u3001Web\u7b49\u591a\u4e2a\u5e73\u53f0\uff0c\u771f\u6b63\u5b9e\u73b0\u8de8\u5e73\u53f0\u7684\u4f7f\u7528\u3002 \r\n\u5173\u6ce8\u7a0b\u5ea6\uff1a\u2605\u2605\u2605\u2606\u2606 \u8da3\u5473\u6307\u6570\uff1a\u2605\u2605\u2605\u2605\u2605 \u5546\u4e1a\u60f3\u6cd5\uff1a\u2605\u2605\u2605\u2606\u2606 \u4ea7\u54c1\u5206\u7c7b\uff1a\u5b58\u50a8\u3001\u4e91\u8ba1\u7b97 \r\n\u5feb\u8bc4\uff1a2010\u5e74\u9664\u4e86LBS\u548c\u56e2\u8d2d\u4ee5\u5916\uff0c\u8fd8\u6709\u4e00\u4e2a\u5927\u70ed\u95e8\u7684\u8bdd\u9898\uff0c\u90a3\u5c31\u662f\u4e91\u5b58\u50a8\u548c\u4e91\u540c\u6b65\u3002\u9762\u5bf9\u5e02\u9762\u4e0a\u8bf8\u591a\u540c\u8d28\u5316\u7684\u4ea7\u54c1\uff08\u76db\u5927-Everbox\u3001\u534e\u4e3a-\u6570\u636e\u94f6\u884c\u3001\u65b0\u6d6a-\u5fae\u76d8\u3001\u91d1\u5c71-\u5feb\u76d8\u3001\u8fc5\u96f7-\u968f\u8eab\u76d8\u3001\u5feb\u8f66-\u888b\u9f20\u7b49\u7b49\uff09\uff0c\u6211\u6700\u7ec8\u505a\u4e86\u4e00\u4e2a\u8270\u96be\u7684\u51b3\u5b9a\uff0c\u5c06Top5\u98