", "\u77ed\u4fe1"]}, {"url": "http://www.microsoft.com/beta/downloads/", "title": "\u5fae\u8f6f\u4e0b\u8f7d\u4e2d\u5fc3\u6539\u7248", "tags": "\u5fae\u8f6f \u4e0b\u8f7d ", "name": "cacard", "posttime": "2007-12-30 11:33:27", "ip": "222.178.10.246", "mark": 4, "note": "\u5fae\u8f6f\u653e\u51fa\u7684\u65b0\u7248\u7684\u4e0b\u8f7d\u4e2d\u5fc3\u6d4b\u8bd5\u9875\u9762,\u4f7f\u7528SilverLight\u6280\u672f,\u6548\u679c\u5341\u5206\u4e0d\u9519~~~~", "imagename": "2ef4eb13832d44eea5a8713687499764.jpg", "infoid": 40913, "category": "technology_internet", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u5fae\u8f6f", "\u4e0b\u8f7d"]}, {"url": "http://wordpress.org/download/#diglog-4caf237bb4c34db7b5f1c673e4513928", "title": "WordPress Version 2.3.2 \u53d1\u5e03", "tags": "", "name": "xmanfu", "posttime": "2007-12-30 06:59:39", "ip": "58.49.104.26", "mark": 5, "note": "WordPress 2.3.2 is an urgent security release that fixes a bug that can be used to expose your draft posts. 2.3.2 also suppresses some error messages that can give away information about your database table structure and limits and stops some information leaks in the XML-RPC and APP implementations. Get 2.3.2 now to protect your blog from these disclosures.\r\n\r\nAs a little bonus, 2.3.2 allows you to define a custom DB error page. Place your custom template at wp-content/db-error.php. If WP has a problem connecting to your database, this page will displayed rather than the default error message.\r\n\r\nFor more detail on what\u2019s new in 2.3.2, view the list of fixed bugs and see the changes between 2.3.1 and 2.3.2.", "imagename": "", "infoid": 40892, "category": "technology_developers", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": null}, {"url": "http://www.weborn.org/download/more-than-100-web-20-online-generators.html", "title": "100\u591a\u4e2aWeb2.0\u5728\u7ebf\u751f\u6210\u5668", "tags": "web2.0 ", "name": "leibniz", "posttime": "2007-12-30 02:51:06", "ip": "58.213.19.16", "mark": 6, "note": "100\u591a\u4e2aWeb2.0\u5728\u7ebf\u751f\u6210\u5668", "imagename": "", "infoid": 40891, "category": "technology_web2", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["web2.0"]}]