u5916 \u6240\u4ee5\u56fd\u5185\u6d88\u606f \u5168\u90e8\u662f\u901a\u8fc7\u65b0\u95fb \u901a\u8fc7\u7f51\u7edc\u6240\u4e86\u89e3\uff0c\u770b\u7740 \u4e00\u5f20\u5f20\u56fe\u7247 \u770b\u7740\u4e00\u5f20\u5f20\u65e0\u5948\u7684\u9762\u5b54\uff0c\u4e0d\u7136\u81ea\u4e3b\u7684\u5fc3\u7d27\u7d27\u63ea\u5230\u4e86\u4e00\u8d77\uff0c\u6709\u79cd\u201c\u611f\u540c\u8eab\u53d7\u201d\u7684\u611f\u89c9\uff0c\u5f88\u65e0\u5948 \u5f88\u60f3\u53bb\u5e2e\u52a9\u4ed6\u4eec \u5374\u4ec0\u4e48\u90fd\u4e0d\u80fd\u505a \u552f\u4e00\u53ef\u4ee5\u505a\u7684\u5c31\u662f\u7948\u7977\uff0c\u7948\u7977\u4ed6\u4eec\u53ef\u4ee5\u5c3d\u5feb\u56de\u5230\u5bb6\u4e61\uff0c\u5c3d\u5feb\u4e00\u5bb6\u56e2\u805a\uff0c\u7948\u7977\u88ab\u56f0\u7684\u6c11\u4f17 \u53ef\u4ee5\u5403\u9971\u7a7f\u6696\uff0c\u7948\u7977\u6240\u6709\u4eba \u6240\u6709\u4eba\u90fd\u53ef\u4ee5\u5e73\u5e73\u5b89\u5b89\u3002\u4e00\u573a\u5927\u96ea\u5e76\u4e0d\u53ef\u6015 \u635f\u593160\u4ebf \u6211\u4eec\u4e5f\u53ef\u4ee5\u518d\u8d5a\u56de\u6765\uff0c\u6211\u4eec\u73b0\u5728\u66f4\u9700\u8981\u7684\u662f \u7ad9\u5728\u4e00\u8d77\uff0c\u6240\u6709\u4e2d\u56fd\u4eba\u7ad9\u5728\u4e00\u8d77\uff0c\u5c31\u50cf\u6297\u65e5\u4e00\u6837 \u53bb\u4fdd\u536b\u6211\u95e8\u7684\u56fd\u5bb6 \u4fdd\u536b\u6211\u4eec\u7684\u5144\u5f1f\u59d0\u59b9\uff0c\u76f8\u4e92\u6276\u6301 \u662f\u6211\u4eec\u7684\u4f18\u826f\u4f20\u7edf\uff0c\u6211\u4eec\u4e5f\u6709\u4e49\u52a1\u628a\u4ed6\u7ee7\u7eed\u4f20\u627f\u4e0b\u53bb\uff0c\u5982\u679c\u53ef\u4ee5\u5e0c\u671b\u5927\u5bb6\u53ef\u4ee5\u5c3d\u529b\u53bb\u5e2e\u52a9\u4ed6\u4eec  \u6211\u77e5\u9053\u5f88\u591a\u88ab\u56f0\u7684\u52b3\u5de5\u670b\u53cb \u4ed6\u4eec\u672c\u8eab\u5f88\u5c11\u63a5\u89e6\u7f51\u7edc \u6240\u4ee5\u5982\u679c\u4f60\u770b\u5230\u8fd9\u4e9b\u670b\u53cb \u4ee3\u8868\u4e00\u4e2a\u4e2d\u56fd\u4eba \u53bb\u8ddf\u4ed6\u8bf4\u58f0 :&quot;\u65b0\u5e74\u5feb\u4e50&quot;  \u5f88\u7b80\u5355\u4e00\u53e5\u8bdd \u4f60\u5374\u53ef\u4ee5\u8ba9\u4ed6\u4eec\u5728\u51b0\u5929\u96ea\u5730\u91cc\u5f