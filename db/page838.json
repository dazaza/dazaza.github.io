06\u4e3a\u5927\u5bb6\u4ecb\u7ecd20\u4f4d\u6700\u5584\u7528\u8272\u5f69\u7684\u5e7f\u544a\u8bbe\u8ba1\u5927\u5e08\u3002", "imagename": "4f4618814c094baaacc7949cc25ecc00.jpg", "infoid": 86330, "category": "technology_design", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u8272\u5f69", "\u5e7f\u544a", "\u8bbe\u8ba1"]}, {"url": "http://www.lenovo.com.cn/y/", "title": "\u8054\u60f3\u9ec4\u91d1\u6027\u80fd \u5b66\u751f\u9650\u65f6\u7279\u60e0", "tags": "\u8054\u60f3 ", "name": "yinyin", "posttime": "2008-08-21 09:53:20", "ip": "122.194.173.3", "mark": 2, "note": "\u8054\u60f3\u5b98\u65b9\u7f51\u4e0a\u5546\u57ce\u4e8e20\u65e5\u53d1\u5e03\u201c\u8054\u60f3\u7b14\u8bb0\u672c\u5927\u5b66\u751f\u4e13\u4f9b\u8ba1\u5212\u201d\uff0c\u63d0\u4f9b\u4e24\u6b3e\u5965\u8fd0\u7b14\u8bb0\u672c\u9488\u5bf9\u5927\u5b66\u751f\u8fdb\u884c\u9650\u65f6\u7279\u60e0\u9500\u552e\u3002\r\n\u8054\u60f3\u5965\u8fd0\u8fd0\u52a8\u7eaa\u5ff5\u7248\u7b14\u8bb0\u672c, \u7531\u5965\u8fd0\u706b\u70ac\u8bbe\u8ba1\u539f\u73ed\u56e2\u961f\u7cbe\u5fc3\u6253\u9020\uff0c\u662f\u7ee707\u5e74\u63a8\u51fa\u7965\u4e91\u7b14\u8bb0\u672c\u540e\u53c8\u4e00\u6b3e\u7ecf\u5178\u529b\u4f5c\u3002\u518d\u4e00\u6b21\u5c06\u6e0a\u6e90\u60a0\u4e45\u7684\u4e2d\u56fd\u6587\u5316\u4e0e\u5965\u6797\u5339\u514b\u7cbe\u795e\u7d27\u5bc6\u878d\u5408\u5728\u4e00\u8d77\uff0c\u63a8\u52a8\u4e86\u7535\u8111\u5728\u5916\u89c2\u8bbe\u8ba1\u4e0a\u7684\u521b\u65b0\uff0c\u66f4\u5f70\u663e\u4e86\u60a0\u4e45\u6587\u5316\u4e0e\u9ad8\u7aef\u79d1\u6280\u878d\u5408\u7684\u9b45\u529b\u3002\r\n\r\n\r\n\r\n\u8fd9\u662f\u5168\u7403\u7b2c\u4e00\u6b3e\u4ee5\u5965\u8fd0\u8fd0\u52a8\u5143\u7d20\u4e3a\u4e3b\u9898\u8bbe\u8ba1\u7684\u7b14\u8bb0\u672c\u4ea7\u54c1.\u901a\u8fc7\u63a8\u51fa\u878d\u5408\u5965\u8fd0\u8fd0\u52a8\u5143\u7d20\u7684\u4ea7\u54c1,\u4ee5\u79d1\u6280\u529b\u91cf\u60e0\u53ca\u6d88\u8d39\u8005,\u8ba9\u4ed6\u4eec\u5728\u4f7f\u7528\u8fc7\u7a0b\u4e2d\u4f53\u9a8c\u5965\u8fd0\u4e4b\u7f8e.\r\n\r\n\u7b14\u8bb0\u672c\u901a\u8eab\u7eaf\u51c0\u7684\u767d\u8272\u5916\u89c2\u4e0a,\u523b\u753b\u4e86\u7531\u7bc6\u6587\u6f14\u53d8\u800c\u6765\u768411\u4e2a\u5317\u4eac\u5965\u8fd0\u4f1a\u6bd4\u8d5b\u9879\u76ee\u56fe\u6807,\u6fc0\u60c5\u800c\u4e0d\u5931\u7a33\u91cd,\u53e4\u6734\u800c\u5e76\u5177\u73b0\u4ee3\u611f,\u4e2d\u56fd\u4f20\u7edf\u6587\u5316\u5143\u7d20\u4e2d\u8574\u542b\u7740\u8fd0\u52a8\u4e0e \u6fc0\u60c5,\u6d3b\u529b\u4e0e\u901f\u5ea6.\u7bc6\u4f53\u56fe\u6807\u5c0f\u4eba\u7684\u6df1\u6d45\u4ee3\u8868\u4ed6\u4eec\u7ad9\u5728\u4e0e\u89c2\u8d4f\u8005\u4e0d\u540c\u7684\u8ddd\u79bb\u5f62\u6210\u4e00\u79cd\u7acb\u4f53\u611f\u89c9,\u4e5f\u4ee4\u4eba\u72b9\u5982\u7f6e\u8eab\u5965\u8fd0\u8d5b\u573a, \u4eff\u4f5b\u8fd0\u52a8\u5065\u513f\u4e0e\u4f60\u64e6\u8eab\u800c\u8fc7.\u8ba9\u60a8\u5728\u4f7f\u7528\u8054\u60f3\u7b14\u8bb0\u672c\u8fc7\u7a0b\u4e2d,\u7528\u79d1\u6280\u628a\u5965\u8fd0\u7684\u70ed\u60c5\u6c14\u6c1b\u5e26\u56de\u5bb6\u4e2d.", "imagename": "e90e231df0104773882223b525e5e5d4.jpg", "infoid": 86289, "category": "technology_internet", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u8054\u60f3"]}, {"url": "http://lianpu.qq.com/index.do", "title": "\u817e\u8baf\u8bf4\u5531\u8138\u8c31\u4e0a\u7ebf", "tags": "\u817e\u8baf \u8bf4\u5531\u8138\u8c31 ", "name": "yinyin", "posttime": "2008-08-21 09:04:50", "ip": "122.194.173.3", "mark": 2, "note": "\u4fd7\u8bdd\u8bf4\u7684\u597d\uff1a\u9762\u7531\u5fc3\u751f\uff0c\u5185\u5fc3\u7684\u60f3\u6cd5\u5f80\u5f80\u53ef\u4ee5\u901a\u8fc7\u9762\u90e8\u8868\u60c5\u53cd\u6620\u51fa\u6765\uff1b\u53cd\u8fc7\u6765\u8bb2\uff0c\u6211\u4eec\u4e5f\u53ef\u4ee5\u901a\u8fc7\u4e00\u5f20\u5f20\u751f\u52a8\u7684\u9762\u90e8\u8868\u60c5\u6765\u4f20\u9012\u60c5\u611f\uff0c\u8868\u8fbe\u5fc3\u58f0\uff0c\u8ba9\u8fd9\u4e9b\u80fd\u8bf4\u4f1a\u5531\u7684\u201c\u8138\u8c31\u201d\u6210\u4e3a\u7231\u5fc3\u5c0f\u7cbe\u7075\uff0c\u7ed9\u670b\u53cb\u634e\u53bb\u4e00\u53e5\u95ee\u5019\