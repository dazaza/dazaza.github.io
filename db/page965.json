89\uff0c\u8fde\u80cc\u666f\u97f3\u4e50\u90fd\u662f\uff0c\u6211\u670d\u4e86\u3002", "imagename": "6e97937bc825446e873ed6250f84a15b.jpg", "infoid": 50032, "category": "videos_gaming", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "videos", "via": null, "real_tags": ["\u6e38\u620f", "\u4fc4\u7f57\u65af\u65b9\u5757", "\u6076\u641e", "\u641e\u7b11", "\u6000\u65e7"]}, {"url": "http://www.49city.net/index.php/archives/181", "title": "MIX08\u5165\u573a\u5238-\u5fae\u8f6f\u63a8\u51fa\u4e00\u7cfb\u5217Windows Live API | \u6b6a\u535a2.0", "tags": "Windows Live API MIX08 AtomPub mashup WLML \u5fae\u8f6f ", "name": "yetilfx", "posttime": "2008-03-01 00:40:30", "ip": "221.223.21.49", "mark": 3, "note": "\u4eca\u5929\u5fae\u8f6f\u5ba3\u5e03\u63a8\u51fa\u4e00\u7cfb\u5217API ,\u5728\u4e0b\u5468\u7684MIX08\u6d3b\u52a8\u4e4b\u524d\u3002\u5176\u4e2d\u5173\u952e\u7ec6\u8282\u5728David Treadwell\uff08Windows Live \u526f\u603b\u88c1\uff09\u7684Blog\u4e2d\u6709\u62ab\u9732\u3002\u4eca\u5929\u7684\u65b0\u95fb\u4e2d\u8c08\u5230\u4e86\u5176\u4e2d\u76845\u4e2aLive API\u3001\u5f00\u53d1\u5de5\u5177\u5bf9web API\u7684\u652f\u6301\u3001\u4ee5\u53caLive \u5bb6\u65cfAPI \u7684\u6574\u4f53\u6280\u672f\u67b6\u6784\uff08\u76ee\u524d\u6709\u8d85\u8fc720\u4e2aAPI\uff09\u3002\u5728\u8fc7\u53bb\u7684\u4e24\u4e09\u5e74\u91cc\uff0c\u5fae\u8f6f\u8d8a\u6765\u8d8a\u591a\u7684\u5c06MIX\u4f5c\u4e3a\u5176\u5728\u5148\u6280\u672f\u5e73\u53f0\u7684\u57fa\u7840\u3002\r\n\r\n    * AtomPub: \u6700\u503c\u5f97\u6ce8\u610f\u7684\u5b98\u65b9\u58f0\u660e\u201c\u5fae\u8f6f\u65a5\u5de8\u8d44\u4e3a\u5f00\u653e\u670d\u52a1\u5236\u5b9a\u7edf\u4e00\u7684\u5f00\u53d1\u5e73\u53f0\u534f\u8bae\uff0c\u57fa\u4e8eAtom format (RFC4287) \u548c the Atom Publishing Protocol (RFC 5023)\u6807\u51c6.\u201d \u4ed6\u4eec\u4eceWindows Live Spaces \u7167\u7247API\u5f00\u59cb\uff0c\u5230\u4ed6\u4eec\u57fa\u4e8e\u5e94\u7528\u7684\u5b58\u50a8\u670d\u52a1\uff0c\u5230Astoria ADO.Net\u6570\u636e\u670d\u52a1\uff0c\u4ee5\u53ca\u201c\u5728MIX\u9886\u57df\u5e26\u6765\u7684\u4e00\u4e9b\u66f4\u591a\u7684\u60ca\u559c\u201d\u3002\u81ea\u4eceGoogle\u2019s GData\uff08\u540c\u6837\u57fa\u4e8eAtom\uff09\u4ee5\u6765\uff0c\u8fd9\u610f\u5473\u7740\u6700\u5927\u7684\u4e24\u4e2a\u7f51\u7edcAPI\u63d0\u4f9b\u5546\u7684\u7f51\u7edc\u670d\u52a1\u5747\u57fa\u4e8eREST\u6a21\u578b\u3002\u5f53\u7136\uff0c\u9b54\u9b3c\u5728\u7ec6\u8282\u4e2d\uff0c\u968f\u7740\u65f6\u95f4\u7684\u63a8\u79fb\uff0c\u6211\u4eec\u5c06\u770b\u5230\u5982\u4f55\u5b9e\u73b0\uff0c\u4f9b\u5e94\u5546\u5c06\u4e0d\u53ef\u907f\u514d\u5730\u6709\u6240\u4e0d\u540c\u3002\r\n    * Windows Live Messenger Library (WLML): \u8fd9\u6761\u65b0\u95fb\u4e2d\u6700\u91cd\u8981\u7684\u4fe1\u606f\u662f\u4e00\u4e2a\u65b0\u7684\u5efa\u7acb\u5728Windows Live Messenger\uff08\u539f\u6765\u7684MSN\uff0c\u67093\u4ebf\u591a\u7528\u6237)\u5e73\u53f0\u4e4b\u4e0a\u7684JavaScript API\uff0c\u5176\u5141\u8bb8\u7f51\u7ad9\u5b9a\u5236\u81ea\u5df1\u4e2a\u6027\u5316\u7684\u804a\u5929\u4f53\u9a8c\u3002\u4f60\u53ef\u4ee5\u4ece\u8fd9\u91cc\u83b7\u5f97\u8fd9\u4e2aAPI\u7684\u66f4\u591a\u7ec6\u8282\u3002\u4e0b\u9762\u7684\u5c4f\u5e55\u622a\u56fe\uff0c\u53f3\u4fa7\u5c55\u793a\u4e86\u4e00\u4e2a\u5ba2\u6237\u5316\u7684\u5e94\u7528\u7a0b\u5e8f\u4e0e\u5de6\u4fa7\u7684\u6807\u51c6Messager\u4e00\u6837\u5c55\u793a\u4e00\u6837\u804a\u5929\u5185\u5bb9\u3002\u8fd9\u4e00API\u652f\u6301 Messager\u6240\u6709\u7684\u6838\u5fc3\u529f\u80fd\uff0c\u50cf\u6587\u672c\u804a\u5929\u3001\u7528\u6237\u72b6\u6001\u3001\u56fe\u7247\u548c\u8054\u7cfb\u4eba\u5217\u8868\u7ba1\u7406\u3002\u901a\u8fc7Windows Live ID\u8fdb\u884c\u767b\u5f55\u7684\u5b89\u5168\u6a21\u578b\uff0c\u4f7f\u5f97\u7f51\u7ad9\u4e0a\u5e94\u7528\u5c06\u4e0d\u53ef\u80fd\u83b7\u5f97\u6237\u7684\u5bc6\u7801\u3002\u8fd9\u4e2a\u51fd\u6570\u5e93\u5b8c\u5168\u9002\u7528\u4e8e\u8fd0\u884c\u5728Windows\u548cMac\u5e73\u53f0\u4e0a\u7684IE\u548cFirefox\u3002\u90a3\u4e48\u6709\u4ec0\u4e48\u9650\u5236\u5462\uff1f\u5b83\u5141\u8bb8\u6ca1\u6708\u6709\u4e00\u767e\u4e07\u7528\u6237\u514d\u8d39\u8bd5\u7528\u3002\u6ce8\u610f\u8fd9\u662f\u4e00\u4e2a\u66f4\u52a0\u5f3a\u5927\u7684\u63a5\u53e3\uff0c\u4e0d\u540c\u4e8e\u73b0\u5728\u7684Windows Live IM Control\u3002\r\n\r\n       \r\n      lwmlex\r\n    * Windows Live ID \u4ee3\u7406\u8ba4\u8bc1: \u8fd9\u4e2a\u6700\u65b0\u7684API\u548cweb\u63a7\u4ef6\u7ed9\u7b2c\u4e09\u65b9\u5e94\u7528\u7a0b\u5e8f\u4e00\u4e2a\u5b89\u5168\u7684\u65b9\u5f0f\u8bbf\u95ee\u7528\u6237\u7684Windows Live\u7684\u6570\u636e\uff0c\u6309\u7167\u7528\u6237\u7ec6\u7c92\u5ea6\u7684\u6743\u9650\u5b9a\u4e49\uff0c\u53ca\u4ec0\u4e48\u53ef\u4ee5\u8bbf\u95ee\u548c\u8bbf\u95ee\u591a\u4e45\uff08\u53c2\u89c1\u8fd9\u91cc\uff09\u3002\u60f3\u8981\u4f7f\u7528\u8fd9\u4e2a\u670d\u52a1\uff0c\u5f00\u53d1\u4eba\u5458\u5fc5\u987b\u5148\u6ce8\u518c\u4ece\u800c\u83b7\u5f97\u4e00\u4e2a\u5e94\u7528\u7a0b\u5e8fID\u3002\u5f53\u7528\u6237\u60f3\u8bbf\u95ee\u4ed6\u4eec\u7684Windows Live\u6570\u636e\u65f6\uff0c\u5e94\u7528\u7a0b\u5e8fID\u63d0\u4f9b\u8fd0\u884c\u65f6\u652f\u6301\uff08\u201c\u8bf7\u6c42\u5e94\u7b54\u201d\u8fc7\u7a0b\uff09\u3002\u8fd9\u4f1a\u7ed9\u7a0b\u5e8f\u4e00\u4e2a\u201c\u5e94\u7b54\u4ee4\u724c\u201d\uff0c\u8fd4\u56de\u4e00\u4e2a\u201c\u4ee3\u7406\u4ee4\u724c\u201d\u7528\u6765\u8ba9\u5e94\u7528\u7a0b\u5e8f\u8bbf\u95ee\u7ed9\u5b9a\u7684Live API\u548c\u65b9\u6cd5\u3002\u8fd9\u4e9b\u4ee4\u724c\u5230\u671f\u540e\u9700\u8981\u88ab\u5e94\u7528\u7a0b\u5e8f\u5237\u65b0\u3002\u8fd9\u5c06\u662f\u4e00\u4e2a\u91cd\u8981\u7684API\u5728Live\u5e73\u53f0\u4e2d\uff0c\u5f88\u591a\u670d\u52a1\u90fd\u4f1a\u4f9d\u8d56\u4e8e\u5b83\u3002\u4e0b\u9762\u7684\u5e7b\u706f\u7247\u5c55\u793a\u4e86\u8fd9\u4e2a\u670d\u52a1\u548c\u4e00\u4e2a\u7167\u7247API\u95f4\u7684\u4ea4\u4e92\u3002\r\n      livephotoauth\r\n    * Windows Live Photo API: \u8fd9\u662f Windows Live Spaces Photo API\u4e00\u4e2a\u91cd\u5927\u7684\u5347\u7ea7\u3002\u8fd9\u4e2aAPI\u8ba9\u7b2c\u4e09\u65b9\u7f51\u7ad9\u5728Windows Live Spaces\u4e0a\u521b\u5efa\u7167\u7247\u5e94\u7528\u7a0b\u5e8f\u