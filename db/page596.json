\u4f5c. \u4e0d\u7ba1\u662f\u4e0a\u7f51, \u804a\u5929, \u8fd8\u662f\u89c2\u770b\u672c\u5730\u56fe\u7247, \u89c6\u9891, \u4e00\u5207\u64cd\u4f5c\u90fd\u8f7b\u677e\u7b80\u5355, \u5b8c\u5168\u56fe\u5f62\u5316. \u60e0\u666e\u8fd8\u5236\u4f5c\u4e86\u4e00\u4e2a\u5a92\u4f53\u64ad\u653e\u7a0b\u5e8f, \u540d\u53eb HP Mediastyle, \u540c\u6837\u8f7b\u677e\u6613\u4e0a\u624b. \u4e00\u8d77\u6765\u770b\u56fe.", "imagename": "", "infoid": 122865, "category": "technology_internet", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u60e0\u666e\u4e0a\u7f51\u672c"]}, {"url": "http://riku.me/club/thread-47-1-1.html", "title": "\u5206\u4eab\uff1a\u66f4\u591a\u6f02\u4eae\u5899\u7eb8\uff08\u6253\u5305\u4e0b\u8f7d\uff09", "tags": "\u5899\u7eb8 ", "name": "rikulu", "posttime": "2009-02-05 13:07:58", "ip": "222.72.160.6", "mark": 2, "note": "\u5206\u4eab\uff1a\u66f4\u591a\u6f02\u4eae\u5899\u7eb8\uff08\u6253\u5305\u4e0b\u8f7d\uff09\u5206\u4eab\uff1a\u66f4\u591a\u6f02\u4eae\u5899\u7eb8\uff08\u6253\u5305\u4e0b\u8f7d\uff09\u5206\u4eab\uff1a\u66f4\u591a\u6f02\u4eae\u5899\u7eb8\uff08\u6253\u5305\u4e0b\u8f7d\uff09\u5206\u4eab\uff1a\u66f4\u591a\u6f02\u4eae\u5899\u7eb8\uff08\u6253\u5305\u4e0b\u8f7d\uff09", "imagename": "0f7661644db54830a76b0ecc58464eea.jpg", "infoid": 122861, "category": "technology_internet", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u5899\u7eb8"]}, {"url": "http://riku.me/2009/02/04/premium_wallpaper.html", "title": "\u6253\u5305\u4e0b\u8f7d\uff1a100\u5f20\u4e13\u4e1a\u7ea7\u8d85\u6f02\u4eae\u5899\u7eb8", "tags": "\u5899\u7eb8 ", "name": "rikulu", "posttime": "2009-02-05 13:06:01", "ip": "222.72.160.6", "mark": 2, "note": "\u65e0\u610f\u4e2d\u5728\u7f51\u4e0a\u627e\u5230\u4e86\u4e00\u6279\u8d85\u6f02\u4eae\u4e13\u4e1a\u7ea7\u7684\u684c\u9762\u5899\u7eb8\uff0c\u5171\u6709100\u5f20\u5de6\u53f3\uff0c\u4e2a\u4eba\u4e5f\u633a\u559c\u6b22\u7684\uff0c\u7279\u62ff\u51f