f8e\u56fd\u65b9\u9762\u5171\u540c\u5f00\u53d1\uff0c\u9488\u5bf9\u4e2d\u56fd\u7528\u6237\u7684\u9700\u6c42\u52a0\u5165\u7279\u5b9a\u7684\u5143\u7d20\u3002\r\n\r\n\u3000\u3000\u6b64\u524d\uff0c\u5927\u90e8\u5206\u7684\u56fd\u5916\u4e92\u8054\u7f51\u516c\u53f8\u8fdb\u5165\u4e2d\u56fd\uff0c\u90fd\u662f\u628a\u82f1\u6587\u5f00\u53d1\u5b8c\u6210\u4e86\u518d\u4ea4\u7ed9\u4e2d\u56fd\u65b9\u9762\u6c49\u5316\uff0c\u9020\u6210\u4e2d\u6587\u7248\u63a8\u51fa\u901f\u5ea6\u6162\u548c\u4ea7\u54c1\u4e0d\u9002\u5408\u4e2d\u56fd\u7528\u6237\u7b49\u3002\u8c2d\u6653\u751f\u5219\u8868\u793a\uff0cMyspace\u7684\u5f00\u53d1\u65b9\u5f0f\u662f\u5f88\u7279\u522b\u7684\uff0c\u5e76\u4e0d\u50cf\u4f20\u7edf\u7684\u8f6f\u4ef6\u3001\u4e92\u8054\u7f51\u5f00\u53d1\u90a3\u4e48\u89c4\u8303\uff0c\u4f46\u8fd9\u6837\u7684\u5f00\u53d1\u65b9\u5f0f\u4fdd\u8bc1\u4e86\u5f00\u53d1\u901f\u5ea6\u548c\u63a8\u51fa\u901f\u5ea6\u66f4\u5feb\u3002\r\n\r\n\u3000\u3000\u5bf9\u4e8eMyspace IM\u3001Myspace\u7f51\u7ad9\u672c\u8eab\u662f\u5426\u9002\u5408\u4e2d\u56fd\u7528\u6237\u7684\u95ee\u9898\uff0c\u8c2d\u6653\u751f\u5219\u8ba4\u4e3a\uff0cMyspace\u7684\u7f51\u7ad9\u98ce\u683c\uff0c\u5c31\u662f\u628a\u5927\u591a\u6570\u529f\u80fd\u4ea4\u7ed9\u7528\u6237\u81ea\u884c\u8bbe\u7f6e\uff0c\u4ece\u83b7\u5f97\u6570\u636e\u6765\u770b\uff0c\u7528\u6237\u5df2\u7ecf\u6162\u6162\u63a5\u53d7\u4e2a\u6027\u5316\u8bbe\u7f6e\u7684\u98ce\u683c\u4e86\u3002Myspace.cn\u4ece4\u670826\u65e5\u63a8\u51fa\u81f3\u4eca\uff0c\u5df2\u7ecf\u83b7\u5f97\u4e8650\u4e07\u4ee5\u4e0a\u7684\u7528\u6237\uff0c\u800c\u9884\u671f\u6ce8\u518c\u7528\u6237\u5927\u7ea6\u4e3a7-8\u4e07\uff0c\u76ee\u524d\u7684\u589e\u957f\u901f\u5ea6\u5df2\u7ecf\u5927\u5927\u8d85\u9884\u671f\u4e86\u3002\r\n\r\n\u3000\u3000\u5206\u6790\u4eba\u58eb\u8ba4\u4e3a\uff0c\u5c3d\u7ba1Myspace\u79f0\u4e0d\u613f\u610f\u4e0eQQ\u3001MSN\u7b49\u7ade\u4e89\uff0c\u4f46\u662f\u8fd9\u51e0\u4e2a\u7f51\u7ad9\u4e4b\u95f4\u7684\u7ade\u4e89\u5728\u672a\u6765\u4f1a\u8d8a\u6765\u8d8a\u660e\u663e\u3002QQ\u662f\u804a\u