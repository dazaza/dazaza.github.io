[{"url": "http://wwwcn.myspace.cn/chinaim", "title": "MySpace Im \u63a8\u51fa", "tags": "MySpace Im ", "name": "yinyin", "posttime": "2007-06-09 09:09:02", "ip": "222.184.55.58", "mark": 6, "note": "MySpace Im \u63a8\u51fa  http://wwwcn.myspace.cn/chinaim", "imagename": "", "infoid": 22050, "category": "technology_software", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["myspace", "im"]}, {"url": "http://news.csdn.net/n/20070608/105055.html", "title": "\u8c37\u6b4c\u540c\u5fd7\uff0c\u60a8\u5230\u5e95\u600e\u4e48\u4e86\uff1f", "tags": "\u8c37\u6b4c\u8f93\u5165\u6cd5 \u641c\u7d22\u5f15\u64ce \u767e\u5ea6 \u5bfc\u822a hao123 \u641c\u72d7 \u4ea7\u54c1 \u5de5\u7a0b\u5e08 ", "name": "huahuaniu", "posttime": "2007-06-09 03:44:50", "ip": "221.14.253.176", "mark": 7, "note": "\u5728\u5168\u7403\u8303\u56f4\u5185\u5e02\u503c\u4e0e\u540d\u58f0\u90fd\u5f88\u9ad8\u7684Google\u5728\u4e2d\u56fd\uff0c\u53eb\u8c37\u6b4c\uff0c\u539f\u672c\uff0c\u6309\u7167\u5e38\u7406\uff0c\u8c37\u6b4c\u5e94\u8be5\u5728\u56fd\u5185\u5e02\u573a\u4e0a\u5360\u636e\u76f8\u5f53\u7684\u5730\u4f4d\uff0c\u7136\u800c\uff0c\u4e8b\u5b9e\u4e0a\uff0c\u8c37\u6b4c\u540c\u5fd7\u5728\u56fd\u5185\u7684\u4e92\u8054\u7f51\u4e1a\u754c\u603b\u662f\u88ab\u595a\u843d\u7684\u5bf9\u8c61\uff0c\u51e0\u4e4e\u6bcf\u4e00\u4e2a\u5e02\u573a\u52a8\u5411\u548c\u4ea7\u54c1\u51fa\u6765\u90fd\u88ab\u559c\u6b22\u4ed6\u548c\u4e0d\u559c\u6b22\u4ed6\u7684\u4eba\u4eec\u5632\u7b11\u7740\u3002\u8c37\u6b4c\u540c\u5fd7\u5c31\u597d\u6bd4\u4e00\u4e2a\u5916\u56fd\u5927\u4e2a\u5b50\uff0c\u4e5f\u60f3\u5728\u4e2d\u56fd\u5e02\u573a\u4e0a\u5206\u4e00\u676f\u7fb9\uff0c\u7136\u800c\u4e2d\u56fd\u7684\u540c\u884c\u90fd\u4e0d\u628a\u4ed6\u5f53\u4f5c\u7ade\u4e89\u5bf9\u624b\u770b\uff0c\u53ea\u662f\u60ca\u8bb6\u4e8e\u4ed6\u7684\u5947\u7279\u7684\u88c5\u675f\uff0c\u77e5\u9053\u4ed6\u662f\u4e2a\u5916\u56fd\u5bcc\u7fc1\uff0c\u77e5\u9053\u4ed6\u542c\u4e0d\u61c2\u4e2d\u56fd\u8bdd\uff0c\u77e5\u9053\u4ed6\u4e0d\u77e5\u9053\u4e2d\u56fd\u4eba\u5728\u60f3\u4ec0\u4e48\uff0c\u4ed6\u4e0d\u77e5\u9053\u4e2d\u56fd\u4eba\u77e5\u9053\u4ec0\u4e48\uff0c\u5728\u60f3\u4ec0\u4e48\u3002\u6240\u4ee5\u8c37\u6b4c\u540c\u5fd7\u6765\u4e2d\u56fd\u7684\u51e0\u5e74\u662f\u51fa\u6d0b\u76f8\u7684\u51e0\u5e74\uff0c\u662f\u5e02\u573a\u4efd\u989d\u8282\u8282\u8d25\u9000\u7684\u51e0\u5e74\u3002? ???\r\n\r\n\u3000\u3000\u6765\u770b\u770b\u8c37\u6b4c\u540c\u5fd7\u7684\u51e0\u4e2a\u4ea7\u54c1\u5427\u3002\r\n\r\n\u3000\u3000\u8c37\u6b4c\u5bfc\u822a___\u5b64\u82b3\u81ea\u8d4f\u7684\u8c37\u6b4c\u5bfc\u822a\uff1a\u8c37\u6b4c\u540c\u5fd7\u6084\u6084\u7684\u5f04\u51fa\u8c37\u6b4c\u5bfc\u822a\uff0c\u4f30\u8ba1\u662f\u60f3\u5b66\u4e60hao123\u7684\u98ce\u5149\uff0c\u6b8a\u4e0d\u77e5\u6b64\u65f6\u7684\u4e92\u8054\u7f51\u4e1a\u754c\u5df2\u7136\u4e0d\u540c\u4e8e\u5f53\u5e74\u7684hao123\u51fa\u9053\u7684\u5e74\u9f84\uff0c\u8c37\u6b4c\u7684\u5bfc\u822a\uff0c\u65e0\u8bba\u662f\u4ece\u8be5\u57df\u540d\uff08daohang.google.com\uff09\u8fd8\u662f\u4ece\u9875\u9762\u98ce\u683c\u90fd\u88ab\u4eba\u8ba5\u7b11\u4e3a\u5916\u884c\uff0c\u751a\u81f3\u8fd9\u4e2a\u4ea7\u54c1\u8c37\u6b4c\u8fd8\u662f\u8bf4\u5de5\u7a0b\u5e08\u4e1a\u4f59\u65f6\u95f4\u5f00\u53d1\u7684\uff0c\u7acb\u9a6c\u6709\u4eba\u8bf4\u8fd9\u4e2a\u5c31\u662f\u8c37\u6b4c\u5de5\u7a0b\u5e08\u7684\u6c34\u51c6\u554a\uff1f\u4f30\u8ba1\u8fd9\u4e2adaohang.google.com\u53ea\u6709\u51e0\u4e2agoogle\u7c89\u4e1d\u770b\u770b\uff0c\u7136\u540e\u5c31\u8c37\u6b4c\u516c\u53f8\u7684\u51e0\u4e2a\u4f1f\u5927\u7684\u5de5\u7a0b\u5e08\u5728\u7528\u4e86\uff0c\u81f3\u5c11\u6211\u6ca1\u770b\u5230\u5468\u8fb9\u6709\u4e00\u4e2a\u7528\u7684\uff0chao123\u7684\u6211\u770b\u5230\u6709\u4eba\u7528\uff0c265 \u4e5f\u6709\uff0c\u4f46\u662f\u5c31\u662f\u6ca1\u770b\u5230\u8c37\u6b4c\u5bfc\u822a\u3002\r\n\r\n\u3000\u3000\u8c37\u6b4c\u5de5\u5177\u6761___\u5728\u4e00\u88c5\u4e00\u5378\u4e2d\u521b\u9020GDP\uff1a\u5de5\u5177\u6761\u8fd9\u4e2a\u4e1c\u897f\u662f\u597d\uff0c\u4f46\u662f\u73b0\u5728\u7684360safe\u5b9e\u5728\u592a\u725b\uff0c\u8f7b\u8f7b\u4e00\u70b9\uff0c\u5220\u9664\u7684\u5e72\u5e72\u51c0\u51c0\uff0c\u8fc5\u96f7\u3001\u5feb\u8f66\u8fd9\u4e9b\u4ea7\u54c1\u90fd\u5728\u6346\u7ed1\u6709\u8c37\u6b4c\u5de5\u5177\u6761\uff0c\u4e0d\u5c11\u7528\u6237\u662f\u88c5\u8f6f\u4ef6\u7684\u65f6\u5019\u88c5\u4e00\u6b21\uff0c\u56de\u5934\u53c8\u7528\u5b89\u5168\u536b\u58eb\u5e72\u6389\uff0c\u8c37\u6b4c\u5c31\u5728\u8fd9\u4e00\u88c5\u4e4b\u540e\u7ed9\u5408\u4f5c\u4f19\u4f34\u4e00\u4e2a\u5de5\u5177\u6761\u591a\u5c11\u94b1\u7684\u5f62\u5f0f\u4ed8\u6b3e\uff0c\u7136\u540e\u53c8\u53bb\u627f\u53d7\u88ab360\u536b\u58eb\u5e72\u6389\u7684\u5c34\u5c2c\uff0c\u5c31\u5728\u8fd9\u4e00\u88c5\u4e00\u5378\u4e4b\u95f4\uff0c\u5468\u9e3f\u794e\u540c\u5fd7\u5c31\u5728\u53cd\u590d\u7684\u4e3a\u56fd\u5185\u4e92\u8054\u7f51\u521b\u9020GDP\uff0c\u638f\u94b1\u7684\u662f\u8c37\u6b4c\uff0c\u5f00\u5fc3\u7684\u662f\u5408\u4f5c\u4f19\u4f34\u3002\r\n\r\n\u3000\u3000\u8c37\u6b4c\u8f93\u5165\u6cd5___\u7070\u5934\u571f\u8138\u7684\u8f93\u5165\u6cd5\uff1a\u8fd9\u4e2a\u8f93\u5165\u6cd5\u6700\u65e9\u662f\u641c\u72d7\u641e\u51fa\u6765\u7684\uff0c\u641c\u72d7\u641e\u641c\u7d22\u5f15\u64ce\u662f\u4e00\u5927\u5931\u8d25\uff0c\u65e0\u5fc3\u63d2\u67f3\u641e\u4e86\u4e2a\u641c\u72d7\u8f93\u5165\u6cd5\uff0c\u7740\u5b9e\u98ce\u706b\u4e86\u4e00\u628a\uff0c\u628a\u82e6\u4e8e\u6d41\u91cf\u5929\u5929\u4e0b\u8dcc\u7684\u8c37\u6b4c\u7fa1\u6155\u6b7b\u4e86\uff0c\u4e5f\u60f3\u7740\u53bb\u641e\u4e2a\u3002\u4e8e\u662f\u547c\u4e00\u8d2f\u7684\u8c37\u6b4c\u98ce\u683c\uff0c\u53c8\u662f\u51e0\u4e2a\u5de5\u7a0b\u5e08\u548c\u5b9e\u4e60\u751f\u641e\u4e86\u4e2a\u8f93\u5165\u6cd5\uff0c\u641e\u8f93\u5165\u6cd5\u5c31\u641e\u561b\uff0c\u53c8\u8fd8\u53bb\u6284\u88ad\u641c\u72d7\u7684\u8bcd\u5e93\uff0c\u7ed3\u679c\u67e5\u5c14\u65af\u5f20\u5c31\u5f97\u5230\u673a\u4f1a\u4e86\uff0c\u731b\u70c8\u7684\u7092\u4f5c\uff0c\u63ea\u4f4f\u5c0f\u8fab\u5b50\u4e0d\u653e\uff0c\u5f04\u5f97\u8c37\u6b4c\u540c\u5fd7\u7070\u5934\u571f\u8138\u7684\uff0c\u5934\u9876\u4e0a\u7684\u9ec4\u6bdb\u90fd\u88ab\u641c\u72d7\u7684\u67e5\u5c14\u65af\u5f20\u5feb\u6293\u6ca1\u6709\u4e86\u3002\r\n\r\n\u3000\u3000\u641c\u7d22\u5f15\u64ce___\u88ab\u9609\u5272\u4e86\u7684\u641c\u7d22\u5f15\u64ce\uff1a\u641c\u7d22\u5f15\u64ce\u662fGOOGLE\u540c\u5fd7\u51fa\u9053\u5728\u5168\u7403\u6240\u5411\u62ab\u9761\u7684\u5229\u5668\uff0c\u662f\u5c60\u9f99\u5200\uff0c\u662f\u501a\u5929\u5251\uff0c\u6ca1\u60f3\u5230\u5230\u4e86\u5728\u4e2d\u56fd\u5c60\u9f99\u5200\u53d8\u6210\u4e86\u5c60\u866b\u5200\uff0c\u501a\u5929\u5251\u751f\u4e86\u9508\uff0c\u65e9\u4e9b\u5e74google\u8fd8\u662f\u5f88\u591a\u7f51\u6c11\u7684\u9996\u9009\uff0c\u4f46\u662fgoogle\u5728\u4e2d\u56fd\u9047\u5230\u4e86\u751a\u81f3\u4ee5\u540e\u662f\u4ed6\u6700\u5f3a\u52b2\u7684\u5bf9\u624b\u4e4b\u4e00\u767e\u5ea6\uff0c\u767e\u5ea6\u540c\u5fd7\u5bf9\u56fd\u4eba\u7684\u4e86\u89e3\u53ef\u4ee5\u79f0\u5f97\u4e0a\u662f\u6dcb\u6f13\u5c3d\u81f4\uff0c\u5546\u4e1a\u624b\u6cd5\u4e5f\u662f\u9887\u6709\u664b\u5546\u98ce\u8303\uff0c\u4e09\u5e74\u4e4b\u5185\uff0c\u767e\u5ea6\u5df2\u7136\u8d8a\u8fc7google\u6210\u4e3a\u4e2d\u56fd\u5e02\u573a\u4e0a\u7684\u9738\u4e3b\uff0c\u6700\u8fd1\u8fd9\u4e09\u5e74\u5df2\u7ecf\u662f\u5730\u4f4d\u8d8a\u53d1\u5de9\u56fa\u3002\u867d\u7136google\u548c\u767e\u5ea6\u90fd\u662f\u5916\u4f01\uff0c\u4f46\u662fgoogle\u8fdc\u4e0d\u5982\u767e\u5ea6\u4f1a\u4f2a\u88c5\uff0c\u4f1a\u548c\u4e2d\u56fd\u4eba\u6500\u4ea4\u60c5\uff0cgoogle\u662f\u771f\u7684\u4e0d\u77e5\u9053\u4e2d\u56fd\u4eba\u60f3\u77e5\u9053\u4ec0\u4e48\uff0c\u52a0\u4e0a\u5bf9\u624b\u5b9e\u5728\u662f\u80fd\u5f81\u5584\u6218\uff0cgoogle\u5728\u67d0\u6bb5\u65f6\u95f4\u8fd8\u88ab\u653f\u5e9c\u5173\u4e86\u4e2a\u7981\u95ed\uff0c\u7b49\u5230\u653e\u98ce\u51fa\u6765\u53d1\u89c9\u5929\u4e0b\u5df2\u7ecf\u4e3a\u4ed6\u4eba\u6240\u6709\uff0c\u81ea\u5df1\u5df2\u7ecf\u5728\u8fd9\u4e2a\u5e02\u573a\u4e0a\u4ece\u9886\u5bfc\u8005\u53d8\u6210\u4e86\u8ffd\u9010\u8005\uff0c\u5f52\u6839\u7ed3\u5e95\u548cgoogle\u7684\u88ab\u9609\u5272\u4e0d\u65e0\u5173\u7cfb\u3002\r\n\r\n\u3000\u3000\u6709\u4e00\u4e9b\u4e71\u4e03\u516b\u7cdf\u7684\uff1a \u524d\u4e9b\u65e5\u5b50\u51fa\u73b0\u7684\u6cb8\u6cb8\u626c\u626c265\u7684\u57df\u540d\u4e8b\u4ef6\uff0c\u8fd9\u6b21\u7684\u6b63\u671b\u54a8\u8be2\u7684\u62a5\u544a\uff0c\u8ba9\u8c37\u6b4c\u603b\u662f\u5728\u4e2d\u56fd\u4f1a\u9677\u5165\u5728\u53e3\u6c34\u98ce\u66b4\u4e2d\u7b49\u7b49\uff0c\u603b\u4e4b\uff0c\u4e0d\u4e00\u800c\u8db3\uff0c\u592a\u591a\u4e86\u592a\u591a\u4e86\uff01\r\n\r\n\u3000\u3000\u5e73\u5fc3\u800c\u8bba\uff0c\u8c37\u6b4c\u662f\u4e2a\u597d\u4ea7\u54c1\uff0c\u4f46\u662f\u5728googe\u5728\u4e2d\u56fd\u662f??\u4e00\u6d41\u7684\u4ea7\u54c1\uff0c\u505a\u51fa\u4e86\u4e8c\u6d41\u7684\u516c\u53f8\uff0c\u6210\u5c31\u4e86\u4e00\u4e9b\u4e09\u6d41\u7684\u4eba\uff0c\u6ee1\u8db3\u4e86\u4e00\u4e9b\u4e0d\u5165\u6d41\u4eba\u7684\u613f\u671b\uff01\r\n\r\n\u3000\u3000\u4e3a\u8c37\u6b4c\u60b2\u54c0\uff01\r\n\r\n\u3000\u3000\u5e73\u5fc3\u800c\u8bba\uff0c\u7b14\u8005\u8fd8\u662f\u5f88\u559c\u6b22\u8c37\u6b4c\uff0c\u8c08\u53ca\u8fd9\u4e9b\uff0c\u53ea\u662f\u5e0c\u671b\u8c37\u6b4c\u4f1a\u8d8a\u6765\u8d8a\u597d\u3002", "imagename": "", "infoid": 22046, "category": "technology_internet", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u8c37\u6b4c\u8f93\u5165\u6cd5", "\u641c\u7d22\u5f15\u64ce", "\u767e\u5ea6", "\u5bfc\u822a", "hao123", "\u641c\u72d7", "\u4ea7\u54c1", "\u5de5\u7a0b\u5e08"]}, {"url": "http://news.sohu.com/20070609/n250473590.shtml", "title": "\u6bd4\u5c14&#183;\u76d6\u8328\u56de\u5230\u6bcd\u6821\uff0c\u63a5\u53d7\u4e86\u54c8\u4f5b\u5927\u5b66\u8363\u8a89\u5b66\u4f4d", "tags": "", "name": "huahuaniu", "posttime": "2007-06-09 03:41:51", "ip": "221.14.253.176", "mark": 7, "note": "\u201c\u54c8\u4f5b\u6700\u8457\u540d\u7684\u8f8d\u5b66\u751f\u201d\u7ec8\u4e8e\u6bd5\u4e1a\u4e86\u30026\u67087\u65e5\uff0c\u5168\u7403\u9996\u5bcc\u3001\u8f6f\u4ef6\u5e1d\u56fd\u7684\u7f14\u9020\u8005\u6bd4\u5c14&#183;\u76d6\u8328\u56de\u5230\u6bcd\u6821\uff0c\u63a5\u53d7\u4e86\u54c8\u4f5b\u5927\u5b66\u8363\u8a89\u5b66\u4f4d\uff0c\u5b9e\u73b0\u4e86\u6234\u201c\u56db\u65b9\u5e3d\u201d\u7684\u5fc3\u613f\u3002\r\n\r\n\u3000\u3000\u5151\u73b032\u5e74\u524d\u8bfa\u8a00\r\n\r\n\u3000\u3000\u76d6\u83287\u65e5\u4ece\u54c8\u4f5b\u6559\u52a1\u957f\u53f2\u8482\u6587&#183;\u6d77\u66fc\u624b\u4e2d\u63a5\u8fc7\u4e86\u8363\u8a89\u6cd5\u5b66\u535a\u58eb(L.L.D)\u5b66\u4f4d\u7684\u8bc1\u4e66\uff08\u4e0a\u56fe\uff09\u3002\u8fd9\u7c7b\u5b66\u4f4d\u4e3b\u8981\u9881\u53d1\u7ed9\u4e00\u4e9b\u540d\u4eba\u653f\u8981,\u4ee5\u8868\u5f70\u4ed6\u4eec\u7684\u6210\u5c31\u3002\r\n\r\n\u3000\u3000\u6d77\u66fc\u8bf4,\u76d6\u8328\u662f\u54c8\u4f5b\u5927\u5b661977\u5c4a\u201c\u6700\u6770\u51fa\u7684\u201d\u5b66\u751f,\u73b0\u5728\u662f\u4ed6\u7684\u6bcd\u6821\u5411\u4ed6\u9881\u53d1\u8bc1\u4e66\u7684\u65f6\u5019\u4e86\u3002 \r\n \r\n \r\n \r\n\r\n\r\n\u3000\u3000\u54c8\u4f5b\u5927\u5b66\u4ee3\u7406\u6821\u957f\u5fb7\u91cc\u514b&#183;\u535a\u514b\u5728\u4ecb\u7ecd\u76d6\u8328\u65f6\u4e0d\u541d\u8d5e\u7f8e\u4e4b\u8f9e:\u201c\u6211\u4eec\u4eca\u5929\u7684\u6f14\u8bb2\u8005\u662f\u4e16\u754c\u4e0a\u6700\u5177\u5f71\u54cd\u529b\u7684\u4f01\u4e1a\u5bb6,\u4ed6\u5e26\u52a8\u4e86\u4e2a\u4eba\u8ba1\u7b97\u673a\u884c\u4e1a\u7684\u9769\u547d\u3002\u4ece2004\u5e74\u52302007\u5e74,\u4ed6\u8fde\u7eed\u56db\u5e74\u5f53\u9009\u2018\u5168\u7403100\u4f4d\u6700\u5177\u5f71\u54cd\u529b\u4eba\u7269\u2019\u3002\u201d\u968f\u540e,\u4ed6\u4ee5\u5f00\u73a9\u7b11\u7684\u53e3\u543b\u5bf9\u76d6\u8328\u8bf4:\u201c\u5982\u679c\u4f60\u5f53\u521d\u5b8c\u6210\u5269\u4e0b\u7684\u4e24\u5e74\u5b66\u4e1a,\u90a3\u73b0\u5728\u5c06\u53d6\u5f97\u4ec0\u4e48\u6837\u7684\u6210\u5c31\u5440\u3002\u201d\r\n\r\n\u3000\u3000\u76d6\u8328\u4e5f\u4ee5\u8bd9\u8c10\u7684\u5f00\u573a\u767d\u5c55\u5f00\u4e86\u81ea\u5df1\u7684\u6f14\u8bb2\u3002\u201c\u8001\u7238,\u6211\u4e00\u76f4\u544a\u8bc9\u60a8\u6211\u4f1a\u56de\u6765\u62ff\u5230\u6211\u7684\u5b66\u4f4d,\u73b0\u5728\u6211\u505a\u5230\u4e86\u3002\u201d\u76d6\u8328\u5bf9\u7740\u51fa\u5e2d\u4eea\u5f0f\u7684\u7236\u4eb2\u8bf4,\u201c\u4e3a\u4e86\u8bf4\u8fd9\u53e5\u8bdd,\u6211\u5df2\u7ecf\u7b49\u5f8530\u591a\u5e74\u4e86\u3002\u201d\r\n\r\n\u3000\u3000\u76d6\u83281973\u5e74\u8fdb\u5165\u54c8\u4f5b\u5927\u5b66\u6cd5\u5f8b\u7cfb,\u539f\u672c\u5e94\u8be51977\u5e74\u6bd5\u4e1a,\u4f46\u4ed6\u57281975\u5e74\u4fbf\u8f8d\u5b66\u521b\u4e1a,\u4f46\u54c8\u4f5b\u5927\u5b66\u4ecd\u7136\u5c06\u4ed6\u89c6\u4e3a1977\u5c4a\u54c8\u4f5b\u6bd5\u4e1a\u751f\u3002\u4eca\u5e74\u5c06\u662f\u8fd9\u5c4a\u5b66\u751f\u6bd5\u4e1a30\u5468\u5e74\u7684\u7eaa\u5ff5\u65e5,\u56e0\u6b64\u54c8\u4f5b\u9009\u4e2d\u8fd9\u4e2a\u65e5\u5b50\u4e3a\u76d6\u8328\u9001\u4e0a\u4e86\u4e00\u4efd\u5927\u793c\u3002\r\n\r\n\u3000\u3000\u6709\u4e86\u5b66\u5386\u597d\u201c\u8df3\u69fd\u201d\r\n\r\n\u3000\u3000\u76d6\u8328\u5728\u6f14\u8bb2\u4e2d\u8fd8\u620f\u79f0\uff1a\u201c\u6211\u660e\u5e74\u5c06\u4f1a\u6362\u5de5\u4f5c\uff0c\u7ec8\u4e8e\u80fd\u591f\u5728\u6211\u7684\u7b80\u5386\u4e0a\u52a0\u4e0a\u4e00\u4e2a\u5927\u5b66\u5b66\u4f4d\u4e86\uff0c\u771f\u4e0d\u9519\u3002\u201d\u6700\u8fd1\u51e0\u4e2a\u6708\uff0c\u76d6\u8328\u5c06\u5927\u90e8\u5206\u7cbe\u529b\u548c\u65f6\u95f4\u90fd\u7528\u4e8e\u201c\u6bd4\u5c14\u548c\u6885\u6797\u8fbe&#183;\u76d6\u8328\u57fa\u91d1\u4f1a\u201d\uff0c\u81f4\u529b\u4e8e\u89e3\u51b3\u5168\u7403\u536b\u751f\u548c\u6559\u80b2\u95ee\u9898\u3002\u4ed6\u5c06\u4e8e2008\u5e74\u9000\u51fa\u5fae\u8f6f\u65e5\u5e38\u7ba1\u7406\u5de5\u4f5c\uff0c\u5168\u8eab\u5fc3\u5730\u6295\u5165\u5230\u76d6\u8328\u57fa\u91d1\u4f1a\u7684\u5de5\u4f5c\u4e2d\u3002\r\n\r\n\u3000\u3000\u54c8\u4f5b\u5b66\u751f\u515c\u552e\u5165\u573a\u5238\r\n\r\n\u3000\u3000\u76d6\u8328\u9f13\u52b1\u54c8\u4f5b\u540e\u8f88\u4eec\u591a\u591a\u6295\u8eab\u516c\u76ca\uff0c\u800c\u6709\u8da3\u7684\u662f\uff0c\u4e00\u4e9b\u5b66\u751f\u5374\u628a\u5178\u793c\u7684\u514d\u8d39\u5165\u573a\u5238\u62ff\u5230\u7f51\u4e0a\u515c\u552e\uff0c\u8fd9\u79cd\u5546\u4e1a\u610f\u8bc6\u5927\u6982\u4e0d\u4e9a\u4e8e\u5f53\u5e74\u7684\u76d6\u8328\u3002\r\n\r\n\u3000\u3000\u636e\u62a5\u9053\uff0c\u5728\u6bd4\u5c14&#183;\u76d6\u8328\u83b7\u9881\u5b66\u4f4d\u4eea\u5f0f\u4e3e\u884c\u4e4b\u524d\uff0c\u7f8e\u56fd\u524d\u603b\u7edf\u6bd4\u5c14&#183;\u514b\u6797\u987f\u4e5f\u4e8e6\u65e5\u5149\u4e34\u4e86\u54c8\u4f5b\u5927\u5b66\u3002\u4e24\u4e2a\u201c\u6bd4\u5c14\u201d\u540d\u58f0\u8fdc\u626c\uff0c\u4ed6\u4eec\u6f14\u8bb2\u65f6\u7684\u5165\u573a\u5238\u4e5f\u6210\u4e86\u62a2\u624b\u8d27\u3002\u6570\u5341\u540d\u6301\u6709\u514d\u8d39\u5165\u573a\u5238\u7684\u5b66\u751f\u7075\u673a\u4e00\u52a8\uff0c\u5728\u7f51\u4e0a\u8f6c\u552e\u95e8\u7968\uff0c\u90e8\u5206\u53eb\u4ef7\u9ad8\u8fbe100\u7f8e\u5143\u3002\r\n\r\n\u3000\u3000\u6821\u65b9\u5f97\u77e5\u6709\u5b66\u751f\u51fa\u552e\u95e8\u7968\u725f\u5229\uff0c\u611f\u5230\u5341\u5206\u61ca\u607c\uff0c\u5e76\u901a\u8fc7\u7535\u90ae\u8b66\u544a\u4ed6\u4eec\u4e0d\u8981\u8fd9\u6837\u505a\u3002\r\n\r\n\u3000\u3000\u8bbf\u8c08\r\n\r\n\u3000\u3000\u6211\u4e0d\u4e3b\u5f20\u5927\u5bb6\u8f8d\u5b66\r\n\r\n\u3000\u3000\u4eca\u5e744\u6708\uff0c\u6bd4\u5c14&#183;\u76d6\u8328\u5728\u63a5\u53d7\u91c7\u8bbf\u65f6\u66fe\u8c08\u5230\u4e86\u8f8d\u5b66\u4e00\u4e8b\u3002\r\n\r\n\u3000\u3000\u8bb0\u8005\uff1a\u60a8\u662f\u572832\u5e74\u524d\u4ece\u54c8\u4f5b\u9000\u5b66\uff0c\u5f53\u65f6\u60a8\u4e3a\u4ec0\u4e48\u4f1a\u51b3\u5b9a\u9000\u5b66\uff1f\u60a8\u662f\u4e0d\u662f\u53d1\u73b0\u4e86\u4ec0\u4e48\uff1f\r\n\r\n\u3000\u3000\u76d6\u8328\uff1a\u6211\u548c\u6211\u7684\u670b\u53cb\u4fdd\u7f57&#183;\u827e\u4f26\u5171\u540c\u7ecf\u5386\u4e86\u7535\u8111\u53d1\u5c55\u7684\u5168\u90e8\u5386\u7a0b\uff0c\u56e0\u4e3a\u6211\u4eec\u975e\u5e38\u70ed\u8877\u4e8e\u4f7f\u7528\u7535\u8111\uff0c\u6211\u4ece13\u5c81\u8d77\u5c31\u662f\u8fd9\u6837\u3002\u6211\u4eec\u770b\u5230\u4e86\u4e00\u4e2a\u628a\u82af\u7247\u653e\u5230\u7535\u8111\u4e2d\u7684\u4e3b\u610f\uff0c\u6211\u4eec\u610f\u8bc6\u5230\u5b83\u53ef\u80fd\u4f1a\u4f7f\u7535\u8111\u7684\u8fd0\u7528\u4ea7\u751f\u5f88\u5927\u7684\u53d8\u5316\uff0c\u4f1a\u4f7f\u7535\u8111\u4ece\u5927\u673a\u6784\u4f7f\u7528\u7684\u7cfb\u7edf\u53d8\u6210\u4e2a\u4eba\u4f7f\u7528\u7684\u5de5\u5177\u2026\u2026\u5f53\u6211\u4eec\u770b\u5230\u7b2c\u4e00\u53f0\u4eba\u4eec\u82b1\u8d39\u4e0d\u591a\u5c31\u53ef\u4ee5\u4e70\u5230\u7684\u7535\u8111\u9762\u4e16\u7684\u65f6\u5019\uff0c\u6211\u4eec\u5c31\u51b3\u5b9a\u6211\u4eec\u5e94\u8be5\u52a0\u5165\u5230\u8fd9\u4e2a\u5e02\u573a\uff0c\u5e76\u7f16\u5199\u4e86BASIC\u8bed\u8a00\u3002\u6211\u4eec\u4e8e\u662f\u6210\u7acb\u4e86\u516c\u53f8\uff0c\u4e4b\u540e\u6211\u5c31\u540c\u610f\u9000\u5b66\u5e76\u4e14\u548c\u4ed6\u4eec\u4e00\u8d77\u505a\u8fd9\u4ef6\u4e8b\u3002\r\n\r\n\u3000\u3000\u8bb0\u8005\uff1a\u60a8\u4e3a\u6570\u767e\u4e07\u7684\u5e74\u8f7b\u4eba\u6811\u7acb\u4e86\u4e00\u4e2a\u699c\u6837\uff0c\u7279\u522b\u662f\u90a3\u4e9b\u73b0\u5728\u6b63\u5728\u5927\u5b66\u5c31\u8bfb\u7684\u5b66\u751f\uff0c\u4ed6\u4eec\u4f1a\u5f00\u73a9\u7b11\u5730\u8bf4\uff1a\u201c\u770b\uff0c\u6bd4\u5c14\u90fd\u4ece\u54c8\u4f5b\u9000\u5b66\u4e86\uff0c\u6211\u4eec\u53ef\u4ee5\u4ee5\u4ed6\u4e3a\u699c\u6837\u3002\u201d\r\n\r\n\u3000\u3000\u76d6\u8328\uff1a\u6211\u9f13\u52b1\u4eba\u4eec\u8fd8\u662f\u8981\u5b8c\u6210\u5b66\u4e1a\uff0c\u9664\u975e\u6709\u4e00\u4e9b\u975e\u5e38\u7d27\u8feb\u7684\uff0c\u6216\u8005\u662f\u4e0d\u5bb9\u9519\u8fc7\u7684\u4e8b\u60c5\u3002\u5b8c\u6210\u6240\u6709\u7684\u5b66\u4e1a\u4f1a\u597d\u5f97\u591a\u3002\u5b9e\u9645\u4e0a\uff0c\u5728\u6211\u79bb\u5f00\u54c8\u4f5b\u4e4b\u524d\uff0c\u6211\u5df2\u7ecf\u5728\u90a3\u513f\u5b66\u4e60\u4e86\u4e09\u5e74\u7684\u65f6\u95f4\u3002\u90a3\u6bb5\u65f6\u95f4\u4ee4\u6211\u975e\u5e38\u6109\u5feb\u3002\r\n\r\n\u3000\u3000\u8bb0\u8005\uff1a\u6240\u4ee5\u79bb\u60a8\u5b8c\u6210\u6240\u6709\u7684\u5b66\u4e1a\u53ea\u6709\u4e00\u5e74\u7684\u65f6\u95f4\u3002\r\n\r\n\u3000\u3000\u76d6\u8328\uff1a\u4e8b\u5b9e\u4e0a\u4ee5\u6211\u5f53\u65f6\u4fee\u5230\u7684\u5b66\u5206\uff0c\u65f6\u95f4\u5e94\u8be5\u6bd4\u8fd9\u4e2a\u8fd8\u8981\u77ed\u3002\u5982\u679c\u6211\