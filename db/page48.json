[{"url": "http://fotomen.cn/2011/09/carlos-gotay/", "title": "Carlos Gotay\uff1a\u65e0\u4e0e\u4f26\u6bd4\u7684\u7f8e\u4e3d | \u6444\u5f71\u4e4b\u53cb", "tags": "\u6444\u5f71 \u4eba\u50cf \u98ce\u5149 ", "name": "fotomen", "posttime": "2011-09-13 09:04:50", "ip": "218.249.83.129", "mark": 0, "note": "\u4e0d\u8bba\u662f\u9ed1\u767d\u8fd8\u662f\u5f69\u8272\uff0c\u4ed6\u7684\u6bcf\u4e00\u5e45\u4f5c\u54c1\u90fd\u4ee4\u4eba\u611f\u52a8\u3002\u5728\u8c08\u8d77\u5982\u4f55\u8d70\u4e0a\u6444\u5f71\u4e4b\u8def\u65f6\uff0cCarlos\u8fd9\u6837\u89e3\u91ca\uff1a\u201c\u6211\u8ba4\u4e3a\u6211\u5bf9\u827a\u672f\u548c\u6444\u5f71\u7684\u7231\u597d\u662f\u9057\u4f20\u7684\uff0c\u6211\u7684\u7236\u4eb2\u548c\u54e5\u54e5\u90fd\u662f\u753b\u5bb6\uff0c\u4ed6\u4eec\u90fd\u75af\u72c2\u5730\u7231\u597d\u6444\u5f71\uff0c\u5149\u6211\u81ea\u5df1\u5c31\u662f\u4e00\u540d\u6444\u9f84\u5df2\u8fbe30\u5e74\u7684\u53d1\u70e7\u53cb\u4e86\u3002\u201dCarlos\u8fd8\u8bf4\uff0c\u201c\u6211\u6ca1\u6709\u9ad8\u8d85\u7684\u6444\u5f71\u6280\u5de7\uff0c\u4f46\u6211\u6355\u6349\u6bcf\u4e00\u4e2a\u8ba9\u773c\u7403\u6109\u60a6\u7684\u753b\u9762\uff0c\u5e76\u4e14\u559c\u6b22\u5c1d\u8bd5\u62cd\u6444\u4e0d\u540c\u7684\u4e1c\u897f\u3002\u201d", "imagename": "1cd1335161b34e72b4bb0bbf63d19b43.jpg", "infoid": 488377, "category": "culture_picture", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "culture", "via": null, "real_tags": ["\u6444\u5f71", "\u4eba\u50cf", "\u98ce\u5149"]}, {"url": "http://fotomen.cn/2011/09/qianming/", "title": "\u6817\u5c71\u5343\u660e+\u8737\u5ddd\u5b9f\u82b1 \u30d7\u30ea\u30f3\u30bb\u30b9 | \u6444\u5f71\u4e4b\u53cb", "tags": "\u6444\u5f71 \u4eba\u50cf ", "name": "fotomen", "posttime": "2011-09-13 09:04:08", "ip": "218.249.83.129", "mark": 0, "note": "\u5979\u7684\u4f5c\u54c1\u4e00\u51fa\u73b0\u5728\u4e16\u4eba\u9762\u524d\uff0c\u4fbf\u8fc5\u901f\u5f97\u5230\u4e86\u5927\u5bb6\u7684\u8ba4\u53ef\u3002\u5728\u4e1c\u4eac\uff0c\u5982\u4eca\u5979\u7684\u4f5c\u54c1\u5c31\u50cf\u6b63\