bc.co.uk/1/hi/technology/7130416.stm\">http://doggdot.us/rd/92461/http://news.bbc.co.uk/1/hi/technology/7130416.stm</A></SPAN></P>", "imagename": null, "infoid": 38399, "category": "technology_hardware", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["ibm", "\u8ba1\u7b97\u673a\u5927\u5c0f"]}, {"url": "http://publish.it168.com/2007/1206/20071206019701.shtml", "title": "\u7acb\u8db3\u672c\u571f Firefox \u4e2d\u6587\u7248\u7275\u624b\u767e\u5ea6 - \u8f6f\u4ef6\u9891\u9053 | IT168", "tags": "Firefox \u767e\u5ea6 ", "name": "cacard", "posttime": "2007-12-07 23:49:11", "ip": "222.178.10.248", "mark": 5, "note": "\u6628\u65e5\uff0c\u5317\u4eac\u8c0b\u667a\u7f51\u7edc\u6280\u672f\u6709\u9650\u516c\u53f8\u5ba3\u5e03\uff0cFirefox\u4e0e\u767e\u5ea6\u5efa\u7acb\u5408\u4f5c\u4f19\u4f34\u5173\u7cfb\uff0c\u5c06\u5728\u5168\u90e8\u4e2d\u6587\u7248Firefox\u4e2d\u5185\u7f6e\u767e\u5ea6\u641c\u7d22\u5f15\u64ce\u3002\r\n\r\n\u3000\u3000\u636e\u4e86\u89e3\uff0c\u4e2d\u6587\u7248Firefox\u539f\u5df2\u5185\u7f6e\u767e\u5ea6\u641c\u7d22\uff0c\u6b64\u6b21\u53cc\u65b9\u5efa\u7acb\u6b63\u5f0f\u5408\u4f5c\u4f19\u4f34\u5173\u7cfb\u5c06\u4f7f\u73b0\u6709\u7684\u5408\u4f5c\u66f4\u52a0\u660e\u786e\uff0c\u767e\u5ea6\u65b9\u9762\u4e5f\u4f1a\u4e3aFirefox\u5728\u4e2d\u56fd\u7684\u63a8\u5e7f\u63d0\u4f9b\u66f4\u591a\u7684\u652f\u6301\u3002\r\n\r\n\u3000\u3000\u5728\u4e0e\u767e\u5ea6\u6b63\u5f0f\u5408\u4f5c\u4e4b\u524d\uff0cFirefox\u4e0eGoogle\u3001\u96c5\u864e\u7b49\u4e92\u8054\u7f51\u5de8\u5934\u5747\u6709\u7740\u6df1\u5165\u7684\u5408\u4f5c\u3002\u5c24\u5176\u662fGoogle\uff0c\u4e0d\u4ec5\u5229\u7528\u5176\u5f3a\u5927\u7684Adsense\u5e73\u53f0\u4e3aFirefox\u505a\u4e86\u5f88\u591a\u63a8\u5e7f\uff0c\u800c\u4e14\u6bcf\u5e74\u90fd\u4f1a\u5411Mozilla\u57fa\u91d1\u4f1a\u6ce8\u5165\u5927\u91cf\u7684\u8d44\u91d1\uff0c\u662fFirefox\u7684\u4e3b\u8981\u6536\u5165\u6765\u6e90\u3002\r\n\r\n\u3000\u3000\u6b64\u524d\uff0c\u6b64\u524d\u8c0b\u667a\u7f51\u7edc\u8463\u4e8b\u957f\u517cCEO\u5bab\u529b\u66fe\u516c\u5f00\u8868\u793a\uff0c\u4e0eGoogle\u7684\u5173\u7cfb\u4e0d\u4f1a\u5f71\u54cdFirefox\u4e0e\u5176\u4ed6\u516c\u53f8\u7684\u5408\u4f5c\uff0c\u8c0b\u667a\u7f51\u7edc\u5728\u4e2d\u56fd\u5df2\u7ecf\u5f00\u59cb\u548c\u5f88\u591a\u672c\u5730\u516c\u53f8\u63a5\u89e6\u3002\u5bf9\u4e8e\u672c\u6b21\u5408\u4f5c\uff0c\u5bab\u529b\u4e5f\u8868\u793a\uff1a\u201c\u8c0b\u667a\u7f51\u7edc\u4e00\u8d2f\u79c9\u627f\u5f00\u653e\u7684\u7406\u5ff5\uff0c\u81f4\u529b\u4e8e\u4e3a\u4e92\u8054\u7f51\u7528\u6237\u63d0\u4f9b\u591a\u6837\u5316\u7684\u4e0a\u7f51\u6d4f\u89c8\u9009\u62e9\u3002\u706b\u72d0\u6d4f\u89c8\u5668\u5728\u5168\u7403\u5360\u670920%\u7684\u5e02\u573a\u4efd\u989d\uff0c\u5b83\u4e2a\u6027\u5316\u3001\u91cf\u8eab\u5b9a\u5236\u7b49\u7279\u6027\u6df1\u53d7\u5e7f\u5927\u4e92\u8054\u7f51\u7528\u6237\u7684\u559c\u7231\u3002\u6b64\u6b21\u706b\u72d0\u6d4f\u89c8\u5668\u548c\u767e\u5ea6\u641c\u7d22\u5f15\u64ce\u7684\u7ed3\u5408\u662f\u6211\u4eec\u4e3a\u4e2d\u6587\u7f51\u7edc\u6d4f\u89c8\u7528\u6237\u63d0\u4f9b\u591a\u6837\u5316\u670d\u52a1\u7684\u5f00\u59cb\uff0c\u4eca\u540e\u706b\u72d0\u6d4f\u89c8\u5668\u4f1a\u5e26\u7ed9\u5927\u5bb6\u66f4\u591a\u53ef\u4f9b\u9009\u62e9\u7684\u670d\u52a1\u3002\u201d\r\n\r\n\u3000\u3000\u636e\u4e86\u89e3\uff0c\u672c\u6b21\u5408\u4f5c\u7684\u610f\u4e49\u4e0d\u4ec5\u4ec5\u662f\u5185\u5bb9\uff0c\u66f4\u91cd\u8981\u7684\u8fd8\u6709\u8d44\u91d1\u4e0a\u7684\u652f\u6301\uff0c\u901a\u8fc7\u628a\u5408\u4f5c\u4f19\u4f34\u5de5\u5177\u5d4c\u5165Firefox\uff0c\u8c0b\u667a\u7f51\u7edc\u53ef\u83b7\u5f97\u76f8\u5e94\u6536\u5165\u3002\u6b64\u524d\u8c0b\u667a\u7f51\u7edc\u4e00\u76f4\u4f9d\u8d56\u603b\u90e8\u7684\u652f\u6301\uff0c\u4f46\u5bab\u529b\u5e0c\u671b\u65e9\u65e5\u5e26\u9886\u8c0b\u667a\u7f51\u7edc\u5b9e\u73b0\u81ea\u8d1f\u76c8\u4e8f\uff0c\u672c\u6b21\u5408\u4f5c\u53ea\u662f\u4e00\u4e2a\u5f00\u59cb\uff0c\u8c0b\u667a\u7f51\u7edc\u5c06\u7ee7\u7eed\u53d1\u5c55\u672c\u571f\u5408\u4f5c\u4f19\u4f34\uff0c\u516c\u53f8\u672a\u6765\u7684\u6536\u5165\u5c06\u4e3b\u8981\u6765\u81ea\u4ed6\u4eec\u3002\u4e0d\u8fc7\uff0cFirefox\u76ee\u524d\u5c1a\u65e0\u6539\u53d8\u5185\u7f6e\u7684\u641c\u7d22\u5f15\u64ce\u987a\u5e8f\u7684\u8ba1\u5212\uff0c\u4e0e\u767e\u5ea6\u7b7e\u7ea6\u4ee5\u540e\uff0cGoogle\u4ecd\u5c06\u662f\u9ed8\u8ba4\u641c\u7d22\u5f15\u64ce\uff0c\u7528\u6237\u9700\u5728\u641c\u7d22\u6846\u7684\u4e0b\u62c9\u83dc\u5355\u4e2d\u624b\u52a8\u9009\u62e9\u767e\u5ea6\uff0c\u65b9\u53ef\u76f4\u63a5\u5728\u6b64\u4f7f\u7528\u767e\u5ea6\u641c\u7d22\u3002", "imagename": "", "infoid": 38397, "category": "technology_internet", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["firefox", "\u767e\u5ea6"]}, {"url": "http://news.163.com/07/1207/06/3V3C3V5G0001124J.html", "title": "\u6b27\u9633\u81ea\u8fdc\u5f3a\u8c03\u6708\u7167\u771f\u5b9e \u79f0\u62fc\u63a5\u8bef\u5dee\u4e0d\u503c\u4e00\u8c08(\u56fe)_\u7f51\u6613\u65b0\u95fb\u4e2d\u5fc3", "tags": "\u5ae6\u5a25\u4e00\u53f7 ", "name": "cacard", "posttime": "2007-12-07 23:36:15", "ip": "222.178.10.248", "mark": 5, "note": "\u6838\u5fc3\u63d0\u793a\uff1a12\u67086\u65e5\uff0c\u201c\u5ae6\u5a25\u4e00\u53f7\u201d\u5de5\u7a0b\u9996\u5e2d\u79d1\u5b66\u5bb6\u6b27\u9633\u81ea\u8fdc\u8868\u793a\uff0c\u5bf9\u4e8e\u6709\u7f51\u53cb\u6000\u7591\u5ae6\u5a25\u7167\u7247\u7684\u95ee\u9898\uff0c\u6000\u7591\u7167\u7247\u7684\u771f\u5b9e\u6027\u662f\u5bf9\u6211\u4eec\u56fd\u5bb6\u7684\u4fae\u8fb1\uff0c\u662f\u5bf917000\u540d\u5de5\u4f5c\u4eba\u5458\u5de5\u4f5c\u6210\u679c\u7684\u5426\u5b9a\u3002\u6b27\u9633\u81ea\u8fdc\u8868\u793a\u8fd9\u201c\u4e0d\u5bb9\u4efb\u4f55\u6000\u7591\u201d\u3002", "imagename": "203b698f6bbc48b39730695884f00bd8.jpg", "infoid": 38392, "category": "technology_other", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u5ae6\u5a25\u4e00\u53f7"]}, {"url": "http://www.cnetnews.com.cn/2007/1206/671940.shtml", "title": "\u4f20\u6234\u5c14\u62df\u8d2d\u6469\u6258\u7f57\u62c9\u63a8iPhone\u6740\u624b \u5b98\u65b9\u62d2\u7edd\u8bc4\u4ef7 - CNET\u79d1\u6280\u8d44\u8baf\u7f51", "tags": "\u6234\u5c14 \u6469\u6258\u7f57\u62c9 ", "name": "cacard", "posttime": "2007-12-07 23:33:05", "ip": "222.178.10.248", "mark": 4, "note": "\u4ece\u4f20\u8a00\u6536\u8d2dPalm\uff0c\u5230\u5ba3\u5e03\u63a8\u51faPAD\u624b\u6301\u8bbe\u5907\u5e02\u573a\uff0c\u518d\u5230\u8fd1\u65e5\u66dd\u51fa\u62df\u6536\u8d2d\u6469\u6258\u7f57\u62c9\u7684\u4f20\u95fb\u2014\u2014\u5728\u8fc8\u514b\u5c14\u3002\u6234\u5c14\u5fc3\u4e2d\uff0c\u4f3c\u4e4e\u4e00\u76f4\u8426\u7ed5\u7740\u4e00\u4e2a\u624b\u673a\u68a6\u3002\r\n\r\n\u8fd1\u65e5\uff0c\u6709\u6d88\u606f\u79f0\uff0c\u6234\u5c14\u5c06\u6709\u610f\u6536\u8d2d\u6469\u6258\u7f57\u62c9\u8fdb\u519b\u624b\u673a\u5e02\u573a\uff0c\u5e76\u4e14\u5c06\u63a8\u51fa\u7c7b\u4f3c\u82f9\u679ciPhone\u624b\u673a\u7684\u4ea7\u54c1\u3002\r\n\r\n\u5728\u63a5\u53d7CNET\u79d1\u6280\u8d44\u8baf\u7f51\u91c7\u8bbf\u65f6\uff0c\u6234\u5c14\u4e2d\u56fd\u4e00\u4f4d\u76f8\u5173\u8d1f\u8d23\u4eba\u8868\u793a\uff0c\u6211\u4eec\u65e0\u6cd5\u5bf9\u8fd9\u79cd\u4f20\u95fb\u4f5c\u51fa\u8bc4\u4ef7\u3002\u5373\u4f7f\u53d1\u751f\u5e76\u8d2d\u4e5f\u662f\u7f8e\u56fd\u603b\u90e8\u7684\u4e8b\u60c5\uff0c\u4e2d\u56fd\u516c\u53f8\u8fd9\u8fb9\u5e76\u4e0d\u77e5\u60c5\u3002\r\n\r\n\u4e00\u4f4d\u4e1a\u5185\u4eba\u58eb\u5206\u6790\u6307\u51fa\uff0c\u6234\u5c14\u5728\u624b\u6301\u4ee5\u53ca\u624b\u673a\u4e1a\u52a1\u4e0a\u4e00\u76f4\u975e\u5e38\u91cd\u89c6\uff0c\u4f46\u662f\u5176PDA\u4e1a\u52a1\u5e76\u4e0d\u7406\u60f3\u3002\u5728\u4eca\u5e744\u6708\u4efd\uff0c\u6234\u5c14\u9000\u51faPDA\u5e02\u573a\u4e4b\u540e\uff0c\u4f46\u662f\u4e00\u76f4\u8fd8\u5728\u9500\u552ePalm\u548c\u591a\u666e\u8fbe\u7684\u624b\u673a\u3002\u8fd9\u4f3c\u4e4e\u4e5f\u610f\u5473\u7740\u5176\u5bf9\u624b\uff08\u6301\uff09\u673a\u5e02\u573a\u7684\u4f9d\u4f9d\u4e0d\u820d\u3002\r\n\r\n\u6234\u5c14\u516c\u53f8\u521a\u521a\u53d1\u5e03\u76842008\u8d22\u5e74\u7b2c\u4e09\u8d22\u5b63\u8d22\u52a1\u62a5\u544a\u663e\u793a\uff0c\u516c\u53f8\u6536\u5165\u8f83\u53bb\u5e74\u540c\u671f\u589e\u957f9%\uff0c\u521b\u4e0b\u516c\u53f8\u5386\u53f2\u6700\u597d\u4e1a\u7ee9\uff0c\u8fbe\u5230156\u4ebf\u7f8e\u5143\uff1b\u8425\u4e1a\u5229\u6da6\u4e0a\u6da813%\uff0c\u4e3a8.29\u4ebf\u7f8e\u5143\uff1b\u6bcf\u80a1\u6536\u76ca\u8fbe34\u7f8e\u5206\uff0c\u540c\u6bd4\u589e\u957f26%\u3002\r\n\r\n\u672c\u8d22\u5b63\uff0c\u8fd0\u8425\u4ea7\u751f\u7684\u73b0\u91d1\u603b\u8ba1 10\u4ebf\u7f8e\u5143\uff0c\u516c\u53f8\u6301\u6709\u7684\u73b0\u91d1\u548c\u6709\u4ef7\u8bc1\u5238\u603b\u989d\u9ad8\u8fbe146\u4ebf\u7f8e\u5143\u3002\u516c\u53f8\u8ba1\u5212\u572812\u6708\u521d\u7ee7\u7eed\u5b9e\u65bd\u80a1\u7968\u56de\u8d2d\u8ba1\u5212\u3002\r\n\r\n\u6234\u5c14\u516c\u53f8\u8463\u4e8b\u957f\u517c\u9996\u5e2d\u6267\u884c\u5b98\u8fc8\u514b\u5c14\u2022\u6234\u5c14\u6307\u51fa\uff0c\u6234\u5c14\u76ee\u524d\u7684\u4e94\u9879\u6218\u7565\u91cd\u70b9\u5305\u62ec\u6d88\u8d39\u8005\u4e1a\u52a1\u3001\u65b0\u5174\u5e02\u573a\u3001\u7b14\u8bb0\u672c\u7535\u8111\u3001\u4f01\u4e1a\u7ea7\u548c\u4e2d\u5c0f\u4f01\u4e1a\u5e02\u573a\u4e1a\u52a1\u3002\u800c\u5176\u5229\u6da6\u7684\u589e\u957f\u5f97\u76ca\u4e8e\u79fb\u52a8\u4e1a\u52a1\u7684\u8d21\u732e\u3001\u5ba2\u6237\u5bf9\u4f01\u4e1a\u7ea7\u4ea7\u54c1\u7684\u5f3a\u52b2\u9700\u6c42\u548c\u6301\u7eed\u8d70\u4f4e\u7684\u96f6\u90e8\u4ef6\u6210\u672c\u3002\r\n\r\n\u8fc8\u514b\u5c14\u2022\u6234\u5c14\u900f\u9732\uff0c\u672a\u6765\uff0c\u6234\u5c14\u5c06\u7ee7\u7eed\u5173\u6ce8\u4e8e\u6838\u5fc3\u6218\u7565\uff0c\u4e3a\u5ba2\u6237\u63d0\u4f9b\u66f4\u9ad8\u7684\u4ef7\u503c\uff0c\u540c\u65f6\u52aa\u529b\u5b9e\u73b0\u8d44\u91d1\u6d41\u52a8\u7387\u3001\u6536\u76ca\u7387\u548c\u589e\u957f\u4e4b\u95f4\u7684\u6700\u4f73\u5e73\u8861\u3002\u5728\u5b9e\u65bd\u8fd9\u4e9b\u6218\u7565\u7684\u8fc7\u7a0b\u4e2d\uff0c\u516c\u53f8\u5728\u8fdb\u884c\u8c03\u6574\u7684\u540c\u65f6\u5c06\u7ee7\u7eed\u4ea7\u751f\u76f8\u5173\u8d39\u7528\uff0c\u7528\u4e8e\u8fdb\u4e00\u6b65\u63d0\u9ad8\u751f\u4ea7\u529