00\u53d1\u8bba\u575b,\u624b\u673a,\u5f00\u53d1,\u8bba\u575bIPHONE,ANDROID,WINDOWSPHONE,BLACKBERRY,WEBOS\u5145\u7535\u5668\u5df2\u7ecf\u6210\u4e3a\u6211\u4eec\u65e5\u5e38\u751f\u6d3b\u7684\u5fc5\u5907\uff0c\u4f46\u4f60\u4e5f\u8bb8\u4e0d\u4f1a\u60f3\u5230\uff0c\u8bbe\u8ba1\u8005\u5728\u4e00\u4e2a\u5c0f\u5c0f\u7684\u5145\u7535\u5668\u4e0a\u4e5f\u53ef\u4ee5\u7422\u78e8\u51fa\u8fd9\u4e48\u591a\u7684\u82b1\u6837\u6765\u3002\u4ee5\u4e0b\u662f12\u6b3e\u6700\u5177\u521b\u610f\u5e76\u4e14\u6700\u4e3a\u75af\u72c2\u7684\u624b\u673a\u5145\u7535\u5668\uff0c\u8110\u5e26\u9020\u578biPhone\u5145\u7535\u5668\u3001\u592a\u9633\u80fd\u6811\u5f62\u5145\u7535\u5668\u3001\u9b54\u65b9\u5145\u7535\u5668\u548c\u6e9c\u6e9c\u7403\u5145\u7535\u5668\u7eb7\u7eb7\u699c\u4e0a\u6709\u540d\u3002\u6709\u4e86\u8fd9\u4e9b\u6216\u6709\u8da3\u3001\u6216\u602a\u5f02\u53c8\u6216\u8005\u53e6\u7c7b\u5341\u8db3\u7684\u5145\u7535\u5668\uff0c\u672c\u5c31\u9177\u9177\u7684\u79fb\u52a8\u8bbe\u5907\u5438\u5f15\u4eba\u773c\u7403\u7684\u529f\u592b\u81ea\u7136\u662f\u66f4\u4e0a\u4e00\u5c42\u697c\u3002\u6e9c\u6e9c\u7403iPhone\u5145\u7535\u5668\r\n\u4e0d\u77e5\u9053\u8981\u5145\u6ee1iPhone4\u8981\u73a9\u591a\u4e45\u6e9c\u6e9c\u7403\u2026\u6709\u4e86\u8fd9\u6b3e\u5145\u7535\u5668\uff0c\u4f60\u4fbf\u53ef\u5b9e\u73b0\u73a9\u6e9c\u6e9c\u7403\u548c\u4e3a\u82f9\u679ciPhone\u5145\u7535\u4e24\u4e0d\u8bef\u3002\u6e9c\u6e9c\u7403\u5145\u7535\u5668\u88c5\u6709\u4e00\u5757\u5c0f\u578b\u9502\u7535\u6c60\uff0c\u53ef\u4ee5\u50a8\u5b58\u4ea7\u751f\u7684\u7535\u91cf\u3002\u4e5f\u5c31\u662f\u8bf4\uff0c\u4f60\u53ef\u4ee5\u5148\u73a9\u4e0a\u4e00\u4f1a\u6e9c\u6e9c\u7403\u4ea7\u751f\u5e76\u50a8\u5b58\u7535\u91cf\uff0c\u800c\u540e\u518d\u4e3aiPhone\u5145\u7535\u3002\u592a\u9633\u80fd\u6811\u5f62\u5145\u7535\u5668\u8fd9\u6837\u4e00\u76f4\u653e\u5728\u592a\u9633\u5e95\u4e0b\uff0ciPhone4\u5b89\u5168\u561b\uff1f\u592a\u9633\u80fd\u6811\u5f62\u5145\u7535\u5668\u5916\u8868\u9753\u4e3d\u8bf1\u4eba\uff0c\u521b\u610f\u5473\u9053\u5341\u8db3\u3002\u5b83\u662f\u5148\u8fdb\u5de5\u7a0b\u5b66\u624b\u6bb5\u6253\u9020\u7684\u70ab\u9177\u4e4b\u4f5c\uff0c\u88c5\u670954\u5757\u592a\u9633\u80fd\u7535\u6c60\u3002\u53ea\u8981\u6709\u9633\u5149\u7684\u5730\u65b9\uff0c\u4f60\u4fbf\u53ef\u4ee5\u4e3a\u81ea\u5df1\u7684\u79fb\u52a8\u8bbe\u5907\u5145\u7535\uff0c\u53ef\u8c13\u662f\u7ed9\u70b9\u9633\u5149\u5c31\u707f\u70c2\u3002\u4f46\u5982\u679c\u6ca1\u6709\u9633\u5149\uff0c\u8fd9\u6b3e\u5145\u7535\u5668\u53ef\u80fd\u5c31\u53ea\u662f\u4e00\u4e2a\u7f8e\u4e3d\u7684\u6446\u8bbe\u3002\u503c\u5f97\u4e00\u63d0\u7684\u662f\uff0c\u592a\u9633\u80fd\u6811\u5f62\u5145\u7535\u5668\u7684\u6240\u6709\u6811\u679d\u5747\u53ef\u8c03\u8282\uff0c\u4ee5\u786e\u4fdd\u6bcf\u4e00\u5757\u592a\u9633\u80fd\u7535\u6c60\u5bf9\u51c6\u592a\u9633\u3002\u590d\u53e4\u7248iPhone\u5145\u7535\u5668\u5145\u7535\u5668\u517c\u8033\u673a\u529f\u80fd\uff0c\u4e00\u4e3e\u4e24\u5f97\u8fd9\u6b3e\u602a\u5f02\u7684\u5145\u7535\u5668\u540d\u4e3a\u201ciRetrofone\u84b8\u6c7d\u670b\u514b\u94dc\u5236iPhone4dock\u201d\uff0c\u91c7\u7528\u590d\u53e4\u8bbe\u8ba1\uff0c\u5916\u5f62\u662f\u4e00\u90e8\u8001\u7535\u8bdd\uff0c\u80fd\u591f\u5728\u6781\u5927\u7a0b\u5ea6\u4e0a\u6fc0\u53d1\u7528\u6237\u7684\u6000\u65e7\u60c5\u7eea\u3002\u5728\u6ee1\u8db3\u4e3aiPhone\u5145\u7535\u7684\u540c\u65f6\uff0c\u8fd9\u6b3e\u5145\u7535\u5668\u4e5f\u4e0d\u5931\u4e3a\u4e00\u4ef6\u7cbe\u7f8e\u7684\u827a\u672f\u54c1\u3002\u590d\u53e4\u7535\u8bdd\u9020\u578b\u5145\u7535\u5668\u91c7\u7528\u5168\u94dc\u6253\u9020\uff0c\u201c\u4f53\u91cd\u201d\u53ef\u60f3\u800c\u77e5\uff0c\u4f46\u8fd9\u79cd\u91cd\u91cf\u7ea7\u4e5f\u7ed9\u4eba\u4e00\u79cd\u539a\u91cd\u611f\u3002\u8fd9\u6b3eiPhone\u5145\u7535\u5668\u662f\u5bf9\u7528\u6237\u8d22\u529b\u7684\u4e00\u79cd\u8003\u9a8c\u3002\u4ece\u94f8\u9020\u3001\u96d5\u5851\u5230\u629b\u5149\u6253\u78e8\uff0c\u6bcf\u4e00\u4e2a\u5145\u7535\u5668\u5747\u7531\u827a\u672f\u5bb6\u65af\u79d1\u7279\u5f17\u91cc\u5170\u5fb7\u624b\u5de5\u6253\u9020\uff0c\u8fd9\u4e5f\u5c31\u662f\u4e3a\u4ec0\u4e48\u552e\u4ef7\u9ad8\u8fbe450\u7f8e\u5143\u3002\u8fd9\u4e00\u4ef7\u683c\u7edd\u5bf9\u662f\u4e00\u4e2a\u5929\u4ef7\uff0c\u56e0\u4e3a\u4e24\u90e8iPhone4\u7684\u552e\u4ef7\u4e5f\u6ca1\u6709\u8fbe\u5230\u8fd9\u4e2a\u6570\u3002\u4f46\u6709\u4e00\u70b9\u6211\u4eec\u4e5f\u5e94\u8be5\u610f\u8bc6\u5230\uff0c\u5145\u7535\u5668\u81f3\u5c11\u4e0d\u7528\u50cfiPhone\u4e00\u6837\uff0c\u7b7e\u7f72\u4efb\u4f55\u4e24\u5e74\u5408\u7ea6\u3002\u8110\u5e26\u9020\u578biPhone\u5145\u7535\u5668\u8fd8\u8bb0\u5f97\u6211\u4eec\u653e\u8fc7\u7684\u89c6\u9891\u5417\uff1f\u6076\u5fc3\u5230\u4e00\u5b9a\u7684\u5730\u6b65\u554a\u8110\u5e26\u548ciPhone\u663e\u7136\u662f\u4e24\u4e2a\u516b\u7aff\u5b50\u4e5f\u6253\u4e0d\u7740\u7684\u4e1c\u897f\uff0c\u65e0\u8bba\u600e\u4e48\u5f00\u53d1\u60f3\u8c61\u529b\uff0c\u4f60\u53ef\u80fd\u6c38\u8fdc\u4e5f\u4e0d\u4f1a\u5c06\u5b83\u4eec\u7ec4\u5408\u5728\u540c\u4e00\u4e2a\u53e5\u5b50\u91cc\uff0c\u5c24\u5176\u662f\u5728\u6709\u5173\u79fb\u52a8\u8bbe\u5907\u7684\u6587\u7ae0\u4e2d\u3002\u7136\u800c\uff0c\u6211\u4eec\u4e5f\u5fc5\u987b\u6e05\u695a\u5730\u610f\u8bc6\u5230\uff0ciPhone\u5411\u6765\u5c31\u64c5\u957f\u4e0e\u5404\u79cd\u602a\u5f02\u7684\u4e8b\u7269\u7ed3\u5408\u5728\u4e00\u8d77\uff0c\u4e0e\u8110\u5e26\u6302\u94a9\u4f30\u8ba1\u4e5f\u96be\u4e0d\u5012\u5b83\u3002\r\n\u7c73\u5965\u4f0a\u624e\u74e6\u662f\u4e00\u4f4d\u5a92\u4f53\u827a\u672f\u5bb6\uff0c\u6b63\u662f\u4ed6\u521b\u9020\u4e86\u6211\u4eec\u4ece\u6ca1\u6709\u89c1\u8fc7\u7684\u6700\u602a\u5f02\u7684iPhone\u914d\u4ef6\u2014\u2014\u8110\u5e26\u9020\u578biPhone\u5145\u7535\u5668\u3002\u8fd9\u6b3e\u5145\u7535\u5668\u7edd\u4e0d\u662f\u8ba9\u4f60\u5c06iPhone\u63d2\u5728\u771f\u5b9e\u7684\u8110\u5e26\u4e0a\u3002\u60f3\u8c61\u4e00\u4e0b\uff0c\u4e00\u6839\u63d2\u7740iPhone\u5e76\u4e14\u4e0d\u65ad\u8815\u52a8\u7684\u8110\u5e26\uff0c\u90a3\u79cd\u666f\u8c61\u4e00\u5b9a\u975e\u5e38\u6050\u6016\u3002\u8fd9\u6b3e\u5145\u7535\u5668\u4e0d\u8fc7\u662f\u91c7\u7528\u8110\u5e26\u7684\u9020\u578b\u7f62\u4e86\u3002\u63d2\u4e0a\u4e4b\u540e\u7ed9\u4eba\u7684\u611f\u89c9\u662f\uff0c\u8fd9\u4e2a\u8110\u5e26\u4f3c\u4e4e\u8981\u5c06iPhone\u541e\u566c\uff0c\u800c\u5b9e\u9645\u4e0a\u5374\u662f\u6062\u590d\u5b83\u7684\u751f\u673a\u4e0e\u6d3b\u529b\u3002\u771f\u5e0c\u671b\u8bfb\u8005\u4ece\u6ca1\u6709\u542c\u8bf4\u8fc7\u8fd9\u6b3e\u5145\u7535\u5668\uff0c\u56e0\u4e3a\u8110\u5e26\u7684\u9020\u578b\uff0c\u5b83\u5728\u89c6\u89c9\u4e0a\u6beb\u65e0\u7f8e\u611f\u53ef\u8a00\uff0c\u751a\u81f3\u4f1a\u5f71\u54cd\u4eba\u7684\u80c3\u53e3\u3002\u4f46\u4e0d\u7ba1\u600e\u6837\uff0c\u51ed\u501f\u8110\u5e26\u9020\u578b\u8fd9\u4e00\u5f88\u591a\u4eba\u65e0\u6cd5\u60f3\u5230\u7684\u521b\u610f\uff0c\u8fd9\u90fd\u4e0d\u5931\u4e3a\u4e00\u6b3e\u9177\u9177\u7684\u5145\u7535\u8bbe\u5907\u3002\r\n[/url][url=http://www.fansp.net/wp-content/uploads/2010/10/p97058021-52.jpg][url=http://www.fansp.net/tag/%e5%90%89%e6%99%ae%e8%b5%9b/]\u5409\u666e\u8d5b[/url]\u5c0f\u5077\u7684\u84b8\u6c7d\u670b\u514b\u5145\u7535\u5668\u600e\u4e48\u770b\u90fd\u50cf\u662f\u827a\u672f\u652f\u67b6\u591a\u4e00\u70b9\u5409\u666e\u8d5b\u5c0f\u5077\u7684\u84b8\u6c7d\u670b\u514b\u5145\u7535\u5668\u5982\u679c\u5df2\u7ecf\u62e5\u6709\u4e00\u6b3e\u84b8\u6c7d\u670b\u514b\u98ce\u683c\u7684\u4ea7\u54c1\uff0c\u4f60\u4e00\u5b9a\u4f1a\u559c\u6b22\u8fd9\u6b3eiPhone/iPod\u5145\u7535\u5668\u3002\u8fd9\u6b3e\u5145\u7535\u5668\u51fa\u81ea\u51ef\u52d2\u7c73\u52d2\u7684\u56e2\u961f\u201c\u201d\u4e4b\u624b\u3002\u7c73\u52d2\u7ef0\u53f7\u201c\u7626\u5c0f\u7684\u5409\u666e\u8d5b\u5c0f\u5077\u201d\uff0c\u5f39\u5409\u4ed6\u7684\u65f6\u5019\uff0c\u4ed6\u7a81\u53d1\u5947\u60f3\uff0c\u51b3\u5b9a\u4e3aiPhone\u548ciPod\u8bbe\u8ba1\u4e00\u6b3e\u84b8\u6c7d\u670b\u514b\u98ce\u683c\u7684Dock\u5e95\u5ea7\u3002\u4ed6\u8ba4\u4e3a\uff0c\u8482\u59c6\u4f2f\u987f\u53ef\u80fd\u4f1a\u4e3a\u4ed6\u7684iPod\u6216\u8005iPhone\u51c6\u5907\u8fd9\u6837\u4e00\u4e2a\u5145\u7535\u5668\u3002\u84b8\u6c7d\u670b\u514b\u5145\u7535\u5668\u6027\u80fd\u51fa\u8272\uff0c\u6211\u4eec\u5e0c\u671b\u80fd\u591f\u5728\u4e0d\u4e45\u540e\u5728\u7c73\u52d2\u7684Etsy\u5e97\u94fa\u4e0a\u770b\u5230\u5b83\u4eec\u7684\u8eab\u5f71\u3002\u8001\u5f0fiPod\u7535\u5b50\u7ba1\u653e\u5927\u5668/\u5145\u7535\u5668\u8fd9\u4e2a\u6211\u6700\u559c\u6b22\uff0c\u7b26\u5408\u6211\u7684\u54c1\u5473\u5bf9\u4e8e\u90a3\u4e9b\u6562\u4e8e\u4e0e\u4f17\u4e0d\u540c\u7684\u4eba\u6765\u8bf4\uff0c\u8fd9\u6b3e\u5145\u7535\u5668\u7edd\u5bf9\u662f\u4e00\u4e2a\u4f1f\u5927\u7684\u8bbe\u8ba1\u3002\u8001\u5f0fiPod\u7535\u5b50\u7ba1\u653e\u5927\u5668/\u5145\u7535\u5668\u5177\u6709\u5f88\u5f3a\u7684\u79d1\u5e7b\u8272\u5f69\u3002\u5b83\u62e5\u6709\u84b8\u6c7d\u670b\u514b\u98ce\u683c\u5916\u89c2\uff0c\u597d\u4f3c\u4e00\u4e2a\u75af\u72c2\u79d1\u5b66\u5bb6\u7684\u201c\u8001\u5de2\u201d\u3002\u5236\u9020\u8005\u8868\u793a\uff0c\u7528\u6237\u53ef\u4ee5\u4f7f\u7528\u53ea\u6709\u8001\u5f0f\u7535\u5b50\u7ba1\u653e\u5927\u5668\u624d\u80fd\u63d0\u4f9b\u7684\u754c\u9762\u53cb\u597d\u800c\u5185\u5bb9\u4e30\u5bcc\u7684\u64ad\u653e\u5217\u8868\u3002\u867d\u7136\u5e76\u4e0d\u6e05\u695a\u8fd9\u6b3e\u653e\u7535\u5668\u7684\u6027\u80fd\uff0c\u4f46\u51ed\u501f\u70ab\u9177\u7684\u5916\u89c2\uff0c\u5f88\u591a\u4eba\u4e00\u5b9a\u4f1a\u559c\u6b22\u8fd9\u79cd\u8bbe\u8ba1\u3002\u4f7f\u7528\u65f6\uff0c\u7528\u6237\u9700\u8981\u5c06iPod\u63d2\u5165\u5145\u7535\u5668\uff0c\u800c\u540e\u5c31\u662f\u5750\u4e0b\u6765\u6d4f\u89c8\u4ed6\u4eec\u7684\u64ad\u653e\u5217\u8868\u3002\u501f\u52a9\u4e8e\u6bcf\u9891\u905325\u74e6\u7279RMS\u5168\u7535\u5b50\u7ba1\u524d\u7f6e\u653e\u5927\u5668\uff0c\u538b\u7f29MP3\u65f6\u4e22\u5931\u7684\u97f3\u9891\u7ec6\u8282\u4f1a\u620f\u5267\u6027\u5730\u518d\u6b21\u51fa\u73b0\u3002\u8fd9\u6b3e\u5145\u7535\u5668\u552e\u4ef7800\u7f8e\u5143\uff0c\u5bf9\u4e8e\u666e\u901a\u4eba\u800c\u8a00\uff0c\u663e\u7136\u6709\u4e9b\u8d35\u5f97\u79bb\u8c31\u3002\u867d\u7136\u80fd\u591f\u627e\u56de\u4e22\u5931\u7684\u97f3\u9891\u7ec6\u8282\uff0c\u4f46\u6211\u4eec\u4e2d\u4e00\u4e9b\u4eba\u663e\u7136\u5e76\u4e0d\u5728\u4e4e\u5931\u53bb\u8fd9\u4e9b\u65e0\u6cd5\u50cf\u97f3\u4e50\u4e00\u6837\u201c\u5165\u8033\u201d\u7684\u4e1c\u897f\u3002\u70e4\u9762\u5305\u673a\u9020\u578b\u5145\u7535\u8fd9\u662f\u65c5\u884c\u5145\u7535\u5305\uff0c\u5bb9\u91cf\u8fd8\u53ef\u4ee5\u81ea\u5df1\u6269\u5c55\r\n\u70e4\u9762\u5305\u673a\u9020\u578b\u6982\u5ff5\u5145\u7535\u5668\u7531\u8bbe\u8ba1\u5e08Hyun-AKo\u6253\u9020\uff0c\u62e5\u6709\u5404\u79cd\u5c3a\u5bf8\uff0c\u53ef\u4ee5\u6ee1\u8db3\u4e0d\u540c\u5c3a\u5bf8\u9502\u7535\u6c60\u7684\u5145\u7535\u9700\u8981\u3002\u4f7f\u7528\u8fd9\u6b3e\u5145\u7535\u5668\u5145\u7535\u5c31\u50cf\u70e4\u9762\u5305\u4e00\u6837\u3002\u7528\u6237\u9996\u5148\u5c06\u7535\u6c60\u585e\u8fdb\u69fd\u91cc\uff0c\u800c\u540e\u6309\u4e0b\u64cd\u4f5c\u67c4\uff0c\u5145\u7535\u5b8c\u6210\u540e\uff0c\u7535\u6c60\u4f1a\u50cf\u70e4\u597d\u7684\u9762\u5305\u4e00\u6837\u5f39\u51fa\u3002\u4e00\u4e9b\u4eba\u5728\u4f7f\u7528\u70e4\u9762\u5305\u673a\u65f6\u603b\u662f\u628a\u9762\u5305\u7247\u70e4\u7126\uff0c\u4e0d\u77e5\u9053\u4ed6\u4eec\u4f7f\u7528\u8fd9\u6b3e\u5145\u7535\u5668\u65f6\uff0c\u4f1a\u4e0d\u4f1a\u6709\u5fc3\u7406\u9634\u5f71?\u592a\u9633\u80fd\u80f8\u7f69\u5145\u7535\u5668\r\n\u9edb\u5b89\u82ac\u8ddfiPod\u90fd\u80fd\u626f\u4e0a\u5173\u7cfb\uff0c\u8fd9\u4e16\u754c\u4e5f\u592a\u75af\u72c2\u4e86\r\n\u90a3\u4e9b\u5e0c\u671b\u4e3a\u80f8\u90e8\u4e5f\u62ab\u4e0a\u4e00\u4ef6\u201c\u7eff\u8863\u201d\u7684\u5973\u6027\u4e0d\u4e45\u4e4b\u540e\u53ef\u80fd\u5c31\u6709\u673a\u4f1a\u4f53\u9a8c\u592a\u9633\u80fd\u80f8\u7f69\u5145\u7535\u5668\u8fd9\u4e2a\u5c0f\u53d1\u660e\u3002\u592a\u9633\u80fd\u80f8\u7f69\u5145\u7535\u5668\u7531\u65e5\u672c\u8bbe\u8ba1\u4eba\u5458\u6253\u9020\uff0c\u6240\u4ea7\u751f\u7684\u7535\u91cf\u8db3\u53ef\u4ee5\u6ee1\u8db3iPod\u6216\u8005\u624b\u673a\u7684\u5145\u7535\u9700\u6c42\u3002\u5b83\u901a\u8fc7\u7528\u6237\u4f69\u6234\u5728\u8179\u90e8\u7684\u592a\u9633\u80fd\u7535\u6c60\u677f\u53d1\u7535\u3002\u4f46\u5982\u6b64\u8bbe\u8ba1\u9762\u4e34\u7684\u95ee\u9898\u4e5f\u662f\u663e\u800c\u6613\u89c1\u2014\u2014\u5982\u679c\u5973\u6027\u76db\u88c5\u51fa\u884c\u800c\u4e0d\u662f\u4e00\u8eab\u77ed\u6253\u626e\uff0c\u9633\u5149\u5982\u4f55\u7a7f\u8fc7\u8863\u7269\u5e76\u62b5\u8fbe\u5230\u7535\u89c6\u677f\u5462?\r\n\u592a\u9633\u80fd\u80f8\u7f69\u5145\u7535\u5668\u751f\u4ea7\u5546\u2014\u2014\u9edb\u5b89\u82ac\u56fd\u9645\u65e5\u672c\u6709\u9650\u516c\u53f8\u5973\u53d1\u8a00\u4eba\u76ca\u7530\u7f8e\u5b50\u8868\u793a\uff1a\u201c\u8003\u8651\u5230\u5973\u6027\u901a\u5e38\u4e0d\u53ef\u80fd\u4e0d\u7a7f\u8863\u670d\u5c31\u5916\u51fa\uff0c\u8fd9\u79cd\u5145\u7535\u5668\u53ef\u80fd\u5f88\u96be\u5f97\u5230\u5b9e\u9645\u5e94\u7528\u3002\u80fd\u591f\u4f7f\u7528\u8fd9\u79cd\u5145\u7535\u5668\u7684\u5730\u65b9\u53ef\u80fd\u4ec5\u9650\u4e8e\u7528\u6237\u81ea\u5bb6\u9633\u53f0\u6216\u8005\u82b1\u56ed\u7b49\u4e3a\u6570\u4e0d\u591a\u7684\u5730\u65b9\u3002\u201d\u6beb\u4e0d\u4ee4\u4eba\u611f\u5230\u60ca\u8bb6\u7684\u662f\uff0c\u592a\u9633\u80fd\u80f8\u7f69\u91c7\u7528\u8bf1\u4eba\u7684\u7eff\u8272\u8bbe\u8ba1\uff0c\u65e2\u53ef\u4ee5\u5c06\u592a\u9633\u80fd\u8f6c\u6362\u6210\u7535\u80fd\uff0c\u4e3a\u79fb\u52a8\u8bbe\u5907\u5145\u7535\uff0c\u4e5f\u53ef\u4ee5\u76f4\u63a5\u63a5\u901a\u7535\u6e90\uff0c\u5f53\u6210\u666e\u901a\u5145\u7535\u5668\u4f7f\u7528\u3002\r\n\u53ef\u7231\u718a\u9020\u578b\u5145\u7535\u5668\u8fd9\u4e2a\u6811\u718a\u5145\u7535\u5668\u9020\u578b\u76f8\u5f53\u53ef\u7231\u8fd9\u5934\u53ef\u7231\u7684\u718a\u8db4\u5728\u5899\u58c1\u63d2\u5ea7\u4e0a\u5e72\u4ec0\u4e48?iPod\u6570\u636e\u7ebf\u53c8\u5bf9\u718a\u718a\u505a\u4e86\u4e9b\u4ec0\u4e48\u5462?\u7b54\u6848\u662f\u4e3aiPod\u5145\u7535\u3002\u8fd9\u6b3e\u53ef\u7231\u718a\u9020\u578biPod\u5145\u7535\u5668\u51fa\u81ea\u65e5\u672c\u8bbe\u8ba1\u5e08\u4e4b\u624b\uff0c\u552e\u4ef71980\u65e5\u5143(\u7ea6\u540821.75\u7f8e\u5143)\u3002\u867d\u7136\u4e0d\u77e5\u9053\u5177\u4f53\u5728\u4ec0\u4e48\u5730\u65b9\u9500\u552e\uff0c\u4e5f\u4e0d\u6e05\u695a\u5546\u5bb6\u91c7\u53d6\u4f55\u79cd\u9500\u552e\u65b9\u5f0f\uff0c\u4f46\u4ece\u5bcc\u6709\u521b\u