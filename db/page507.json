b4c\u66f2\u3002\u4e0b\u4e00\u6b21\u4efb\u4f55\u4eba\u641c\u7d22\u8fd9\u9996\u6b4c\u65f6\uff0c\u60a8\u7684\u6f14\u5531\u90fd\u53ef\u80fd\u4f1a\u6210\u4e3a\u9996\u6761\u641c\u7d22\u7ed3\u679c\uff01\u60a8\u8fd8\u53ef\u4ee5\u5728 midomi \u5efa\u7acb\u81ea\u5df1\u7684\u6863\u6848\uff0c\u6f14\u5531\u60a8\u81ea\u5df1\u559c\u7231\u7684\u6b4c\uff0c\u4e0e\u670b\u53cb\u5206\u4eab\u8fd9\u4e9b\u6b4c\u66f2\uff0c\u800c\u4e14\u8fd8\u80fd\u8ba9\u5176\u4ed6 midomi \u7528\u6237\u8ba4\u8bc6\u60a8\u3002\u60a8\u53ef\u4ee5\u8046\u542c\u5176\u4ed6\u4eba\u7684\u6f14\u5531\uff0c\u4e3a\u4ed6\u4eec\u6253\u5206\u3001\u89c2\u770b\u4ed6\u4eec\u7684\u56fe\u7247\u3001\u7ed9\u4ed6\u4eec\u53d1\u9001\u6d88\u606f\u3001\u8d2d\u4e70\u539f\u521b\u4e50\u66f2\uff0c\u7b49\u7b49\u3002\r\n\r\n\u3000\u3000midomi\u7684\u6838\u5fc3\u57fa\u4e8e MARS\uff08multimodal adaptive recognition system\uff1d\u590d\u5408\u9002\u5e94\u8bc6\u522b\u7cfb\u7edf\uff09\u6784\u5efa\uff0c\u4ee5\u6b64\u5b9e\u73b0\u4e86\u6211\u4eec\u4ece\u6765\u4e0d\u66fe\u5b9e\u73b0\u7684\u529f\u80fd\u5e94\u7528\u3002\u751a\u81f3\u8c37\u6b4c\uff0c\u767e\u5ea6\u97f3\u4e50\u641c\u7d22\u90fd\u6ca1\u6709\u8fd9\u6837\u7684\u529f\u80fd\u3002\u4e92\u8054\u7f51\u6c38\u8fdc\u90fd\u4e0d\u7f3a\u65b0\u5e94\u7528\uff0c\u8fd8\u6709\u66f4\u591a\u60f3\u5f97\u5230\u505a\u4e0d\u5230\u7684\u5e94\u7528\uff0c\u751a\u81f3\u662f\u60f3\u90fd\u60f3\u4e0d\u5230\u7684\u5e94\u7528\uff0c\u7b49\u7740\u4f60\u53bb\u53d1\u6398\u2026\u2026\r\n\r\n\u70b9\u51fb\u8fdb\u5165\uff1aMidomi\r\nTechnorati \u6807\u7b7e: web2.0,\u5e94\u7528,\u97f3\u4e50", "imagename": "0fdbe24a3a9249cbad6759ff022a3bf6.png", "infoid": 152894, "category": "technology_web2", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["web2.0", "\u5e94\u7528", "\u97f3\u4e50"]}]