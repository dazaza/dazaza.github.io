r\n\u90a3\u4e2a\u6709\u70b9inter\u7684\u98ce\u683c", "imagename": "bb710ea814214ab8a1584e43bfde0b0d.gif", "infoid": 21587, "category": "technology_design", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["diglog"]}, {"url": "http://amazon.cn", "title": "&quot;\u5353\u8d8a\u7f51\u201d\u6b63\u5f0f\u6539\u4e3a\u201c\u5353\u8d8a\u4e9a\u9a6c\u900a&quot;", "tags": "\u5353\u8d8a\u7f51 \u4e9a\u9a6c\u900a ", "name": "yinyin", "posttime": "2007-06-05 12:19:46", "ip": "58.212.139.214", "mark": 9, "note": "\u4eb2\u7231\u7684\u5353\u8d8a\u7f51\u5ba2\u6237:\u60a8\u597d\r\n\u4eca\u5929,\u6211\u4eec\u5df2\u7ecf\u5ba3\u5e03\u4e86\u5353\u8d8a\u7f51\u7ad9\u51e0\u9879\u4ee4\u4eba\u5174\u594b\u7684\u6539\u8fdb.\r\n\u9996\u5148,\u6211\u4eec\u5c06\u7f51\u7ad9\u540d\u79f0\u4ece\u201c\u5353\u8d8a\u7f51\u201d\u6539\u6210\u201c\u5353\u8d8a\u4e9a\u9a6c\u900a\u201d.\u8fd9\u4e00\u6539\u53d8\u53cd\u5e94\u51fa\u4e86\u5353\u8d8a\u7f51\u4e0e\u4e9a\u9a6c\u900a\u7684\u5bc6\u5207\u5408\u4f5c\u4f19\u4f34\u5173\u7cfb.\u4e9a\u9a6c\u900a\u662f\u5168\u7403\u9886\u5148\u7684\u7f51\u4e0a\u96f6\u552e\u5546\u4e4b\u4e00,\u501f\u52a9\u4e9a\u9a6c\u900a\u7684\u6280\u672f\u548c\u7ecf\u9a8c,\u5353\u8d8a\u7f51\u5458\u5de5\u4e3a\u4e2d\u56fd\u7684\u6d88\u8d39\u8005\u63d0\u4f9b\u4e86\u5353\u6709\u6210\u6548\u7684\u670d\u52a1.\r\n\r\n\r\n\r\n    \u4e3a\u4e86\u5e86\u795d\u65b0\u6210\u7acb\u7684\u8054\u540d\u7f51\u7ad9,\u5353\u8d8a\u7f51\u63a8\u51fa\u4e86\u4e00\u9879\u7279\u522b\u7684\u4fc3\u9500\u6d3b\u52a8\u2014\u2014\u201c\u96f6\u5143\u514d\u8d39\u9001\u8d27\u201d.\u4ee5\u524d,\u5353\u8d8a\u7f51\u4f1a\u4e3a\u8d2d\u7269\u6ee199\u5143\u7684\u5ba2\u6237\u63d0\u4f9b\u514d\u8d39\u9001\u8d27\u670d\u52a1\u2014\u2014\u4f46\u662f\u73b0\u5728\u65e0\u8bba\u60a8\u8ba2\u8d2d\u4e86\u591a\u5c11\u94b1\u7684\u5546\u54c1,\u90fd\u53ef\u4ee5\u4eab\u53d7\u5230\u514d\u8d39\u9001\u8d27\u7684\u4f18\u60e0.\u6211\u4eec\u8ba4\u4e3a\u8fd9\u662f\u60a8\u4eb2\u81ea\u4f53\u9a8c\u5353\u8d8a\u7f51\u51fa\u8272\u7684\u4ea7\u54c1\u548c\u670d\u52a1\u7684\u4e00\u4e2a\u7edd\u597d\u7684\u65b9\u6cd5. \r\n\r\n    \u6700\u540e,\u6211\u4eec\u63a8\u51fa\u4e86\u201c\u6211\u7684\u5353\u8d8a\u7f51\u201d\u670d\u52a1.\u8fd9\u662f\u7f51\u7ad9\u7684\u4e00\u9879\u65b0\u529f\u80fd,\u53ef\u4ee5\u6839\u636e\u60a8\u7684\u8d2d\u7269\u53ca\u6d4f\u89c8\u8bb0\u5f55\u4e3a\u60a8\u63d0\u4f9b\u4e2a\u6027\u5316\u7684\u6d88\u8d39\u5efa\u8bae,\u56e0\u6b64\u60a8\u53ef\u4ee5\u53d1\u73b0\u8fde\u60a8\u81ea\u5df1\u90fd\u6ca1\u610f\u8bc6\u5230\u7684\u4f60\u9700\u8981\u7684\u5546\u54c1.\r\n\r\n    \u5168\u4f53\u5353\u8d8a\u7f51/\u4e9a\u9a6c\u900a\u7684\u5458\u5de5\u5c06\u4e00\u5982\u65e2\u5f80\u5730\u81f4\u529b\u4e8e\u6539\u5584\u60a8\u7684\u8d2d\u7269\u4f53\u9a8c,\u6253\u9020\u4e16\u754c\u4e00\u6d41\u7684\u5ba2\u6237\u670d\u52a1.\u6211\u4eec\u8877\u5fc3\u5730\u5e0c\u671b\u60a8\u80fd\u559c\u6b22\u6211\u4eec\u7684\u65b0\u7f51\u7ad9,\u5728\u6b64\u5bf9\u60a8\u7684\u5149\u987e\u8868\u793a\u8bda\u631a\u7684\u611f\u8c22.\r\n\u001f  \r\n\u6770\u592b&#183;\u8d1d\u7d22\u65af \u4e9a\u9a6c\u900a\u516c\u53f8\u521b\u529e\u4eba\r\n\u548c\r\n\u738b\u6c49\u534e \u5353\u8d8a\u7f51\u603b\u88c1", "imagename": "1a5eeb900b8c42c49db5992073f78749.gif", "infoid": 21586, "category": "technology_internet", "isanchordig": 1, "ischecked": 1, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u5353\u8d8a\u7f51", "\u4e9a\u9a6c\u900a"]}, {"url": "http://hirise.lpl.arizona.edu/", "title": "NASA\u5411\u516c\u4f17\u516c\u5e031.7TB\u5bb9\u91cf\u7684\u706b\u661f\u7167\u7247", "tags": "NASA ", "name": "yinyin", "posttime": "2007-06-05 12:12:03", "ip": "58.212.139.214", "mark": 7, "note": "\u5728NASA\u4e13\u95e8\u8d1f\u8d23\u9ad8\u89e3\u6790\u5ea6\u56fe\u7247\u62cd\u6444\u7684&quot;Mars Reconnaissance Orbiter&quot;\u521a\u521a\u5c061200\u5f20\u706b\u661f\u56fe\u7247,\u5171\u8ba1\u5bb9\u91cf1.7\u4e2aTB\u5168\u90e8\u516c\u4e4b\u4e8e\u4f17,\u4ed6\u4eec\u5c06\u8fd9\u4e9b\u6570\u636e\u63d0\u4f9b\u5230\u4e13\u4e1a\u7a