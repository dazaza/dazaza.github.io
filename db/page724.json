5148\u5173\u6ce8\u63d0\u9ad8\u6536\u5165\u548c\u5229\u6da6\u3002</P>\r\n<P>\u3000\u3000\u6700\u8fd1\uff0cDigg\u5f00\u59cb\u5728\u5176RSS\u53cd\u9988\u529f\u80fd\u4e2d\u51fa\u552e\u5e7f\u544a\u3002\u516c\u53f8\u6b63\u5728\u5f00\u53d1\u672c\u5730\u5316<A href=\"http://search.iresearch.cn/\" target=_blank>\u641c\u7d22\u5f15\u64ce</A>\uff0c\u5e0c\u671b\u4ee5\u6b64\u5f00\u53d1\u66f4\u591a\u7684\u76f8\u5173\u548c\u6709\u76ca\u5e7f\u544a\u3002\u4e00\u6708\u5185\uff0cDigg\u5c06\u4e0e\u79fb\u52a8\u548c\u5e7f\u544a\u63d0\u4f9b\u5546\u8fbe\u6210\u5408\u4f5c\u534f\u8bae\uff0c\u5728\u624b\u673a\u4e0a\u51fa\u552e\u66f4\u591a\u7684\u5e7f\u544a\u3002\u4ed6\u8868\u793a\uff1a\u201c\u6211\u4eec\u5c06\u7406\u6027\u6295\u8d44\uff0c\u5173\u6ce8\u4e8e\u5229\u6da6\u589e\u957f\uff0c\u6b64\u524d\u6211\u4eec\u4e0d\u662f\u8fd9\u6837\u505a\u7684\u3002\u201d\u4ed6\u8868\u793a\uff0c\u53d7\u7ecf\u6d4e\u5371\u673a\u7684\u5f71\u54cd\uff0c\u516c\u53f8\u52a0\u5feb\u4e86\u53d1\u5c55\u6b65\u4f10\u3002\u4eca\u5e749\u6708\uff0cDigg\u79f0\uff0c\u8fc7\u5e74\u516c\u53f8\u7684\u6536\u5165\u589e\u957f\u4e86\u4e09\u500d\u3002\u660e\u5e74\uff0c\u4ed6\u9884\u6d4b\u201c\u81f3\u5c11\u4f1a\u518d\u589e\u957f\u4e09\u500d\u201d\u3002\u4eca\u5e74\u65e9\u4e9b\u65f6\u5019\uff0c\u4ed6\u6307\u51fa\uff0c\u516c\u53f8\u8981\u5728\u4e24\u5e74\u5185\u5b9e\u73b0\u8d62\u5229\u3002\u73b0\u5728\uff0c\u4ed6\u8868\u793a\u5e0c\u671b\u5728\u4e00\u5e74\u5185\u5b8c\u6210\u8fd9\u4e00\u4efb\u52a1\u3002</P>\r\n<P>\u3000\u3000\u4eca\u5e749\u6708\uff0cDigg\u4ece\u98ce\u6295\u7ec4\u7ec7Highland Capital Partners\uff0c Greylock Partners\uff0c Omidyar Network\u548cSVB Capital\u83b7\u5f97\u4e86\u7ea62870\u4e07\u7f8e\u5143\u7684\u6295\u8d44\u3002\u4ed6\u6307\u51fa\uff0cDigg\u6b63\u5728\u8003\u8651\u8fdb\u884c\u81ea\u5df1\u7684\u6536\u8d2d\u3002\u5c3d\u7ba1\u516c\u53f8\u672a\u5b8c\u6210\u4e00\u8d77\u6536\u8d2d\uff0c\u4f46\u6b63\u5728\u5bfb\u627e\u6536\u8d2d\u7684\u5bf9\u8c61\u3002\u201c\u5728\u4e16\u754c\u5404\u5730\uff0c\u90fd\u6709Digg\u514b\u9686\u7f51\u7ad9\u3002\u6211\u5c06\u8fdb\u5165\u8fd9\u4e9b\u5e02\u573a\u6e05\u7406\u8fd9\u4e9b\u7f51\u7ad9\uff0c\u5982\u679c\u6211\u9700\u8981\u66f4\u591a\u7684\u8d44\u672c\u6765\u5b8c\u6210\u6536\u8d2d\uff0c\u6211\u4e5f\u4f1a\u7ee7\u7eed\u878d\u8d44\u3002\u201d\u5982\u679cDigg\u4e0d\u518d\u662f\u88ab\u6536\u8d2d\u7684\u5bf9\u8c61\uff0c\u516c\u53f8\u5c31\u5fc5\u987b\u9762\u4e34\u589e\u957f\u7684\u538b\u529b\uff0c\u4ece<A href=\"http://web2.iresearch.cn/58\" target=_blank>\u793e\u533a</A>\u7528\u6237\u8eab\u4e0a\u83b7\u5f97\u5229\u6da6\u3002\u5c3d\u7ba1Digg\u5ba3\u79f0\u6bcf\u6708\u67093500\u4e07\u7528\u6237\uff0c\u4f46\u636e\u5e02\u573a\u7814\u7a76\u7ec4\u7ec7comScore\u79f0\uff0cDigg\u622a\u6b62\u4eca\u5e7410\u6708\u5728\u5168\u7403\u67091630\u4e07\u7528\u6237\uff0c\u540c\u6bd4\u589e\u957f\u4e8631%.\u4f46\u662f\uff0cDigg\u575a\u6301\u81ea\u5df1\u7edf\u8ba1\u7684\u6570\u636e\u3002\u4ed6\u6307\u51fa\uff0ccomScore\u7684panel\u7edf\u8ba1\u65b9\u6cd5\u4f4e\u4f30\u4e86\u793e\u4ea4\u7f51\u7ad9\u7684\u6d41\u91cf\u3002\u4ed6\u6307\u51fa\uff0c\u516c\u53f8\u7684\u7edf\u8ba1\u6570\u636e\u57fa\u4e8eOmniture\u548cQuantcast\u7ec4\u7ec7\u7684\u6570\u636e\u3002\u4f46\u636eQuantcast\u7684\u6570\u636e\uff0c\u622a\u6b6211\u670830\u65e5\uff0cDigg\u5ba3\u4f20\u7528\u6237\u6570\u91cf\u4e3a2170\u4e07\u4eba\u3002</P>\r\n<P>\u3000\u3000\u76ee\u524d\uff0c\u5411\u56fd\u9645\u5e02\u573a\u62d3\u5c55\u672a\u5217\u5165\u4f18\u5148\u8ba1\u5212\uff0cDigg\u8868\u793a\u63d0\u9ad8\u7f51\u7ad9\u7684\u627f\u8bfa\u6bd4\u4ee5\u5f80\u66f4\u4e3a\u91cd\u8981\u3002\u5728\u672a\u6765\u51e0\u4e2a\u6708\u5185\uff0cDigg\u5c06\u63a8\u51fa\u65b0\u529f\u80fd\uff0c\u65e8\u5728\u5438\u5f15\u5404\u5730\u7528\u6237\u3002\u201c\u76ee\u524d\uff0c\u6211\u4eec\u670915\u81f320\u9879\u5de5\u4f5c\u8981\u505a\u3002\u201d\u4f7fDigg\u7f51\u7ad9\u66f4\u793e\u4ea4\u5316\uff0c\u4e3a\u7528\u6237\u66f4\u6709\u5438\u5f15\u529b\u7684\u5185\u5bb9\u3002\u5982\u679c\u8fd9\u4e00\u6218\u7565\u6210\u529f\uff0c\u968f\u7740\u66f4\u591a\u7528\u6237\u70b9\u51fb\u7f51\u9875\uff0c\u5b83\u5c06\u5e2e\u52a9\u516c\u53f8\u5b9e\u73b0\u8d62\u5229\u3002\u201c\u901a\u8fc7\u5438\u5f15\u66f4\u591a\u7528\u6237\uff0c\u6295\u653e\u66f4\u591a\u5e7f\u544a\uff0c\u53ef\u4ee5\u5b9e\u73b0\u8d62\u5229\u3002\u201d\u6700\u8fd1\uff0c\u6709\u62a5\u9053\u79f0\uff0cAdelson\u548c\u7f51\u7ad9\u521b\u59cb\u4eba\u51ef\u6587o\u7f57\u65af\u7b49\u5728\u51fa\u552e\u624b\u4e2d\u7684\u80a1\u7968\u3002\u5bf9\u6b64\uff0c\u4ed6\u6307\u51fa\uff0c\u201c\u516c\u53f8\u56e2\u961f\u5185\u6ca1\u6709\u4eba\u51fa\u552e\u80a1\u7968\u3002\u6211\u4e0e\u51ef\u6587\u6301\u6709\u516c\u53f8\u5927\u7b14\u7684\u80a1\u7968\uff0c\u6211\u4eec\u76f8\u4fe1\uff0c\u672a\u6765\u524d\u666f\u66f4\u597d\u3002\u201d</P>\r\n<P>\u827e\u745e\u7f51</P>", "imagename": null, "infoid": 108276, "category": "technology_web2", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["digg"]}, {"url": null, "title": "\u524dAOL\u9996\u5e2d\u6267\u884c\u5b98\u7b79\u8d44\u8d2d\u4e70\u96c5\u864e", "tags": "AOL \u96c5\u864e ", "name": "yinyin", "posttime": "2008-12-03 11:23:47", "ip": "222.128.48.207", "mark": 1, "note": "<P>\u5fae\u8f6f\u6536\u8d2d\u96c5\u864e\u4f20\u95fb\u4e2d\u7684\u4e3b\u89d2\u4e4b\u4e00\uff0c<STRONG>\u524dAOL\u9996\u5e2d\u6267\u884c\u5b98Jonathan Miller\u5bf9\u5916\u8868\u793a\uff0c\u4ed6\u6b63\u5728\u5bfb\u6c42\u5fd7\u540c\u9053\u5408\u7684\u6295\u8d44\u8005\u62ff\u51fa300\u4ebf\u7f8e\u5143\uff0c\u8d2d\u4e70\u5168\u90e8\u6216\u90e8\u5206\u96c5\u864e\u516c\u53f8\u3002</STRONG></P>\r\n<P><IMG style=\"BORDER-RIGHT: black 1px solid; BORDER-TOP: black 1px solid; BORDER-LEFT: black 1px solid; BORDER-BOTTOM: black 1px solid\" height=204 alt=\u524dAOL\u9996\u5e2d\u6267\u884c\u5b98\u7b79\u8d44\u8d2d\u4e70\u96c5\u864e src=\"http://news.mydrivers.com/img/20081203/10253418.jpg\" width=160><BR><STRONG>Jonathan Miller</STRONG></P>\r\n<P>\u4f46\u662f\uff0c\u5ba2\u89c2\u539f\u56e0\u662f\u5728\u7ecf\u6d4e\u5371\u673a\u7684\u5927\u80cc\u666f\u4e0b\uff0c\u641e\u8fd9\u4e48\u591a\u94b1\u5e76\u975e\u6613\u4e8b\uff0c\u94f6\u884c\u4e0d\u613f\u8d37\u6b3e\uff0c\u5df2\u7ecf\u88ab\u7ecf\u6d4e\u5371\u673a\u6298\u78e8\u7684\u56db\u5206\u4e94\u88c2\u7684\u5176\u4ed6\u516c\u53f8\u66f4\u662f\u4e0d\u53ef\u80fd\u51fa\u94b1\u3002</P>\r\n<P>Miller\u8868\u793a\uff0c<STRONG>\u4ed6\u5e0c\u671b\u80fd\u5728\u96c5\u864e\u80a1\u4ef7\u6da8\u523020-22\u7f8e\u5143\u4e4b\u524d\uff0c\u7b79\u96c6\u5230280\u4ebf\u6216300\u4ebf\u7f8e\u5143\u4e70\u4e0b\u6574\u5bb6\u96c5\u864e\u516c\u53f8</STRONG>\u3002\u800c\u6839\u636e\u76ee\u524d\u7684\u80a1\u4ef7\uff0c\u96c5\u864e\u516c\u53f8\u7684\u5e02\u503c\u4e3a157\u4ebf\u3002</P>\r\n<P>\u636e\u6089\uff0cMiller\u4ece2002\u5e74\u81f32006\u5e74\u95f4\u9886\u5bfcAOL\uff0c\u65f6\u4ee3\u534e\u7eb3\u5728\u7ebf\u5e7f\u544a\u90e8\u95e8\u3002Collins Stewart\u7684\u5206\u6790\u5e08Sandeep Aggrawal\u8bc4\u4ef7\u8bf4\u201cMiller\u662f\u4e00\u4e2a\u6709\u4e92\u8054\u7f51\u8fdc\u89c1\u7684\uff0c\u91cd\u89c6\u5de5\u4f5c\u7684\u4eba\uff0c\u4ed6\u5728AOL\u505a\u7684\u5f88\u597d\u201d</P>\r\n<P>\u4f46\u5206\u6790\u5bb6\u5bf9Miller\u7684\u8ba1\u5212\u80fd\u5426\u6210\u529f\u4ecd\u6301\u6000\u7591\u6001\u5ea6\uff0c\u9274\u4e8e\u76ee\u524d\u7684\u5e02\u573a\u73af\u5883\u548c\u96c5\u864e\u7684\u591a\u91cd\u6311\u6218\uff08\u5305\u62ec\u6768\u81f4\u8fdc\u5728\u5bfb\u627e\u65b0\u7684CEO\uff0c\u5728\u7ebf\u5e7f\u544a\u5e02\u573a\u5728\u65e5\u76ca\u7f29\u5c0f\u7b49\uff09\u3002\u5206\u6790\u5e08\u8ba4\u4e3a\uff1a\u201c\u73b0\u5728\u6211\u5f88\u96be\u76f8\u4fe1\u8c01\u80fd\u62ff\u51fa\u6765\u8fd9\u4e48\u591a\u95f2\u94b1\u4e70\u96c5\u864e\u201d\u3002</P>\r\n<P><SPAN style=\"DISPLAY: inline\"><A class=newstiao3 href=\"http://www.mydrivers.com/\" target=_blank><FONT color=#4c4c4c>\u9a71\u52a8\u4e4b\u5bb6</FONT></A></SPAN></P>", "imagename": null, "infoid": 108275, "category": "technology_internet", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["aol", "\u96c5\u864e"]}, {"