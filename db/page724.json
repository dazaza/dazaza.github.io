488\u5bf9\u767e\u5ea6\u7ade\u4ef7\u6392\u540d\u53d1\u8868\u81ea\u5df1\u7ecf\u5178\u7684\u89c2\u70b9\uff1b\u5728\u56fd\u5916\uff0c\u96c5\u864e\u6768\u81f4\u8fdc\u4e0b\u8bfe\u4e5f\u662f\u88ab\u4e1a\u754c\u5e7f\u4e3a\u8bc4\u8bf4\uff0c\u5fae\u8f6f\u6536\u8d2d\u96c5\u864e\u7684\u4e8b\u60c5\u662f\u4e4e\u8fd8\u6ca1\u7ed3\u675f\uff0c\u5fae\u8f6f\u5728\u4e0a\u5468\u7684\u80a1\u4e1c\u5927\u4f1a\u4e0a\u8868\u793a\u4ecd\u613f\u4e3a\u96c5\u864e\u655e\u5f00\u5927\u95e8\uff0c\u5728\u641c\u7d22\u9886\u57df\u5c55\u5f00\u5408\u4f5c\uff0c\u4f46\u5374\u4ece\u672a\u653e\u677e\u5bf9LiveSearch\u7684\u6295\u5165\uff0c\u4ece\u73b0\u91d1\u56de\u9988\uff08CashBack\uff09\u670d\u52a1\u5230\u6536\u8d2dPowerset\u5f15\u64ce\uff0c\u8fd9\u4e9b\u4f53\u73b0\u4e86\u5fae\u8f6f\u5bf9LiveSearch\u7684\u671f\u671b\u548c\u8fdb\u5165\u641c\u7d22\u5f15\u64ce\u7684\u91ce\u5fc3\u548c\u51b3\u5fc3\u3002\r\n<P>\u3000\u3000\u5fae\u8f6f\u76ee\u524d\u6b63\u5728\u7740\u624b\u5c06LiveSearch\u548c\u5176\u5b83WindowsLive\u4ea7\u54c1\u4ee5\u53caWindows\u7ed3\u5408\u8d77\u6765\uff0c\u5e76\u4e14\u8017\u8d443\u4ebf\u7f8e\u5143\uff0c\u53d1\u8d77\u4e86\u201cWindows\uff0c\u65e0\u754c\u751f\u6d3b\u201d\u7684\u5e7f\u544a\u6d3b\u52a8\uff0c\u8bb8\u591a\u4e1a\u754c\u4eba\u58eb\u731c\u6d4b\uff0c\u5fae\u8f6f\u5c06\u4f1a\u4e3a\u8fd9\u79cd\u6574\u5408\u7684\u670d\u52a1\u91cd\u65b0\u9009\u4e00\u4e2a\u7edf\u4e00\u7684\u540d\u79f0\u3002</P>\r\n<P>\u3000\u300011\u670824\u65e5\u6d88\u606f\uff0c\u636e\u56fd\u5916\u5a92\u4f53\u62a5\u9053\uff0c\u4e00\u4e9b\u7ec6\u5fc3\u7684\u7f51\u6c11\u8fd1\u65e5\u53d1\u73b0\uff0c\u5fae\u8f6f\u6b64\u524d\u5df2\u6536\u8d2d\u4e86Kumo.com\u57df\u540d\uff0c\u5e76\u6307\u5411\u4e00\u4e2a\u4ec5\u5411\u5fae\u8f6f\u5185\u90e8\u5458\u5de5\u5f00\u653e\u7684\u6d4b\u8bd5\u7f51\u7ad9\u3002\u5206\u6790\u4eba\u58eb\u5bf9\u6b64\u8868\u793a\uff0c\u5fae\u8f6f\u5f88\u6709\u53ef\u80fd\u628aKumo\u4f5c\u4e3aLive\u641c\u7d22\u7684\u65b0\u54c1\u724c\u3002\u957f\u671f\u4ece\u4e8b\u5fae\u8f6f\u5e02\u573a\u52a8\u6001\u7814\u7a76\u7684\u7f8e\u56fd\u4f5c\u5bb6\u739b\u4e3d\u3002\u4e54\u3002\u5f17\u83b1\uff08MaryJoFoley\uff09\u6570\u6708\u524d\u66fe\u900f\u9732\uff0c\u5fae\u8f6f\u6b63\u8003\u8651\u5bf9Live\u641c\u7d22\u8fdb\u884c\u91cd\u65b0\u547d\u540d\u3002\u5982\u679c\u6b64\u5f17\u83b1\u7684\u8fd9\u79cd\u8bf4\u6cd5\u5c5e\u5b9e\uff0cKumo\u65e0\u7591\u5c06\u662fLive\u641c\u7d22\u7684\u5019\u9009\u540d\u79f0\u4e4b\u4e00\u3002\u636e\u6089\uff0cKumo\u5728\u65e5\u8bed\u4e2d\u4e3a\u201c\u4e91\u201d\u548c\u201c\u8718\u86db\u201d\u4e4b\u610f\uff0c\u56e0\u6b64\u8be5\u540d\u79f0\u4e5f\u6697\u542b\u4e86\u5fae\u8f6f\u5c06\u5927\u529b\u8fdb\u5165\u4e91\u8ba1\u7b97\u5e02\u573a\u7684\u4f01\u56fe\u3002</P>\r\n<P>\u3000\u3000\u6765\u81eaLiveSide.Net\u7f51\u7ad9\u7684\u6d88\u606f\u79f0\uff0c\u5fae\u8f6f\u5df2\u7ecf\u83b7\u5f97\u4e86Kumo.com\u57df\u540d\uff0c\u5e76\u4e14\u5728\u5185\u90e8\u5c55\u5f00\u6d4b\u8bd5\uff0c\u5c06\u90e8\u5206<A class=hui14_line href=\"http://detail.zol.com.cn/server_index/subcate31_list_1.html\"><FONT style=\"COLOR: #333\">\u670d\u52a1\u5668</FONT></A>\u91cd\u65b0\u5b9a\u5411\u5230\u8be5\u5730\u5740\u3002\u51e0\u4e2a\u6708\u524d\u5c31\u6709\u6d88\u606f\u79f0\uff0c\u5fae\u8f6f\u5bf9\u201cLive\u641c\u7d22\u201d\u54c1\u724c\u5e76\u4e0d\u6ee1\u610f\uff0c\u5e76\u4e14\u5df2\u7ecf\u915d\u917f\u51fa\u4e09\u4e2a\u65b0\u7684\u5019\u9009\u54c1\u724c\uff1aBing\u3001Hook\u548cKumo.\u5982\u4eca\u770b\u6765\uff0cKumo\u6709\u671b\u6210\u4e3a\u5fae\u8f6f\u641c\u7d22\u7684\u65b0\u54c1\u724c\u3002\u5f53\u7136\uff0c\u76ee\u524d\u8fd8\u4e0d\u80fd\u786e\u5b9aLive\u641c\u7d22\u5c06\u66f4\u540d\u4e3aKumo\uff0c\u4f46\u6211\u4eec\u53ef\u4ee5\u4ece\u4e2d\u5f97\u51fa\u4e00\u4e2a\u7ed3\u8bba\uff1a\u5fae\u8f6f\u6536\u8d2d\u96c5\u864e\u7684\u53ef\u80fd\u6027\u8d8a\u6765\u8d8a\u5c0f\uff0c\u66f4\u6362\u641c\u7d22\u54c1\u724c\u610f\u5473\u7740\u5fae\u8f6f\u5df2\u51b3\u5b9a\u4f9d\u9760\u81ea\u8eab\u529b\u91cf\u53d1\u5c55\u641c\u7d22\u4e1a\u52a1\u3002\u4e92\u8054\u7f51\u5b75\u5316\u4e13\u5bb6\u9ec4\u76f8\u5982\u548c\u591a\u6570\u5206\u6790\u4eba\u58eb\u8ba4\u4e3a\uff0c\u65e0\u8bba\u5fae\u8f6f\u662f\u5426\u5c06\u628aKumo\u4f5c\u4e3aLive\u641c\u7d22\u7684\u65b0\u540d\u79f0\uff0c\u5c31\u76ee\u524d\u800c\u8a00\uff0c\u5982\u679c\u5fae\u8f6f\u5e0c\u671b\u5927\u529b\u63d0\u9ad8\u641c\u7d22\u5b9e\u529b\uff0c\u6700\u4f73\u529e\u6cd5\u8fd8\u662f\u6536\u8d2d\u96c5\u864e\u3002</P>\r\n<P>\u3000\u3000\u63d0\u5347LiveSearch\u7684\u641c\u7d22\u8d28\u91cf\u867d\u7136\u662f\u6700\u6839\u672c\u7684\u95ee\u9898\uff0c\u4e0d\u8fc7\u54c1\u724c\u7684\u6253\u9020\u65b9\u9762\u4e5f\u4e0d\u5bb9\u5ffd\u89c6\uff0c\u5c3d\u7ba1LiveSearch\u7684\u4ee3\u53f7\u662fRome\uff0c\u4f46\u6b63\u5f0f\u63a8\u51fa\u7684\u540d\u5b57\u8fd8\u672a\u786e\u5b9a\uff0c\u4e00\u4e9b\u7f51\u6c11\u53d1\u73b0\uff0c\u76ee\u524d\u4f7f\u7528tracert\u547d\u4ee4\u67e5\u8be2Kumo.com\u7684\u8def\u7531\u65f6\uff0c\u53ef\u4ee5\u53d1\u73b0\u8fd9\u4e00\u8def\u7531\u7ecf\u8fc7\u4e86\u6570\u4e2a<A class=hui14_line href=\"http://xiazai.zol.com.cn/detail/11/109664.shtml\"><FONT style=\"COLOR: #333\">msn</FONT></A>.com\u670d\u52a1\u5668\uff1b\u800c\u6700\u7ec8\u4fe1\u606f\u663e\u793a\uff0cKumo.com\u57df\u540d\u76ee\u524d\u4ec5\u4f9b\u5fae\u8f6f\u5185\u90e8\u5458\u5de5\u4f7f\u7528\u3002\u4e1a\u754c\u4eba\u58eb\u6307\u51fa\uff0c\u867d\u7136\u5fae\u8f6f\u5df2\u8003\u8651Live\u641c\u7d22\u7684\u91cd\u65b0\u547d\u540d\u4e8b\u5b9c\uff0c\u4f46\u76ee\u524d\u5c1a\u4e0d\u80fd\u80af\u5b9a\u65b0\u54c1\u724c\u5c06\u91c7\u7528Kumo\u540d\u79f0\u3002</P>\r\n<P>zol</P>", "imagename": null, "infoid": 108273, "category": "technology_internet", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["\u5fae\u8f6f", "\u641c\u7d22"]}, {"url": "", "title": "YouTube\u5c06\u4e25\u683c\u76d1\u7ba1\u6210\u4eba\u5185\u5bb9\u89c6\u9891", "tags": "YouTube \u6210\u4eba \u89c6\u9891 ", "name": "yinyin", "posttime": "2008-12-03 11:16:34", "ip": "222.128.48.207", "mark": 1, "note": "<P>YouTube\u535a\u5ba2\u4eca\u5929\u53d1\u8868\u6587\u7ae0\u79f0\uff0c\u4e3a\u4e86\u63d0\u9ad8\u5185\u5bb9\u4e0e\u7528\u6237\u7684\u76f8\u5173\u6027\uff0c\u5c06\u5bf9\u6210\u4eba\u5185\u5bb9\u8fdb\u884c\u4e25\u683c\u76d1\u7ba1\uff0c\u5e76\u5bf9\u5185\u5bb9\u5448\u73b0\u65b9\u5f0f\u52a0\u4ee5\u6539\u8fdb\u3002</P>\r\n<P>\u3000\u3000YouTube\u8868\u793a\uff0c\u5c06\u5bf9\u6210\u4eba\u5185\u5bb9\u91c7\u53d6\u66f4\u4e3a\u4e25\u683c\u7684\u7ba1\u7406\uff0c\u5305\u62ec\u5220\u9664\u5e26\u6709\u8272\u60c5\u56fe\u7247\u6216\u8005\u5177\u6709\u6027\u884c\u4e3a\u7684\u89c6\u9891\u3002\u540c\u65f6\u5c06\u63d0\u9ad8\u89c6\u9891\u5185\u5bb9\u5b58\u5728\u201c\u6027\u6697\u793a\u201d\u7684\u6807\u51c6\uff0c\u5982\u679c\u89c6\u9891\u88ab\u8ba4\u5b9a\u4e3a\u6709\u201c\u6027\u6697\u793a\u201d\u5185\u5bb9\u4f46\u65e0\u9700\u5220\u9664\uff0c\u5c06\u5bf9\u89c2\u770b\u8be5\u89c6\u9891\u7684\u7528\u6237\u5e74\u9f84\u8fdb\u884c\u9650\u5236\uff0c\u53ea\u4f1a\u63d0\u4f9b\u7ed918\u5c81\u4ee5\u4e0a\u7684\u7528\u6237\u3002</P>\r\n<P>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; \u6b64\u5916\uff0cYouTube\u8fd8\u5c06\u8c03\u6574\u7b97\u6cd5\uff0c\u5bf9\u5177\u6709\u201c\u6027\u6697\u793a\u201d\u6216\u542b\u6709\u4e0d\u96c5\u5185\u5bb9\u7684\u89c6\u9891\u8fdb\u884c\u964d\u7ea7\u5904\u7406\uff0c\u4e0d\u518d\u8ba9\u5305\u542b\u7c7b\u4f3c\u5185\u5bb9\u7684\u89c6\u9891\u4e00\u518d\u51fa\u73b0\u5728\u201c\u89c2\u770b\u6b21\u6570\u6700\u9ad8\u201d\u6216\u201c\u7528\u6237\u6700\u559c\u6b22\u7684\u201d\u5217\u8868\u4e4b\u5185\u3002</P>\r\n<P>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; YouTube\u79f0\u5c06\u5bf9\u89c6\u9891\u7f29\u7565\u56fe\u8fdb\u884c\u6539\u8fdb\uff0c\u4e0d\u518d\u4ece25/50/75\u4e09\u4e2a\u4f4d\u7f6e\u81ea\u52a8\u751f\u6210\u89c6\u9891\u7d22\u5f15\uff0c\u4f46\u7528\u6237\u4ecd\u53ef\u4ee5\u4ece\u7cfb\u7edf\u751f\u6210\u7684\u89c6\u9891\u7d22\u5f15\u4e2d\u9009\u62e93\u4e2a\u4f5c\u4e3a\u63cf\u8ff0\u89c6\u9891\u7684\u7f29\u7565\u56fe\u3002</P>\r\n<P>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; \u53e6\u5916\uff0cYouTube\u8868\u793a\uff0c\u5c06\u5bf9\u89c6\u98