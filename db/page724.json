[{"url": "http://column.iresearch.cn/u/fjun99/archives/2008/43346.shtml", "title": "Cooliris \u4e0e ColourLovers", "tags": "Cooliris ", "name": "yinyin", "posttime": "2008-12-03 12:05:00", "ip": "222.128.48.207", "mark": 1, "note": "\u770b\u5230\u4e24\u4e2a\u5f88\u9177\u7684\u4e1c\u897f\uff0c\u4e00\u4e2a\u662fFirefox\u7684Add-ons\uff0c\u540d\u4e3aCooliris\uff1b\u4e00\u4e2a\u662f\u8272\u5f69\u7f51\u7ad9ColourLovers\u3002\u3000Cooliris\u4ee5Firefox\u4e3a\u57fa\u7840\u5b9e\u73b0\u4e86\u4ee5\u56fe\u7247\u4e3a\u754c\u9762\u7684\u6d4f\u89c8\uff0c\u9002\u5408\u8bfb\u56fe\u65f6\u4ee3\u3002", "imagename": "2739bab872704fb8bea815cd48a6c71a.jpg", "infoid": 108301, "category": "technology_design", "isanchordig": 1, "ischecked": 0, "isdelete": 0, "categoryclass": "technology", "via": null, "real_tags": ["cooliris"]}, {"url": "http://www.trendmicro.com.cn/TIS2009_Beta", "title": "\u8d8b\u52bf\u79d1\u6280\u63a8\u51fa2009\u5355\u673a\u7248\u6709\u5956\u516c\u6d4b", "tags": "\u8d8b\u52bf\u79d1\u6280 ", "name": "yinyin", "posttime": "2008-12-03 12:01:51", "ip": "222.128.48.207", "mark": 2, "note": "\u65e5\u524d\uff0c\u4f5c\u4e3a\u7f51\u7edc\u5b89\u5168\u8f6f\u4ef6\u53ca\u670d\u52a1\u9886\u57df\u7684\u5168\u7403\u9886\u5bfc\u8005\u8d8b\u52bf\u79d1\u6280\u503e\u529b\u5168\u7403\u6700\u65b0\u7684\u6740\u6bd2\u6280\u672f\u548c\u7814\u7a76\u6210\u679c\uff0c\u63a8\u51fa\u4e86\u8d8b\u52bf\u79d1\u6280\u7f51\u7edc\u5b89\u5168\u4e13\u5bb62009\uff08TrendMicro Internet Security PC-cillin 2009\uff0c\u4ee5\u4e0b\u7b80\u79f0TIS2009\uff09\u5355\u673a\u4ea7\u54c1\u7684\u516c\u6d4b\u7248\uff0c\u5411\u4e2d\u56fd\u7528\u6237\u63d0\u4f9b\u514d\u8d39\u4e0b\u8f7d\u548c\u8bd5\u7528\u6743\u9650\u3002\r\n\r\n\u5e7f\u5927\u7f51\u6c11\u767b\u9646http://www.trendmicro.com.cn/TIS2009_Beta \uff0c\u4ece\u5373\u65e5\u8d77\u52302009\u5e743\u670814\u65e5\u671f\u95f4\u4e0b\u8f7d\u8be5\u4ea7\u54c1\uff0c\u5373\u53ef\u83b7\u5f97\u514d\u8d3990\u5929\u8d85\u957f\u4ea7\u54c1\u8bd5\u7528\u673a\u4f1a\u3002\r\n\r\n\u4e0e\u6b64\u540c\u65f6\uff0c\u53c2\u4e0e\u6d4b\u8bd5\u7684\u7528\u6237\uff0c\u66f4\u6709\u673a\u4f1a\u514d\u8d39\u5347\u7ea7\u4e3a10,000\u540dTIS2009 \u6b63\u5f0f\u7248\u7528\u6237\u4e4b\u4e00\u3002\r\n\r\n\u6d3b\u52a8\u5c06\u4e8e2009\u5e743\u6708\u5e95\u524d\u901a\u8fc7\u7528\u6237\u6ce8\u518cEmail\u62bd\u53d6\u5e78\u8fd0\u7528\u6237\uff0c\u8d60\u9001\u8d8b\u52bf\u79d1\u6280TIS2009\u5355\u673a\u7248\u4e00\u5e74\u514d\u8d39\u7684\u4f7f\u7528\u6743\u9650! \u6b22\u8fce\u5e7f\u5927\u7f51\u53cb\u4e0b\u8f7d\u8d8b\u52bf\u79d1\u6280TIS2009\u516c\u6d4b\u7248\uff0c\u4f53\u9a8c\u5168\u7403\u9876\u7ea7\u7684\u5b89\u5168\u9632\u62a4\u6280\u672f\u3002\r\n\r\nTIS2009\u5e94\u7528\u4e86\u8d8b\u52bf\u79d1\u6280\u4e8e08\u5e745\u6708\u5728\u7f8e\u56fd\u7387\u5148\u63a8\u51fa\u7684\u201c\u4e91\u5b89\u5168\u201d\u6280\u672f\uff0c\u662f\u56fd\u5185\u9996\u6b3e\u5e94\u7528\u771f\u6b63\u201c\u4e91\u5b89\u5168\u201d\u6280\u672f\u7684\u5355\u673a\u7248\u9632\u75c5\u6bd2\u4ea7\u54c1\u3002\r\n\r\n\u8d8b\u52bf\u79d1\u6280\u8fd9\u4e00\u5386\u65f62\u5e74\u534a\uff0c\u65a5\u8d443\u4ebf\u591a\u7f8e\u91d1\u6253\u9020\u7684\u201c\u4e91\u5b89\u5168\u201d\u8ba1\u5212\uff0c\u65e8\u5728\u901a\u8fc7\u67b6\u8bbe\u5728\u5168\u7403\u76845\u4e2a\u5a01\u80c1\u6570\u636e\u4e2d\u5fc3\uff0c\u53ca34,000\u53f0\u4e91\u7aef\u670d\u52a1\u5668\uff0c\u5c06\u6f5c\u5728\u548c\u672a\u77e5\u7684Web\u5a01\u80c1\u201c\u8ba1\u7b97\u201d\u51fa\u6765\uff0c\u5e76\u5728\u5176\u5230\u8fbe\u7528\u6237\u7535\u8111\u524d\u5c06\u5176\u62e6\u622a\uff0c\u4ece\u800c\u7a81\u7834\u4f20\u7edf\u7684\u5355\u4e00\u75c5\u6bd2\u4ee3\u7801\u6bd4\u5bf9\u7684\u9632\u6bd2\u65b9\u5f0f\uff0c\u505a\u5230\u771f\u6b63\u7684\u4e3b\u52a8\u9632\u5fa1\uff01\r\n\r\n\u540c\u65f6\uff0c\u901a\u8fc7\u4e91\u7aef\u63d0\u524d\u62e6\u622a\u6f5c\u5728\u5a01\u80c1\uff0c\u53ef\u4ee5\u6709\u6548\u51cf\u5c11\u75c5\u6bd2\u4ee3\u7801\u4e0b\u8f7d\u6570\u91cf\uff0c\u8fdb\u800c\u5927\u5e45\u964d\u4f4e\u5bf9\u7528\u6237\u7f51\u7edc\u3001\u7cfb\u7edf\u8d44\u6e90\u7684\u5360\u7528\uff0c\u4e0d\u4f1a\u53d1\u751f\u56e0\u9632\u6bd2\u8f6f\u4ef6\u5de5\u4f5c\u800c\u5e72\u6270\u7528\u6237\u4eab\u53d7\u7f51\u7edc\u6e38\u620f\u5feb\u611f\u3002\r\n\r\n\u636e\u6089\uff0c\u65b0\u7248\u672cTIS2009\u5bf9\u8ba1\u7b97\u673a\u6838\u5fc3\u8bb0\u5fc6\u4f53\u7684\u5360\u7528\u91cf\u5373\u53ef\u8282\u770140%\uff0c\u5f00\u673a\u901f\u5ea6\u4e5f\u52a0\u5feb50%\uff0c\u786e\u4fdd\u7528\u6237\u53ef\u4ee5\u4ece\u5bb9\u9762\u5bf9\u76ee\u524d\u6bcf4\u79d2\u65b0\u589e1\u652f\u75c5\u6bd2\u7684\u6d77\u91cf\u589e\u957f\uff01\r\n\r\nTIS2009\u5728\u5e94\u7528\u201c\u4e91\u5b89\u5168\u201d\u6280\u672f\u57fa\u7840\u4e0a\uff0c\u540c\u65f6\u4f9d\u62582007\u5e74\u6210\u7acb\u4e8e\u4e0a\u6d77\u7684\u4e2d\u56fd\u533a\u7f51\u7edc\u5b89\u5168\u76d1\u6d4b\u5b9e\u9a8c\u5ba4\uff0c\u5f3a\u5316\u4e86\u5bf9\u4e2d\u56fd\u533a\u672c\u571f\u75c5\u6bd2\u3001\u6076\u610f\u8f6f\u4ef6\u7684\u4fa6\u6d4b\u80fd\u529b\uff0c\u6700\u7ec8\u5b9e\u73b0\u201c\u96f6\u79d2\u5dee\u201d\u7684\u622a\u6bd2\u6548\u679c\uff0c\u505a\u5230\u672c\u5730\u3001\u5168\u7403\u5a01\u80c1\u540c\u6b65\u67e5\u6740\uff0c\u4e3a\u7528\u6237\u5e26\u6765\u201c\u9632\u6bd2\u4e8e\u65e0\u5f62\u201d\u7684\u5feb\u611f\uff01\r\n\r\n\u636e\u8d8b\u52bf\u79d1\u6280\u7684\u4ea7\u54c1\u6280\u672f\u987e\u95ee\u5f90\u5b66\u9f99\u4ecb\u7ecd\uff1a\u201c\u8d8b\u52bf\u79d1\u6280TIS2009\u662f\u9488\u5bf9\u4e2d\u56fd\u7f51\u6c11\u91cf\u8eab\u6253\u9020\u7684\u4e00\u6b3e\u529f\u80fd\u6700\u5b8c\u6574\u7684\u3001\u9632\u6bd2\u7cbe\u51c6\u800c\u6548\u679c\u8f7b\u5feb\u7684\u5b89\u5168\u9632\u62a4\u89e3\u51b3\u65b9\u6848\u3002\r\n\r\n\u4e3a\u4e86\u4e0e\u66f4\u591a\u7f51\u53cb\u4e00\u540c\u5206\u4eab\u65b0\u4ea7\u54c1\u7684\u6280\u672f\u6548\u679c\uff0cTIS2009\u540c\u6837\u5c06\u63d0\u4f9b1\u5957\u8f6f\u4ef6\u53ef\u5b89\u88c53\u53f0\u8ba1\u7b97\u673a\u7684\u4f18\u60e0\u65b9\u6848\u3002\u201d \r\n\r\n\u6b64\u5916\uff0c\u636e\u8bb0\u8005\u4e86\u89e3\uff0c\u8d8b\u52bf\u79d1\u6280TIS2009\u4e0a\u5e02\u540e\uff0c\u8fd8\u5c06\u5177\u6709\u66f4\u5f3a\u5927\u7684\u4e91\u5b89\u5168\u9632\u62a4\u529f\u80fd\u3002\r\n\r\n\u8fd9\u610f\u5473\u7740\uff0c\u4e2d\u56fd\u7f51\u53cb\u53ef\u4ee5\u4e0d\u7528\u518d\u62c5\u5fc3\u4e2a\u4eba\u8d44\u6599\u9057\u5931\u7684\u5371\u673a\uff0c\u80fd\u591f\u5c3d\u60c5\u4eab\u53d7\u6bcf\u6b21\u6309\u4e0b\u952e\u76d8\u5e26\u6765\u7684\u7f51\u7edc\u4fbf\u5229\u751f\u6d3b\uff01\r\n\r\n\u8d8b\u52bf\u79d1\u6280TIS2009\u529f\u80fd\u4e00\u89c8\uff1a \r\n\u5168\u9762\u9632\u62a4\u65e0\u7ebf\u548c\u5bb6\u5ead\u7f51\u7edc\u5b89\u5168\r\n\u5185\u7f6e\u53cc\u5411\u9632\u706b\u5899\uff0c\u9632\u6b62\u9ed1\u5ba2\u5165\u4fb5\u7f51\u7edc\u3002\r\n\u65e0\u7ebf\u4e0a\u7f51\u65f6\uff0c\u53ef\u9632\u6b62\u4e0d\u660e\u7f51\u7edc\u8fde\u63a5\u5165\u4fb5\u60a8\u7684\u8ba1\u7b97\u673a\u3002\r\n\u4e00\u88c5\u4e09\uff0c\u53ef\u540c\u65f6\u7ba1\u7406\u591a\u53f0\u8ba1\u7b97\u673a\uff0c\u5c01\u9501\u4e0d\u826f\u7f51\u7ad9\u5e76\u7ba1\u7406\u513f\u7ae5\u4e0a\u7f51\u65f6\u95f4\u3002\r\n\u62a2\u5148\u963b\u6321\u6076\u610f\u7f51\u9875\uff0c\u9632\u6b62\u4e2a\u4eba\u8d44\u6599\u88ab\u7a83\r\n\u5168\u7403\u6700\u5feb\uff01\u5185\u7f6e\u201c\u4e91\u7aef WTP \u626b\u6bd2\u5f15\u64ce\u201d\u53ef\u83b7\u5f97\u6bcf\u79d2\u53ca\u65f6\u66f4\u65b0\u9632\u62a4\uff0c\u9632\u6b62\u7535\u8111\u611f\u67d3\u75c5\u6bd2\u3001\u95f4\u8c0d\u8f6f\u4ef6\u3002\r\n\u9632\u6b62\u7f51\u7edc\u8bc8\u9a97\u3001\u5783\u573e\u90ae\u4ef6\r\n\u201c\u7f51\u7edc\u9493\u9c7c\u9632\u62a4\u201d\u529f\u80fd\uff0c\u9632\u6b62\u906d\u53d7\u7f51\u7edc\u8bc8\u9a97\uff0c\u5bfc\u81f4\u8d44\u6599\u88ab\u9a97\u3002\r\n\u201c\u5783\u573e\u90ae\u4ef6\u9632\u62a4\u201d\u529f\u80fd\uff0c\u9632\u5835\u5783\u573e\u90ae\u4ef6\u5e76\u663e\u793a\u90ae\u4ef6\u4e2d\u5939\u5e26\u7684\u6076\u610f\u7f51\u5740\u3002\r\n\u6548\u7387\u5927\u5e45\u63d0\u5347\uff0c\u4f7f\u7528\u96f6\u8d1f\u62c5\r\n\u6838\u5fc3\u5185\u5b58\u7528\u91cf\u51cf\u5c11 40%\uff0c\u5f00\u673a\u901f\u5ea6\u5feb 50%\r\n\u9488\u5bf9\u6e38\u620f\u73a9\u5bb6\u8bbe\u8ba1\u7684\u201c\u5168\u5c4f\u5e55\u96f6\u5e72\u6270\u6a21\u5f0f\u201d\u